      "timeUnit": "Month",
      "sink": "immune_population_region_1"
    },
    {
      "name": "immune_population_region_2_net_flow",
      "comment": "Net flow for immune population region 2",
      "equation": "susceptible_to_immune_population_flow_region_2",
      "timeUnit": "Month",
      "sink": "immune_population_region_2"
    }
  ],
  "variables": [
    {
      "name": "normal_immune_population_fraction_region_1",
      "comment": "normal immune population fraction region 1",
      "equation": "LOOKUP(normal_immune_population_fraction_region_1_lookup, TIME)",
      "unit": "Dmnl"
    },
    {
      "name": "recoveries_region_2",
      "comment": "recoveries region 2",
      "equation": "infected_population_region_2/recovering_time",
      "unit": "persons/Month"
    },
    {
      "name": "susceptible_to_immune_population_flow_region_2",
      "comment": "susceptible to immune population flow region 2",
      "equation": "IF((normal_immune_population_region_2-immune_population_region_2)/susceptible_to_immune_population_delay_time_region_2\n\t>0, MIN((normal_immune_population_region_2-immune_population_region_2)/susceptible_to_immune_population_delay_time_region_2 ,susceptible_population_region_2/susceptible_to_immune_population_delay_time_region_2\n\t), MIN((normal_immune_population_region_2-immune_population_region_2)/susceptible_to_immune_population_delay_time_region_2 ,immune_population_region_2/susceptible_to_immune_population_delay_time_region_2\n\t))",
      "unit": "persons/Month"
    },
    {
      "name": "normal_immune_population_fraction_region_2",
      "comment": "normal immune population fraction region 2",
      "equation": "LOOKUP(normal_immune_population_fraction_region_2_lookup, TIME)",
      "unit": "Dmnl"
    },
    {
      "name": "normal_immune_population_region_2",
      "comment": "normal immune population region 2",
      "equation": "normal_immune_population_fraction_region_2*total_population_region_2",
      "unit": "persons"
    },
    {
      "name": "recoveries_region_1",
      "comment": "recoveries region 1",
      "equation": "infected_population_region_1/recovering_time",
      "unit": "persons/Month"
    },
    {
      "name": "infection_fraction_region_1",
      "comment": "infection fraction region 1",
      "equation": "infected_population_region_1/total_population_region_1*100",
      "unit": "percent"
    },
    {
      "name": "infection_fraction_region_2",
      "comment": "infection fraction region 2",
      "equation": "infected_population_region_2/total_population_region_2*100",
      "unit": "Dmnl"
    },
    {
      "name": "total_population_region_1",
      "comment": "total population region 1",
      "equation": "infected_population_region_1+recovered_population_region_1+susceptible_population_region_1 +immune_population_region_1",
      "unit": "persons"
    },
    {
      "name": "total_population_region_2",
      "comment": "total population region 2",
      "equation": "infected_population_region_2+recovered_population_region_2+susceptible_population_region_2 +immune_population_region_2",
      "unit": "persons"
    },
    {
      "name": "infections_region_1",
      "comment": "infections region 1",
      "equation": "susceptible_population_region_1*contact_rate_region_1*infection_rate_region_1*infection_fraction_region_1 /100 + susceptible_population_region_1*interregional_contact_rate*infection_rate_region_1 *infection_fraction_region_2/100",
      "unit": "persons/Month"
    },
    {
      "name": "infections_region_2",
      "comment": "infections region 2",
      "equation": "susceptible_population_region_2*contact_rate_region_2*infection_rate_region_2*infection_fraction_region_2 /100 + susceptible_population_region_2*interregional_contact_rate*infection_rate_region_2 *infection_fraction_region_1/100",
      "unit": "persons/Month"
    },
    {
      "name": "susceptible_to_immune_population_flow_region_1",
      "comment": "susceptible to immune population flow region 1",
      "equation": "IF((normal_immune_population_region_1-immune_population_region_1)/susceptible_to_immune_population_delay_time_region_1 >0, MIN((normal_immune_population_region_1-immune_population_region_1)/susceptible_to_immune_population_delay_time_region_1 ,susceptible_population_region_1/susceptible_to_immune_population_delay_time_region_1 ), MIN((normal_immune_population_region_1-immune_population_region_1)/susceptible_to_immune_population_delay_time_region_1 ,immune_population_region_1/susceptible_to_immune_population_delay_time_region_1))",
      "unit": "persons/Month"
    },
    {
      "name": "normal_immune_population_region_1",
      "comment": "normal immune population region 1",
