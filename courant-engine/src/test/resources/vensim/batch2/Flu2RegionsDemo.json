    {
      "name": "infected_population_region_1_net_flow",
      "comment": "Net flow for infected population region 1",
      "equation": "infections_region_1-recoveries_region_1",
      "timeUnit": "Month",
      "sink": "infected_population_region_1"
    },
    {
      "name": "infected_population_region_2_net_flow",
      "comment": "Net flow for infected population region 2",
