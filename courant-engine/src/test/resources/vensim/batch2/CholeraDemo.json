{
  "name": "Cholera",
  "stocks": [
    {
      "name": "cumulative_cholera_cases",
      "comment": "cumulative cholera cases",
      "initialValue": 0.0,
      "unit": ""
    },
    {
      "name": "cumulative_cholera_deaths",
      "comment": "cumulative cholera deaths",
      "initialValue": 0.0,
      "unit": "person"
    },
    {
      "name": "recently_infected_population",
      "comment": "recently infected population",
      "initialValue": 0.0,
      "unit": ""
    },
    {
      "name": "recovered_temporarily_immune_population",
      "comment": "recovered temporarily immune population",
      "initialValue": 0.0,
      "initialExpression": "1.3228e+007-3e+006-1000-1000-50",
      "unit": "person"
    },
    {
      "name": "mildly_infected_population",
      "comment": "mildly infected population",
      "initialValue": 0.0,
      "unit": "person"
    },
    {
      "name": "heavily_infected_population",
      "comment": "heavily infected population",
      "initialValue": 0.0,
      "unit": "person"
    },
    {
      "name": "susceptible_population",
      "comment": "susceptible population",
      "initialValue": 3000000.0,
      "unit": ""
    }
  ],
  "flows": [
    {
      "name": "cumulative_cholera_cases_net_flow",
      "comment": "Net flow for cumulative cholera cases",
      "equation": "recorded_cholera_cases",
      "timeUnit": "Day",
      "sink": "cumulative_cholera_cases"
    },
    {
      "name": "cumulative_cholera_deaths_net_flow",
      "comment": "Net flow for cumulative cholera deaths",
      "equation": "cholera_deaths",
      "timeUnit": "Day",
      "sink": "cumulative_cholera_deaths"
    },
    {
      "name": "recently_infected_population_net_flow",
      "comment": "Net flow for recently infected population",
      "equation": "cholera_infections-mildly_infected-heavily_infected",
      "timeUnit": "Day",
      "sink": "recently_infected_population"
    },
    {
      "name": "recovered_temporarily_immune_population_net_flow",
      "comment": "Net flow for recovered temporarily immune population",
      "equation": "recovered_from_heavy_infection+recovered_from_mild_infection-recovered_to_susceptible_by_loss_of_immunity",
      "timeUnit": "Day",
      "sink": "recovered_temporarily_immune_population"
    },
    {
      "name": "mildly_infected_population_net_flow",
      "comment": "Net flow for mildly infected population",
      "equation": "+mildly_infected-recovered_from_mild_infection",
      "timeUnit": "Day",
      "sink": "mildly_infected_population"
    },
    {
      "name": "heavily_infected_population_net_flow",
      "comment": "Net flow for heavily infected population",
      "equation": "+heavily_infected-cholera_deaths-recovered_from_heavy_infection",
      "timeUnit": "Day",
      "sink": "heavily_infected_population"
    },
    {
      "name": "susceptible_population_net_flow",
      "comment": "Net flow for susceptible population",
      "equation": "recovered_to_susceptible_by_loss_of_immunity-cholera_infections",
      "timeUnit": "Day",
      "sink": "susceptible_population"
    }
  ],
  "variables": [
    {
      "name": "recorded_cholera_cases",
      "comment": "recorded cholera cases",
      "equation": "heavily_infected+mildly_infected*0.25",
      "unit": ""
    },
    {
      "name": "effect_of_prevention_and_sanitation_on_the_indirect_degree_of_infection",
      "comment": "effect of prevention and sanitation on the indirect degree of infection",
      "equation": "LOOKUP(effect_of_prevention_and_sanitation_on_the_indirect_degree_of_infection_lookup, MAX(condition_of_the_sanitary_infrastructure,level_of_prevention))",
      "unit": ""
    },
    {
      "name": "level_of_prevention",
      "comment": "([(0,0)-(4000,10)],(0,0.1),(130,0.1),(186,0.3),(206,0.5),(365,0.8),(3650,0. 8) )",
      "equation": "0.1",
      "unit": "Dmnl"
    },
    {
      "name": "fraction_of_infected",
      "comment": "fraction of infected",
      "equation": "(recently_infected_population+mildly_infected_population+heavily_infected_population )/(recently_infected_population\n+mildly_infected_population+heavily_infected_population+susceptible_population+recovered_temporarily_immune_population )",
      "unit": "Dmnl"
    },
    {
      "name": "smoothed_fraction_of_contaminated_water",
      "comment": "smoothed fraction of contaminated water",
      "equation": "DELAY3I(effect_of_the_fraction_of_infected_on_the_fraction_of_contaminated_water, 14 , 0.0004)",
      "unit": ""
    },
    {
      "name": "indirect_degree_of_infection",
      "comment": "indirect degree of infection",
      "equation": "smoothed_fraction_of_contaminated_water*effect_of_prevention_and_sanitation_on_the_indirect_degree_of_infection *connectedness_of_aquifers",
      "unit": "1/Day"
    },
    {
      "name": "cholera_deaths",
      "comment": "cholera deaths",
      "equation": "heavily_infected_population/average_duration_of_illness*effect_of_the_average_state_of_health_services_on_the_fraction_of_cholera_deaths",
      "unit": "person/Day"
    },
    {
      "name": "effect_of_the_fraction_of_infected_on_the_fraction_of_contaminated_water",
      "comment": "([(0,0)-(1,1)],(0,0),(0.25,0.8),(0.5,0.95),(0.75,0.98),(1,1) )\\!\\!\\!",
      "equation": "LOOKUP(effect_of_the_fraction_of_infected_on_the_fraction_of_contaminated_water_lookup, fraction_of_infected)",
      "unit": ""
    },
    {
      "name": "effect_of_the_average_state_of_health_services_on_the_fraction_of_cholera_deaths",
      "comment": "effect of the average state of health services on the fraction of cholera deaths",
      "equation": "LOOKUP(effect_of_the_average_state_of_health_services_on_the_fraction_of_cholera_deaths_lookup, average_state_of_health_services)",
      "unit": ""
    },
    {
      "name": "average_immunity_period",
      "comment": "average immunity period",
      "equation": "6*365",
      "unit": "Day"
    },
    {
      "name": "average_state_of_health_services",
      "comment": "([(0,0)-(4000,1)],(0,0.15),(130,0.15),(183,0.4),(206,0.7),(250,0.75),(300,0 .8),(3650,0.8) ) over time",
      "equation": "0.15",
      "unit": ""
    },
    {
      "name": "recovered_from_heavy_infection",
      "comment": "recovered from heavy infection",
      "equation": "heavily_infected_population/average_duration_of_illness*(1-effect_of_the_average_state_of_health_services_on_the_fraction_of_cholera_deaths )",
      "unit": "person/Day"
    },
    {
      "name": "recovered_to_susceptible_by_loss_of_immunity",
      "comment": "recovered to susceptible by loss of immunity",
      "equation": "recovered_temporarily_immune_population/average_immunity_period",
      "unit": ""
    },
    {
      "name": "cholera_infections",
      "comment": "cholera infections",
      "equation": "susceptible_population*indirect_degree_of_infection",
      "unit": "person/Day"
    },
    {
      "name": "recovered_from_mild_infection",
      "comment": "recovered from mild infection",
      "equation": "mildly_infected_population/average_duration_of_illness",
      "unit": "person/Day"
    },
    {
      "name": "condition_of_the_sanitary_infrastructure",
      "comment": "([(0,0)-(4000,1)],(0,0.5),(183,0.55),(365,0.6),(1825,0.85),(3650,0.9) )  over time",
      "equation": "0.5",
      "unit": "Dmnl"
    },
    {
      "name": "mildly_infected",
      "comment": "mildly infected",
      "equation": "recently_infected_population/average_incubation_time*effect_of_the_average_health_condition_on_the_fraction_of_mildly_infected_of_all_infected",
      "unit": "person/Day"
    },
    {
      "name": "heavily_infected",
      "comment": "heavily infected",
      "equation": "recently_infected_population/average_incubation_time*(1-effect_of_the_average_health_condition_on_the_fraction_of_mildly_infected_of_all_infected )",
      "unit": ""
    },
    {
      "name": "TIME_STEP",
      "equation": "0.5",
      "unit": "Day"
    },
    {
      "name": "INITIAL_TIME",
      "equation": "0",
      "unit": "Day"
    },
    {
      "name": "FINAL_TIME",
      "equation": "3650",
      "unit": "Day"
    },
    {
      "name": "connectedness_of_aquifers",
      "equation": "0.28",
      "comment": "connectedness of aquifers"
    },
    {
      "name": "effect_of_the_average_health_condition_on_the_fraction_of_mildly_infected_of_all_infected",
      "equation": "0.95",
      "comment": "effect of the average health condition on the fraction of mildly infected of all infected"
    },
    {
      "name": "average_incubation_time",
      "equation": "1",
      "comment": "average incubation time",
      "unit": "Day"
    },
    {
      "name": "average_duration_of_illness",
      "equation": "10",
      "comment": "average duration of illness",
      "unit": "Day"
    }
  ],
