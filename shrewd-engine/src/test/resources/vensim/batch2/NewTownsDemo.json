{
  "name": "NewTowns",
  "stocks": [
    {
      "name": "bevolking",
      "comment": "bevolking",
      "initialValue": 50000.0,
      "unit": "people"
    },
    {
      "name": "bedrijven",
      "comment": "bedrijven",
      "initialValue": 1000.0,
      "unit": "units"
    },
    {
      "name": "huizen",
      "comment": "huizen",
      "initialValue": 14000.0,
      "unit": "units"
    }
  ],
  "flows": [
    {
      "name": "bevolking_net_flow",
      "comment": "Net flow for bevolking",
      "equation": "immigratie+geboortes-emigratie-sterftes",
      "timeUnit": "Year",
      "sink": "bevolking"
    },
    {
      "name": "bedrijven_net_flow",
      "comment": "Net flow for bedrijven",
      "equation": "constructie_van_bedrijfsgebouwen-afbraak_van_bedrijfsgebouwen",
      "timeUnit": "Year",
      "sink": "bedrijven"
    },
    {
      "name": "huizen_net_flow",
      "comment": "Net flow for huizen",
      "equation": "constructie_van_huizen-afbraak_van_huizen",
      "timeUnit": "Year",
      "sink": "huizen"
    }
  ],
  "auxiliaries": [
    {
      "name": "emigratie",
      "comment": "emigratie",
      "equation": "bevolking*normale_emigratiegraad*(1+(1-slummultiplicator_voor_migratie))",
      "unit": "people/year"
    },
    {
      "name": "immigratie",
      "comment": "immigratie",
      "equation": "bevolking*normale_immigratiegraad*jobbeschikbaarheids_multiplicator_voor_immigratie* huizenbeschikbaarheids_multiplicator_voor_immigratie\n\t*(slummultiplicator_voor_migratie*switch_leegstandseffect+(1-switch_leegstandseffect ))",
      "unit": "people/year"
    },
    {
      "name": "slummultiplicator_voor_migratie",
      "comment": "slummultiplicator voor migratie",
      "equation": "LOOKUP(slummultiplicator_voor_migratie_lookup, leegstandsgraad_van_huizen)",
      "unit": ""
    },
    {
      "name": "afbraak_van_huizen",
      "comment": "afbraak van huizen",
      "equation": "afbraakgraad_van_huizen*huizen+extra_afbraakgraad*huizen*switch_leegstandseffect",
      "unit": "structure/year"
    },
    {
      "name": "landgebruik",
      "comment": "landgebruik",
      "equation": "(bedrijven*grondgebruik_per_bedrijf + huizen*grondgebruik_per_huis)/totale_grondoppervlakte",
      "unit": "fraction"
    },
    {
      "name": "leegstandsgraad_van_huizen",
      "comment": "leegstandsgraad van huizen",
      "equation": "MIN(MAX((1-verhouding_huishoudens_tot_huizen),0),1)",
      "unit": ""
    },
    {
      "name": "effect_schaarste_landgebruik_op_intensiviteit_bedrijfsgebouwen",
      "comment": "effect schaarste landgebruik op intensiviteit bedrijfsgebouwen",
      "equation": "LOOKUP(effect_schaarste_landgebruik_op_intensiviteit_bedrijfsgebouwen_lookup, landgebruik)",
      "unit": ""
    },
    {
      "name": "extra_afbraakgraad",
      "comment": "extra afbraakgraad",
      "equation": "LOOKUP(extra_afbraakgraad_lookup, leegstandsgraad_van_huizen)",
      "unit": ""
    },
    {
      "name": "jobs",
      "comment": "jobs",
      "equation": "initieel_aantal_jobs_per_bedrijfsgebouw*bedrijven*(effect_schaarste_landgebruik_op_intensiviteit_bedrijfsgebouwen *switch_jobs + (1- switch_jobs))",
      "unit": "job"
    },
    {
      "name": "verhouding_huishoudens_tot_huizen",
      "comment": "verhouding huishoudens tot huizen",
      "equation": "huishoudens/huizen",
      "unit": "family/structure"
    },
    {
      "name": "geboortes",
      "comment": "geboortes",
      "equation": "geboortegraad*bevolking",
      "unit": "people/year"
    },
    {
      "name": "huishoudens",
      "comment": "huishoudens",
      "equation": "bevolking/gemiddelde_grootte_van_huishoudens",
      "unit": "units"
    },
    {
      "name": "sterftes",
      "comment": "sterftes",
      "equation": "sterftegraad*bevolking",
      "unit": ""
    },
    {
      "name": "werkloosheidsgraad",
      "comment": "werkloosheidsgraad",
      "equation": "MIN(MAX((1 - 1/beroepsbevolking_tot_jobs_ratio),0),1)",
      "unit": ""
    },
    {
      "name": "constructie_van_huizen",
      "comment": "constructie van huizen",
      "equation": "constructiegraad_van_huizen*landbeschikbaarheids_multiplicator_voor_huizen*huizenschaarste_multiplicator *huizen",
      "unit": "structure/year"
    },
    {
      "name": "constructie_van_bedrijfsgebouwen",
      "comment": "constructie van bedrijfsgebouwen",
      "equation": "constructiegraad_van_bedrijfsgebouwen*landbeschikbaarheids_multiplicator_voor_bedrijfsgebouwen *beroepsbevolkings_multiplicator_voor_bedrijven*bedrijven",
      "unit": "structure/year"
    },
    {
      "name": "jobbeschikbaarheids_multiplicator_voor_immigratie",
      "comment": "jobbeschikbaarheids multiplicator voor immigratie",
      "equation": "LOOKUP(jobbeschikbaarheids_multiplicator_voor_immigratie_lookup, beroepsbevolking_tot_jobs_ratio)",
      "unit": "fraction"
    },
    {
      "name": "huizenbeschikbaarheids_multiplicator_voor_immigratie",
      "comment": "huizenbeschikbaarheids multiplicator voor immigratie",
      "equation": "LOOKUP(huizenbeschikbaarheids_multiplicator_voor_immigratie_lookup, verhouding_huishoudens_tot_huizen)",
      "unit": "fraction"
    },
    {
      "name": "afbraak_van_bedrijfsgebouwen",
      "comment": "afbraak van bedrijfsgebouwen",
      "equation": "afbraakgraad_van_bedrijfsgebouwen*bedrijven",
      "unit": "structure/year"
    },
    {
      "name": "beroepsbevolkings_multiplicator_voor_bedrijven",
      "comment": "beroepsbevolkings multiplicator voor bedrijven",
      "equation": "LOOKUP(beroepsbevolkings_multiplicator_voor_bedrijven_lookup, beroepsbevolking_tot_jobs_ratio)",
      "unit": "fraction"
    },
    {
      "name": "landbeschikbaarheids_multiplicator_voor_bedrijfsgebouwen",
      "comment": "landbeschikbaarheids multiplicator voor bedrijfsgebouwen",
      "equation": "LOOKUP(landbeschikbaarheids_multiplicator_voor_bedrijfsgebouwen_lookup, landgebruik)",
