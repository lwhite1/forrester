{
  "name": "ProjectManagement",
  "stocks": [
    {
      "name": "remaining_project_tasks",
      "comment": "remaining project tasks",
      "initialValue": 1200.0,
      "unit": "tasks"
    },
    {
      "name": "undiscovered_rework",
      "comment": "undiscovered rework",
      "initialValue": 0.0,
      "unit": "tasks"
    },
    {
      "name": "cumulative_effort",
      "comment": "cumulative effort",
      "initialValue": 0.001,
      "unit": "person*Month"
    },
    {
      "name": "properly_completed_project_tasks",
      "comment": "properly completed project tasks",
      "initialValue": 0.0,
      "unit": "tasks"
    },
    {
      "name": "workforce",
      "comment": "workforce",
      "initialValue": 2.0,
      "unit": "person"
    }
  ],
  "flows": [
    {
      "name": "remaining_project_tasks_net_flow",
      "comment": "Net flow for remaining project tasks",
      "equation": "detecting_undiscovered_rework-poor_completion_of_project_tasks-proper_completion_of_project_tasks",
      "timeUnit": "Month",
      "sink": "remaining_project_tasks"
    },
    {
      "name": "undiscovered_rework_net_flow",
      "comment": "Net flow for undiscovered rework",
      "equation": "poor_completion_of_project_tasks - detecting_undiscovered_rework",
      "timeUnit": "Month",
      "sink": "undiscovered_rework"
    },
    {
      "name": "cumulative_effort_net_flow",
      "comment": "Net flow for cumulative effort",
      "equation": "additional_cumulative_effort",
      "timeUnit": "Month",
      "sink": "cumulative_effort"
    },
    {
      "name": "properly_completed_project_tasks_net_flow",
      "comment": "Net flow for properly completed project tasks",
      "equation": "proper_completion_of_project_tasks",
      "timeUnit": "Month",
      "sink": "properly_completed_project_tasks"
    },
    {
      "name": "workforce_net_flow",
      "comment": "Net flow for workforce",
      "equation": "net_hiring_of_personnel",
      "timeUnit": "Month",
      "sink": "workforce"
    }
  ],
  "variables": [
    {
      "name": "fraction_personnel_for_testing",
      "comment": "gerapporteerde fractie detectie van onontdekt rework",
      "equation": "LOOKUP(fraction_personnel_for_testing_lookup, reported_fraction_detection_undiscovered_rework)",
      "unit": "dmnl"
    },
    {
      "name": "average_quality_of_completed_project_tasks",
      "comment": "average quality of completed project tasks",
      "equation": "properly_completed_project_tasks/MAX((properly_completed_project_tasks+undiscovered_rework ),1)",
      "unit": "dmnl"
    },
    {
      "name": "productivity_of_testing",
      "comment": "productivity of testing",
      "equation": "maximum_productivity_of_testing*fraction_undiscovered_rework",
      "unit": "tasks/(person*Month)"
    },
    {
      "name": "perceived_time_remaining",
      "comment": "Time remaining",
      "equation": "MAX(0.25,SMOOTH(TIME + (perceived_effort_remaining/desired_workforce),time_to_adapt_the_project_schedule ,initial_project_time_remaining) - TIME)",
      "unit": "Month"
    },
    {
      "name": "additional_cumulative_effort",
      "comment": "additional cumulative effort",
      "equation": "workforce",
      "unit": "Month*person/Month"
    },
    {
      "name": "reported_fraction_detection_undiscovered_rework",
      "comment": "reported fraction detection undiscovered rework",
      "equation": "DELAY3I( detecting_undiscovered_rework/(proper_completion_of_project_tasks+detecting_undiscovered_rework ),1,0)",
      "unit": "dmnl"
    },
    {
      "name": "fraction_undiscovered_rework",
      "comment": "fraction undiscovered rework",
      "equation": "undiscovered_rework/MAX(perceived_cumulative_progress,0.01)",
      "unit": "dmnl"
    },
    {
      "name": "project_personnel",
      "comment": "project personnel",
      "equation": "(1-fraction_personnel_for_testing)*workforce",
      "unit": "person"
    },
    {
      "name": "detecting_undiscovered_rework",
      "comment": "detecting undiscovered rework",
      "equation": "productivity_of_testing*testing_personnel",
      "unit": "tasks/Month"
    },
    {
      "name": "progress",
      "comment": "progress",
      "equation": "gross_productivity_of_project_personnel*project_personnel",
      "unit": "tasks/Month"
    },
    {
      "name": "testing_personnel",
      "comment": "testing personnel",
      "equation": "fraction_personnel_for_testing*workforce",
      "unit": "person"
    },
    {
      "name": "gross_productivity_of_project_personnel",
      "comment": "gross productivity of project personnel",
      "equation": "LOOKUP(gross_productivity_of_project_personnel_lookup, remaining_project_tasks)",
      "unit": "tasks/person/Month"
    },
    {
      "name": "perceived_effort_remaining",
      "comment": "perceived effort remaining",
      "equation": "remaining_project_tasks/MAX(perceived_productivity,1)",
      "unit": "person*Month"
    },
    {
      "name": "poor_completion_of_project_tasks",
      "comment": "poor completion of project tasks",
      "equation": "progress*(1 - fraction_properly_completed)",
      "unit": "tasks/Month"
    },
    {
      "name": "proper_completion_of_project_tasks",
      "comment": "proper completion of project tasks",
      "equation": "progress* fraction_properly_completed",
      "unit": "tasks/Month"
    },
    {
      "name": "net_hiring_of_personnel",
      "comment": "(gewenst personeelsbestand - personeelsbestand)/tijd om personeelsbestand  aan te passen",
      "equation": "(desired_workforce - workforce)/time_to_adapt_workforce",
      "unit": "person/Month"
    },
    {
      "name": "perceived_cumulative_progress",
      "comment": "behoorlijk afgewerkte projecttaken + MAX(0,\"gebrekkig afgewerkte  projecttaken (undiscovered rework)\")",
      "equation": "properly_completed_project_tasks + undiscovered_rework",
      "unit": "tasks"
    },
    {
      "name": "perceived_fraction_completed",
      "comment": "perceived fraction completed",
      "equation": "perceived_cumulative_progress/initial_number_of_project_tasks",
      "unit": "fraction"
    },
    {
      "name": "perceived_productivity",
      "comment": "perceived productivity",
      "equation": "perceived_cumulative_progress/cumulative_effort",
      "unit": "tasks/person/Month"
    },
    {
      "name": "desired_workforce",
      "comment": "desired workforce",
      "equation": "perceived_effort_remaining/perceived_time_remaining",
      "unit": "person"
    },
    {
      "name": "TIME_STEP",
      "equation": "0.0078125",
      "unit": "Month"
    },
    {
      "name": "INITIAL_TIME",
      "equation": "0",
      "unit": "Month"
    },
    {
      "name": "FINAL_TIME",
      "equation": "100",
      "unit": "Month"
    },
    {
      "name": "initial_project_time_remaining",
      "equation": "40",
      "comment": "initial project time remaining",
      "unit": "Month"
    },
    {
      "name": "maximum_productivity_of_testing",
      "equation": "2",
      "comment": "maximum productivity of testing",
      "unit": "tasks/(person*Month)"
    },
    {
      "name": "time_to_adapt_workforce",
      "equation": "1",
      "comment": "time to adapt workforce",
      "unit": "Month"
    },
    {
      "name": "time_to_adapt_the_project_schedule",
      "equation": "1",
      "comment": "time to adapt the project schedule",
      "unit": "Month"
    },
    {
      "name": "fraction_properly_completed",
      "equation": "0.5",
      "comment": "fraction properly completed",
      "unit": "dmnl"
    },
    {
      "name": "initial_number_of_project_tasks",
      "equation": "1200",
      "comment": "initial number of project tasks",
      "unit": "tasks"
    }
  ],
  "lookupTables": [
