    {
      "name": "desired_fraction_new_capacity_T3",
      "comment": "MIN(1, MAX(0, 1-(desired fraction new capacity of technology 2 + desired  fraction new capacity of technology 3)))",
      "equation": "MIN(1, MAX(0, 1/marginal_cost_new_capacity_T3/(1/marginal_cost_new_capacity_T1+1/marginal_cost_new_capacity_T3 +1/marginal_cost_new_capacity_T2)))",
      "unit": "dmnl"
    },
    {
      "name": "newly_planned_capacity_T3",
      "comment": "newly planned capacity T3",
      "equation": "MAX(expected_new_capacity_to_be_installed * desired_fraction_new_capacity_T3,0)",
      "unit": "MW/YEAR"
    },
    {
      "name": "cumulatively_installed_capacity_previous_year_T3",
      "comment": "cumulatively installed capacity previous year T3",
      "equation": "DELAY_FIXED(\n\tcumulatively_installed_capacity_T3, 1, cumulatively_installed_capacity_T3)",
      "unit": "MW"
    },
    {
      "name": "commissioning_capacity_T3",
      "comment": "commissioning capacity T3",
