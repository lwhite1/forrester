{
  "name": "Deradicalization",
  "stocks": [
    {
      "name": "extremists",
      "comment": "extremists",
      "initialValue": 0.0,
      "unit": "citizens"
    },
    {
      "name": "convinced_citizens",
      "comment": "convinced citizens",
      "initialValue": 100000.0,
      "unit": "citizens"
    },
    {
      "name": "activists",
      "comment": "activists",
      "initialValue": 1000.0,
      "unit": "citizens"
    },
    {
      "name": "unconvinced_citizens",
      "comment": "unconvinced citizens",
      "initialValue": 12900000.0,
      "unit": "citizens"
    },
    {
      "name": "animal_distress",
      "comment": "animal distress",
      "initialValue": 100.0,
      "unit": "Dmnl"
    }
  ],
  "flows": [
    {
      "name": "extremists_net_flow",
      "comment": "Net flow for extremists",
      "equation": "activists_2_extremists",
      "timeUnit": "Year",
      "sink": "extremists"
    },
    {
      "name": "convinced_citizens_net_flow",
      "comment": "Net flow for convinced citizens",
      "equation": "persuasion-convinced_2_activist",
      "timeUnit": "Year",
      "sink": "convinced_citizens"
    },
    {
      "name": "activists_net_flow",
      "comment": "Net flow for activists",
      "equation": "convinced_2_activist-activists_2_extremists",
      "timeUnit": "Year",
      "sink": "activists"
    },
    {
      "name": "unconvinced_citizens_net_flow",
      "comment": "Net flow for unconvinced citizens",
      "equation": "-persuasion",
      "timeUnit": "Year",
      "sink": "unconvinced_citizens"
    },
    {
      "name": "animal_distress_net_flow",
      "comment": "Net flow for animal distress",
      "equation": "net_increase_of_animal_distress",
      "timeUnit": "Year",
      "sink": "animal_distress"
    }
  ],
  "variables": [
    {
      "name": "visibility_of_the_problem",
      "comment": "visibility of the problem",
      "equation": "problem_symptoms*radical_action_level*commitment_of_radical_individuals_to_radical_action",
      "unit": "Dmnl"
    },
    {
      "name": "frustration_of_convinced_citizens",
      "comment": "OLD: min(MAX(frustration due to marginalization*frustration due to  inertia*average degree of conviction of convinced citizens*percived  magnitude of the problem,0),1)",
      "equation": "min(MAX((frustration_due_to_marginalization+frustration_due_to_inertia)*perceived_animal_distress ,0),1)",
      "unit": "Dmnl"
    },
    {
      "name": "nonradical_action_level",
      "comment": "OLD: (1-frustration of convinced citizens)*\"total readiness to take  non-radical action\"*(homegrown activists+convinced citizens)/total  population",
      "equation": "frustration_of_convinced_citizens",
      "unit": "Dmnl"
    },
    {
      "name": "fraction_of_convinced_citizens",
      "comment": "fraction of convinced citizens",
      "equation": "(convinced_citizens+activists+extremists)/(convinced_citizens+activists+extremists+unconvinced_citizens +citizens_that_cannot_be_convinced)",
      "unit": "Dmnl"
    },
    {
      "name": "radical_action_level",
      "comment": "EXPRESSED IN TOTALLY FRUSTRATED CITIZENS TAKING RADICAL ACTION",
      "equation": "frustration_of_convinced_citizens*extremists*fraction_of_convinced_citizens",
      "unit": "citizens"
    },
    {
      "name": "activists_2_extremists",
      "comment": "activists 2 extremists",
      "equation": "(potential_number_of_extremists-extremists)/average_time_to_change_states",
      "unit": "citizens/Year"
    },
    {
      "name": "persuasion",
      "comment": "min(dedicated contact rate of convinced citizens*fraction of convinced  citizens*unconvinced citizens*\"persuasiveness of non-radical actions\"  *visibility of the problem/\"strength of incompatible  self-interest\"/average time to change states,unconvinced citizens/average  time to change states)",
      "equation": "min(contact_rate_of_convinced_citizens*fraction_of_convinced_citizens*unconvinced_citizens *persuasiveness_of_nonradical_actions *visibility_of_the_problem/strength_of_incompatible_selfinterest /average_time_to_change_states,unconvinced_citizens/average_time_to_change_states)",
      "unit": "citizens/Year"
    },
    {
      "name": "convinced_2_activist",
      "comment": "convinced 2 activist",
      "equation": "(potential_number_of_activitsts-activists)/average_time_to_change_states",
      "unit": "citizens/Year"
    },
    {
      "name": "contact_rate_of_convinced_citizens",
      "comment": "DIFFERENT FORMULATION",
      "equation": "min(normal_contact_rate_of_convinced_citizens*nonradical_action_level,3650)",
      "unit": "contacts/(citizen)"
    },
    {
      "name": "potential_number_of_extremists",
      "comment": "potential number of extremists",
      "equation": "potential_fraction_of_extremists*activists*frustration_of_convinced_citizens*frustration_due_to_marginalization",
      "unit": "citizens"
    },
    {
      "name": "potential_number_of_activitsts",
      "comment": "potential number of activitsts",
      "equation": "potential_fraction_of_activists*convinced_citizens*frustration_of_convinced_citizens",
      "unit": "citizens"
    },
    {
      "name": "frustration_due_to_inertia",
      "comment": "frustration due to inertia",
      "equation": "DELAY_FIXED( (maximum_attainable_rate_of_decrease_through_societal_change-rate_of_decrease_through_societal_change )/maximum_attainable_rate_of_decrease_through_societal_change, 1, (maximum_attainable_rate_of_decrease_through_societal_change -rate_of_decrease_through_societal_change)/maximum_attainable_rate_of_decrease_through_societal_change )",
      "unit": "Dmnl"
    },
    {
      "name": "frustration_due_to_marginalization",
      "comment": "frustration due to marginalization",
      "equation": "LOOKUP(frustration_due_to_marginalization_lookup, fraction_of_convinced_citizens)",
      "unit": "Dmnl"
    },
    {
      "name": "net_increase_of_animal_distress",
      "comment": "net increase of animal distress",
      "equation": "animal_distress*(exogenous_rate_of_increase_of_animal_distress-rate_of_decrease_through_societal_change )",
      "unit": "1/Year"
    },
    {
      "name": "perceived_animal_distress",
      "comment": "perceived animal distress",
      "equation": "SMOOTH( animal_distress/societal_acceptation_threshold_with_regard_to_animal_distress ,1)",
      "unit": "Dmnl"
    },
    {
      "name": "problem_symptoms",
      "comment": "problem symptoms",
      "equation": "MAX(animal_distress-societal_acceptation_threshold_with_regard_to_animal_distress,0) /societal_acceptation_threshold_with_regard_to_animal_distress",
      "unit": "Dmnl"
    },
    {
      "name": "societal_acceptation_threshold_with_regard_to_animal_distress",
      "comment": "60",
      "equation": "LOOKUP(societal_acceptation_threshold_with_regard_to_animal_distress_lookup, TIME)",
      "unit": "Dmnl"
    },
    {
      "name": "rate_of_decrease_through_societal_change",
      "comment": "rate of decrease through societal change",
      "equation": "fraction_of_convinced_citizens*maximum_attainable_rate_of_decrease_through_societal_change",
      "unit": "1/Year"
    },
    {
      "name": "TIME_STEP",
      "equation": "0.125",
      "unit": "Year"
    },
    {
      "name": "INITIAL_TIME",
      "equation": "1980",
      "unit": "Year"
    },
    {
      "name": "FINAL_TIME",
      "equation": "2080",
      "unit": "Year"
    },
    {
      "name": "commitment_of_radical_individuals_to_radical_action",
      "equation": "1",
      "comment": "commitment of radical individuals to radical action",
      "unit": "1/citizens"
    },
    {
      "name": "potential_fraction_of_extremists",
      "equation": "0.1",
      "comment": "potential fraction of extremists",
      "unit": "Dmnl"
    },
    {
      "name": "average_time_to_change_states",
      "equation": "10",
      "comment": "average time to change states",
      "unit": "Year"
    },
    {
      "name": "ini_extremists",
      "equation": "0",
      "comment": "ini extremists",
      "unit": "citizens"
    },
    {
      "name": "ini_activists",
      "equation": "1000",
      "comment": "ini activists",
      "unit": "citizens"
    },
    {
      "name": "potential_fraction_of_activists",
      "equation": "0.1",
      "comment": "potential fraction of activists",
      "unit": "Dmnl"
    },
    {
      "name": "persuasiveness_of_nonradical_actions",
      "equation": "0.01",
      "comment": "OLD: \"non-radical action level\"*normal persuasiveness",
      "unit": "citizens/contacts"
    },
    {
      "name": "citizens_that_cannot_be_convinced",
      "equation": "3000000",
      "comment": "citizens that cannot be convinced",
      "unit": "citizens"
    },
    {
      "name": "ini_convinced",
      "equation": "100000",
      "comment": "ini convinced",
      "unit": "citizens"
    },
    {
      "name": "ini_unconvinced",
      "equation": "12900000",
      "comment": "ini unconvinced",
      "unit": "citizens"
    },
    {
      "name": "initial_value_of_underlying_phenomenon",
      "equation": "100",
      "comment": "initial value of underlying phenomenon",
      "unit": "Dmnl"
    },
    {
      "name": "exogenous_rate_of_increase_of_animal_distress",
      "equation": "0",
      "comment": "exogenous rate of increase of animal distress",
      "unit": "1/Year"
    },
    {
      "name": "maximum_attainable_rate_of_decrease_through_societal_change",
      "equation": "0.05",
      "comment": "maximum attainable rate of decrease through societal change",
      "unit": "1/Year"
    },
    {
      "name": "normal_contact_rate_of_convinced_citizens",
      "equation": "1000",
      "comment": "normal contact rate of convinced citizens",
      "unit": "contacts/citizen"
    },
    {
      "name": "strength_of_incompatible_selfinterest",
      "equation": "10",
      "comment": "\"strength of incompatible self-interest\"",
      "unit": "Dmnl"
    }
  ],
