{
  "name": "HousingMarket",
  "stocks": [
    {
      "name": "cumulative_inflation",
      "comment": "cumulative inflation",
      "initialValue": 1.0,
      "unit": ""
    },
    {
      "name": "in_planning_and_under_construction",
      "comment": "in planning and under construction",
      "initialValue": 250000.0,
      "unit": ""
    },
    {
      "name": "new_houses",
      "comment": "new houses",
      "initialValue": 1550000.0,
      "unit": "houses"
    },
    {
      "name": "old_houses",
      "comment": "schaarste...",
      "initialValue": 3600000.0,
      "unit": "houses"
    }
  ],
  "flows": [
    {
      "name": "cumulative_inflation_net_flow",
      "comment": "Net flow for cumulative inflation",
      "equation": "expected_inflation_rate * cumulative_inflation * MAX((1 - (uncertainty-1)),0)",
      "timeUnit": "Year",
      "sink": "cumulative_inflation"
    },
    {
      "name": "in_planning_and_under_construction_net_flow",
      "comment": "Net flow for in planning and under construction",
      "equation": "in_planning_and_construction-construction_of_new_houses",
      "timeUnit": "Year",
      "sink": "in_planning_and_under_construction"
    },
    {
      "name": "new_houses_net_flow",
      "comment": "Net flow for new houses",
      "equation": "construction_of_new_houses-aging_of_houses",
      "timeUnit": "Year",
      "sink": "new_houses"
    },
    {
      "name": "old_houses_net_flow",
      "comment": "Net flow for old houses",
      "equation": "aging_of_houses-demolition_of_old_houses",
      "timeUnit": "Year",
      "sink": "old_houses"
    }
  ],
  "auxiliaries": [
    {
      "name": "aging_of_houses",
      "comment": "aging of houses",
      "equation": "DELAY_FIXED(construction_of_new_houses,lifetime_of_new_houses,construction_of_new_houses )",
      "unit": ""
    },
    {
      "name": "average_house_prices",
      "comment": "SMOOTH(average lending capacity per household*housing scarcity,10)",
      "equation": "SMOOTH(average_house_spending_capacity_per_household*housing_scarcity_ratio,1)",
      "unit": "Euros"
    },
    {
      "name": "average_house_spending_capacity_per_household",
      "comment": "average house spending capacity per household",
      "equation": "average_salary_per_household*(1+salary_lending_multiplier)",
      "unit": "Euros"
    },
    {
      "name": "average_salary_per_household",
      "comment": "average salary per household",
      "equation": "initial_average_salary * SMOOTH(cumulative_inflation,2) * expected_effective_workforce /expected_households",
      "unit": "Euros"
    },
    {
      "name": "construction_of_new_houses",
      "comment": "in planning and under construction/average planning and construction time",
      "equation": "DELAY3I(in_planning_and_construction, normal_planning_and_construction_time, in_planning_and_under_construction /normal_planning_and_construction_time)",
      "unit": "houses/Year"
    },
    {
      "name": "demolition_multiplicator",
      "comment": "MAX(1,housing scarcity),3,MAX(1,housing scarcity)",
      "equation": "DELAY_FIXED(\n\t1/housing_scarcity_ratio,1,1/housing_scarcity_ratio)",
      "unit": ""
    },
    {
      "name": "demolition_of_old_houses",
      "comment": "demolition of old houses",
      "equation": "old_houses/average_lifetime_old_houses * demolition_multiplicator",
      "unit": "houses/Year"
    },
    {
      "name": "expected_effective_workforce",
      "comment": "2000, 2020, 2040 RC 7,5 7,5 6,6\n\t\tSE 7,5 8,1 7,9\n\t\tTM 7,5 8,1 7,6\n\t\tGE 7,5 8,7 9,0",
      "equation": "LOOKUP(expected_effective_workforce_lookup, TIME)",
      "unit": ""
    },
    {
      "name": "housing_scarcity_ratio",
      "comment": "housing scarcity ratio",
      "equation": "expected_households/total_expected_supply_of_houses",
      "unit": "Dmnl"
    },
    {
      "name": "in_planning_and_construction",
      "comment": "SMOOTH(profitable housing gap * (1 + MAX(profitability of new house  construction,0)),1)",
      "equation": "housing_gap * profitability_multiplier",
      "unit": ""
    },
    {
      "name": "loan_risk",
      "comment": "loan risk",
      "equation": "DELAY3(MAX(0,uncertainty-1)/2,2)",
      "unit": ""
    },
    {
      "name": "normal_planning_and_construction_time",
      "comment": "normal planning and construction time",
      "equation": "LOOKUP(normal_planning_and_construction_time_lookup, in_planning_and_under_construction/ini_in_planning_and_under_construction)",
      "unit": "Year"
    },
    {
      "name": "normal_salary_lending_multiplier",
      "comment": "normal salary lending multiplier",
      "equation": "LOOKUP(normal_salary_lending_multiplier_lookup, TIME)",
      "unit": "Dmnl"
    },
    {
      "name": "profitability_multiplier",
      "comment": "profitability multiplier",
      "equation": "LOOKUP(profitability_multiplier_lookup, profitability_of_new_house_construction)",
      "unit": "Dmnl"
    },
    {
      "name": "profitability_of_new_house_construction",
      "comment": "(((1+new house premium) * average house prices-total construction cost new houses)*  construction of new houses - capacity house construction sector\n\t\t*fixed costs construction sector)/ (total construction cost new houses *  construction of new houses + capacity house construction sector\n\t\t*fixed costs construction sector)",
      "equation": "((1+new_house_premium)*average_house_prices-total_construction_cost_new_houses)/total_construction_cost_new_houses",
      "unit": "Dmnl"
    },
    {
      "name": "housing_gap",
      "comment": "IF THEN ELSE(profitability of new house construction>0,MAX(total demand  for houses-total supply of houses,0),0)",
      "equation": "MAX(expected_households*houses_per_household-total_expected_supply_of_houses,0)",
      "unit": "houses"
    },
    {
      "name": "salary_lending_multiplier",
      "comment": "salary lending multiplier",
      "equation": "normal_salary_lending_multiplier * (1-loan_risk)/uncertainty",
      "unit": "Dmnl"
    },
    {
      "name": "total_construction_cost_new_houses",
      "comment": "total construction cost new houses",
      "equation": "_1985_construction_cost_new_houses*cumulative_inflation",
      "unit": "Euros"
    },
    {
      "name": "total_expected_supply_of_houses",
      "comment": "new houses+in planning and under construction+old houses-old  houses/average lifetime old houses                     2010: 7118344.  Bron:  http://www.z24.nl/z24geld/huizen_wonen/artikel_255353.z24/Huizenmarkt__feit en_en_cijfers.html",
      "equation": "new_houses+in_planning_and_under_construction+old_houses-old_houses/average_lifetime_old_houses",
      "unit": "houses"
    },
    {
      "name": "expected_households",
      "comment": "Het aantal huishoudens op 1 januari 2011 bedroeg 7,47 miljoen en neemt  sterker toe dan de bevolkingsomvang. Dit wordt veroorzaakt door de sterke  toename van het aantal eenpersoonshuishoudens tot ruim 2,75 miljoen op 1  januari 2011.REF:  http://www.compendiumvoordeleefomgeving.nl/indicatoren/nl0001-Bevolkingsomv ang-en-huishoudens.html?i=15-12",
      "equation": "LOOKUP(expected_households_lookup, TIME)",
      "unit": "houses"
    },
    {
      "name": "uncertainty",
      "comment": "uncertainty",
      "equation": "LOOKUP(uncertainty_lookup, TIME)",
      "unit": ""
    },
    {
      "name": "TIME_STEP",
      "equation": "0.0078125",
      "unit": "Year"
    },
    {
      "name": "INITIAL_TIME",
      "equation": "1985",
      "unit": "Year"
    },
    {
      "name": "FINAL_TIME",
      "equation": "2085",
      "unit": "Year"
    },
    {
      "name": "_1985_construction_cost_new_houses",
      "equation": "95000",
      "comment": "\"1985 construction cost new houses\"",
      "unit": "Euros"
    },
    {
      "name": "average_lifetime_old_houses",
      "equation": "60",
      "comment": "average lifetime old houses",
      "unit": "Year"
    },
    {
      "name": "houses_per_household",
      "equation": "1",
      "comment": "houses per household",
      "unit": "houses/households"
    },
    {
      "name": "expected_inflation_rate",
      "equation": "0.02",
      "comment": "expected inflation rate"
    },
    {
      "name": "ini_in_planning_and_under_construction",
      "equation": "250000",
      "comment": "ini in planning and under construction",
      "unit": "houses"
    },
    {
      "name": "initial_average_salary",
      "equation": "27000",
      "comment": "initial average salary",
      "unit": "Euros"
    },
    {
      "name": "lifetime_of_new_houses",
      "equation": "15",
      "comment": "lifetime of new houses",
      "unit": "Year"
    },
    {
      "name": "new_house_premium",
      "equation": "0.05",
      "comment": "new house premium"
    }
  ],
