{
  "name" : "PROJ",
  "stocks" : [ {
    "name" : "Cumulative Complex Progress",
    "comment" : "CUMULATIVE COMPLEX PROGRESS",
    "initialValue" : 0.0,
    "unit" : "TASKS"
  }, {
    "name" : "Undiscovered Rework",
    "comment" : "UNDISCOVERED REWORK",
    "initialValue" : 0.0,
    "unit" : "TASKS"
  }, {
    "name" : "Perceived Productivity",
    "comment" : "PERCEIVED PRODUCTIVITY",
    "initialValue" : 0.0,
    "initialExpression" : "Indicated_Productivity",
    "unit" : "TASKS/WORKER/MONTH"
  }, {
    "name" : "Experienced Workforce",
    "comment" : "EXPERIENCED WORKFORCE",
    "initialValue" : 2.0,
    "unit" : "WORKERS"
  }, {
    "name" : "New Workforce",
    "comment" : "NEW WORKFORCE",
    "initialValue" : 1.0,
    "unit" : "WORKERS"
  }, {
    "name" : "Scheduled Completion Date",
    "comment" : "SCHEDULED COMPLETION DATE",
    "initialValue" : 40.0,
    "unit" : "MONTH"
  }, {
    "name" : "Cumulative Effort",
    "comment" : "CUMULATIVE EFFORT",
    "initialValue" : 0.0,
    "unit" : "WORKER*MONTH"
  } ],
  "flows" : [ {
    "name" : "Cumulative Complex Progress net flow",
    "comment" : "Net flow for Cumulative Complex Progress",
    "equation" : "real_progress_rate",
    "timeUnit" : "Month",
    "sink" : "Cumulative Complex Progress"
  }, {
    "name" : "Undiscovered Rework inflow 1",
    "equation" : "generation_of_undiscovered_rework",
    "timeUnit" : "Month",
    "sink" : "Undiscovered Rework"
  }, {
    "name" : "Undiscovered Rework outflow 2",
    "equation" : "detection_of_undiscovered_rework",
    "timeUnit" : "Month",
    "source" : "Undiscovered Rework"
  }, {
    "name" : "Perceived Productivity net flow",
    "comment" : "Net flow for Perceived Productivity",
    "equation" : "(Indicated_Productivity-Perceived_Productivity)/time_to_perceive_productivity",
    "timeUnit" : "Month",
    "sink" : "Perceived Productivity"
  }, {
    "name" : "Experienced Workforce net flow",
    "comment" : "Net flow for Experienced Workforce",
    "equation" : "workforce_assimilation_rate",
    "timeUnit" : "Month",
    "sink" : "Experienced Workforce"
  }, {
    "name" : "New Workforce net flow",
    "comment" : "Net flow for New Workforce",
    "equation" : "hiring_rate",
    "timeUnit" : "Month",
    "sink" : "New Workforce"
  }, {
    "name" : "Scheduled Completion Date net flow",
    "comment" : "Net flow for Scheduled Completion Date",
    "equation" : "net_additions_to_schedule",
    "timeUnit" : "Month",
    "sink" : "Scheduled Completion Date"
  }, {
    "name" : "Cumulative Effort net flow",
    "comment" : "Net flow for Cumulative Effort",
    "equation" : "workforce*effect_of_schedule_pressure_on_gross_productivity",
    "timeUnit" : "Month",
    "sink" : "Cumulative Effort"
  } ],
  "variables" : [ {
    "name" : "real progress rate",
    "comment" : "REAL PROGRESS RATE",
    "equation" : "apparent_progress_rate*fraction_satisfactory",
    "unit" : "TASKS/MONTH"
  }, {
    "name" : "apparent progress rate",
    "comment" : "APPARENT PROGRESS RATE",
    "equation" : "workforce*gross_productivity*effect_of_schedule_pressure_on_gross_productivity",
    "unit" : "TASKS/MONTH"
  }, {
    "name" : "gross productivity",
    "comment" : "GROSS PRODUCTIVITY",
    "equation" : "normal_gross_productivity*effect_of_experience_on_gross_productivity",
    "unit" : "TASKS/WORKER/MONTH"
  }, {
    "name" : "normal gross productivity",
    "comment" : "NORMAL GROSS PRODUCTIVITY",
    "equation" : "1",
    "unit" : "TASKS/WORKER/MONTH"
  }, {
    "name" : "fraction satisfactory",
    "comment" : "FRACTION SATISFACTORY",
    "equation" : "normal_fraction_satisfactory*effect_of_experience_on_fraction_satisfactory*effect_of_schedule_pressure_on_fraction_satisfactory",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "normal fraction satisfactory",
    "comment" : "NORMAL FRACTION SATISFACTORY",
    "equation" : "LOOKUP(normal_fraction_satisfactory_lookup, fraction_completed)",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "effect of experience on gross productivity",
    "comment" : "EFFECT OF EXPERIENCE ON GROSS PRODUCTIVITY",
    "equation" : "LOOKUP(effect_of_experience_on_gross_productivity_lookup, fraction_of_workforce_experienced)",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "fraction of workforce experienced",
    "comment" : "FRACTION OF WORKFORCE EXPERIENCED",
    "equation" : "Experienced_Workforce/workforce",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "effect of experience on fraction satisfactory",
    "comment" : "EFFECT OF EXPERIENCE ON FRACTION SATISFACTORY",
    "equation" : "LOOKUP(fraction_of_workforce_experienced_lookup, fraction_of_workforce_experienced)",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "effect of schedule pressure on fraction satisfactory",
    "comment" : "EFFECT OF SCHEDULE PRESSURE ON FRACTION SATISFACTORY",
    "equation" : "LOOKUP(effect_of_schedule_pressure_on_fraction_satisfactory_lookup, indicated_completion_date /Scheduled_Completion_Date)",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "effect of schedule pressure on gross productivity",
    "comment" : "EFFECT OF SCHEDULE PRESSURE ON GROSS PRODUCTIVITY",
    "equation" : "LOOKUP(effect_of_schedule_pressure_on_gross_productivity_lookup, indicated_completion_date/Scheduled_Completion_Date)",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "generation of undiscovered rework",
    "comment" : "GENERATION OF UNDISCOVERED REWORK",
    "equation" : "apparent_progress_rate*(1-fraction_satisfactory)",
    "unit" : "TASKS/MONTH"
  }, {
    "name" : "detection of undiscovered rework",
    "comment" : "DETECTION OF UNDICOVERED REWORK",
    "equation" : "Undiscovered_Rework/time_to_detect_rework",
    "unit" : "TASKS/MONTH"
  }, {
    "name" : "time to detect rework",
    "comment" : "TIME TO DETECT REWORK",
    "equation" : "LOOKUP(time_to_detect_rework_lookup, fraction_perceived_complete)",
    "unit" : "MONTHS"
  }, {
    "name" : "cumulative perceived progress",
    "comment" : "CUMULATIVE PERCEIVED PROGRESS",
    "equation" : "Cumulative_Complex_Progress+Undiscovered_Rework",
    "unit" : "TASKS"
  }, {
    "name" : "fraction perceived complete",
    "comment" : "FRACTION PERCEIVED COMPLETE",
    "equation" : "cumulative_perceived_progress/current_project_definition",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "current project definition",
    "comment" : "CURRENT PROJECT DEFINITION",
    "equation" : "LOOKUP(project_definition_lookup, fraction_completed)",
    "unit" : "TASKS"
  }, {
    "name" : "final project definition",
    "comment" : "FINAL PROJECT DEFINITION",
    "equation" : "INITIAL( LOOKUP(project_definition_lookup, 1))",
    "unit" : "TASKS"
  }, {
    "name" : "fraction completed",
    "comment" : "FRACTION COMPLETED",
    "equation" : "Cumulative_Complex_Progress/final_project_definition",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "effort perceived remaining",
    "comment" : "EFFORT PERCEIVED REMAINING",
    "equation" : "(current_project_definition-cumulative_perceived_progress)/Perceived_Productivity",
    "unit" : "WORKER*MONTHS"
  }, {
    "name" : "time to perceive productivity",
    "comment" : "TIME TO PERCEIVE PRODUCTIVITY",
    "equation" : "6",
    "unit" : "MONTHS"
  }, {
    "name" : "Indicated Productivity",
    "comment" : "INDICATED PRODUCTIVITY",
    "equation" : "weight_to_real_productivity*real_productivity+(1-weight_to_real_productivity)*normal_gross_productivity",
    "unit" : "TASKS/WORKER/MONTH"
  }, {
    "name" : "weight to real productivity",
    "comment" : "WEIGHT TO REAL PRODUCTIVITY",
    "equation" : "LOOKUP(weight_to_perceived_productivity_lookup, fraction_perceived_complete)",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "real productivity",
    "comment" : "REAL PRODUCTIVITY",
    "equation" : "normal_gross_productivity*fraction_satisfactory",
    "unit" : "TASKS/WORKER/MONTH"
  }, {
    "name" : "workforce",
    "comment" : "WORKFORCE",
    "equation" : "Experienced_Workforce+New_Workforce",
    "unit" : "WORKERS"
  }, {
    "name" : "initial experienced workforce",
    "comment" : "INITIAL EXPERIENCED WORKFORCE",
    "equation" : "2",
    "unit" : "WORKERS"
  }, {
    "name" : "workforce assimilation rate",
    "comment" : "WORKFORCE ASSIMILATION RATE",
    "equation" : "New_Workforce/assimilation_time",
    "unit" : "WORKERS/MONTH"
  }, {
    "name" : "assimilation time",
    "comment" : "ASSIMILATION TIME",
    "equation" : "6",
    "unit" : "MONTHS"
  }, {
    "name" : "initial new workforce",
    "comment" : "INITIAL NEW WORKFORCE",
    "equation" : "1",
    "unit" : "WORKERS"
  }, {
    "name" : "hiring rate",
    "comment" : "HIRING RATE",
    "equation" : "((workforce_sought-workforce)/workforce_adjustment_time)",
    "unit" : "WORKERS/MONTH"
  }, {
    "name" : "workforce adjustment time",
    "comment" : "WORKFORCE ADJUSTMENT TIME",
    "equation" : "3",
    "unit" : "MONTHS"
  }, {
    "name" : "workforce sought",
    "comment" : "WORKFORCE SOUGHT",
    "equation" : "willingness_to_change_workforce*indicated_workforce+(1-willingness_to_change_workforce )*workforce",
    "unit" : "WORKERS"
  }, {
    "name" : "willingness to change workforce",
    "comment" : "WILLINGNESS TO CHANGE WORKFORCE",
    "equation" : "LOOKUP(willingness_to_change_workforce_lookup, time_remaining)",
    "unit" : "DIMENSIONLESS"
  }, {
    "name" : "indicated workforce",
    "comment" : "INDICATED WORKFORCE",
    "equation" : "effort_perceived_remaining/time_remaining",
    "unit" : "WORKERS"
  }, {
    "name" : "time remaining",
    "comment" : "TIME REMAINING",
    "equation" : "Scheduled_Completion_Date-TIME",
    "unit" : "MONTHS"
  }, {
    "name" : "initial scheduled completion date",
    "comment" : "INITIAL SCHEDULED COMPLETION DATE",
    "equation" : "40",
    "unit" : "MONTH"
  }, {
    "name" : "net additions to schedule",
    "comment" : "NET ADDITIONS TO SCHEDULE",
    "equation" : "(indicated_completion_date-Scheduled_Completion_Date)/schedule_adjustment_time",
    "unit" : "MONTHS/MONTH"
  }, {
    "name" : "schedule adjustment time",
    "comment" : "SCHEDULE ADJUSTMENT TIME",
    "equation" : "6",
    "unit" : "MONTHS"
  }, {
    "name" : "indicated completion date",
    "comment" : "INDICATED COMPLETION DATE",
    "equation" : "TIME+time_perceived_required",
    "unit" : "MONTH"
  }, {
    "name" : "time perceived required",
    "comment" : "TIME PERCEIVED REQUIRED",
    "equation" : "effort_perceived_remaining/workforce_sought",
    "unit" : "MONTHS"
  }, {
    "name" : "cost",
    "comment" : "COST",
    "equation" : "cost_per_worker_month*Cumulative_Effort",
    "unit" : "DOLLARS"
  }, {
    "name" : "cost per worker month",
    "comment" : "COST PER WORKER MONTH",
    "equation" : "3000",
    "unit" : "DOLLARS/(WORKER*MONTH)"
  }, {
    "name" : "MAXLEN",
    "comment" : "MAXLEN",
    "equation" : "100",
    "unit" : "MONTH"
  } ],
