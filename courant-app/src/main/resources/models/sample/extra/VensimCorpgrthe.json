    "name" : "Sales Force",
    "comment" : "Sales Force",
    "initialValue" : 10.0,
    "unit" : "person"
  } ],
  "flows" : [ {
    "name" : "Delivery Delay Recognized net flow",
    "comment" : "Net flow for Delivery Delay Recognized",
    "equation" : "(delivery_delay_impending - Delivery_Delay_Recognized) / time_for_delivery_delay_recognition",
    "timeUnit" : "Month",
    "sink" : "Delivery Delay Recognized"
  }, {
    "name" : "Backlog inflow 1",
    "equation" : "orders_entered",
    "timeUnit" : "Month",
    "sink" : "Backlog"
  }, {
    "name" : "Backlog outflow 2",
    "equation" : "orders_completed",
    "timeUnit" : "Month",
    "source" : "Backlog"
  }, {
    "name" : "Sales Force net flow",
    "comment" : "Net flow for Sales Force",
    "equation" : "net_hires",
    "timeUnit" : "Month",
    "sink" : "Sales Force"
  } ],
  "variables" : [ {
    "name" : "normal backlog",
    "comment" : "normal backlog",
    "equation" : "8000",
    "unit" : "unit"
  }, {
    "name" : "normal delivery delay recognized",
    "comment" : "normal delivery delay recognized",
    "equation" : "2",
    "unit" : "Month"
  }, {
    "name" : "normal delivery rate",
    "comment" : "normal delivery rate",
    "equation" : "4000",
    "unit" : "unit/Month"
  }, {
    "name" : "normal sales effectivness",
    "comment" : "normal sales effectivness",
    "equation" : "350",
    "unit" : "unit/(Month*person)"
  }, {
    "name" : "delivery rate",
    "comment" : "delivery rate",
    "equation" : "normal_delivery_rate * effect_of_backlog_on_delivery_rate",
    "unit" : "unit/Month"
  }, {
    "name" : "effect of backlog on delivery rate",
    "comment" : "effect of backlog on delivery rate",
    "equation" : "LOOKUP(effect_of_backlog_on_delivery_rate_lookup, Backlog/normal_backlog)",
    "unit" : "dmnl"
  }, {
    "name" : "effect of delivery delay recognized",
    "comment" : "effect of delivery delay recognized",
    "equation" : "LOOKUP(effect_of_delivery_delay_recognized_lookup, Delivery_Delay_Recognized/normal_delivery_delay_recognized)",
    "unit" : "dmnl"
  }, {
    "name" : "sales effectiveness",
    "comment" : "sales effectiveness",
    "equation" : "normal_sales_effectivness * effect_of_delivery_delay_recognized",
    "unit" : "unit/(person*Month)"
  }, {
    "name" : "budget",
    "comment" : "budget",
    "equation" : "orders_booked * revenue_to_sales",
    "unit" : "dollars/Month"
  }, {
    "name" : "delivery delay impending",
    "comment" : "delivery delay impending",
    "equation" : "Backlog / delivery_rate",
    "unit" : "Month"
  }, {
    "name" : "indicated sales force",
    "comment" : "indicated sales force",
    "equation" : "budget / sales_person_salary",
    "unit" : "person"
  }, {
    "name" : "net hires",
    "comment" : "net hires",
    "equation" : "(indicated_sales_force - Sales_Force) / sales_force_adjustment_time",
    "unit" : "person/Month"
  }, {
    "name" : "orders booked",
    "comment" : "orders booked",
    "equation" : "Sales_Force * sales_effectiveness",
    "unit" : "unit/Month"
  }, {
    "name" : "orders completed",
    "comment" : "orders completed",
    "equation" : "delivery_rate",
    "unit" : "unit/Month"
  }, {
    "name" : "orders entered",
    "comment" : "orders entered",
    "equation" : "orders_booked",
    "unit" : "unit/Month"
  }, {
    "name" : "revenue to sales",
    "comment" : "revenue to sales",
    "equation" : "10",
    "unit" : "dollars/unit"
  }, {
    "name" : "sales force adjustment time",
    "comment" : "sales force adjustment time",
    "equation" : "20",
    "unit" : "Month"
  }, {
    "name" : "sales person salary",
    "comment" : "sales person salary",
    "equation" : "2000",
    "unit" : "dollars/(person*Month)"
  }, {
    "name" : "time for delivery delay recognition",
    "comment" : "time for delivery delay recognition",
    "equation" : "5",
    "unit" : "Month"
  } ],
