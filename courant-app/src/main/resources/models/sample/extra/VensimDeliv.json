  }, {
    "name" : "Backlog inflow 1",
    "equation" : "orders",
    "timeUnit" : "Week",
    "sink" : "Backlog"
  }, {
    "name" : "Backlog outflow 2",
    "equation" : "shipments",
    "timeUnit" : "Week",
    "source" : "Backlog"
  } ],
  "variables" : [ {
    "name" : "new customers",
    "comment" : "new customers",
    "equation" : "shipments / products_per_customer",
    "unit" : "Person/Week"
  }, {
    "name" : "new people ready to order",
    "comment" : "new people ready to order",
    "equation" : "Customers * normal_effective_referral_fraction",
    "unit" : "Person/Week"
  }, {
    "name" : "orders",
    "comment" : "orders",
    "equation" : "new_people_ready_to_order * effect_of_delivery_delay_on_orders * products_per_customer",
    "unit" : "Machine/Week"
  }, {
    "name" : "products per customer",
    "comment" : "products per customer",
    "equation" : "1",
    "unit" : "Machine/Person"
  }, {
    "name" : "capacity",
    "comment" : "capacity",
    "equation" : "1000",
    "unit" : "Machine/Week"
  }, {
    "name" : "delivery delay",
    "comment" : "delivery delay",
    "equation" : "Backlog/shipments",
    "unit" : "Week"
  }, {
    "name" : "effect of delivery delay on orders",
    "comment" : "effect of delivery delay on orders",
    "equation" : "LOOKUP(effect_of_delivery_delay_on_orders_lookup, delivery_delay/normal_delivery_delay)",
    "unit" : "Dmnl"
  }, {
    "name" : "minimum cycle time",
    "comment" : "minimum cycle time",
    "equation" : "1",
    "unit" : "Week"
  }, {
    "name" : "normal delivery delay",
    "comment" : "normal delivery delay",
    "equation" : "2",
    "unit" : "Week"
  }, {
    "name" : "normal effective referral fraction",
    "comment" : "normal effective referral fraction",
    "equation" : "0.1",
    "unit" : "fraction/Week"
  }, {
    "name" : "shipments",
    "comment" : "shipments",
    "equation" : "MIN(Backlog/minimum_cycle_time, capacity)",
    "unit" : "Machine/Week"
  } ],
  "lookupTables" : [ {
