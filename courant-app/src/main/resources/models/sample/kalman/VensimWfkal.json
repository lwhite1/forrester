{
  "name" : "WFKAL",
  "stocks" : [ {
    "name" : "Inventory",
    "comment" : "The amount of inventory on hand.",
    "initialValue" : 0.0,
    "initialExpression" : "des_inventory",
    "unit" : "widget"
  }, {
    "name" : "Workforce",
    "comment" : "The number of working people.",
    "initialValue" : 0.0,
    "initialExpression" : "initial_workforce",
    "unit" : "person"
  }, {
    "name" : "Exp Sales",
    "comment" : "The expected amount of sales.",
    "initialValue" : 0.0,
    "initialExpression" : "sales",
    "unit" : "widget/month"
  } ],
  "flows" : [ {
    "name" : "Inventory inflow 1",
    "equation" : "production",
    "timeUnit" : "Month",
    "sink" : "Inventory"
  }, {
    "name" : "Inventory outflow 2",
    "equation" : "sales",
    "timeUnit" : "Month",
    "source" : "Inventory"
  }, {
    "name" : "Workforce net flow",
    "comment" : "Net flow for Workforce",
    "equation" : "net_hire",
    "timeUnit" : "Month",
    "sink" : "Workforce"
  }, {
    "name" : "Exp Sales net flow",
    "comment" : "Net flow for Exp Sales",
    "equation" : "(sales - Exp_Sales)/Time_Avg_Sales",
    "timeUnit" : "Month",
    "sink" : "Exp Sales"
  } ],
  "variables" : [ {
    "name" : "initial workforce",
    "comment" : "The number of people working initially.",
    "equation" : "INITIAL( des_workforce)",
    "unit" : "person"
  }, {
    "name" : "net hire",
    "comment" : "The net hire rate.",
    "equation" : "(des_workforce - Workforce)/time_adjust_workforce + net_hire_noise*RANDOM_UNIFORM(-0.5,0.5,0)",
    "unit" : "person/month"
  }, {
    "name" : "net hire noise",
    "comment" : "Noise in net hiring to to unexpected events.",
    "equation" : "0",
    "unit" : "person/month"
  }, {
    "name" : "time adjust workforce",
    "comment" : "The time to adjust the workforce.",
    "equation" : "12",
    "unit" : "month"
  }, {
    "name" : "des workforce",
    "comment" : "The desired number of people working.",
    "equation" : "des_production / norm_productivity",
    "unit" : "person"
  }, {
    "name" : "productivity",
    "comment" : "The average productivity of workers.",
    "equation" : "(norm_productivity+RANDOM_UNIFORM(-0.5,0.5,0)*productivity_noise)",
    "unit" : "widget/person/month"
  }, {
    "name" : "norm productivity",
    "comment" : "The normal average productivity of workers.",
    "equation" : "1",
    "unit" : "widget/person/month"
  }, {
    "name" : "productivity noise",
    "comment" : "The magnitude of driving noise in determining productivity.",
    "equation" : "0",
    "unit" : "widget/(person*month)"
  }, {
    "name" : "des production",
    "comment" : "The desired production level.",
    "equation" : "Exp_Sales + inv_correction",
    "unit" : "widget/month"
  }, {
    "name" : "Time Avg Sales",
    "comment" : "The horizon over which sales are averaged.",
    "equation" : "6",
    "unit" : "month"
  }, {
    "name" : "inv correction",
    "comment" : "The desired correction to the level of inventory held.",
    "equation" : "(des_inventory - Inventory)/ time_correct_inventory",
    "unit" : "widget/month"
  }, {
    "name" : "time correct inventory",
    "comment" : "The time over which inventory discrepencies are \n\t\t        corrected.",
    "equation" : "4",
    "unit" : "month"
  }, {
    "name" : "des inventory",
    "comment" : "The desired amunt of stock to keep in inventory.",
    "equation" : "Exp_Sales * inventory_coverage",
    "unit" : "widget"
  }, {
    "name" : "inventory coverage",
    "comment" : "The number of months of sales held in inventory.",
    "equation" : "3",
    "unit" : "month"
  }, {
    "name" : "production",
    "comment" : "The rate of production.",
    "equation" : "Workforce * productivity",
    "unit" : "widget/month"
  }, {
    "name" : "meas inventory",
    "comment" : "The error prone measured sales.",
    "equation" : "Inventory * (1+RANDOM_UNIFORM(-0.5,0.5,0)*inventory_meas_noise)",
    "unit" : "widget"
  }, {
    "name" : "inventory meas noise",
    "comment" : "The magnitude of error in measuring inventory.",
    "equation" : "0",
    "unit" : "dmnl"
  }, {
    "name" : "meas workforce",
    "comment" : "The error prone measured sales.",
    "equation" : "Workforce * (1+RANDOM_UNIFORM(-0.5,0.5,0)*workforce_meas_noise)",
    "unit" : "person"
  }, {
    "name" : "workforce meas noise",
    "comment" : "The magnitude of error in measuring workforce..",
    "equation" : "0",
    "unit" : "dmnl"
  }, {
    "name" : "sales",
    "comment" : "The rate at which products are sold - exogenously input.",
    "equation" : "0",
    "unit" : "widget/month"
  }, {
    "name" : "meas workforce variance",
    "comment" : "The variance in measurement. .0833*(.025*100)^2",
    "equation" : "0.5",
    "unit" : "dmnl"
  }, {
    "name" : "meas inventory variance",
    "comment" : "The variance in measurement .0833*(.4*300)^2",
    "equation" : "1200",
    "unit" : "dmnl"
  }, {
    "name" : "inventory drive variance",
    "comment" : "The variance in driving noise .0833*(.2*1*100)",
    "equation" : "33",
    "unit" : "dmnl"
  }, {
    "name" : "workforce drive variance",
    "comment" : "The variance in driving workforce noise .0833*(4)^2",
    "equation" : "1.3",
    "unit" : "dmnl"
  } ],
  "comments" : [ {
