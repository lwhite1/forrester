  }, {
    "name" : "stock market value",
    "comment" : "stock market value",
    "initialValue" : 24.6,
    "unit" : "EURO"
  } ],
  "flows" : [ {
    "name" : "estimated underlying asset value inflow 1",
    "equation" : "underlying_asset_increase",
    "timeUnit" : "Week",
    "sink" : "estimated underlying asset value"
  }, {
    "name" : "estimated underlying asset value outflow 2",
    "equation" : "underlying_asset_loss",
    "timeUnit" : "Week",
    "source" : "estimated underlying asset value"
  }, {
    "name" : "stock market value inflow 1",
    "equation" : "stock_market_value_increase",
    "timeUnit" : "Week",
    "sink" : "stock market value"
  }, {
    "name" : "stock market value outflow 2",
    "equation" : "stock_market_value_loss",
    "timeUnit" : "Week",
    "source" : "stock market value"
  } ],
  "variables" : [ {
    "name" : "TIME_STEP",
    "equation" : "0.0078125",
    "unit" : "Week"
  }, {
    "name" : "INITIAL_TIME",
    "equation" : "0",
    "unit" : "Week"
  }, {
    "name" : "FINAL_TIME",
    "equation" : "52",
    "unit" : "Week"
  }, {
    "name" : "liquid deposits and loans loss fraction",
    "comment" : "liquid deposits and loans loss fraction",
    "equation" : "average_bank_clients_fear_and_uncertainty/average_stickiness_of_deposits_and_loans",
    "unit" : "1/Week"
  }, {
    "name" : "underlying asset loss",
    "comment" : "underlying asset loss",
    "equation" : "MAX((liquid_deposits_and_loans_loss_fraction*fraction_of_asset_loss_to_deposit_loss+ external_shock_real_value_loss)*estimated_underlying_asset_value ,0)",
    "unit" : "EURO/Week"
  }, {
    "name" : "fraction of asset loss to deposit loss",
    "comment" : "fraction of asset loss to deposit loss",
    "equation" : "1",
    "unit" : "Dmnl"
  }, {
    "name" : "external shock real value loss",
    "comment" : "0.01 - STEP(0.01,11)",
    "equation" : "STEP(size_of_the_external_underlying_asset_shock,10) - STEP(size_of_the_external_underlying_asset_shock ,11)",
    "unit" : "1/Week"
  }, {
    "name" : "size of the external underlying asset shock",
    "comment" : "size of the external underlying asset shock",
    "equation" : "0.35",
    "unit" : "1/Week"
  }, {
    "name" : "stock market value increase",
    "comment" : "stock market value increase",
    "equation" : "MAX(stock_market_value * perceived_undervaluation/market_increase_delay,0)",
    "unit" : "EURO/Week"
  }, {
    "name" : "action delay",
    "comment" : "action delay",
    "equation" : "1",
    "unit" : "Week"
  }, {
    "name" : "average profitability",
    "comment" : "average profitability",
    "equation" : "0.002",
    "unit" : "1/Week"
  }, {
    "name" : "average stickiness of deposits and loans",
    "comment" : "average stickiness of deposits and loans",
    "equation" : "4",
    "unit" : "Week"
  }, {
    "name" : "degree of external climate of fear",
    "comment" : "degree of external climate of fear",
    "equation" : "2",
    "unit" : "Dmnl"
  }, {
    "name" : "market loss delay",
    "comment" : "market loss delay",
    "equation" : "1",
    "unit" : "Week"
  }, {
    "name" : "financial intervention",
    "comment" : "IF THEN ELSE(estimated asset value<initial underlying value*0.5, initial  underlying value*0.2, 0)",
    "equation" : "MAX(0,(fraction_initial_guaranteed*initial_estimated_underlying_asset_value - estimated_underlying_asset_value )/action_delay) * policy_switch",
    "unit" : "EURO/Week"
  }, {
    "name" : "fraction initial guaranteed",
    "comment" : "fraction initial guaranteed",
    "equation" : "0.5",
    "unit" : "Dmnl"
  }, {
    "name" : "initial market fear and uncertainty",
    "comment" : "initial market fear and uncertainty",
    "equation" : "0",
    "unit" : "Dmnl"
  }, {
    "name" : "initial stock market value",
    "comment" : "initial stock market value",
    "equation" : "24.6",
    "unit" : "EURO"
  }, {
    "name" : "initial estimated underlying asset value",
    "comment" : "initial estimated underlying asset value",
    "equation" : "25",
    "unit" : "EURO"
  }, {
    "name" : "instant market fear and uncertainty",
    "comment" : "instant market fear and uncertainty",
    "equation" : "MIN(stock_market_value_loss/(stock_market_value/market_loss_delay*stock_market_fear_factor ) * degree_of_external_climate_of_fear,1)",
    "unit" : "Dmnl"
  }, {
    "name" : "average bank clients fear and uncertainty",
    "comment" : "average bank client's fear and uncertainty",
    "equation" : "smoothed_market_fear_and_uncertainty",
    "unit" : "Dmnl"
  }, {
    "name" : "perceived overvaluation",
    "comment" : "perceived overvaluation",
    "equation" : "MAX((stock_market_value-estimated_underlying_asset_value)/stock_market_value,0)",
    "unit" : "Dmnl"
  }, {
    "name" : "perceived undervaluation",
    "comment" : "perceived undervaluation",
    "equation" : "MAX((estimated_underlying_asset_value-stock_market_value)/stock_market_value,0)",
    "unit" : "Dmnl"
  }, {
    "name" : "policy switch",
    "comment" : "policy switch",
    "equation" : "0",
    "unit" : "Dmnl"
  }, {
    "name" : "market increase delay",
    "comment" : "market increase delay",
    "equation" : "4",
    "unit" : "Week"
  }, {
    "name" : "smoothed market fear and uncertainty",
    "comment" : "smoothed market fear and uncertainty",
    "equation" : "DELAY3I(instant_market_fear_and_uncertainty, uncertainty_and_fear_delay, initial_market_fear_and_uncertainty )",
    "unit" : "Dmnl"
  }, {
    "name" : "stock market fear factor",
    "comment" : "stock market fear factor",
    "equation" : "0.25",
    "unit" : "Dmnl"
  }, {
    "name" : "stock market value loss",
    "comment" : "stock market value loss",
    "equation" : "MAX(stock_market_value * (perceived_overvaluation/market_loss_delay),0)",
    "unit" : "EURO/Week"
  }, {
    "name" : "uncertainty and fear delay",
    "comment" : "uncertainty and fear delay",
    "equation" : "2",
    "unit" : "Week"
  }, {
    "name" : "underlying asset increase",
    "comment" : "underlying asset increase",
    "equation" : "average_profitability*estimated_underlying_asset_value + financial_intervention",
    "unit" : "EURO/Week"
  } ],
