    "equation" : "price_factor*production",
    "unit" : "$/Year"
  }, {
    "name" : "profit",
    "comment" : "profit",
    "equation" : "(1-INVESTMENT_FRACTION)*investment_generation/INVESTMENT_FRACTION",
