    "comment" : "INVESTMENT FRACTION",
    "equation" : "0.5",
    "unit" : "1"
  }, {
    "name" : "investment generation",
    "comment" : "MAX((net revenue-repayment), 0)",
    "equation" : "INVESTMENT_FRACTION*MAX((net_revenue-repayment), 0)",
    "unit" : "$/Year"
  }, {
    "name" : "investment",
    "comment" : "investment",
    "equation" : "investment_generation+credit",
    "unit" : "$/Year"
  }, {
    "name" : "INVESTMENT EFFECTIVENESS",
    "comment" : "INVESTMENT EFFECTIVENESS",
    "equation" : "0.5",
    "unit" : "1"
  }, {
    "name" : "credit",
    "comment" : "credit",
    "equation" : "CREDIT_AMOUNT*CREDIT_FUNCTION",
    "unit" : "$/Year"
  }, {
    "name" : "CREDIT FUNCTION",
    "comment" : "CREDIT FUNCTION",
    "equation" : "LOOKUP(CREDIT_FUNCTION_lookup, TIME)",
    "unit" : "1"
  }, {
    "name" : "CREDIT AMOUNT",
    "comment" : "CREDIT AMOUNT",
    "equation" : "100",
    "unit" : "$/Year"
  }, {
    "name" : "DEMAND",
    "comment" : "DEMAND",
    "equation" : "100",
    "unit" : "Stück/Year"
  }, {
    "name" : "net revenue",
    "comment" : "net revenue",
    "equation" : "revenue-interest_payment",
    "unit" : "$/Year"
  }, {
    "name" : "price factor",
    "comment" : "price factor",
    "equation" : "LOOKUP(price_factor_lookup, production/DEMAND)",
    "unit" : "1"
  }, {
    "name" : "production",
    "comment" : "production",
    "equation" : "SPECIFIC_PRODUCTION*production_plants",
    "unit" : "$/Year"
  }, {
    "name" : "DEBT REPAYMENT FRACTION",
    "comment" : "DEBT REPAYMENT FRACTION",
    "equation" : "0.5",
    "unit" : "1"
  }, {
    "name" : "repayment",
    "comment" : "repayment",
    "equation" : "IF((net_revenue>0) and (debt>0), DEBT_REPAYMENT_FRACTION*net_revenue, 0)",
    "unit" : "$/Year"
  }, {
    "name" : "debt decrease",
    "comment" : "debt decrease",
    "equation" : "repayment",
    "unit" : "$/Year"
  }, {
    "name" : "debt increase",
    "comment" : "debt increase",
    "equation" : "credit+interest_debt",
    "unit" : "$/Year"
  }, {
    "name" : "SPECIFIC PRODUCTION",
    "comment" : "SPECIFIC PRODUCTION",
    "equation" : "1",
    "unit" : "($/Year)/$"
  }, {
    "name" : "deterioration",
    "comment" : "deterioration",
    "equation" : "DETERIORATION_RATE*production_plants",
    "unit" : "$/Year"
  }, {
    "name" : "DETERIORATION RATE",
    "comment" : "DETERIORATION RATE",
    "equation" : "0.05",
    "unit" : "1/Year"
  }, {
    "name" : "interest",
    "comment" : "interest",
    "equation" : "interest_payment",
    "unit" : "$/Year"
  }, {
    "name" : "INTEREST RATE",
    "comment" : "INTEREST RATE",
    "equation" : "0.07",
    "unit" : "1/Year"
  }, {
    "name" : "interest debt",
    "comment" : "interest debt",
    "equation" : "MAX(-net_revenue, 0)",
