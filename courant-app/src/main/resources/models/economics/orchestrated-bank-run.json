  }, {
    "name" : "intervention cost net flow",
    "comment" : "Net flow for intervention cost",
    "equation" : "new_liquid_assets",
    "timeUnit" : "Day",
    "sink" : "intervention cost"
  }, {
    "name" : "liquid assets inflow 1",
    "equation" : "liquidation",
    "timeUnit" : "Day",
    "sink" : "liquid assets"
  }, {
