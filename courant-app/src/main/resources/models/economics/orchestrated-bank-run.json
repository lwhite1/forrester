    "equation" : "new_liquid_assets",
    "timeUnit" : "Day",
    "sink" : "liquid assets"
  }, {
    "name" : "liquid assets outflow 3",
    "equation" : "liquid_assets_lost",
    "timeUnit" : "Day",
    "source" : "liquid assets"
  }, {
    "name" : "fixed assets outflow 1",
    "equation" : "liquidation",
    "timeUnit" : "Day",
    "source" : "fixed assets"
  }, {
    "name" : "fixed assets outflow 2",
    "equation" : "liquidation_losses",
    "timeUnit" : "Day",
    "source" : "fixed assets"
  }, {
    "name" : "liquid deposits and loans net flow",
    "comment" : "Net flow for liquid deposits and loans",
    "equation" : "-liquid_deposits_and_loans_lost",
    "timeUnit" : "Day",
    "sink" : "liquid deposits and loans"
  } ],
  "variables" : [ {
    "name" : "TIME_STEP",
    "equation" : "0.0625",
    "unit" : "Day"
  }, {
    "name" : "INITIAL_TIME",
    "equation" : "0",
    "unit" : "Day"
  }, {
    "name" : "FINAL_TIME",
    "equation" : "100",
    "unit" : "Day"
  }, {
    "name" : "initial credibility DSB",
    "comment" : "initial credibility DSB",
    "equation" : "0.9",
    "unit" : "Dmnl"
  }, {
    "name" : "concerted liquid fraction running",
    "comment" : "concerted liquid fraction running",
    "equation" : "organised_run*(STEP(concerted_percentage_running,2)-STEP(concerted_percentage_running ,4))",
    "unit" : "Dmnl"
  }, {
    "name" : "concerted percentage running",
    "comment" : "concerted percentage running",
    "equation" : "0.05",
    "unit" : "Dmnl"
  }, {
    "name" : "credibility denials",
    "comment" : "credibility denials",
    "equation" : "initial_credibility_DSB-STEP(loss_of_credibility_DSB,1)*organised_run",
    "unit" : "Dmnl"
  }, {
    "name" : "new fixed loan",
    "comment" : "new fixed loan",
    "equation" : "0",
    "unit" : "EURO/Day"
  }, {
    "name" : "loss of credibility DSB",
    "comment" : "loss of credibility DSB",
    "equation" : "0.8",
    "unit" : "Dmnl"
  }, {
    "name" : "new fixed deposits and loans",
    "comment" : "new fixed deposits and loans",
    "equation" : "liquid_deposits_and_loans_lost*new_fixed_loan_as_fraction_of_liq_lost+new_fixed_loan",
    "unit" : "EURO/Week"
  }, {
    "name" : "new liquid assets",
    "comment" : "new liquid assets",
    "equation" : "new_fixed_deposits_and_loans+new_liquid_equity",
    "unit" : "EURO/Day"
  }, {
    "name" : "new liquid equity",
    "comment" : "new liquid equity",
    "equation" : "0",
    "unit" : "EURO/Day"
  }, {
    "name" : "new fixed loan as fraction of liq lost",
    "comment" : "new fixed loan as fraction of liq lost",
    "equation" : "0",
    "unit" : "Dmnl"
  }, {
    "name" : "organised run",
    "comment" : "organised run",
    "equation" : "1",
    "unit" : "Dmnl"
  }, {
    "name" : "total asset total liability ratio",
    "comment" : "total asset total liability ratio",
    "equation" : "(fixed_assets+liquid_assets)/(liquid_deposits_and_loans+fixed_deposits_and_loans)",
    "unit" : "Dmnl"
  }, {
    "name" : "perceived likelihood bank failure risk",
    "comment" : "perceived likelihood bank failure risk",
    "equation" : "MAX(perceived_likelihood_liquidity_failure,perceived_likelihood_solvency_failure)*(1 -credibility_denials)",
    "unit" : "Dmnl"
  }, {
    "name" : "anger",
    "comment" : "anger",
    "equation" : "0.5",
    "unit" : "Dmnl"
  }, {
    "name" : "liquid fraction running",
    "comment" : "liquid fraction running",
    "equation" : "LOOKUP(liquid_fraction_running_lookup, perceived_likelihood_bank_failure_risk)",
    "unit" : "Dmnl"
  }, {
    "name" : "liquidation losses",
    "comment" : "liquidation losses",
    "equation" : "liquidation/(1-liquidation_premium)*liquidation_premium",
    "unit" : "EURO/Day"
  }, {
    "name" : "liquidation time",
    "comment" : "liquidation time",
    "equation" : "1",
    "unit" : "Day"
  }, {
    "name" : "liquid asset liability target",
    "comment" : "liquid asset liability target",
    "equation" : "0.2",
    "unit" : "Dmnl"
  }, {
    "name" : "liquidation",
    "comment" : "liquidation",
    "equation" : "MAX(0,(liquid_asset_liability_target*liquid_deposits_and_loans-liquid_assets)/liquidation_time *(1-liquidation_premium))",
    "unit" : "EURO/Day"
  }, {
    "name" : "liquid deposits and loans lost",
    "comment" : "MIN((liquid fraction running+concerted liquid fraction running)*hindrance  bank failures*liquid deposits and loans/opnametijd,liquid deposits and  loans/opnametijd)",
    "equation" : "MIN((liquid_fraction_running*(1+expected_hindrance_possible_bank_failure)*(1+anger)+ concerted_liquid_fraction_running)*liquid_deposits_and_loans /withdrawal_time ,liquid_deposits_and_loans/withdrawal_time)",
    "unit" : "EURO/Day"
  }, {
    "name" : "DNB bank failure declaration",
    "comment" : "DNB bank failure declaration",
    "equation" : "IF(liquid_asset_liability_ratio < 0.01  or  total_asset_total_liability_ratio < 0.9, 1, 0)",
    "unit" : ""
  }, {
    "name" : "expected hindrance possible bank failure",
    "comment" : "expected hindrance possible bank failure",
    "equation" : "0.5",
    "unit" : "Dmnl"
  }, {
    "name" : "perceived likelihood solvency failure",
    "comment" : "solvency = total assets/total deposits and loans",
    "equation" : "LOOKUP(perceived_likelihood_solvency_failure_lookup, total_asset_total_liability_ratio)",
    "unit" : "Dmnl"
  }, {
    "name" : "liquid asset liability ratio",
    "comment" : "liquid asset liability ratio",
    "equation" : "liquid_assets/liquid_deposits_and_loans",
    "unit" : "Dmnl"
  }, {
    "name" : "perceived likelihood liquidity failure",
    "comment" : "perceived likelihood liquidity failure",
    "equation" : "LOOKUP(perceived_likelihood_liquidity_failure_lookup, liquid_asset_liability_ratio)",
    "unit" : "Dmnl"
  }, {
    "name" : "withdrawal time",
    "comment" : "withdrawal time",
    "equation" : "1",
    "unit" : "Day"
  }, {
    "name" : "liquid assets lost",
    "comment" : "liquid assets lost",
    "equation" : "liquid_deposits_and_loans_lost",
    "unit" : "EURO/Day"
  }, {
    "name" : "initial number of shares",
    "comment" : "initial number of shares",
    "equation" : "100000000",
    "unit" : "share"
  }, {
    "name" : "liquidation premium",
    "comment" : "liquidation premium",
    "equation" : "0.15",
    "unit" : "Dmnl"
  } ],
