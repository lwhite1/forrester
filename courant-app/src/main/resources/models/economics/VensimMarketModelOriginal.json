    "equation" : "60",
    "unit" : "Months"
  }, {
    "name" : "prod obsolescence rate",
    "comment" : "prod obsolescence rate",
    "equation" : "Products / prod_obs_time",
    "unit" : "Product / Month"
  }, {
    "name" : "retained cash flow",
