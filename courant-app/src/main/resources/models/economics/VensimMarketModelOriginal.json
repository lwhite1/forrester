  }, {
    "name" : "frac budget mfg",
    "comment" : "frac budget mfg",
    "equation" : "0.47",
    "unit" : "Dimensionless"
  }, {
    "name" : "frac budget r and d",
    "comment" : "frac budget r and d",
    "equation" : "0.15",
    "unit" : "Dimensionless"
  }, {
    "name" : "frac cash retained",
    "comment" : "frac cash retained",
    "equation" : "( 1 - frac_budget_mfg - frac_budget_r_and_d - percent_budget_adv/100 - percent_budget_ext_sales_reps/100 - percent_budget_int_dir_sales /100)",
    "unit" : "Fraction"
  }, {
    "name" : "fraction custs buying",
    "comment" : "fraction custs buying",
    "equation" : "LOOKUP(table_for_frac_buying, Pot_Orders_In_Negotiation / Potential_Orders)",
    "unit" : "Dimensionless"
  }, {
    "name" : "int dir sales cost",
    "comment" : "int dir sales cost",
    "equation" : "2400",
    "unit" : "$/ Person / Month"
  }, {
    "name" : "lifetime of mailing list",
    "comment" : "lifetime of mailing list",
    "equation" : "60",
    "unit" : "Months"
  }, {
    "name" : "normal lead gen effic",
    "comment" : "normal lead gen effic",
    "equation" : "7",
    "unit" : "Orders / Products / Month"
  }, {
    "name" : "normal share of sales",
    "comment" : "normal share of sales",
    "equation" : "0.8",
