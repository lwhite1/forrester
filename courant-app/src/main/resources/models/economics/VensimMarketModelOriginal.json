    "equation" : "400",
    "unit" : "$/ Person / Month"
  }, {
    "name" : "external sales reps",
    "comment" : "external sales reps",
    "equation" : "cash_revenue * percent_budget_ext_sales_reps/100 / ext_sales_rep_fee",
