    "name" : "demos per person month",
    "comment" : "demos per person month",
    "equation" : "12",
    "unit" : "Orders / Month / Person"
  }, {
    "name" : "eff of lead avail on demos",
    "comment" : "eff of lead avail on demos",
    "equation" : "LOOKUP(table_for_eff_of_leads, Potential_Orders / Int_Dir_Salespeople)",
