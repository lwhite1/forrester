  }, {
    "name" : "pot orders lost to comp",
    "comment" : "pot orders lost to comp",
    "equation" : "Pot_Orders_In_Negotiation * fraction_custs_buying * ( 1 - normal_share_of_sales ) / duration_of_negotiation",
    "unit" : "Orders / Month"
  }, {
    "name" : "pot orders not buying",
    "comment" : "pot orders not buying",
    "equation" : "Pot_Orders_In_Negotiation * ( 1 - fraction_custs_buying ) / duration_of_negotiation",
    "unit" : "Orders / Month"
  }, {
    "name" : "pot orders moving to negot",
    "comment" : "pot orders moving to negot",
    "equation" : "Int_Dir_Salespeople * demos_per_person_month * eff_of_lead_avail_on_demos * sales_rep_effect_mult",
    "unit" : "Orders / Month"
  }, {
    "name" : "pot ords obs rate",
    "comment" : "pot ords obs rate",
    "equation" : "Potential_Orders / lifetime_of_mailing_list",
    "unit" : "Orders / Month"
  }, {
    "name" : "potential orders initial",
    "comment" : "potential orders initial",
    "equation" : "2400",
    "unit" : "Orders"
  }, {
    "name" : "price",
    "comment" : "price",
    "equation" : "7000",
    "unit" : "$/ Orders"
  }, {
    "name" : "prod dev budget",
    "comment" : "prod dev budget",
    "equation" : "cash_revenue * frac_budget_r_and_d",
