    "equation" : "pot_ords_obs_rate",
    "timeUnit" : "Month",
    "source" : "Potential Orders"
  }, {
    "name" : "Potential Orders outflow 3",
    "equation" : "pot_orders_moving_to_negot",
    "timeUnit" : "Month",
    "source" : "Potential Orders"
  }, {
    "name" : "Potential Orders inflow 4",
    "equation" : "pot_orders_not_buying",
    "timeUnit" : "Month",
    "sink" : "Potential Orders"
  }, {
    "name" : "prod gen rate net flow",
    "comment" : "Net flow for prod gen rate",
