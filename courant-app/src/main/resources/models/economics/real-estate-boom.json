{
  "name": "RealEstateBoom",
  "stocks": [
    {
      "name": "REU under construction",
      "comment": "REU under construction",
      "initialValue": 0.0,
      "initialExpression": "immigrants/workers_per_REU_under_construction",
      "unit": "real estate unit"
    },
    {
      "name": "immigrants",
      "comment": "immigrants",
      "initialValue": 2000000.0,
      "unit": "person"
    },
    {
      "name": "locals",
      "comment": "locals",
      "initialValue": 220000.0,
      "unit": "person"
    },
    {
      "name": "REU supply",
      "comment": "REU supply",
      "initialValue": 1800000.0,
      "unit": "real estate unit"
    }
  ],
  "flows": [
    {
      "name": "REU under construction net flow",
      "comment": "Net flow for REU under construction",
      "equation": "new_REU_plans_approved-REU_commissioning",
      "timeUnit": "Month",
      "sink": "REU under construction"
    },
    {
      "name": "immigrants net flow",
      "comment": "Net flow for immigrants",
      "equation": "workforce_immigration-workforce_emigration-immigrant_integration",
      "timeUnit": "Month",
      "sink": "immigrants"
    },
    {
      "name": "locals net flow",
      "comment": "Net flow for locals",
      "equation": "immigrant_integration",
      "timeUnit": "Month",
      "sink": "locals"
    },
    {
      "name": "REU supply net flow",
      "comment": "Net flow for REU supply",
      "equation": "REU_commissioning-REU_demolition",
      "timeUnit": "Month",
      "sink": "REU supply"
    }
  ],
  "variables": [
    {
      "name": "relative attractiveness to immigrate",
      "comment": "relative attractiveness to immigrate",
      "equation": "(avg_salary_immigrants/normal_salary_immigrants)/(REU_price/subsidy)",
      "unit": "Dmnl"
    },
    {
      "name": "workforce emigration",
      "comment": "workforce emigration",
      "equation": "MAX((immigrants-labour_demand)/avg_emigration_time,0)",
      "unit": "person/Month"
    },
    {
      "name": "REU price",
      "comment": "REU price",
      "equation": "normal_cost_REU*LOOKUP(REU_shortage_price_effect, REU_shortage)",
      "unit": "dollar/real estate unit"
    },
    {
      "name": "labour shortage",
      "comment": "labour shortage",
      "equation": "labour_demand/immigrants",
      "unit": "Dmnl"
    },
    {
      "name": "avg salary immigrants",
      "comment": "avg salary immigrants",
      "equation": "normal_salary_immigrants*labour_shortage",
      "unit": "dollar/person/Month"
    },
    {
      "name": "expected new REU due to immigration",
      "comment": "expected new REU due to immigration",
      "equation": "(immigrants - immigrants_previous_period)*immigration_multiplication_factor",
      "unit": "real estate unit"
    },
    {
      "name": "expected REU shortage",
      "comment": "expected REU shortage",
      "equation": "REU_demand-REU_supply-REU_under_construction + expected_new_REU_due_to_immigration",
      "unit": "real estate unit"
    },
    {
      "name": "immigrants previous period",
      "comment": "immigrants previous period",
      "equation": "DELAY_FIXED(immigrants, 1, immigrants)",
      "unit": "person"
    },
    {
      "name": "workforce immigration",
      "comment": "workforce immigration",
      "equation": "MAX(relative_attractiveness_to_immigrate*immigrants/avg_immigration_time,0)",
      "unit": "person/Month"
    },
    {
      "name": "immigrant integration",
      "comment": "immigrant integration",
      "equation": "immigrants*immigrant_integration_rate",
      "unit": "person/Month"
    },
    {
      "name": "labour demand",
      "comment": "labour demand",
      "equation": "workers_per_REU_under_construction*REU_under_construction",
      "unit": "person"
    },
    {
      "name": "new REU plans approved",
      "comment": "new REU plans approved",
      "equation": "MAX(expected_REU_shortage/avg_REU_approval_time,0) + Al_Maktoum_exogenous_investment_rate *REU_supply/avg_REU_approval_time",
      "unit": "real estate unit/Month"
    },
    {
      "name": "normal cost REU",
      "comment": "normal cost REU",
      "equation": "50000 + avg_salary_immigrants*REU_construction_time*workers_per_REU_under_construction",
      "unit": "dollar/real estate unit"
    },
    {
      "name": "REU shortage",
      "comment": "REU shortage",
      "equation": "REU_demand/REU_supply",
      "unit": "Dmnl"
    },
    {
      "name": "REU commissioning",
      "comment": "REU commissioning",
      "equation": "MIN(immigrants/workers_per_REU_under_construction,REU_under_construction)/REU_construction_time",
      "unit": "real estate unit/Month"
    },
    {
      "name": "REU demand",
      "comment": "REU demand",
      "equation": "(immigrants+locals)*REU_demand_per_person",
      "unit": "real estate unit"
    },
    {
      "name": "REU demand per person",
      "comment": "REU demand per person",
      "equation": "LOOKUP(REU_demand_per_person_lookup, TIME)",
      "unit": "real estate unit/person"
    },
    {
      "name": "REU demolition",
      "comment": "REU demolition",
      "equation": "REU_supply/avg_lifetime_REU",
      "unit": "real estate unit/Month"
    },
    {
      "name": "subsidy",
      "equation": "960",
      "comment": "subsidy",
      "unit": "dollar/real estate unit"
    },
    {
      "name": "avg REU approval time",
      "equation": "1",
      "comment": "avg REU approval time",
      "unit": "Month"
    },
    {
      "name": "avg emigration time",
      "equation": "1",
      "comment": "avg emigration time",
      "unit": "Month"
    },
    {
      "name": "avg immigration time",
      "equation": "1",
      "comment": "avg immigration time",
      "unit": "Month"
    },
    {
      "name": "avg lifetime REU",
      "equation": "500",
      "comment": "avg lifetime REU",
      "unit": "Month"
    },
    {
      "name": "Al Maktoum exogenous investment rate",
      "equation": "0.01",
      "comment": "Al Maktoum exogenous investment rate",
      "unit": "Dmnl"
    },
    {
      "name": "immigration multiplication factor",
      "equation": "1",
      "comment": "immigration multiplication factor",
      "unit": "real estate unit/person"
    },
    {
      "name": "immigrant integration rate",
      "equation": "0.001",
      "comment": "immigrant integration rate",
      "unit": "1/Month"
    },
    {
      "name": "normal salary immigrants",
      "equation": "1000",
      "comment": "normal salary immigrants",
      "unit": "dollar/person/Month"
    },
    {
      "name": "REU construction time",
      "equation": "3",
      "comment": "REU construction time",
      "unit": "Month"
    },
    {
      "name": "workers per REU under construction",
      "equation": "25",
      "comment": "workers per REU under construction",
      "unit": "person/real estate unit"
    }
  ],
  "lookupTables": [
    {
      "name": "REU shortage price effect",
      "comment": "REU shortage price effect",
      "xValues": [
        0.0,
