    "equation" : "100",
    "unit" : "$/Box"
  }, {
    "name" : "target revenue",
    "comment" : "target revenue",
    "equation" : "10000+STEP(5000, 10)",
    "unit" : "$/Month"
  }, {
    "name" : "time to adjust price up",
    "comment" : "time to adjust price up",
    "equation" : "4",
    "unit" : "Month"
