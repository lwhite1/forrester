    "name" : "FINAL_TIME",
    "equation" : "100",
    "unit" : "Month"
  }, {
    "name" : "target price",
    "comment" : "target price",
    "equation" : "MIN( IF((expected_demand) == 0, maximum_price, (target_revenue) / (expected_demand)), maximum_price)",
    "unit" : "$/Box"
  }, {
    "name" : "maximum price",
    "comment" : "maximum price",
    "equation" : "25000",
    "unit" : "$/Box"
  }, {
    "name" : "change in price",
    "comment" : "change in price",
    "equation" : "IF(target_price > price, (target_price - price)/time_to_adjust_price_up, (target_price-price)/time_to_adjust_price_down)",
    "unit" : "$/Box/Month"
  }, {
    "name" : "time to adjust price down",
    "comment" : "time to adjust price down",
    "equation" : "6",
    "unit" : "Month"
  }, {
    "name" : "demand",
    "comment" : "demand",
    "equation" : "reference_demand * effect_price_demand",
    "unit" : "Box/Month"
  }, {
    "name" : "demand elasticity",
    "comment" : "demand elasticity",
    "equation" : "1",
    "unit" : "Dmnl"
  }, {
    "name" : "effect price demand",
    "comment" : "effect price demand",
    "equation" : "EXP(-demand_elasticity * LN(price/reference_price))",
    "unit" : "Dmnl"
  }, {
    "name" : "expected demand",
    "comment" : "expected demand",
    "equation" : "SMOOTH(demand,time_to_form_expectations)",
    "unit" : "Box/Month"
  }, {
    "name" : "initial price",
    "comment" : "initial price",
    "equation" : "100",
