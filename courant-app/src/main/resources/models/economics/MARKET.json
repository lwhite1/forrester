    "unit" : "Product / $"
  }, {
    "name" : "PROD DEVT TIME",
    "comment" : "PROD DEVT TIME",
    "equation" : "12",
    "unit" : "Month"
  }, {
    "name" : "PROD OBS TIME",
    "comment" : "PROD OBS TIME",
    "equation" : "60",
    "unit" : "Months"
  }, {
    "name" : "prod obsolescence rate",
    "comment" : "prod obsolescence rate",
    "equation" : "Products / PROD_OBS_TIME",
    "unit" : "Product / Month"
  }, {
    "name" : "retained cash flow",
    "comment" : "retained cash flow",
    "equation" : "cash_revenue * frac_cash_retained",
    "unit" : "$/ Month"
  }, {
    "name" : "sales rep effect mult",
    "comment" : "sales rep effect mult",
    "equation" : "LOOKUP(TABLE_FOR_SALES_REP_EFFECT, external_sales_reps / Potential_Orders)",
