  }, {
    "name" : "THIDS",
    "comment" : "THIDS",
    "equation" : "10",
    "unit" : "Months"
  }, {
    "name" : "TIME TO CLEAR RECEIVABLES",
    "comment" : "TIME TO CLEAR RECEIVABLES",
    "equation" : "6",
    "unit" : "Months"
  }, {
    "name" : "unit sales",
    "comment" : "unit sales",
    "equation" : "Pot_Orders_In_Negotiation * NORMAL_SHARE_OF_SALES * fraction_custs_buying / DURATION_OF_NEGOTIATION",
    "unit" : "Orders / Month"
  } ],
