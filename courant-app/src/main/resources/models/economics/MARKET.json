  }, {
    "name" : "DURATION OF NEGOTIATION",
    "comment" : "DURATION OF NEGOTIATION",
    "equation" : "1",
    "unit" : "Month"
  }, {
    "name" : "EXT SALES REP FEE",
    "comment" : "EXT SALES REP FEE",
    "equation" : "400",
    "unit" : "$/ Person / Month"
  }, {
    "name" : "external sales reps",
    "comment" : "external sales reps",
    "equation" : "cash_revenue * FRAC_BUDGET_EXT_SALES_REPS / EXT_SALES_REP_FEE",
    "unit" : "People"
  }, {
    "name" : "FRAC BUDGET ADV",
    "comment" : "FRAC BUDGET ADV",
    "equation" : "INITIAL(PERCENT_BUDGET_ADV/100)",
    "unit" : "Dimensionless"
  }, {
    "name" : "FRAC BUDGET EXT SALES REPS",
    "comment" : "FRAC BUDGET EXT SALES REPS",
    "equation" : "INITIAL(PERCENT_BUDGET_EXT_SALES_REPS/100)",
    "unit" : "Dimensionless"
  }, {
    "name" : "FRAC BUDGET INT DIR SALES",
    "comment" : "FRAC BUDGET INT DIR SALES",
    "equation" : "INITIAL(PERCENT_BUDGET_INT_DIR_SALES/100)",
    "unit" : "Dimensionless"
  }, {
    "name" : "FRAC BUDGET MFG",
    "comment" : "FRAC BUDGET MFG",
    "equation" : "0.47",
    "unit" : "Dimensionless"
  }, {
    "name" : "FRAC BUDGET R AND D",
    "comment" : "FRAC BUDGET R AND D",
    "equation" : "0.15",
    "unit" : "Dimensionless"
  }, {
    "name" : "frac cash retained",
    "comment" : "frac cash retained",
    "equation" : "( 1 - FRAC_BUDGET_MFG - FRAC_BUDGET_R_AND_D - FRAC_BUDGET_ADV - FRAC_BUDGET_EXT_SALES_REPS - FRAC_BUDGET_INT_DIR_SALES )",
    "unit" : "Fraction"
  }, {
    "name" : "fraction custs buying",
    "comment" : "fraction custs buying",
