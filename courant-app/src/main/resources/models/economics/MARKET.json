    "name" : "pot order creation",
    "comment" : "pot order creation",
    "equation" : "NORMAL_LEAD_GEN_EFFIC * Products * effect_of_advertising",
    "unit" : "Orders / Month"
  }, {
    "name" : "pot orders lost to comp",
    "comment" : "pot orders lost to comp",
    "equation" : "Pot_Orders_In_Negotiation * fraction_custs_buying * ( 1 - NORMAL_SHARE_OF_SALES ) / DURATION_OF_NEGOTIATION",
    "unit" : "Orders / Month"
  }, {
    "name" : "pot orders not buying",
    "comment" : "pot orders not buying",
    "equation" : "Pot_Orders_In_Negotiation * ( 1 - fraction_custs_buying ) / DURATION_OF_NEGOTIATION",
    "unit" : "Orders / Month"
  }, {
    "name" : "pot ords mov to negot",
    "comment" : "pot ords mov to negot",
