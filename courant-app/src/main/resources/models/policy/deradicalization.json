  }, {
    "name" : "initial number of convinced citizens",
    "comment" : "initial number of convinced citizens",
    "equation" : "1000",
    "unit" : "citizens"
  }, {
    "name" : "initial number of unconvinced citizens",
    "comment" : "initial number of unconvinced citizens",
    "equation" : "12999000",
    "unit" : "citizens"
  }, {
    "name" : "initial readiness to take action per contact",
    "comment" : "initial readiness to take action per contact",
    "equation" : "0.8",
    "unit" : "Dmnl"
  }, {
    "name" : "initial value of underlying phenomena",
    "comment" : "initial value of underlying phenomena",
    "equation" : "50",
    "unit" : "Dmnl"
  }, {
    "name" : "intristic rate of increase of the underlying phenomenon",
    "comment" : "intristic rate of increase of the underlying phenomenon",
    "equation" : "0.01",
    "unit" : "1/Year"
  }, {
    "name" : "maximum attainable rate of decrease through societal change",
    "comment" : "maximum attainable rate of decrease through societal change",
    "equation" : "0.05",
    "unit" : "1/Year"
  }, {
    "name" : "netincrease of the underlying phenomenon",
