  }, {
    "name" : "visibillity of the problem",
    "comment" : "visibillity of the problem",
    "equation" : "problem_syntoms*reinforcement_of_the_visibility_of_the_problem_through_radical_and_nonradical_actions",
    "unit" : "Dmnl"
  }, {
    "name" : "persuasion",
    "comment" : "persuasion",
    "equation" : "contact_rate_of_convinced_citizens*fraction_of_convinced_citizens*unconvinced_citizens *persuasivness_of_nonradical_actions*visibillity_of_the_problem/strength_of_incompatible_selfinterest",
    "unit" : "citizens/Year"
  }, {
    "name" : "average degree of conviction of convinced citizens",
    "comment" : "average degree of conviction of convinced citizens",
    "equation" : "total_readiness_to_take_action_of_all_the_convinced_citizens/convinced_citizens",
    "unit" : "Dmnl"
  }, {
    "name" : "average readiness to take action",
    "comment" : "average readiness to take action",
    "equation" : "total_readiness_to_take_action_of_all_the_convinced_citizens/convinced_citizens",
    "unit" : "Dmnl"
  }, {
    "name" : "citizens that cannot be convinced",
    "comment" : "citizens that cannot be convinced",
    "equation" : "3000000",
    "unit" : "citizens"
  }, {
    "name" : "contact rate of convinced citizens",
    "comment" : "contact rate of convinced citizens",
    "equation" : "normal_contact_rate_of_convinced_citizens*(1-radical_action_level)",
    "unit" : "contacts/(Year*citizen)"
  }, {
    "name" : "fraction of convinced citizens",
    "comment" : "fraction of convinced citizens",
    "equation" : "convinced_citizens/total_population",
    "unit" : "Dmnl"
  }, {
    "name" : "frustration due to inertia",
    "comment" : "frustration due to inertia",
    "equation" : "(maximum_attainable_rate_of_decrease_through_societal_change-rate_of_decrease_through_societal_change )/maximum_attainable_rate_of_decrease_through_societal_change",
    "unit" : "Dmnl"
  }, {
    "name" : "frustration due to marginalization",
    "comment" : "frustration due to marginalization",
    "equation" : "LOOKUP(frustration_due_to_marginalization_lookup, fraction_of_convinced_citizens)",
    "unit" : "Dmnl"
  }, {
    "name" : "frustration of convinced citizens",
    "comment" : "frustration of convinced citizens",
    "equation" : "min(MAX(frustration_due_to_marginalization*frustration_due_to_inertia*average_degree_of_conviction_of_convinced_citizens *percived_magnitude_of_the_problem,0),1)",
