  }, {
    "name" : "Sugar",
    "comment" : "The amount of sugar in the bowl.",
    "initialValue" : 100.0,
    "unit" : "g"
  }, {
    "name" : "Yeast Count",
    "comment" : "The number of yeast.",
    "initialValue" : 100.0,
    "unit" : "Cell"
  } ],
  "flows" : [ {
    "name" : "Water net flow",
    "comment" : "Net flow for Water",
    "equation" : "- water_consumption",
    "timeUnit" : "Minute",
    "sink" : "Water"
  }, {
    "name" : "Sugar net flow",
    "comment" : "Net flow for Sugar",
    "equation" : "-sugar_consumption",
    "timeUnit" : "Minute",
    "sink" : "Sugar"
  }, {
    "name" : "Yeast Count inflow 1",
    "equation" : "divisions",
    "timeUnit" : "Minute",
    "sink" : "Yeast Count"
  }, {
    "name" : "Yeast Count outflow 2",
    "equation" : "terminations",
    "timeUnit" : "Minute",
    "source" : "Yeast Count"
  } ],
  "variables" : [ {
    "name" : "TIME_STEP",
    "equation" : "0.5",
    "unit" : "Minute"
  }, {
    "name" : "INITIAL_TIME",
    "equation" : "0",
    "unit" : "Minute"
  }, {
    "name" : "FINAL_TIME",
    "equation" : "300",
    "unit" : "Minute"
  }, {
    "name" : "water per division",
    "comment" : "water per division",
    "equation" : "0.001",
    "unit" : "ml/Cell"
  }, {
    "name" : "water consumption",
    "comment" : "water consumption",
    "equation" : "divisions * water_per_division",
    "unit" : "ml/Minute"
  }, {
    "name" : "sugar consumption",
    "comment" : "sugar consumption",
    "equation" : "divisions * sugar_per_division",
    "unit" : "g/Minute"
  }, {
    "name" : "sugar per division",
    "comment" : "sugar per division",
    "equation" : "0.001",
    "unit" : "g/Cell"
  }, {
    "name" : "average water",
    "comment" : "The average amount of water.  Note use of ZIDZ to prevent problems on 0 \t\t\t\t\t\t\t\t\t\t yeast count.",
    "equation" : "IF((Yeast_Count) == 0, 0, (Water) / (Yeast_Count))",
    "unit" : "ml/Cell"
  }, {
    "name" : "average lifetime",
    "comment" : "The average length of time a yeast survives.",
    "equation" : "norm_lifetime* LOOKUP(life_from_temp_lookup, temperature/norm_temperature) * LOOKUP(life_from_water_lookup, average_water/norm_water) * LOOKUP(life_from_sugar_lookup, average_sugar/norm_sugar)",
    "unit" : "Minute"
  }, {
    "name" : "average sugar",
    "comment" : "The average amount of sugar.  Note the use of ZIDZ to prevent problems \t\t\t\t\t\t\t\t\t\t when Yeast Count is 0.",
    "equation" : "IF((Yeast_Count) == 0, 0, (Sugar) / (Yeast_Count))",
    "unit" : "g/Cell"
  }, {
    "name" : "division rate",
    "comment" : "The rate at which yeast divide.",
    "equation" : "norm_division_rate * LOOKUP(division_from_temp_lookup, temperature/norm_temperature) * LOOKUP(division_from_sugar_lookup, average_sugar/norm_sugar) * LOOKUP(division_from_water_lookup, average_water/norm_water)",
    "unit" : "1/Minute"
  }, {
    "name" : "norm water",
    "comment" : "The normal amount of water for a cell.",
    "equation" : "0.001",
    "unit" : "ml/Cell"
  }, {
    "name" : "norm sugar",
    "comment" : "The normal amount of sugar.",
    "equation" : "0.001",
    "unit" : "g/Cell"
  }, {
    "name" : "norm lifetime",
    "comment" : "The normal lifetime of a cell at normal temperature.",
    "equation" : "250",
    "unit" : "Minute"
  }, {
    "name" : "norm temperature",
    "comment" : "The normal termperature used as a reference to determine division and \t\t\t\t\t\t\t\t\t\t termination effects.",
    "equation" : "80",
    "unit" : "degrees farenheit"
  }, {
    "name" : "norm division rate",
    "comment" : "The normal rate of division at normal temperatures",
    "equation" : "0.08",
    "unit" : "1/Minute"
  }, {
    "name" : "divisions",
    "comment" : "divisions",
    "equation" : "Yeast_Count*division_rate",
    "unit" : "Cell/Minute"
  }, {
    "name" : "temperature",
    "comment" : "The temperature of the water in the bowl.",
    "equation" : "85",
    "unit" : "degrees farenheit"
  }, {
    "name" : "terminations",
    "comment" : "The rate of termination of yeast.  Using a MIN to prevent silly results on extreme \t\t\t\t\t\t\t\t\t\t conditions\n\t\t         integration.",
    "equation" : "MIN(Yeast_Count/TIME_STEP,Yeast_Count/average_lifetime)",
    "unit" : "Cell/Minute"
  }, {
    "name" : "RC START TIME",
    "comment" : "RC START TIME",
    "equation" : "10",
    "unit" : "Minute"
  } ],
