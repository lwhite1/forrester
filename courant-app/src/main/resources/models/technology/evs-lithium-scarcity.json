{
  "name": "EVsLithium",
  "stocks": [
    {
      "name": "conventional vehicles",
      "comment": "conventional vehicles",
      "initialValue": 100000000.0,
      "unit": "auto"
    },
    {
      "name": "electric vehicles EV",
      "comment": "electric vehicles EV",
      "initialValue": 1000.0,
      "unit": "auto"
    },
    {
      "name": "processing of lithium in products",
      "comment": "processing of lithium in products",
      "initialValue": 22.0,
      "unit": "ktonLi"
    },
    {
      "name": "annual ICT lithium demand",
      "comment": "annual ICT lithium demand",
      "initialValue": 20.0,
      "unit": "ktonLi/year"
    },
    {
      "name": "lithium in products",
      "comment": "lithium in products",
      "initialValue": 100.0,
      "unit": "ktonLi"
    },
    {
      "name": "lithium in recycling",
      "comment": "lithium in recycling",
      "initialValue": 0.0,
      "unit": "ktonLi"
    },
    {
      "name": "unexploited lithium reserves",
      "comment": "unexploited lithium reserves",
      "initialValue": 13000.0,
      "unit": "ktonLi"
    }
  ],
  "flows": [
    {
      "name": "conventional vehicles net flow",
      "comment": "Net flow for conventional vehicles",
      "equation": "-electrification_European_vehicle_fleet",
      "timeUnit": "Year",
      "sink": "conventional vehicles"
    },
    {
      "name": "electric vehicles EV net flow",
      "comment": "Net flow for \"electric vehicles (EV)\"",
      "equation": "+electrification_European_vehicle_fleet",
      "timeUnit": "Year",
      "sink": "electric vehicles EV"
    },
    {
      "name": "processing of lithium in products net flow",
      "comment": "Net flow for processing of lithium in products",
      "equation": "+lithium_exploitation-lithium_products_brought_into_use+lithium_from_recycling_to_reprocessing",
      "timeUnit": "Year",
      "sink": "processing of lithium in products"
    },
    {
      "name": "annual ICT lithium demand net flow",
      "comment": "Net flow for annual ICT lithium demand",
      "equation": "net_increase_annual_ICT_lithium_demand",
      "timeUnit": "Year",
      "sink": "annual ICT lithium demand"
    },
    {
      "name": "lithium in products net flow",
      "comment": "Net flow for lithium in products",
      "equation": "lithium_products_brought_into_use-loss_of_nonrecyled_lithium-recovery_lithium_through_recycling",
      "timeUnit": "Year",
      "sink": "lithium in products"
    },
    {
      "name": "lithium in recycling net flow",
      "comment": "Net flow for lithium in recycling",
      "equation": "recovery_lithium_through_recycling-lithium_from_recycling_to_reprocessing",
      "timeUnit": "Year",
      "sink": "lithium in recycling"
    },
    {
      "name": "unexploited lithium reserves net flow",
      "comment": "Net flow for unexploited lithium reserves",
      "equation": "-lithium_exploitation",
      "timeUnit": "Year",
      "sink": "unexploited lithium reserves"
    }
  ],
  "variables": [
    {
      "name": "EV batteries needed",
      "comment": "EV batteries needed",
      "equation": "electrification_European_vehicle_fleet*battery_per_vehicle+electric_vehicles_EV/ average_lifetime_EV_batteries*batteries_per_vehicle",
      "unit": "accu/year"
    },
    {
      "name": "lithium exploitation",
      "comment": "lithium exploitation",
      "equation": "MAX(MIN(total_demand_lithium_to_be_exploited-lithium_in_recycling/average_recycling_time ,unexploited_lithium_reserves/exploitation_time),0)",
      "unit": "ktonLi/year"
    },
    {
      "name": "lithium from recycling to reprocessing",
      "comment": "lithium from recycling to reprocessing",
      "equation": "lithium_in_recycling/average_recycling_time",
      "unit": "ktonLi/year"
    },
    {
      "name": "lithium products brought into use",
      "comment": "lithium products brought into use",
      "equation": "processing_of_lithium_in_products/processing_and_introduction_time",
      "unit": "ktonLi/year"
    },
    {
      "name": "approximated fraction of lithium use in EV batteries over the total amount of lithium in use",
      "comment": "approximated fraction of lithium use in EV batteries over the total amount of lithium in use",
      "equation": "lithium_needed_for_EV_batteries/total_demand_lithium_to_be_exploited",
      "unit": "Dmnl"
    },
    {
      "name": "lithium needed for EV batteries",
      "comment": "lithium needed for EV batteries",
      "equation": "lithium_per_EV_battery*EV_batteries_needed",
      "unit": "ktonLi/year"
    },
    {
      "name": "average lifetime products containing lithium",
      "comment": "average lifetime products containing lithium",
      "equation": "average_use_time_of_ICT_products_containing_lithium*(1-approximated_fraction_of_lithium_use_in_EV_batteries_over_the_total_amount_of_lithium_in_use )+average_lifetime_EV_batteries_during_and_after_use_in_EV*approximated_fraction_of_lithium_use_in_EV_batteries_over_the_total_amount_of_lithium_in_use",
      "unit": "year"
    },
    {
      "name": "electrification European vehicle fleet",
      "comment": "electrification European vehicle fleet",
      "equation": "intensive_advertisement*conventional_vehicles/average_lifetime_conventional_vehicles *electric_vehicles_EV/totale_European_vehicle_fleet",
      "unit": "auto/year"
    },
    {
      "name": "total demand lithium to be exploited",
      "comment": "total demand lithium to be exploited",
      "equation": "lithium_needed_for_EV_batteries+annual_ICT_lithium_demand",
      "unit": "ktonLi/year"
    },
    {
      "name": "net increase annual ICT lithium demand",
      "comment": "net increase annual ICT lithium demand",
      "equation": "annual_ICT_lithium_demand*growth_rate_lithium_demand_ICT_sector",
      "unit": "ktonLi/year/year"
    },
    {
      "name": "intensive advertisement",
      "comment": "intensive advertisement",
      "equation": "10-STEP(9,2017)",
      "unit": "Dmnl"
    },
    {
      "name": "totale European vehicle fleet",
      "comment": "totale European vehicle fleet",
      "equation": "conventional_vehicles+electric_vehicles_EV",
      "unit": "auto"
    },
    {
      "name": "recovery lithium through recycling",
      "comment": "recovery lithium through recycling",
      "equation": "lithium_in_products/average_lifetime_products_containing_lithium * effective_recycling_fraction_lithium",
      "unit": "ktonLi/year"
    },
    {
      "name": "loss of nonrecyled lithium",
      "comment": "loss of nonrecyled lithium",
      "equation": "lithium_in_products/average_lifetime_products_containing_lithium * (1-effective_recycling_fraction_lithium )",
      "unit": "ktonLi/year"
    },
    {
      "name": "TIME STEP",
