{
  "name" : "STOCK",
  "stocks" : [ {
    "name" : "Cumulative Profit",
    "comment" : "Cumulative Profit",
    "initialValue" : 0.0,
    "unit" : "dollars"
  }, {
    "name" : "forecast orders",
    "comment" : "forecast orders",
    "initialValue" : 0.0,
    "initialExpression" : "orders",
    "unit" : "unit/day"
  }, {
    "name" : "Store Inventory",
    "comment" : "Store Inventory",
    "initialValue" : 0.0,
    "initialExpression" : "orders*(leadtime)",
    "unit" : "unit"
  }, {
    "name" : "Qty On Order",
    "comment" : "Qty On Order",
    "initialValue" : 0.0,
    "unit" : "unit"
  } ],
  "flows" : [ {
    "name" : "Cumulative Profit net flow",
    "comment" : "Net flow for Cumulative Profit",
    "equation" : "profit",
    "timeUnit" : "Day",
    "sink" : "Cumulative Profit"
  }, {
    "name" : "forecast orders net flow",
    "comment" : "Net flow for forecast orders",
    "equation" : "(orders-forecast_orders)* WEIGHT_TO_CURRENT",
    "timeUnit" : "Day",
    "sink" : "forecast orders"
  }, {
    "name" : "Store Inventory inflow 1",
    "equation" : "receipts",
    "timeUnit" : "Day",
    "sink" : "Store Inventory"
  }, {
    "name" : "Store Inventory outflow 2",
    "equation" : "units_sold",
    "timeUnit" : "Day",
    "source" : "Store Inventory"
  }, {
    "name" : "Qty On Order inflow 1",
    "equation" : "distr_orders",
    "timeUnit" : "Day",
    "sink" : "Qty On Order"
  }, {
    "name" : "Qty On Order outflow 2",
    "equation" : "receipts",
    "timeUnit" : "Day",
    "source" : "Qty On Order"
  } ],
  "variables" : [ {
    "name" : "TIME_STEP",
    "equation" : "1",
    "unit" : "Day"
  }, {
    "name" : "INITIAL_TIME",
    "equation" : "0",
    "unit" : "Day"
  }, {
    "name" : "FINAL_TIME",
    "equation" : "60",
    "unit" : "Day"
  }, {
    "name" : "distr orders other",
    "comment" : "distr orders other",
    "equation" : "0",
    "unit" : "unit/day"
  }, {
    "name" : "ORDER RULE SWITCH",
    "comment" : "1 for periodic replenishment rule, 2 for minimum rule 3 for other rule",
    "equation" : "2",
    "unit" : "Dmnl"
  }, {
    "name" : "distr orders",
    "comment" : "distr orders",
    "equation" : "IF(ORDER_RULE_SWITCH==1, distr_orders_periodic, IF(ORDER_RULE_SWITCH==2, distr_orders_minimum, distr_orders_other))",
    "unit" : "unit/day"
  }, {
    "name" : "distr orders minimum",
    "comment" : "distr orders minimum",
    "equation" : "IF( Store_Inventory+Qty_On_Order<min_inventory_value, (max_inventory_value-Qty_On_Order-Store_Inventory)/TIME_STEP,0)",
    "unit" : "unit/day"
  }, {
    "name" : "Order Cost",
    "comment" : "Order Cost",
    "equation" : "IF( distr_orders>0, PROCESSING_COST+transport_cost, 0)",
    "unit" : "dollars/day"
  }, {
    "name" : "transport cost",
    "comment" : "transport cost",
    "equation" : "LOOKUP(TRANSPORT_RATE, distr_orders/UNIT_ORDER)",
    "unit" : "dollars/day"
  }, {
    "name" : "max inventory value",
    "comment" : "max inventory value",
    "equation" : "100",
    "unit" : "unit"
  }, {
    "name" : "receipts",
    "comment" : "receipts",
    "equation" : "DELAY_FIXED(distr_orders, leadtime, 0)",
    "unit" : "unit/day"
  }, {
    "name" : "min inventory value",
    "comment" : "min inventory value",
    "equation" : "20",
    "unit" : "unit"
  }, {
    "name" : "UNIT ORDER",
    "comment" : "UNIT ORDER",
    "equation" : "1",
    "unit" : "unit/day"
  }, {
    "name" : "distr orders periodic",
    "comment" : "distr orders periodic",
    "equation" : "IF(order_placement_day!=0, ( forecast_orders*(leadtime+REPLENISH_PERIOD)- Store_Inventory-Qty_On_Order)/order_placement_day ,0)",
    "unit" : "unit/day"
  }, {
    "name" : "total cost",
    "comment" : "total cost",
    "equation" : "Cost_Of_Goods + Holding_Cost + Order_Cost",
    "unit" : "dollars/day"
  }, {
    "name" : "profit",
    "comment" : "profit",
    "equation" : "Sales_Revenue -  total_cost",
    "unit" : "dollars/day"
  }, {
    "name" : "order placement day",
    "comment" : "order placement day",
    "equation" : "IF(MODULO(TIME,REPLENISH_PERIOD)==0,1,0)",
    "unit" : "day"
  }, {
    "name" : "DAYS PER YEAR",
    "comment" : "DAYS PER YEAR",
    "equation" : "365",
    "unit" : "day/Year"
  }, {
    "name" : "WEIGHT TO CURRENT",
    "comment" : "WEIGHT TO CURRENT",
    "equation" : "0.2",
    "unit" : "1/day"
  }, {
    "name" : "Cost Of Goods",
    "comment" : "Cost Of Goods",
    "equation" : "item_cost*units_sold",
    "unit" : "dollars/day"
  }, {
    "name" : "REPLENISH PERIOD",
    "comment" : "REPLENISH PERIOD",
    "equation" : "10",
    "unit" : "day"
  }, {
    "name" : "orders",
    "comment" : "orders",
    "equation" : "0",
    "unit" : ""
  }, {
    "name" : "item cost",
    "comment" : "item cost",
    "equation" : "(1-PCT_MARGIN/100)*ITEM_PRICE",
    "unit" : "dollars/unit"
  }, {
    "name" : "PCT MARGIN",
    "comment" : "PCT MARGIN",
    "equation" : "10",
    "unit" : "Dmnl"
  }, {
    "name" : "leadtime",
    "comment" : "leadtime",
    "equation" : "5",
    "unit" : "day"
  }, {
    "name" : "ITEM PRICE",
    "comment" : "ITEM PRICE",
    "equation" : "200",
    "unit" : "dollars/unit"
  }, {
    "name" : "PROCESSING COST",
    "comment" : "PROCESSING COST",
    "equation" : "2",
    "unit" : "dollars/day"
  }, {
    "name" : "Holding Cost",
    "comment" : "Holding Cost",
    "equation" : "Store_Inventory*item_cost*INTEREST/DAYS_PER_YEAR",
    "unit" : "dollars/day"
  }, {
    "name" : "Sales Revenue",
    "comment" : "Sales Revenue",
    "equation" : "units_sold*ITEM_PRICE",
    "unit" : "dollars/day"
  }, {
    "name" : "INTEREST",
    "comment" : "INTEREST",
    "equation" : "0.25",
    "unit" : "1/Year"
  }, {
    "name" : "units sold",
    "comment" : "units sold",
    "equation" : "IF(Store_Inventory-orders>0,orders,Store_Inventory)",
    "unit" : "unit/day"
  } ],
