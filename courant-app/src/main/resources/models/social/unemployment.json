{
  "name" : "1802_UnemploymentBasedOnEZ511",
  "stocks" : [ {
    "name" : "state debt",
    "comment" : "state debt",
    "initialValue" : 0.0,
    "unit" : "1"
  }, {
    "name" : "employment in services",
    "comment" : "employment in services",
    "initialValue" : 0.5,
    "unit" : "1"
  }, {
    "name" : "employment in production",
    "comment" : "employment in production",
    "initialValue" : 1.0,
    "unit" : "1"
  }, {
    "name" : "productivity",
    "comment" : "productivity",
    "initialValue" : 1.0,
    "unit" : "1/Year"
  }, {
    "name" : "financial buffer of the state",
    "comment" : "financial buffer of the state",
    "initialValue" : 1.0,
    "unit" : "1"
  } ],
  "flows" : [ {
    "name" : "state debt net flow",
    "comment" : "Net flow for state debt",
    "equation" : "state_debt_increase",
    "timeUnit" : "Year",
    "sink" : "state debt"
  }, {
    "name" : "employment in services net flow",
    "comment" : "Net flow for employment in services",
    "equation" : "net_service_jobs_additions",
    "timeUnit" : "Year",
    "sink" : "employment in services"
  }, {
    "name" : "employment in production net flow",
    "comment" : "Net flow for employment in production",
    "equation" : "-net_production_jobs_reductions",
    "timeUnit" : "Year",
    "sink" : "employment in production"
  }, {
    "name" : "productivity net flow",
    "comment" : "Net flow for productivity",
    "equation" : "productivity_increase",
    "timeUnit" : "Year",
    "sink" : "productivity"
  }, {
    "name" : "financial buffer of the state inflow 1",
    "equation" : "state_cash_inflow",
    "timeUnit" : "Year",
    "sink" : "financial buffer of the state"
  }, {
    "name" : "financial buffer of the state outflow 2",
    "equation" : "state_cash_outflow",
    "timeUnit" : "Year",
    "source" : "financial buffer of the state"
  } ],
  "variables" : [ {
    "name" : "TIME_STEP",
    "equation" : "0.0625",
    "unit" : "Year"
  }, {
    "name" : "INITIAL_TIME",
    "equation" : "0",
    "unit" : "Year"
  }, {
    "name" : "FINAL_TIME",
    "equation" : "40",
    "unit" : "Year"
  }, {
    "name" : "state cash inflow",
    "comment" : "state cash inflow",
    "equation" : "tax_revenues_on_sales_value+state_debt_increase",
    "unit" : "1/Year"
  }, {
    "name" : "state debt increase",
    "comment" : "state debt increase",
    "equation" : "IF(financial_buffer_of_the_state<0, -financial_buffer_of_the_state/ TIME_STEP , 0)",
    "unit" : "1/Year"
  }, {
    "name" : "REDUCTION RATE",
    "comment" : "REDUCTION RATE",
    "equation" : "0.1",
    "unit" : "1/Year"
  }, {
    "name" : "productivity increase",
    "comment" : "productivity increase",
    "equation" : "PRODUCTIVITY_INCREASE_RATE*productivity*(1-productivity/PRODUCTIVITY_LIMIT)",
    "unit" : "1/(Year*Year)"
  }, {
    "name" : "net production jobs reductions",
    "comment" : "IF THEN ELSE(relative production surplus<0.1, REDUCTION RATE* relative  production surplus*employment in production, 0.1*REDUCTION RATE*employment  in production)",
    "equation" : "REDUCTION_RATE * employment_in_production * MIN(relative_production_surplus,0.1)",
    "unit" : "1/Year"
  }, {
    "name" : "PRODUCTIVITY INCREASE RATE",
    "comment" : "PRODUCTIVITY INCREASE RATE",
    "equation" : "0.1",
    "unit" : "1/Year"
  }, {
    "name" : "net service jobs additions",
    "comment" : "net service jobs additions",
    "equation" : "(1-service_demand_fulfillment)*financial_buffer_of_the_state*unemployment_rate*service_jobs_hiring_rate",
    "unit" : "1/Year"
  }, {
    "name" : "service jobs hiring rate",
    "comment" : "service jobs hiring rate",
    "equation" : "0.05",
    "unit" : "1/Year"
  }, {
    "name" : "tax revenues on sales value",
    "comment" : "tax revenues on sales value",
    "equation" : "revenues_dependent_tax_rate*sales_value",
    "unit" : "1/Year"
  }, {
    "name" : "revenues dependent tax rate",
    "comment" : "revenues dependent tax rate",
    "equation" : "LOOKUP(revenues_dependent_tax_rate_lookup, financial_buffer_of_the_state)",
    "unit" : "1"
  }, {
    "name" : "sales value",
    "comment" : "sales value",
    "equation" : "IF(DEMAND_VALUE>product_value, product_value, DEMAND_VALUE)",
    "unit" : "1/Year"
  }, {
    "name" : "POTENTIAL LABOR FORCE",
    "comment" : "POTENTIAL LABOR FORCE",
    "equation" : "1.5",
    "unit" : "1"
  }, {
    "name" : "unemployment rate",
    "comment" : "unemployment rate",
    "equation" : "(POTENTIAL_LABOR_FORCE-employment_in_production-employment_in_services)/POTENTIAL_LABOR_FORCE",
    "unit" : "1"
  }, {
    "name" : "SERVICE DEMAND",
    "comment" : "SERVICE DEMAND",
    "equation" : "1",
    "unit" : "1"
  }, {
    "name" : "service demand fulfillment",
    "comment" : "service demand fulfillment",
    "equation" : "employment_in_services/SERVICE_DEMAND",
    "unit" : "1"
  }, {
    "name" : "wages",
    "comment" : "wages",
    "equation" : "wage_index*WAGE_FACTOR*employment_in_services",
    "unit" : "1/Year"
  }, {
    "name" : "WAGE FACTOR",
    "comment" : "WAGE FACTOR",
    "equation" : "0.25",
    "unit" : "1"
  }, {
    "name" : "wage index",
    "comment" : "wage index",
    "equation" : "productivity",
    "unit" : "1/Year"
  }, {
    "name" : "DEMAND VALUE",
    "comment" : "DEMAND VALUE",
    "equation" : "1",
    "unit" : "1/Year"
  }, {
    "name" : "PRODUCTIVITY LIMIT",
    "comment" : "PRODUCTIVITY LIMIT",
    "equation" : "5",
    "unit" : "1/Year"
  }, {
    "name" : "product value",
    "comment" : "product value",
    "equation" : "employment_in_production*productivity",
    "unit" : "1/Year"
  }, {
    "name" : "relative production surplus",
    "comment" : "relative production surplus",
    "equation" : "(product_value-DEMAND_VALUE)/DEMAND_VALUE",
    "unit" : "1"
  }, {
    "name" : "state cash outflow",
    "comment" : "state cash outflow",
    "equation" : "wages",
    "unit" : "1/Year"
  } ],
