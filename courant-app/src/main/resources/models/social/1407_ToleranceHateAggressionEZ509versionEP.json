{
  "name" : "1407_ToleranceHateAggressionEZ509versionEP",
  "stocks" : [ {
    "name" : "unfamiliarity",
    "comment" : "unfamiliarity",
    "initialValue" : 0.1,
    "unit" : "1"
  }, {
    "name" : "hate",
    "comment" : "hate",
    "initialValue" : 0.1,
    "unit" : "1"
  }, {
    "name" : "restraint threshold",
    "comment" : "restraint threshold",
    "initialValue" : 0.5,
    "unit" : "1"
  }, {
    "name" : "tolerance",
    "comment" : "tolerance",
    "initialValue" : 0.5,
    "unit" : "1"
  } ],
  "flows" : [ {
    "name" : "unfamiliarity inflow 1",
    "equation" : "unfamiliar_experience",
    "timeUnit" : "Month",
    "sink" : "unfamiliarity"
  }, {
    "name" : "unfamiliarity outflow 2",
    "equation" : "accustoming",
    "timeUnit" : "Month",
    "source" : "unfamiliarity"
  }, {
    "name" : "hate inflow 1",
    "equation" : "hate_increase",
    "timeUnit" : "Month",
    "sink" : "hate"
  }, {
    "name" : "hate outflow 2",
    "equation" : "hate_decrease",
    "timeUnit" : "Month",
    "source" : "hate"
  }, {
    "name" : "restraint threshold inflow 1",
    "equation" : "restraint_buildup",
    "timeUnit" : "Month",
    "sink" : "restraint threshold"
  }, {
    "name" : "restraint threshold outflow 2",
    "equation" : "restraint_loss",
    "timeUnit" : "Month",
    "source" : "restraint threshold"
  }, {
    "name" : "tolerance inflow 1",
    "equation" : "increase_in_tolerance_through_educational_effort",
    "timeUnit" : "Month",
    "sink" : "tolerance"
  }, {
    "name" : "tolerance outflow 2",
    "equation" : "tolerance_erosion",
    "timeUnit" : "Month",
    "source" : "tolerance"
  } ],
  "variables" : [ {
    "name" : "unfamiliar experience",
    "comment" : "unfamiliar experience",
    "equation" : "intolerance*DEGREE_OF_UNFAMILIARITY*encounters*ENCOUNTER_INTENSITY*unfamiliarity*(1- unfamiliarity/MAX_UNFAMILIARITY) * (1+violence)",
    "unit" : "1/Month"
  }, {
    "name" : "hate increase",
    "comment" : "hate increase",
    "equation" : "unfamiliarity*intolerance*social_problems*hate*(1-hate/MAX_HATE)/adaptation_TIME * ( 1+violence)",
    "unit" : "1/Month"
  }, {
    "name" : "tolerance erosion",
    "comment" : "tolerance erosion",
    "equation" : "tolerance*hate/adaptation_TIME * (1+violence)",
    "unit" : "1/Month"
  }, {
    "name" : "increase in tolerance through educational effort",
    "comment" : "increase in tolerance through educational effort",
    "equation" : "SMOOTH(education_effort*tolerance*(1-tolerance/MAX_TOLERANCE),1)",
    "unit" : "1/Month"
  }, {
    "name" : "restraint loss",
    "comment" : "restraint loss",
    "equation" : "hate*social_problems*VIOLENCE_IN_MEDIA*restraint_threshold/adaptation_TIME",
    "unit" : "1/Month"
  }, {
    "name" : "restraint buildup",
    "comment" : "restraint buildup",
    "equation" : "max_restraint*restraint_threshold*(1-restraint_threshold/max_restraint)/adaptation_TIME",
    "unit" : "1/Month"
  }, {
    "name" : "EDUCATION ACTIVITY",
    "comment" : "EDUCATION ACTIVITY",
    "equation" : "0.5",
    "unit" : "1/Month"
  }, {
    "name" : "education effort",
    "comment" : "education effort",
    "equation" : "0+EDUCATION_ACTIVITY*STEP(1, 15)",
    "unit" : "1/Month"
  }, {
    "name" : "encounters",
    "comment" : "encounters",
    "equation" : "PULSE_TRAIN(5,1, ENCOUNTER_INTERVAL,50)",
    "unit" : "1/Month"
  }, {
    "name" : "ENCOUNTER INTERVAL",
    "comment" : "ENCOUNTER INTERVAL",
    "equation" : "2",
    "unit" : "Month"
  }, {
    "name" : "ENCOUNTER INTENSITY",
    "comment" : "ENCOUNTER INTENSITY",
    "equation" : "5",
    "unit" : "1"
  }, {
    "name" : "DEGREE OF UNFAMILIARITY",
    "comment" : "DEGREE OF UNFAMILIARITY",
    "equation" : "0.5",
    "unit" : "1"
  }, {
    "name" : "violence",
    "comment" : "violence",
    "equation" : "hate*violent_action",
    "unit" : "1"
  }, {
    "name" : "VIOLENCE IN MEDIA",
    "comment" : "VIOLENCE IN MEDIA",
    "equation" : "0.4",
    "unit" : "1"
  }, {
    "name" : "violent action",
    "comment" : "violent action",
    "equation" : "IF(hate-restraint_threshold>0, 1, 0)",
    "unit" : "1"
  }, {
    "name" : "accustoming",
    "comment" : "accustoming",
    "equation" : "unfamiliarity*tolerance/adaptation_TIME",
    "unit" : "1/Month"
  }, {
    "name" : "ETHICAL SCRUPLES",
    "comment" : "ETHICAL SCRUPLES",
    "equation" : "0.1",
    "unit" : "1"
  }, {
    "name" : "hate decrease",
    "comment" : "hate decrease",
    "equation" : "hate*tolerance/adaptation_TIME",
    "unit" : "1/Month"
  }, {
    "name" : "intolerance",
    "comment" : "intolerance",
    "equation" : "MAX_TOLERANCE-tolerance",
    "unit" : "1"
  }, {
    "name" : "MAX UNFAMILIARITY",
    "comment" : "MAX UNFAMILIARITY",
    "equation" : "1",
    "unit" : "1"
  }, {
    "name" : "MAX HATE",
    "comment" : "MAX HATE",
    "equation" : "1",
    "unit" : "1"
  }, {
    "name" : "max restraint",
    "comment" : "max restraint",
    "equation" : "govt_authority*(1-VIOLENCE_IN_MEDIA)+ETHICAL_SCRUPLES",
    "unit" : "1"
  }, {
    "name" : "MAX TOLERANCE",
    "comment" : "MAX TOLERANCE",
    "equation" : "1",
    "unit" : "1"
  }, {
    "name" : "PROBLEM BEGINNING",
    "comment" : "PROBLEM BEGINNING",
    "equation" : "5",
    "unit" : "Month"
  }, {
    "name" : "PROBLEM STRENGTH",
    "comment" : "PROBLEM STRENGTH",
    "equation" : "4",
    "unit" : "1"
  }, {
    "name" : "social problems",
    "comment" : "social problems",
    "equation" : "STEP(PROBLEM_STRENGTH, PROBLEM_BEGINNING)",
    "unit" : "1"
  }, {
    "name" : "govt authority",
    "comment" : "govt authority",
    "equation" : "0+GOVT_RESOLVE*STEP(1, 10)",
    "unit" : "1"
  }, {
    "name" : "GOVT RESOLVE",
    "comment" : "GOVT RESOLVE",
    "equation" : "1",
    "unit" : "1"
  }, {
    "name" : "adaptation TIME",
    "comment" : "adaptation TIME",
    "equation" : "5",
    "unit" : "Month"
  } ],
