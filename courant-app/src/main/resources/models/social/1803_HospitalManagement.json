    "sink" : "PreOperative Patients on the Waiting List for Hospitalisation"
  }, {
    "name" : "PreOperative Patients on the Waiting List for Hospitalisation inflow 3",
    "equation" : "NonRecovered_Patients_With_Aftercare_Referred_Back_to_the_Hospital",
    "timeUnit" : "Week",
    "sink" : "PreOperative Patients on the Waiting List for Hospitalisation"
  }, {
    "name" : "PreOperative Patients on the Waiting List for Hospitalisation outflow 4",
    "equation" : "Hospitalisation_of_PreOperative_Patients",
    "timeUnit" : "Week",
    "source" : "PreOperative Patients on the Waiting List for Hospitalisation"
  } ],
  "variables" : [ {
    "name" : "PostOperative Patients Directed Towards Aftercare",
    "comment" : "\"Post-Operative Patients Directed Towards Aftercare\"",
    "equation" : "MAX( (Capacity_of_the_PostOperative_Aftercare - PostOperative_Patients_in_Aftercare )/Average_Administrative_Processing_Time_before_Hospitalisation_of_Transfer_to_Aftercare + NonRecovered_Patients_With_Aftercare_Referred_Back_to_the_Hospital + Recovered_PostOperative_Patients_With_Aftercare,Number_of_Discharged_PostOperative_Patients )",
    "unit" : "patient/Week"
  }, {
    "name" : "Average Administrative Processing Time before Hospitalisation",
    "comment" : "Average Administrative Processing Time before Hospitalisation",
    "equation" : "1",
    "unit" : "Week"
  }, {
    "name" : "Average Administrative Processing Time before Hospitalisation of Transfer to Aftercare",
    "comment" : "Average Administrative Processing Time before Hospitalisation of Transfer to Aftercare",
    "equation" : "1",
    "unit" : "Week"
  }, {
    "name" : "Hospitalisation of PreOperative Patients",
    "comment" : "\"Hospitalisation of Pre-Operative Patients\"",
    "equation" : "MAX((Capacity_of_the_Hospital - Operative_Patients_in_the_Hospital)/Average_Administrative_Processing_Time_before_Hospitalisation + PostOperative_Patients_Directed_Towards_Aftercare + PostOperative_Patients_Directed_Home_Without_Aftercare ,PreOperative_Patients_on_the_Waiting_List_for_Hospitalisation/Average_Administrative_Processing_Time_before_Hospitalisation )",
    "unit" : "patient/Week"
  }, {
    "name" : "Number of Discharged PostOperative Patients",
    "comment" : "\"Number of Discharged Post-Operative Patients\"",
    "equation" : "Operative_Patients_in_the_Hospital/Average_Residence_Time_in_the_Hospital",
    "unit" : "patient/Week"
  }, {
    "name" : "Capacity of the PostOperative Aftercare",
    "comment" : "\"Capacity of the Post-Operative Aftercare\"",
    "equation" : "1000 + STEP(Capacity_Extension_of_the_Aftercare,26)",
    "unit" : "patient"
  }, {
    "name" : "Capacity of the Hospital",
    "comment" : "Capacity of the Hospital",
    "equation" : "700+STEP(Capacity_Extension_of_the_Hospital,52)",
    "unit" : "patient"
  }, {
    "name" : "Capacity Extension of the Aftercare",
    "comment" : "500",
    "equation" : "0",
    "unit" : "patient"
  }, {
    "name" : "Capacity Extension of the Hospital",
    "comment" : "250",
    "equation" : "0",
    "unit" : "patient"
  }, {
    "name" : "Fraction of Recovered Patients With Aftercare",
    "comment" : "Fraction of Recovered Patients With Aftercare",
    "equation" : "0.98",
    "unit" : "Dmnl"
  }, {
    "name" : "Fraction of Recovered Patients Without Aftercare",
    "comment" : "Fraction of Recovered Patients Without Aftercare",
    "equation" : "0.8",
    "unit" : "Dmnl"
  }, {
    "name" : "Average Recovery Time Without Aftercare",
    "comment" : "Average Recovery Time Without Aftercare",
    "equation" : "7",
    "unit" : "Week"
  }, {
    "name" : "Average Residence Time in Aftercare",
    "comment" : "Average Residence Time in Aftercare",
    "equation" : "3",
    "unit" : "Week"
  }, {
    "name" : "Average Residence Time in the Hospital",
    "comment" : "Average Residence Time in the Hospital",
    "equation" : "1",
    "unit" : "Week"
  }, {
    "name" : "Recovered PostOperative Patients With Aftercare",
    "comment" : "\"Recovered Post-Operative Patients With Aftercare\"",
    "equation" : "Fraction_of_Recovered_Patients_With_Aftercare * PostOperative_Patients_in_Aftercare / Average_Residence_Time_in_Aftercare",
    "unit" : "patient/Week"
  }, {
    "name" : "Recovered PostOperative Patients Without Aftercare",
    "comment" : "\"Recovered Post-Operative Patients Without Aftercare\"",
    "equation" : "Fraction_of_Recovered_Patients_Without_Aftercare * PostOperative_Patients_Without_Aftercare /Average_Recovery_Time_Without_Aftercare",
    "unit" : "patient/Week"
  }, {
    "name" : "Newly Referred PreOperative Patients",
    "comment" : "\"Newly Referred Pre-Operative Patients\"",
    "equation" : "800",
    "unit" : "patient/Week"
  }, {
    "name" : "PostOperative Patients Directed Home Without Aftercare",
    "comment" : "\"Post-Operative Patients Directed Home Without Aftercare\"",
    "equation" : "Number_of_Discharged_PostOperative_Patients - PostOperative_Patients_Directed_Towards_Aftercare",
    "unit" : "patient/Week"
  }, {
    "name" : "NonRecovered Patients Without Aftercare Referred Back to the Hospital",
    "comment" : "\"Non-Recovered Patients Without Aftercare Referred Back to the Hospital\"",
    "equation" : "(1-Fraction_of_Recovered_Patients_Without_Aftercare) * PostOperative_Patients_Without_Aftercare / Average_Recovery_Time_Without_Aftercare",
    "unit" : "patient/Week"
  }, {
    "name" : "NonRecovered Patients With Aftercare Referred Back to the Hospital",
    "comment" : "\"Non-Recovered Patients With Aftercare Referred Back to the Hospital\"",
    "equation" : "(1 - Fraction_of_Recovered_Patients_With_Aftercare) * PostOperative_Patients_in_Aftercare / Average_Residence_Time_in_Aftercare",
    "unit" : "patient/Week"
  } ],
