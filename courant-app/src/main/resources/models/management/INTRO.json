{
  "name" : "INTRO",
  "stocks" : [ {
    "name" : "Average Worker Hours",
    "comment" : "The average number of hours worked per week",
    "initialValue" : 40.0,
    "unit" : "Hour/Month"
  }, {
    "name" : "Workforce",
    "comment" : "The number of workers",
    "initialValue" : 0.0,
    "initialExpression" : "target_production/normal_productivity",
    "unit" : "Person"
  } ],
  "flows" : [ {
    "name" : "Average Worker Hours net flow",
    "comment" : "Net flow for Average Worker Hours",
    "equation" : "change_in_hours_worked",
    "timeUnit" : "Month",
    "sink" : "Average Worker Hours"
  }, {
    "name" : "Workforce net flow",
    "comment" : "Net flow for Workforce",
    "equation" : "net_hires",
    "timeUnit" : "Month",
    "sink" : "Workforce"
  } ],
  "variables" : [ {
    "name" : "change in hours worked",
    "comment" : "change in hours worked",
    "equation" : "(required_worker_hours-Average_Worker_Hours) / delay_in_adding_or_removing_overtime_hours",
    "unit" : "Hour/(Month*Month)"
  }, {
    "name" : "delay in adding or removing overtime hours",
    "comment" : "delay in adding or removing overtime hours",
    "equation" : "3",
    "unit" : "Month"
  }, {
    "name" : "production",
    "comment" : "Total amount produced.",
    "equation" : "Workforce * required_worker_hours * productivity / normal_workweek",
    "unit" : "Widget/Month"
  }, {
    "name" : "required worker hours",
    "comment" : "The amount relative to normal that people have to work to\n\t\t         produce enough.",
    "equation" : "IF((Workforce*productivity) == 0, 0, (target_production) / (Workforce*productivity)) * normal_workweek",
    "unit" : "Hour/Month"
  }, {
    "name" : "net hires",
    "comment" : "The net number of people hired (laid off if negative).",
    "equation" : "(desired_workforce-Workforce)/time_to_hire_or_layoff",
    "unit" : "Person/Month"
  }, {
    "name" : "normal workweek",
    "comment" : "normal workweek",
    "equation" : "40",
    "unit" : "Hour/Month"
  }, {
    "name" : "time to hire or layoff",
    "comment" : "time to hire or layoff",
    "equation" : "6",
    "unit" : "Month"
  }, {
    "name" : "desired workforce",
    "comment" : "The desired number of workers.",
    "equation" : "IF((productivity) == 0, 0, (target_production) / (productivity))",
    "unit" : "Person"
  }, {
    "name" : "morale",
    "comment" : "Morale - 1 is normal.",
    "equation" : "LOOKUP(morale_lookup, Average_Worker_Hours/normal_workweek)",
    "unit" : "Dmnl"
  }, {
    "name" : "normal productivity",
    "comment" : "The normal amount produced in the absence of morale effects.",
    "equation" : "1",
    "unit" : "Widget/Month/Person"
  }, {
    "name" : "productivity",
    "comment" : "The amount each peson can produce given morale effects.",
    "equation" : "normal_productivity*LOOKUP(effect_of_morale_on_productivity_lookup, morale)",
    "unit" : "Widget/(Month*Person)"
  }, {
    "name" : "sales",
    "comment" : "The total amount sold.",
    "equation" : "IF(TIME > 20,120,100)",
    "unit" : "Widget/Month"
  }, {
    "name" : "target production",
    "comment" : "The target amount produced.",
    "equation" : "sales",
    "unit" : "Widget/Month"
  } ],
  "lookupTables" : [ {
    "name" : "effect of morale on productivity lookup",
