  }, {
    "name" : "workforce",
    "comment" : "workforce",
    "initialValue" : 2.0,
    "unit" : "person"
  } ],
  "flows" : [ {
    "name" : "remaining project tasks inflow 1",
    "equation" : "detecting_undiscovered_rework",
    "timeUnit" : "Month",
