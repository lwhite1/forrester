{
  "name" : "PROCRAST",
  "stocks" : [ {
    "name" : "Decision is Made",
    "comment" : "An indication that the decision has been made.",
    "initialValue" : 0.0,
    "unit" : "Dmnl"
  }, {
    "name" : "Thought Accomplished",
    "comment" : "Information that has been reviewed and correctly interpretted.",
    "initialValue" : 0.0,
    "unit" : "Bytes"
  }, {
    "name" : "Info Requiring Rethinking",
    "comment" : "The amount of information that has been interpreted incorrectly,\n\t\t       but for which that error has not yet been discovered.",
    "initialValue" : 0.0,
    "initialExpression" : "initial_info_proc  * ( 1 - norm_frac_thinking_correct )",
    "unit" : "Bytes"
  } ],
  "flows" : [ {
    "name" : "Decision is Made net flow",
    "comment" : "Net flow for Decision is Made",
    "equation" : "IF(perc_info_req_thought < min_threshold_delay,1/TIME_STEP,0)",
    "timeUnit" : "Days",
    "sink" : "Decision is Made"
  }, {
    "name" : "Thought Accomplished net flow",
    "comment" : "Net flow for Thought Accomplished",
    "equation" : "correct_thinking_rate",
    "timeUnit" : "Days",
    "sink" : "Thought Accomplished"
  }, {
    "name" : "Info Requiring Rethinking inflow 1",
    "equation" : "thinking_error_rate",
    "timeUnit" : "Days",
    "sink" : "Info Requiring Rethinking"
  }, {
    "name" : "Info Requiring Rethinking outflow 2",
    "equation" : "disc_info_req_rethink",
    "timeUnit" : "Days",
    "source" : "Info Requiring Rethinking"
  } ],
  "variables" : [ {
    "name" : "TIME_STEP",
    "equation" : "0.25",
    "unit" : "Days"
  }, {
    "name" : "INITIAL_TIME",
    "equation" : "0",
    "unit" : "Days"
  }, {
    "name" : "FINAL_TIME",
    "equation" : "100",
    "unit" : "Days"
  }, {
    "name" : "correct thinking rate",
    "comment" : "The rate at which in formation is thought about and correctly interpreted.",
    "equation" : "intensity_effort_applied * fraction_thinking_correct",
    "unit" : "Bytes / Day"
  }, {
    "name" : "thinking error rate",
    "comment" : "The rate at which errors are being made in the review of information.",
    "equation" : "intensity_effort_applied * ( 1 - fraction_thinking_correct )",
    "unit" : "Bytes / Day"
  }, {
    "name" : "intensity effort applied",
    "comment" : "The intensity with which the problem is attacked by the decision maker.",
    "equation" : "IF(Decision_is_Made,0, indicated_intensity_of_effort_applied)",
    "unit" : "Bytes / Day"
  }, {
    "name" : "effect of tension on frac correct",
    "comment" : "The effect of tension on the fraction of the thinking that is\n\t\t        done correctly.",
    "equation" : "LOOKUP(effect_tension_on_frac_correct_lookup, tension/normal_tension)",
    "unit" : "Dimensionless"
  }, {
    "name" : "indicated intensity of effort applied",
    "comment" : "The  intensity with which a problem of the specified importance is \t\t attacked by the decision maker.",
    "equation" : "INITIAL(perc_info_req_thought/Expected_Decision_Time )",
    "unit" : "Bytes / Day"
  }, {
    "name" : "eff importance tension",
    "comment" : "The effect of the importance of a decision on the tension that\n\t\t         decision generates.",
    "equation" : "1",
    "unit" : "Dimensionless"
  }, {
    "name" : "tension",
    "comment" : "The tension that the decision maker is under.",
    "equation" : "IF(Decision_is_Made,0, normal_tension * eff_importance_tension * eff_time_remaining_tension)",
    "unit" : "Tension units"
  }, {
    "name" : "eff time remaining tension",
    "comment" : "The effect of time remaining on the tension felt by the decision maker.",
    "equation" : "LOOKUP(eff_time_remaining_tension_lookup, time_remaining/Expected_Decision_Time)",
    "unit" : "Dimensionless"
  }, {
    "name" : "Expected Decision Time",
    "comment" : "The time expected to make a decision before any of the thinking takes \t\t place.",
    "equation" : "15",
    "unit" : "Day"
  }, {
    "name" : "initial info proc",
    "comment" : "The intial amount of information that has actually been processed\n\t\t        (thought about).",
    "equation" : "0",
    "unit" : "Bytes"
  }, {
    "name" : "min threshold delay",
    "comment" : "The minimum threshold in terms of information that remains to be thought\n\t\t        about warranting further delay.",
    "equation" : "1",
    "unit" : "Bytes"
  }, {
    "name" : "Time to detect errors",
    "comment" : "The time to detect errors that have occured in the processing of\n\t\t        information.",
    "equation" : "2",
    "unit" : "days"
  }, {
    "name" : "disc info req rethink",
    "comment" : "The discovery of information that has been misinterpreted and therefore\n\t\t        requires rethinking.",
    "equation" : "Info_Requiring_Rethinking / Time_to_detect_errors",
    "unit" : "Bytes/Day"
  }, {
    "name" : "perc info req thought",
    "comment" : "The percieved amount of information that remains to be though about.",
    "equation" : "tot_info_req_thought - info_perceived_reviewed",
    "unit" : "Bytes"
  }, {
    "name" : "info perceived reviewed",
    "comment" : "The amount of information that it is perceived has been correctly\n\t\t        reviewed.",
    "equation" : "Thought_Accomplished + Info_Requiring_Rethinking",
    "unit" : "Bytes"
  }, {
    "name" : "fraction thinking correct",
    "comment" : "The fraction of thinking that is done correctly.",
    "equation" : "norm_frac_thinking_correct * effect_of_tension_on_frac_correct",
    "unit" : "Fraction"
  }, {
    "name" : "norm frac thinking correct",
    "comment" : "The fraction of information that is normally processed without error\n\t\t        or misinterpretation.",
    "equation" : "0.8",
    "unit" : "Fraction"
  }, {
    "name" : "normal tension",
    "comment" : "The normal amount of tension that a decision of this importance would\n\t\t        bring about.",
    "equation" : "10",
    "unit" : "Tension units"
  }, {
    "name" : "time remaining",
    "comment" : "Time remaining required to make the decision - given no external\n\t\t        deadlines.",
    "equation" : "max(0,IF((intensity_effort_applied) == 0, 0, (perc_info_req_thought -  min_threshold_delay) / (intensity_effort_applied)))",
    "unit" : "days"
  }, {
    "name" : "tot info req thought",
    "comment" : "The size of the decision.",
    "equation" : "10",
    "unit" : "Bytes"
  } ],
  "lookupTables" : [ {
    "name" : "effect tension on frac correct lookup",
    "comment" : "Table for the effect of tension on the fraction of thinking that\n\t\t        is done correctly.",
    "xValues" : [ 0.0, 2.5, 5.0, 7.5, 10.0, 11.0, 12.5, 20.0 ],
    "yValues" : [ 1.2, 1.1, 0.9, 0.6, 0.2, 0.12, 0.08, 0.05 ],
    "interpolation" : "LINEAR"
  }, {
