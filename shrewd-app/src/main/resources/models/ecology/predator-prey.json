      "initialValue": 100.0,
      "unit": "Animal"
    },
    {
      "name": "Coyotes",
      "initialValue": 10.0,
      "unit": "Animal"
    }
  ],
  "flows": [
    {
      "name": "Prey Births",
      "equation": "Prey_Birth_Rate * Rabbits",
