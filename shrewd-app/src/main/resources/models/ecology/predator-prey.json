      "source": "Rabbits"
    },
    {
      "name": "Predator Births",
      "equation": "Predator_Efficiency * Predation_Rate * Rabbits * Coyotes",
      "timeUnit": "Year",
      "sink": "Coyotes"
    },
    {
      "name": "Predator Deaths",
      "equation": "Predator_Death_Rate * Coyotes",
      "timeUnit": "Year",
      "source": "Coyotes"
    }
  ],
