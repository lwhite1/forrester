{
  "name": "MicroCHP",
  "stocks": [
    {
      "name": "clients",
      "comment": "clients",
      "initialValue": 100.0,
      "unit": "person"
    },
    {
      "name": "potential clients",
      "comment": "potential clients",
      "initialValue": 16000000.0,
      "unit": "persoon"
    }
  ],
  "flows": [
    {
      "name": "clients net flow",
      "comment": "Net flow for clients",
      "equation": "new_clients",
      "timeUnit": "Month",
      "sink": "clients"
    },
    {
      "name": "potential clients net flow",
      "comment": "Net flow for potential clients",
      "equation": "- new_clients",
      "timeUnit": "Month",
      "sink": "potential clients"
    }
  ],
  "auxiliaries": [
    {
      "name": " 99 per cent",
      "comment": "\"99 per cent\"",
      "equation": "0.99*total_market",
      "unit": "person"
    },
    {
      "name": "new clients",
      "comment": "new clients",
      "equation": "contacts_of_potential_clients_with_clients*convincing_degree",
      "unit": "person/Month"
    },
    {
      "name": "contacts of potential clients with clients",
      "comment": "contacts of potential clients with clients",
      "equation": "contacts_with_clients*potential_client_concentration",
      "unit": "contact/Month"
    },
    {
      "name": "contacts with clients",
      "comment": "contacts with clients",
      "equation": "clients*social_contacts_per_person_per_month",
      "unit": "contact/Month"
    },
    {
      "name": "potential client concentration",
      "comment": "potential client concentration",
      "equation": "potential_clients/total_market",
      "unit": "dmnl"
    },
    {
      "name": "total market",
      "comment": "total market",
      "equation": "clients+potential_clients",
      "unit": "person"
    },
    {
      "name": "convincing degree",
      "equation": "0.01",
      "comment": "convincing degree",
      "unit": "person/contact"
    },
    {
      "name": "social contacts per person per month",
      "equation": "50",
      "comment": "social contacts per person per month",
      "unit": "contact/person/Month"
    }
  ],
