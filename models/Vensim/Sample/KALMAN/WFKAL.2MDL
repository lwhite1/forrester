{UTF-8}
********************************************************
	.Wfinv
********************************************************~
		
		
		 A simple workforce inventory oscillator.
	|

Inventory  = A FUNCTION OF( -des inventory,production,-sales) ~~|
Inventory = INTEG(production - sales,des inventory)
	~	widget
	~	 The amount of inventory on hand.
	|

Workforce = INTEG(net hire,initial workforce)
	~	person
	~	 The number of working people.
	|

initial workforce= INITIAL(
	 des workforce)
	~	person
	~	 The number of people working initially.
	|

net hire = (des workforce - Workforce)/time adjust workforce +
           net hire noise*RANDOM UNIFORM(-0.5,0.5,0)
	~	person/month
	~	  The net hire rate.
	|

net hire noise = 0
	~	person/month
	~	 Noise in net hiring to to unexpected events.
	|

time adjust workforce = 12
	~	month
	~	  The time to adjust the workforce.
	|

des workforce = des production / norm productivity
	~	person
	~	  The desired number of people working.
	|

productivity = (norm productivity+RANDOM UNIFORM(-0.5,0.5,0)*productivity noise)
	~	widget/person/month
	~	  The average productivity of workers.
	|

norm productivity = 1
	~	widget/person/month
	~	  The normal average productivity of workers.
	|

productivity noise = 0
	~	widget/(person*month)
	~	  The magnitude of driving noise in determining productivity.
	|

des production = Exp Sales + inv correction
	~	widget/month
	~	 The desired production level.
	|

Exp Sales = INTEG((sales - Exp Sales)/Time Avg Sales,sales)
	~	widget/month
	~	 The expected amount of sales.
	|

Time Avg Sales = 6
	~	month
	~	 The horizon over which sales are averaged.
	|

inv correction = (des inventory - Inventory)/
            time correct inventory
	~	widget/month
	~	 The desired correction to the level of inventory held.
	|

time correct inventory = 4
	~	month
	~	  The time over which inventory discrepencies are 
		        corrected.
	|

des inventory = Exp Sales * inventory coverage
	~	widget
	~	 The desired amunt of stock to keep in inventory.
	|

inventory coverage = 3
	~	month
	~	 The number of months of sales held in inventory.
	|

production = Workforce * productivity
	~	widget/month
	~	 The rate of production.
	|

********************************************************
	.Measurement
********************************************************~
		  Measurement equations.
	|

meas inventory = Inventory * (1+RANDOM UNIFORM(-0.5,0.5,0)*inventory meas noise)
	~	widget
	~	 The error prone measured sales.
	~	:SUPPLEMENTARY 
	|

inventory meas noise = 0
	~	dmnl
	~	 The magnitude of error in measuring inventory.
	|

meas workforce = Workforce * (1+RANDOM UNIFORM(-0.5,0.5,0)*workforce meas noise)
	~	person
	~	 The error prone measured sales.
	~	:SUPPLEMENTARY 
	|

workforce meas noise = 0
	~	dmnl
	~	 The magnitude of error in measuring workforce..
	|

********************************************************
	.Exogenous
********************************************************~
		   Exogenouse inputs.
	|

sales
	~	widget/month
	~	 The rate at which products are sold - exogenously input.
	|

********************************************************
	.filter
********************************************************~
		   Filter control constants
	|

meas workforce variance = 0.5
	~	dmnl
	~	  The variance in measurement. .0833*(.025*100)^2
	~	:SUPPLEMENTARY 
	|

meas inventory variance=
	1200
	~	dmnl
	~	  The variance in measurement .0833*(.4*300)^2
	~	:SUPPLEMENTARY 
	|

inventory drive variance = 33
	~	dmnl
	~	  The variance in driving noise .0833*(.2*1*100)
	~	:SUPPLEMENTARY 
	|

workforce drive variance = 1.3
	~	dmnl
	~	  The variance in driving workforce noise .0833*(4)^2
	~	:SUPPLEMENTARY 
	|

********************************************************
	.control
********************************************************~
		   Simulation control constants.
	|

FINAL TIME  =100
	~	month
	~	  The final time for the simulation
	|

INITIAL TIME  = 0
	~	month
	~	 The initial time for the simulation
	|

SAVEPER  = 1
	~	month
	~	 The frequency with which data is stored
	|

TIME STEP  = 1
	~	month
	~	 The time step for the simulation
	|

