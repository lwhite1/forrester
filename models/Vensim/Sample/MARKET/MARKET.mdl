{UTF-8}
{UTF-8}

accrued revenue  =
        unit sales
             * PRICE
	~	$/ Month
	~		|

adv budget  =
        FRAC BUDGET ADV
             * cash revenue
	~	$/ Month
	~		|

Adv Budget Effective  =
        INTEG( ( adv budget
                  - Adv Budget Effective )
                  / ADV IMPACT DELAY ,
             adv budget )
	~	$/ Month
	~		|

ADV IMPACT DELAY  = 12
	~	Months
	~		|

cash revenue  =
        Receivables
             / TIME TO CLEAR RECEIVABLES
	~	$/ Month
	~		|

Cum Retained Cash  =
        INTEG( retained cash flow ,
             0)
	~	$
	~		~	:SUPPLEMENTARY 
	|

DEMOS PER PERSON MONTH  = 12
	~	Orders / Month / Person
	~		|

eff of lead avail on demos  =
        TABLE FOR EFF OF LEADS ( Potential Orders
                  / Int Dir Salespeople )
	~	Dimensionless
	~		|

effect of advertising  =
        TABLE FOR EFFECT OF ADV ( Adv Budget Effective
                  / Products )
	~	Dimensionless
	~		|

DURATION OF NEGOTIATION  = 1
	~	Month
	~		|

EXT SALES REP FEE  = 400
	~	$/ Person / Month
	~		|

external sales reps  =
        cash revenue
             * FRAC BUDGET EXT SALES REPS
             / EXT SALES REP FEE
	~	People
	~		|

FINAL TIME  = 60
	~	Month
	~	    The final time for the simulation
	|

FRAC BUDGET ADV  = INITIAL(PERCENT BUDGET ADV/100)
	~	Dimensionless
	~		|

FRAC BUDGET EXT SALES REPS  = INITIAL(PERCENT BUDGET EXT SALES REPS/100)
	~	Dimensionless
	~		|

FRAC BUDGET INT DIR SALES  = INITIAL(PERCENT BUDGET INT DIR SALES/100)
	~	Dimensionless
	~		|

FRAC BUDGET MFG  = 0.47
	~	Dimensionless
	~		|

FRAC BUDGET R AND D  = 0.15
	~	Dimensionless
	~		|

frac cash retained  =
        ( 1
             - FRAC BUDGET MFG
             - FRAC BUDGET R AND D
             - FRAC BUDGET ADV
             - FRAC BUDGET EXT SALES REPS
             - FRAC BUDGET INT DIR SALES )
	~	Fraction
	~		|

fraction custs buying  =
        TABLE FOR FRAC BUYING ( Pot Orders In Negotiation
                  / Potential Orders )
	~	Dimensionless
	~		|

INITIAL TIME  = 0
	~	Month
	~	    The initial time for the simulation
	|

INT DIR SALES COST  = 2400
	~	$/ Person / Month
	~		|

Int Dir Salespeople  =
        INTEG( ( target int dir sales
                  - Int Dir Salespeople )
                  / THIDS ,
             target int dir sales )
	~	People
	~		|

LIFETIME OF MAILING LIST  = 60
	~	Months
	~		|

NORMAL LEAD GEN EFFIC  = 7
	~	Orders / Products / Month
	~		|

NORMAL SHARE OF SALES  = 0.8
	~	Dimensionless
	~		|

PERCENT BUDGET ADV  = 4
	~	Dimensionless
	~		|

PERCENT BUDGET EXT SALES REPS  = 8
	~	Dimensionless
	~		|

PERCENT BUDGET INT DIR SALES  = 6
	~	Dimensionless
	~		|

pot order creation  =
        NORMAL LEAD GEN EFFIC
             * Products
             * effect of advertising
	~	Orders / Month
	~		|

Pot Orders In Negotiation  =
        INTEG( pot ords mov to negot
                  - unit sales
                  - pot orders lost to comp
                  - pot orders not buying ,
             25)
	~	Orders
	~		|

pot orders lost to comp  =
        Pot Orders In Negotiation
             * fraction custs buying
             * ( 1
                  - NORMAL SHARE OF SALES )
             / DURATION OF NEGOTIATION
	~	Orders / Month
	~		|

pot orders not buying  =
        Pot Orders In Negotiation
             * ( 1
                  - fraction custs buying )
             / DURATION OF NEGOTIATION
	~	Orders / Month
	~		|

pot ords mov to negot  =
        Int Dir Salespeople
             * DEMOS PER PERSON MONTH
             * eff of lead avail on demos
             * sales rep effect mult
	~	Orders / Month
	~		|

pot ords obs rate  =
        Potential Orders
             / LIFETIME OF MAILING LIST
	~	Orders / Month
	~		|

Potential Orders  =
        INTEG( pot order creation
                  - pot ords obs rate
                  - pot ords mov to negot
                  + pot orders not buying
                  + unit sales ,
             POTENTIAL ORDERS I )
	~	Orders
	~		|

POTENTIAL ORDERS I  = 2400
	~	Orders
	~		|

PRICE  = 7000
	~	$/ Orders
	~		|

prod dev budget  =
        cash revenue
             * FRAC BUDGET R AND D
	~	$/ Month
	~		|

PROD DEV EFFICIENCY  = 3e-05
	~	Product / $
	~		|

PROD DEVT TIME  = 12
	~	Month
	~		|

Prod Gen Rate  =
        INTEG( ( PROD DEV EFFICIENCY
                  * prod dev budget
                  - Prod Gen Rate )
                  / PROD DEVT TIME ,
             PROD DEV EFFICIENCY
                  * prod dev budget )
	~	Product / Month
	~		|

PROD OBS TIME  = 60
	~	Months
	~		|

prod obsolescence rate  =
        Products
             / PROD OBS TIME
	~	Product / Month
	~		|

Products  =
        INTEG( Prod Gen Rate
                  - prod obsolescence rate ,
             10)
	~	Product
	~		|

Receivables  =
        INTEG( accrued revenue
                  - cash revenue ,
             accrued revenue
                  * TIME TO CLEAR RECEIVABLES )
	~	$
	~		|

retained cash flow  =
        cash revenue
             * frac cash retained
	~	$/ Month
	~		|

sales rep effect mult  =
        TABLE FOR SALES REP EFFECT ( external sales reps
                  / Potential Orders )
	~	Dimensionless
	~		|

SAVEPER  = 1
	~	Month
	~	    The frequency with which data is stored
	|

TABLE FOR EFF OF LEADS  (
            0, 100, 200, 300, 400, 500, 0, 0.32, 0.6, 0.8, 0.9, 1 )
	~	Dimensionless
	~		|

TABLE FOR EFFECT OF ADV  (
            0, 40, 80, 120, 160, 200, 240, 280, 320, 360, 400, 0.01, 0.2, 0.5
            , 0.7, 0.8, 1, 1.03, 1.06, 1.08, 1.09, 1.1 )
	~	Dimensionless
	~		|

TABLE FOR FRAC BUYING  (
            0, 0.005, 0.01, 0.015, 0.02, 0.025, 0.03, 1, 0.75, 0.55, 0.43,
            0.38, 0.35, 0.34 )
	~	Dimensionless
	~		|

TABLE FOR SALES REP EFFECT  (
            0.0017, 0.0027, 0.0037, 0.0047, 0.0057, 0.0067, 0.0077, 0.0087,
            0.0097, 0.0107, 0.4, 0.55, 0.7, 0.85, 1, 1.1, 1.2, 1.3, 1.4, 1.4
             )
	~	Dimensionless
	~		|

target int dir sales  =
        cash revenue
             * FRAC BUDGET INT DIR SALES
             / INT DIR SALES COST
	~	People
	~		|

THIDS  = 10
	~	Months
	~		|

TIME STEP  = 1
	~	Month
	~	    The time step for the simulation
	|

TIME TO CLEAR RECEIVABLES  = 6
	~	Months
	~		|

unit sales  =
        Pot Orders In Negotiation
             * NORMAL SHARE OF SALES
             * fraction custs buying
             / DURATION OF NEGOTIATION
	~	Orders / Month
	~		|

