{UTF-8}
{UTF-8}

accrued revenue  =
        unit sales
             * price
	~	$/ Month
	~		|

adv budget  =
        percent budget adv/100
             * cash revenue
	~	$/ Month
	~		|

Adv Budget Effective  =
        INTEG( ( adv budget
                  - Adv Budget Effective )
                  / adv impact delay ,
             adv budget )
	~	$/ Month
	~		|

adv impact delay  = 12
	~	Months
	~		|

cash revenue  =
        Receivables
             / time to clear receivables
	~	$/ Month
	~		|

Cum Retained Cash  =
        INTEG( retained cash flow ,
             0)
	~	$
	~		~	:SUPPLEMENTARY 
	|

demos per person month  = 12
	~	Orders / Month / Person
	~		|

eff of lead avail on demos  =
        table for eff of leads ( Potential Orders
                  / Int Dir Salespeople )
	~	Dimensionless
	~		|

effect of advertising  =
        table for effect of adv ( Adv Budget Effective
                  / Products )
	~	Dimensionless
	~		|

duration of negotiation  = 1
	~	Month
	~		|

ext sales rep fee  = 400
	~	$/ Person / Month
	~		|

external sales reps  =
        cash revenue
             * percent budget ext sales reps/100
             / ext sales rep fee
	~	People
	~		|

FINAL TIME  = 60
	~	Month
	~	   The final time for the simulation
	|

frac budget mfg  = 0.47
	~	Dimensionless
	~		|

frac budget r and d  = 0.15
	~	Dimensionless
	~		|

frac cash retained  =
        ( 1
             - frac budget mfg
             - frac budget r and d
             - percent budget adv/100
             - percent budget ext sales reps/100
             - percent budget int dir sales /100)
	~	Fraction
	~		|

fraction custs buying  =
        table for frac buying ( Pot Orders In Negotiation
                  / Potential Orders )
	~	Dimensionless
	~		|

INITIAL TIME  = 0
	~	Month
	~	   The initial time for the simulation
	|

int dir sales cost  = 2400
	~	$/ Person / Month
	~		|

Int Dir Salespeople  =
        INTEG( ( target int dir sales
                  - Int Dir Salespeople )
                  / time to hire int dir salespeople ,
             target int dir sales )
	~	People
	~		|

lifetime of mailing list  = 60
	~	Months
	~		|

normal lead gen effic  = 7
	~	Orders / Products / Month
	~		|

normal share of sales  = 0.8
	~	Dimensionless
	~		|

percent budget adv  = 4
	~	Dimensionless
	~		|

percent budget ext sales reps  = 8
	~	Dimensionless
	~		|

percent budget int dir sales  = 6
	~	Dimensionless
	~		|

pot order creation  =
        normal lead gen effic
             * Products
             * effect of advertising
	~	Orders / Month
	~		|

Pot Orders In Negotiation  =
        INTEG( pot orders moving to negot
                  - unit sales
                  - pot orders lost to comp
                  - pot orders not buying ,
             23)
	~	Orders
	~		|

pot orders lost to comp  =
        Pot Orders In Negotiation
             * fraction custs buying
             * ( 1
                  - normal share of sales )
             / duration of negotiation
	~	Orders / Month
	~		|

pot orders not buying  =
        Pot Orders In Negotiation
             * ( 1
                  - fraction custs buying )
             / duration of negotiation
	~	Orders / Month
	~		|

pot orders moving to negot  =
        Int Dir Salespeople
             * demos per person month
             * eff of lead avail on demos
             * sales rep effect mult
	~	Orders / Month
	~		|

pot ords obs rate  =
        Potential Orders
             / lifetime of mailing list
	~	Orders / Month
	~		|

Potential Orders  =
        INTEG( pot order creation
                  - pot ords obs rate
                  - pot orders moving to negot
                  + pot orders not buying,
             potential orders initial )
	~	Orders
	~		|

potential orders initial  = 2400
	~	Orders
	~		|

price  = 7000
	~	$/ Orders
	~		|

prod dev budget  =
        cash revenue
             * frac budget r and d
	~	$/ Month
	~		|

prod dev efficiency  = 3e-05
	~	Product / $
	~		|

prod dev time  = 12
	~	Month
	~		|

prod gen rate  =
        INTEG( ( prod dev efficiency
                  * prod dev budget
                  - prod gen rate )
                  / prod dev time ,
             prod dev efficiency
                  * prod dev budget )
	~	Product / Month
	~		|

prod obs time  = 60
	~	Months
	~		|

prod obsolescence rate  =
        Products
             / prod obs time
	~	Product / Month
	~		|

Products  =
        INTEG( prod gen rate
                  - prod obsolescence rate ,
             10)
	~	Product
	~		|

Receivables  =
        INTEG( accrued revenue
                  - cash revenue ,
             accrued revenue
                  * time to clear receivables )
	~	$
	~		|

retained cash flow  =
        cash revenue
             * frac cash retained
	~	$/ Month
	~		|

sales rep effect mult  =
        table for sales rep effect ( external sales reps
                  / Potential Orders )
	~	Dimensionless
	~		|

SAVEPER  = 1
	~	Month
	~	   The frequency with which data is stored
	|

table for eff of leads  (
            0, 100, 200, 300, 400, 500, 0, 0.32, 0.6, 0.8, 0.9, 1 )
	~	Dimensionless
	~		|

table for effect of adv  (
            0, 40, 80, 120, 160, 200, 240, 280, 320, 360, 400, 0.01, 0.2, 0.5
            , 0.7, 0.8, 1, 1.03, 1.06, 1.08, 1.09, 1.1 )
	~	Dimensionless
	~		|

table for frac buying  (
            0, 0.005, 0.01, 0.015, 0.02, 0.025, 0.03, 1, 0.75, 0.55, 0.43,
            0.38, 0.35, 0.34 )
	~	Dimensionless
	~		|

table for sales rep effect  (
            0.0017, 0.0027, 0.0037, 0.0047, 0.0057, 0.0067, 0.0077, 0.0087,
            0.0097, 0.0107, 0.4, 0.55, 0.7, 0.85, 1, 1.1, 1.2, 1.3, 1.4, 1.4
             )
	~	Dimensionless
	~		|

target int dir sales  =
        cash revenue
             * percent budget int dir sales/100
             / int dir sales cost
	~	People
	~		|

time to hire int dir salespeople  = 10
	~	Months
	~		|

TIME STEP  = 1
	~	Month
	~	   The time step for the simulation
	|

time to clear receivables  = 6
	~	Months
	~		|

unit sales  =
        Pot Orders In Negotiation
             * normal share of sales
             * fraction custs buying
             / duration of negotiation
	~	Orders / Month
	~		|

