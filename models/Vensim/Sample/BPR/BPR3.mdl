{UTF-8}
activating = MIN(Awaiting Activation/TIME STEP,Activating Capacity)
	~	Line/Day
	~		|

Activating Capacity = INTEG((Awaiting Activation/target activation delay-
                              Activating Capacity)/activation adj time,
                              Awaiting Activation/target activation delay)
	~	Line/Day
	~		|

activation adj time = 4
	~	Day
	~		|

Processing Capacity = INTEG((Orders in Process/target process delay -
                                           Processing Capacity)/proc adj time,
                                          Orders in Process/target process delay)
	~	Line/Day
	~		|

dispatch adj time = 60
	~	Day
	~		|

Testing Capacity = INTEG((Orders Requiring Testing/target test delay-
                                Testing Capacity)/test adj time,
                                   Orders Requiring Testing/target test delay)
	~	Line/Day
	~		|

Dispatching Capacity = INTEG((Orders Requiring Service/target service delay -
                                       Dispatching Capacity)/dispatch adj time,
                                       Orders Requiring Service/target service delay)
	~	Line/Day
	~		|

test adj time = 10
	~	Day
	~		|

New Customers = INTEG(activating,0)
	~	Line
	~		~	:SUPPLEMENTARY 
	|

proc adj time = 20
	~	Day
	~		|

Awaiting Activation = INTEG(dispatching+testing*fraction facilities good-activating,
                           (dispatching+testing*fraction facilities good)*
                            target activation delay)
	~	Line
	~		|

target activation delay = 1
	~	Day
	~		|

dispatching = MIN(Dispatching Capacity,Orders Requiring Service/TIME STEP)
	~	Line/Day
	~		|

FINAL TIME  = 100
	~	Day
	~	  The final time for the simulation.
	|

fraction facilities good = 0.8
	~	Dmnl
	~		|

fraction facilities ready = 0.7
	~	Dmnl
	~		|

INITIAL TIME  = 0
	~	Day
	~	  The initial time for the simulation.
	|

orders = start orders *(1+STEP(0.1,10))
	~	Line/Day
	~		|

start orders = 100
	~	Line/Day
	~		|

Orders in Process = INTEG(orders-processing,orders*target process delay)
	~	Line
	~		|

target process delay = 1
	~	Day
	~		|

Orders Requiring Service = INTEG(processing*(1-fraction facilities ready)+
                          testing*(1-fraction facilities good)-dispatching,
					(processing*(1-fraction facilities ready)+
                          testing*(1-fraction facilities good))*
					target service delay)
	~	Line
	~		|

target service delay = 3
	~	Day
	~		|

Orders Requiring Testing = INTEG(processing*fraction facilities ready-testing,
						(processing*fraction facilities ready)*
						target test delay)
	~	Line
	~		|

target test delay = 1
	~	Day
	~		|

processing = MIN(Orders in Process/TIME STEP,Processing Capacity)
	~	Line/Day
	~		|

SAVEPER  = 1
	~	Day
	~	  The frequency with which output is stored.
	|

testing = MIN(Orders Requiring Testing/TIME STEP,Testing Capacity)
	~	Line/Day
	~		|

TIME STEP  = 0.5
	~	Day
	~	  The time step for the simulation.
	|

