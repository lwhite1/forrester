{UTF-8}
********************************************************
	.mproj3
********************************************************~
		
		
		
		  A simple multitask project model.  
		  Copyright (c) 1991,1992 Ventana Systems, Inc.
		  This is a simple example showing prerequisite dependency 
		  and work quality flow through.
	|

max labor[task] = 1000
	~	person
	~		|

overrun charge = IF THEN ELSE(:NOT: project is done :AND:
         Time > init sched comp time[TASK4],
         overrun charge rate,0)
	~	$/Month
	~	     The charge applied to a project based on the overrun
		         penalty
		         applied past the initial start time.
	|

overrun charge rate = 100000
	~	$/Month
	~	     The penalty assessed on project lateness.
	|

Project Compl Time = INTEG(IF THEN ELSE(Project Compl Time = 0 :AND: 
               project is done,Time/TIME STEP,0),0)
	~	Month
	~	    The time at which the project was completed.
	|

total cost plus penalty = total cost + overrun charge
	~	$/Month
	~	     The total cost of the project plus the penalties accrued.
	~	:SUPPLEMENTARY 
	|

********************************************************
	.Activity
********************************************************~
	|

task is active[task]=
	IF THEN ELSE(task is started[task] :AND: :NOT: 
	    task is done[task],1,0)
	~	dmnl
	~	       Flag to show which tasks are active.
	|

task is started[task]=
	IF THEN ELSE(Time >= Sched Start Time[task],1,
	0)
	~	dmnl
	~	       Flag to indicate if a task has been started.
	|

project is done = task is done[TASK4]
	~	dmnl
	~	       Flag to indicate that the project is completed.
	|

task is done[task] = IF THEN ELSE(rep frac complete[task] > 
     req frac complete[task],1,0)
	~	dmnl
	~	       Flag to indicate if the task is finished.
	|

********************************************************
	.Control
********************************************************~
		
		
		
		
		
		
		  Control parameters for the model.
	|

FINAL TIME = IF THEN ELSE(Project Compl Time > 0,
                 QUANTUM(Project Compl Time+15*UNIT TIME,10*UNIT TIME)
,
                 max final time)
	~	Month
	~	       The time at which the simulation ends.
	|

INITIAL TIME = INITIAL(VMIN(init sched start time[task!]))
	~	Month
	~	       The initial time for the simulation
	|

max final time = 100
	~	Month
	~	      The maximum number of months for simulation even
		        when the project is not finished.
	|

SAVEPER = 1
	~	Month
	~	       The frequency with which data is stored.
	|

TIME STEP = 0.25
	~	Month
	~	       The solution interval for simulating the model.
	|

UNIT TIME=1
	~	Month
	~	      Unit time used for dimensional consistency
	|

********************************************************
	.Definition
********************************************************~
		
		
		
		
		
		
		  The size, scheduling, work requirements and patterns for
		         the project.
	|

init sched comp time[task] = 20,40,50,70
	~	Month
	~	       The initial scheduled completion timee.
	|

init sched start time[task] = 0,20,40,50
	~	Month
	~	       The time at which the project starts.
	|

normal productivity[task] = 20,25,15,25
	~	dwg/person/Month
	~	       The normal amount of work that is done in the absence of
		         any effects on productivity.
	|

normal quality[task] = 0.95
	~	dmnl
	~	       The normal quality of work done when no factors are
		         deteriorating performance.
	|

prereq req[TASK1,prereq] = 0,0,0,0 ~~|
prereq req[TASK2,prereq] = 1,0,0,0 ~~|
prereq req[TASK3,prereq] = 1,1,0,0 ~~|
prereq req[TASK4,prereq] = 1,1,1,0
	~	dmnl
	~	       Switches showing which tasks depend on which for
		         completion.
	|

prereq req frac complete = 0.9
	~	dmnl
	~	       The required completeness on prerequisite work before a
		         task can be started.  Could be by [task,prereq].
	|

req frac complete[task] = 0.98
	~	dmnl
	~	       The fraction of a task that needs to be complete before
		         the
		         task can be stopped.
	|

task definition[task] = 100000,200000,50000,400000
	~	dwg
	~	       The definition of how big the job is, in drawing
		         equivalent
		         units.
	|

********************************************************
	.Financial
********************************************************~
		
		
		
		
		
		
		 Financial performance of the project
	|

cost[task] = labor cost[task]
	~	$/Month
	~	       The ongoing cost of a task including labor and
		         materials.
	|

Cum Cost[task] = INTEG(cost[task],0)
	~	$
	~	       The cummulative cost of each task
	|

labor cost[task] = Labor[task]*wage rate
	~	$/Month
	~	       The cost of labor for each particular task and skill
		         type.
	|

total cost = SUM(cost[task!])
	~	$/Month
	~	       The total ongoing cost of running the project
	|

total cum cost = SUM(Cum Cost[task!])
	~	$
	~	       The total cummulative cost of running the project
	~	:SUPPLEMENTARY 
	|

wage rate = 8000
	~	$/Month/person
	~	       The wage rate (including benefits and overhead) for
		         workers.
	|

********************************************************
	.Productivity
********************************************************~
		
		
		
		
		
		
		   The total amount of work people get done, and are able to
		         get done.
	|

Avg Overtime Frac[task] = INTEG(
              (overtime frac[task] - Avg Overtime Frac[task])/
          time avg overtime,1)
	~	dmnl
	~	       The average overtime fraction used as a measure of
		         fatigue.
	|

eff fatigue prod[task] = table eff fatigue prod(
           Avg Overtime Frac[task])
	~	dmnl
	~	       The effect of fatigue on productivity.
	|

eff morale prod[task] = table eff morale prod(
               (exp comp time[task] - init sched comp time[task])/
                 init task length[task])
	~	dmnl
	~	       The effect of morale on productivity
	|

eff prereq ready prod[task,prereq] = 
      IF THEN ELSE(prereq req[task,prereq],
        IF THEN ELSE(task is done[prereq],
           1,
           prereq eff speed lookup(rep frac complete[task])),
        1)
	~	dmnl
	~	      The effect of prerequisite readyness on work speed.
	|

eff sched press prod[task] = table eff sched press prod(MIN(5,
    XIDZ(exp time remaining[task],sched time remaining[task],5)))
	~	dmnl
	~	       The effect of schedule pressure on gross productivity.
	|

gross productivity[task] = normal productivity[task] *
     eff morale prod[task] *
     eff fatigue prod[task] *
     eff sched press prod[task] *
     PROD(eff prereq ready prod[task,prereq!])
        * (1 + (RANDOM 0 1() - 0.5) * productivity noise)
	~	dwg/person/Month
	~	       The gross amount that people can get done in an hour
		         neglecting
		       any quality or potential rework measures.
	|

prereq eff speed lookup((0,1),(0.5,1),(1,0))
	~	dmnl
	~	      Table relating the fraction complete of a task to 
		         effect on work speed of prerequisites that are not
		         yet completely finished.
	|

productivity noise = 0
	~	dmnl
	~	       The noise in productivity.
	|

table eff fatigue prod ( 0.5,1,1.1,1.2,1.3,1.4,1.5,
                                 1,1,0.95,0.9,0.85,0.8,0.7)
	~	dmnl
	~	       Table showing the effect of fatigue (average overtime)
		         on
		         productivity.
	|

table eff morale prod (-1,-0.5,0,0.5,1,1.5,2,
     4,2,1,0.85,0.75,0.7,0.65)
	~	dmnl
	~	       The table describing the effect of morale on
		         productivity.
	|

table eff sched press prod (0,1,2,5,10,
                    1,1,1.1,1.2,1.25)
	~	dmnl
	~	       Table showing the effect of schedule pressure on
		         productivity.
	|

time avg overtime = 2
	~	Month
	~	       The time taken to average overtime in determining its
		         impact on
		          fatigue.
	|

********************************************************
	.Progress
********************************************************~
		
		
		
		
		
		
		  Work that is actually getting done.
	|

rep work remaining[task]=
	MAX(0,
	            task definition[task] - reported work complete[task])
	~	dwg
	~	       The reported amount of work remaining.
	|

exp time remaining[task]=
	IF THEN ELSE(task is started[task],
	         IF THEN ELSE(task is done[task],
	             0,
	             MIN(2*init task length[task],
	                XIDZ(rep work remaining[task],
	                    normal productivity[task] * 
	                    expected effective labor[task],
	                    2*init task length[task]))),
	         init task length[task])
	~	Month
	~	       The expected time remaining to the completion of the
		         task.
	|

expected effective labor[task]=
	XIDZ(Labor[task],
	         relative effort intensity[task],
	         rep work remaining[task]/normal productivity[task]/
	           init task length[task])
	~	person
	~	       The expected effective workforce based on perceived
		       flexibility into the future.  A convex combination of
		       desired and effective would be better.
	|

rep frac complete[task]=
	reported work complete[task]/task definition
	[task
	]
	~	dmnl
	~	       The fraction of work that is reported to be complete.
	|

downstream rework disc[downstream,task] = IF THEN ELSE(
         task is active[downstream] :AND:
         prereq req[downstream,task], Undis Rework[task]/
         prereq rework disc time[downstream,task],
          0)
	~	dwg/Month
	~	       The discovery of errors in downstream tasks.
	|

gross completion rate[task] = Labor[task] * 
            overtime frac[task] *
            gross productivity[task]
	~	dwg/Month
	~	       The rate at which both correct and flawed work is being
		         completed.
	|

norm rework disc time[task] = 40,25,15,10
	~	Month
	~	       The normal time it takes to discover errors.
	|

overtime frac[task] = table overtime frac(XIDZ(exp time remaining[task
],sched time remaining[task],
            1))
	~	dmnl
	~	The amount of overtime being worked.
	|

prereq rework disc time[TASK1,task] = 1 ~~|
prereq rework disc time[TASK2,task] = 6 ~~|
prereq rework disc time[TASK3,task] = 6 ~~|
prereq rework disc time[TASK4,task] = 2
	~	Month
	~	       The time to discover errors in prerequisite work.
	|

reported work complete[task] = Work Completed Correctly[task] + Undis Rework
[task]
	~	dwg
	~	       The amount of work that is reported to be complete.
	|

rework discovery[task] = MAX(0,MIN(Undis Rework[task]/
          TIME STEP,
          Undis Rework[task]/rework discovery time[task] +
           SUM(downstream rework disc[downstream!,task])))
	~	dwg/Month
	~	       The rate of discovery of rework.
	|

rework discovery time[task] = norm rework disc time[task] *
        table eff frac complete[task](rep frac complete[task])
	~	Month
	~	       The time required to detect existing problems.
	|

table eff frac complete[TASK1] ((0,1),(0.5,1),(0.6,0.8),(0.7,0.6),
        (0.8,0.4),(1,0.2)) ~~|
table eff frac complete[TASK2] ((0,1),(0.5,0.9),(0.75,0.4),
           (1,0.2)) ~~|
table eff frac complete[TASK3] ((0,1),(0.5,0.9),(0.75,0.4),
           (1,0.2)) ~~|
table eff frac complete[TASK4] ((0,1),(0.5,0.9),(0.75,0.4),
           (1,0.1))
	~	dmnl
	~	       Table showing the effect of the fraction complete on the
		         speed with which
		       errors are discovered.
	|

table overtime frac ( -0.1,0,1,1.2,1.5,2,3,
                     0,0.3,1,1.1,1.2,1.3,1.3)
	~	dmnl
	~	       Table showint the overtime fraction as a function of
		         behind
		         schedule.
	|

Undis Rework[task] = INTEG(gross completion rate[task] * (1-work quality
[task]) -
                   rework discovery[task],0)
	~	dwg
	~	       The amount of work that is done incorrectly and requires
		         correction,
		     but has not yet been detected.
	|

Work Completed Correctly[task] = INTEG(gross completion rate[task] * work quality
[task],
     0)
	~	dwg
	~	       The amount of work that is completed correctly.
	|

********************************************************
	.Quality
********************************************************~
		
		
		
		
		
		
		   Equations describing quality and its determinants.
	|

eff fatigue qual[task] = table eff fatigue qual(
           Avg Overtime Frac[task])
	~	dmnl
	~	       The effect of fatigue on quality.
	|

eff morale qual[task] = table eff morale qual(
               (exp comp time[task] - init sched comp time[task])/
                 init task length[task])
	~	dmnl
	~	       The effect of morale on qualuctivity
	|

eff prereq qual qual[task,prereq] = 
   IF THEN ELSE(prereq req[task,prereq],
     XIDZ(Work Completed Correctly[prereq],reported work complete[prereq
],1),
   1)
	~	dmnl
	~	      The effect of prerequisite quality on quality.  Note
		      quality is computed in terms of unmeasurable
		         quantities.
	|

eff sched press qual[task] = IF THEN ELSE(task is active[task],
     table eff sched press qual(XIDZ(
     exp time remaining[task],sched time remaining[task],5)),
     1)
	~	dmnl
	~	       The effect of schedule pressure on gross quality.
	|

quality noise = 0
	~	dmnl
	~	       Noise output as a result of quality variation.
	|

table eff fatigue qual ( 0.5,1,1.1,1.2,1.3,1.4,1.5,
                           1,1,0.95,0.9,0.85,0.8,0.7)
	~	dmnl
	~	       Table showing the effect of fatigue (average overtime)
		         on
		         quality.
	|

table eff morale qual (-1,-0.5,0,0.5,1,1.5,2,
     1,1,1,0.95,0.9,0.85,0.85)
	~	dmnl
	~	       The table describing the effect of morale on quality.
	|

table eff sched press qual (0,1,2,5,10,
               1,1,0.95,0.9,0.8)
	~	dmnl
	~	       Table showing the effect of schedule pressure on
		         quality.
	|

work quality[task] = normal quality[task] *
     eff morale qual[task] *
     eff fatigue qual[task] *
     eff sched press qual[task] *
     PROD(eff prereq qual qual[task,prereq!]) *
      (1 - RANDOM 0 1() * quality noise)
	~	dmnl
	~	       The quality of work being done by people.
	|

********************************************************
	.Schedule
********************************************************~
		
		
		
		
		
		
		  Things relating to scheduling.
	|

exp comp time[task]=
	IF THEN ELSE(task is active[task],
	                Time + exp time remaining[task],
	                Sched Comp Time[task])
	~	Month
	~	       The excpected time at which the task will complete.
	|

sched start time slip[task]=
	IF THEN ELSE(task is active[task] :OR:
	             VMIN(prereq in place[task,prereq!]) > 0  :OR:
	             (Time + TIME STEP < Sched Start Time[task]) ,
	             0,start slip increment/TIME STEP)
	~	Month/Month
	~	       The amount of time the scheduled start time slips in
		         response to slippage
		     in prerequisite tasks.
	|

sched comp time slip[task]=
	sched start time slip[task] +
	                IF THEN ELSE(task is active[task] :AND:
	                  sched time remaining[task] < slip zone :AND:
	                  exp time remaining[task] -
	                  sched time remaining[task] > slip trigger,
	                  slip increment/TIME STEP,0)
	~	Month/Month
	~	       The slippage in the scheduled completion time.
	|

prereq in place[task,prereq]=
	IF THEN ELSE((prereq req[task,prereq] = 0) :OR:
	        rep frac complete[prereq] > 
	          prereq req frac complete,1,0)
	~	dmnl
	~	       Switch to indicate if all prerequisites are in place.
	|

fraction schedule passed[task] = IF THEN ELSE (
           Time > Sched Start Time[task],
           IF THEN ELSE(Time < Sched Comp Time[task],
              (Time - Sched Start Time[task])/
               (Sched Comp Time[task] - 
                  Sched Start Time[task]),1),0)
	~	dmnl
	~	      The fraction of the schedule that has passed - not the
		         same
		         as
		       the fraction of work done.  Adjusts itself in
		         response to
		       schedule shifts.
	|

init task length[task] = INITIAL(
         init sched comp time[task] - init sched start time[task])
	~	Month
	~	       The initial length of the task in months.
	|

Sched Comp Time[task] = INTEG(sched comp time slip[task],
           init sched comp time[task])
	~	Month
	~	       The scheduled completion time.
	|

Sched Start Time[task] = INTEG(sched start time slip[task],init sched start time
[task])
	~	Month
	~	       The scheduled start time.
	|

sched time remaining[task] = MAX(0,Sched Comp Time[task] - Time)
	~	Month
	~	       The amount of time remaining in the schedule.
	|

slip increment = 1
	~	Month
	~	       The amount of time the schedule is slipped, if it needs
		         slipping.
	|

slip trigger = 2
	~	Month
	~	       The amount of time behind schedule at which the
		         completion
		         date will be slipped.
	|

slip zone = 4
	~	Month
	~	       The distance from the end of a project at which schedule
		         slippage becomes an
		     alternative.
	|

start slip increment = 0.5
	~	Month
	~	       The slip increment for starting a task up if things are
		         behind schedule.
	|

********************************************************
	.Subscript
********************************************************~
		
		
		
		
		
		
		   A list of subscripts used by the model.
	|

downstream <-> task
	~	Nil
	~	       Downstreem tasks.
	|

prereq <-> task
	~	Nil
	~	       The prerequisites for doing task (other tasks)
	|

task : TASK1, TASK2, TASK3, TASK4
	~	Nil
	~	       The tasks that need to be done
	|

********************************************************
	.Workforce
********************************************************~
	|

des labor[task]=
	MIN(max labor[task],
	           IF THEN ELSE(Time + time adj labor[task]>= 
	            Sched Start Time[task] :AND: :NOT: 
	            task is done[task],
	           XIDZ(
	              (planned work remaining[task] / 
	                normal productivity[task])
	             *planned relative effort intensity[task],
	             sched time remaining[task],max labor[task]),0))
	~	person
	~	       The amount of labor it is desired to have.
	|

planned fraction schedule passed[task]=
	IF THEN ELSE (
	           Time + time adj labor[task]> Sched Start Time[task],
	           IF THEN ELSE(Time + time adj labor[task] < 
	                Sched Comp Time[task],
	              (Time +time adj labor[task] - Sched Start Time[task])/
	               (Sched Comp Time[task] - 
	                  Sched Start Time[task]),1),0)
	~	dmnl
	~	      The fraction of the schedule that has passed - not the
		         same
		         as
		       the fraction of work done.  Adjusts itself in
		         response to
		       schedule shifts.
	|

Labor[task] = INTEG(net labor adj[task],des labor[task])
	~	person
	~	        The number of people of a given skill on a given task.
	|

max labor adj[task] = 250
	~	person/Month
	~	      The maximum rate at which labor can be adjusted for
		        a task.
	|

net labor adj[task] = MIN(max labor adj[task],
                (des labor[task] - Labor[task])/
                  time adj labor[task])
	~	person/Month
	~	      The net adjustment of labor (additions or 
		        reductions.  Notice this is capped.
	|

planned relative effort intensity[task] = 
            XIDZ(planned work profile[task]
                    (planned fraction schedule passed[task]) *
                    (1 - planned fraction schedule passed[task]),
                     LOOKUP AREA(planned work profile[task],
                     planned fraction schedule passed[task],1),1)
	~	dmnl
	~	      Relative effort intensity as determined by the planned 
		        profile of effort - for the fraction of time in a
		         task left
		        remaining.
	|

planned work profile[TASK1] ((0,0),(0.2,1),(0.8,1),(1,0)) ~~|
planned work profile[TASK2] ((0,0),(0.2,0.5),(0.8,1),(1,0)) ~~|
planned work profile[TASK3] ((0,0),(0.2,1),(0.8,1),(1,0)) ~~|
planned work profile[TASK4] ((0,0),(0.2,1),(0.8,1),(1,0))
	~	dmnl
	~	      The planned profile of effort for each task - shows ramp
		       up and ramp down.  The actual numbers are irrelevent,
		         only
		       the relative values are used.
	|

planned work remaining[task] = ACTIVE INITIAL(
        MAX(0,rep work remaining[task] -
           Labor[task]*normal productivity[task]*
           time adj labor[task] *
           XIDZ({planned work profile[task](
                fraction schedule passed[task]) +}
                planned work profile[task](
                planned fraction schedule passed[task]),
                {2*}   planned work profile[task](
                   fraction schedule passed[task]),1)),
        rep work remaining[task])
	~	dwg
	~	      The planned amount of work remaining as used in 
		         hiring decisions.
	|

relative effort intensity[task] = XIDZ(planned work profile[task]
                    (fraction schedule passed[task]) *
                    (1 - fraction schedule passed[task]),
                     LOOKUP AREA(planned work profile[task],
                     fraction schedule passed[task],1),1)
	~	dmnl
	~	      Relative effort intensity as determined by the planned 
		        profile of effort - for the fraction of time in a
		         task left
		        remaining.
	|

time adj labor[task] = 1
	~	Month
	~	      The amount of time required to adjust labor to 
		        target values.
	|

