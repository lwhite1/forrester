persistent pollution technology change use custom=
	0
	~	Dmnl [0,1,1]
	~		|

persistent pollution technology change time s=
	IF THEN ELSE ( scenario = 0 :OR: persistent pollution technology change use custom =\
		 1 ,
	   persistent pollution technology change time ,
	   persistent pollution technology change scenario table ( scenario ) )
	~	year
	~		|

persistent pollution technology change mult table 1  ( 
            (-1,0),(0,0) )
	~	1/year
	~	  Table relating persisten pollution to changes due to
		         technology (POLGFMT#--).
	|

persistent pollution technology change mult table 2(
	[(-1,-0.04)-(0,0.2)],(-1,-0.04),(0,0))
	~	1/year
	~	  Table relating persisten pollution to changes due to
		         technology (POLGFMT#--).\!\!
	|

persistent pollution technology change multiplier=
	IF THEN ELSE ( Time < persistent pollution technology change time s, 
	   persistent pollution technology change multiplier 1 ,
	   persistent pollution technology change multiplier 2 )
	~	1/year
	~	POLLUTION CONTROL TECHNOLOGY CHANGE MULTIPLIER (POLGFM#--).
	|

persistent pollution technology change multiplier 1=
	persistent pollution technology change mult table 1 ( 1
	                  - persistent pollution index 
	                       / desired persistent pollution index )
	~	1/year
	~	  POLLUTION CONTROL TECHNOLOGY CHANGE MULTIPLIER
		         (POLGFM#--).
	|

persistent pollution technology change multiplier 2=
	persistent pollution technology change mult table 2 ( 1  - persistent pollution index\
		 / desired persistent pollution index )
	~	1/year
	~	  POLLUTION CONTROL TECHNOLOGY CHANGE MULTIPLIER
		         (POLGFM#--).
	|

