zero population growth time use custom=
	0
	~	Dmnl [0,1,1]
	~		|

zero population growth time=
	2100
	~	year [1900,2100,1]
	~		|

zero population growth time s=
	IF THEN ELSE ( scenario = 0 :OR: zero population growth time use custom = 1 ,
	   zero population growth time ,
	   zero population growth time scenario table ( scenario ) )
	~	year
	~		|

zero population growth time scenario table(
	[(0,0)-(20,2100)],(6,2100),(7,2002),(9,2002),(10,1982),(11,2012))
	~	year
	~	A table for allowing easy selection of which scenario to run, and to allow \
		preferred percent to be used so that two scenario values may be merged \
		into that preferred.\!\!\!
	|

resource technology change time=
	2100
	~	year [1900,2100,1]
	~		|

resource technology change time s=
	IF THEN ELSE ( scenario = 0 :OR: resource technology change time use custom = 1 ,
	   resource technology change time ,
	   resource technology change time scenario table ( scenario ) )
	~	year
	~		|

resource technology change time scenario table(
	[(0,0)-(20,2100)],(4,2100),(6,2002),(7,2100),(8,2100),(9,2002),(10,1982),(11,2012))
	~	year
	~	A table for allowing easy selection of which scenario to run, and to allow \
		preferred percent to be used so that two scenario values may be merged \
		into that preferred.\!\!\!
	|

resource technology change time use custom=
	0
	~	Dmnl [0,1,1]
	~		|

resource technology change table 1(
	[(-1,0)-(0,10)],(-1,0),(0,0))
	~	1/year
	~		|

resource technology change table 2(
	[(-1,-0.1)-(0,0)],(-1,-0.04),(0,0))
	~	1/year
	~		|

resource technology change rate multiplier=
	IF THEN ELSE ( Time < resource technology change time s ,
	   resource technology change rate multiplier 1 ,
	   resource technology change rate multiplier 2 )
	~	1/year
	~	Resource technology change multiplier (NRCM#--)
	|

resource technology change rate multiplier 1=
	resource technology change table 1 ( 1  - resource usage rate / desired resource use rate\
		 )
	~	1/year
	~	  Resource technology change multiplier (NRCM#--)
	|

resource technology change rate multiplier 2=
	resource technology change table 2 ( 1  - resource usage rate / desired resource use rate\
		 )
	~	1/year
	~	  Resource technology change multiplier (NRCM#--)
	|

industrial output per capita desired use custom=
	0
	~	Dmnl [0,1,1]
	~		|

initial nonrenewable resources=
