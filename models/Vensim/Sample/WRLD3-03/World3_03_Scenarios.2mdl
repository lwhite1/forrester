	|

land yield technology change rate multiplier 1=
	land yield technology change rate multiplier table 1 ( desired food ratio 
	                  - food ratio )
	~	1/year
	~	  Land yield from technology change multiplier
		         (LYCM#--)
	|

land yield technology change rate multiplier 2=
	land yield technology change rate multiplier table 2 ( desired food ratio 
	                  - food ratio )
	~	1/year
	~	  Land yield from technology change multiplier
		         (LYCM#--)
	|

land yield technology change rate multiplier table 1  ( 
            (0,0),(1,0) )
	~	1/year
	~	  Table relating the food ratio gap to the change in
		         agricultural technology (LYCMT#--).
	|

land yield technology change rate multiplier table 2(
	[(0,0)-(1,0.2)],(0,0),(1,0.04))
	~	1/year
	~	  Table relating the food ratio gap to the change in
		         agricultural technology (LYCMT#--).\!\!\!
	|

industrial output per capita desired s=
	IF THEN ELSE ( scenario = 0 :OR: industrial output per capita desired use custom = 1\
		 ,
	   industrial output per capita desired ,
	   industrial output per capita desired scenario table ( scenario ) )
	~	$/(Person*year)
	~	  Industrial output per capita desired (IOPCD#59.2).
	|

industrial output per capita desired scenario table(
	[(0,0)-(10,1000)],(7,400),(8,350))
	~	$/(Person*year)
