{UTF-8}
{UTF-8}

Accounts Receivable = INTEG(billings-cash receipts-losses,billings /

            (1/average payable delay + fractional loss rate))
	~	$
	~		|

average payable delay = 0.09
	~	Year
	~		|

Awaiting Billing = INTEG(price * production-billings,price * production * billing processing time\
		)
	~	$
	~		|

billing processing time = 0.04
	~	Year
	~		|

billings = Awaiting Billing/billing processing time
	~	$/Year
	~		|

Book Value = INTEG(new investment-tax depreciation,0)
	~	$
	~		|

borrowing = new investment * debt financing fraction
	~	$/Year
	~		|

capacity cost = 0.5
	~	$*Year/Gadget
	~		|

CAPACITY COST MAX = 0.6
	~	Gadget/Year
	~		~	:SUPPLEMENTARY 
	|

CAPACITY COST MIN = 0.4
	~	Gadget/Year
	~		~	:SUPPLEMENTARY 
	|

cash receipts = Accounts Receivable/average payable delay
	~	$/Year
	~		|

Debt = INTEG(borrowing-principal repayment,0)
	~	$
	~		|

debt financing fraction = 0.6
	~	Dmnl
	~		|

debt retirement time = 3
	~	Year
	~		|

direct costs = production * variable production cost
	~	$/Year
	~		|

discount rate = 0.12
	~	1/Year
	~		|

FINAL TIME  = 5
	~	Year
	~	      The final time for the simulation.
	|

fractional loss rate = 0.06
	~	1/Year
	~		|

gross income = billings
	~	$/Year
	~		|

initial potential customers = 1e+07
	~	Person
	~		|

variable production cost = 0.6
	~	$/Widget
	~		|

interest payments = Debt * interest rate
	~	$/Year
	~		|

interest rate = 0.12
	~	1/Year
	~		|

losses = Accounts Receivable * fractional loss rate
	~	$/Year
	~		|

net cash flow = cash receipts + borrowing - new investment - 

                              direct costs - interest payments - 

                              principal repayment - taxes
	~	$/Year
	~		|

net income = taxable income - taxes
	~	$/Year
	~		|

new investment = investment * capacity cost
	~	$/Year
	~		|

npv cash flow = NPV(net cash flow,discount rate,0,1)
	~	$
	~		~	:SUPPLEMENTARY 
	|

npv income = NPV(net income,discount rate,0,1)
	~	$
	~		~	:SUPPLEMENTARY 
	|

price = 1
	~	$/Widget
	~		|

PRICE MAX = 1.2
	~	$/Widget
	~		~	:SUPPLEMENTARY 
	|

PRICE MIN = 0.9
	~	$/Widget
	~		~	:SUPPLEMENTARY 
	|

principal repayment = Debt/debt retirement time
	~	$/Year
	~		|

SALES FRACTION MAX = 0.006
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

SALES FRACTION MIN = 0.004
	~	Dmnl
	~		~	:SUPPLEMENTARY 
	|

taxes = taxable income * tax rate
	~	$/Year
	~		|

tax depreciation = Book Value/tax depreciation time
	~	$/Year
	~		|

tax depreciation time = 2
	~	Year
	~		|

tax rate = 0.4
	~	Dmnl
	~		|

taxable income = gross income - direct costs - losses - interest payments - tax depreciation
	~	$/Year
	~		|

VARIABLE PRODUCTION COST MIN = 0.5
	~	$/Widget
	~		~	:SUPPLEMENTARY 
	|

VARIABLE PRODUCTION COST MAX = 0.7
	~	$/Widget
	~		~	:SUPPLEMENTARY 
	|

INITIAL TIME  = 0
	~	Year
	~	      The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year
	~	      The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year
	~	      The time step for the simulation.
	|

********************************************************
	.Customer
********************************************************~
		  Equations detailing the customer behavior.
	|

Potential Customers = INTEG(-committals,initial potential customers)
	~	Person
	~		|

average life of product = 2
	~	Year
	~		|

committals = customer with non customer contacts * sales fraction
	~	Person/Year
	~		|

completions = new shipments/product per customer
	~	Person/Year
	~		|

contact rate = 500
	~	1/Year
	~		|

customer prevalence = Customers/total market
	~	Dmnl
	~		|

customer with non customer contacts = non customer contacts *
                       customer prevalence
	~	Person/Year
	~		|

Customers = INTEG(completions,initial customers)
	~	Person
	~		|

initial customers = 100000
	~	Person
	~		|

New Backlog = INTEG(new orders-new shipments,
                    new orders*normal delivery delay)
	~	Gadget
	~		|

new orders = committals * product per customer
	~	Gadget/Year
	~		|

new shipments = total shipments * New Backlog/
         total backlog
	~	Gadget/Year
	~		|

non customer contacts = Potential Customers * contact rate
	~	Person/Year
	~		|

normal delivery delay = 0.125
	~	Year
	~		|

Product In Use = INTEG(new shipments+replacement shipments-
                 replacement orders,Customers*product per customer)
	~	Gadget
	~		|

product per customer = 1
	~	Gadget/Person
	~		|

Replacement Backlog = INTEG(replacement orders-replacement shipments,
                      replacement orders*normal delivery delay)
	~	Gadget
	~		|

replacement orders = 
     Product In Use/average life of product
	~	Gadget/Year
	~		|

replacement shipments = total shipments *Replacement Backlog/
         total backlog
	~	Gadget/Year
	~		|

sales fraction = 0.005
	~	Dmnl
	~		|

total backlog = New Backlog + Replacement Backlog
	~	Gadget
	~		|

total market= ACTIVE INITIAL (
	Potential Customers +Waiting Customers + Customers,
		 Potential Customers)
	~	Person
	~		|

total shipments = production
	~	Gadget/Year
	~		|

********************************************************
	.Producer
********************************************************~
		 Production sector.
	|

orders received =total orders
	~	Gadget/Year
	~		|

Average Orders = INTEG((orders received-Average Orders)/time to average orders,orders received
     )
	~	Gadget/Year
	~		|

Backlog = INTEG(orders received-production,desired backlog  )
	~	Gadget
	~		|

backlog correction = (Backlog-desired backlog)/time to correct backlog
	~	Gadget/Year
	~		|

Capacity = INTEG(investment-reductions,
    desired capacity )
	~	Gadget/Year
	~		|

capacity adjustment = (desired capacity - Capacity)/time to adjust capacity
	~	Gadget/Year/Year
	~		|

capacity life = 2
	~	Year
	~		|

delivery delay = Backlog/production
	~	Year
	~		~	:SUPPLEMENTARY 
	|

desired backlog = Average Orders* target delivery delay
	~	Gadget
	~		|

desired capacity = desired production
	~	Gadget/Year
	~		|

desired production = Average Orders + backlog correction
	~	Gadget/Year
	~		|

investment = capacity adjustment + replacement investment
	~	Gadget/Year/Year
	~		|

potential production = Capacity
	~	Gadget/Year
	~		|

production = MIN(desired production,potential production)
	~	Gadget/Year
	~		|

reductions = Capacity/capacity life
	~	Gadget/(Year*Year)
	~		|

replacement investment = reductions
	~	Gadget/Year/Year
	~		|

target delivery delay = 0.125
	~	Year
	~		|

time to average orders = 0.25
	~	Year
	~		|

time to adjust capacity = 1
	~	Year
	~		|

time to correct backlog = 0.5
	~	Year
	~		|

total orders = new orders + replacement orders
	~	Gadget/Year
	~		|

Waiting Customers = INTEG(committals-completions,New Backlog/product per customer)
	~	Person
	~		|

