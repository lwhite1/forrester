{UTF-8}
{UTF-8}

new customers=
	shipments / products per customer
	~	Person/Week
	~		|

new people ready to order=
	Customers * normal effective referral fraction
	~	Person/Week
	~		|

orders=
	new people ready to order * effect of delivery delay on orders 
	* products per customer
	~	Machine/Week
	~		|

Customers= INTEG (
	new customers,
		100)
	~	Person
	~		|

products per customer=
	1
	~	Machine/Person
	~		|

Backlog= INTEG (
	orders-shipments,
		10)
	~	Machine
	~		|

capacity=
	1000
	~	Machine/Week
	~		|

delivery delay=
	Backlog/shipments
	~	Week
	~		|

effect of delivery delay on orders=
	effect of delivery delay on orders lookup(delivery delay/normal delivery delay)
	~	Dmnl
	~		|

effect of delivery delay on orders lookup(
	[(0,0)-(10,2)],(0,2)
	,(0.4,1.4),(1,1),(2.5,0.6),(5,0.3),(10,0))
	~	Dmnl
	~		|

minimum cycle time=
	1
	~	Week
	~		|

normal delivery delay=
	2
	~	Week
	~		|

normal effective referral fraction=
	0.1
	~	fraction/Week
	~		|

shipments=
	MIN(Backlog/minimum cycle time, capacity)
	~	Machine/Week
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 208
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Week
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.5
	~	Week
	~	The time step for the simulation.
	|

