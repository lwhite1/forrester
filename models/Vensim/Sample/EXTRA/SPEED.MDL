{UTF-8}

acceleration = (target speed-Speed)/time to adjust speed
	~	Miles/Hour/Second
	~		|

FINAL TIME  = 60
	~	Second
	~	 The final time for the simulation.
	|

initial speed = 0
	~	Miles/Hour
	~		|

INITIAL TIME  = 0
	~	Second
	~	 The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Second
	~	 The frequency with which output is stored.
	|

Speed = INTEG(acceleration,initial speed)
	~	Miles/Hour
	~		|

target speed = 55
	~	Miles/Hour
	~		|

TIME STEP  = 0.5
	~	Second
	~	 The time step for the simulation.
	|

time to adjust speed = 10
	~	Second
	~		|

