{UTF-8}
Delivery Delay Recognized= INTEG (
	(delivery delay impending - Delivery Delay Recognized) 
	          / time for delivery delay recognition,
		 2)
	~	Month
	~		|

normal backlog = 8000
	~	unit
	~		|

normal delivery delay recognized = 2
	~	Month
	~		|

normal delivery rate = 4000
	~	unit/Month
	~		|

normal sales effectivness = 350
	~	unit/(Month*person)
	~		|

delivery rate = normal delivery rate * effect of backlog on delivery rate
	~	unit/Month
	~		|

effect of backlog on delivery rate = effect of backlog on delivery rate lookup(
Backlog/normal backlog
)
	~	dmnl
	~		|

effect of delivery delay recognized = effect of delivery delay recognized lookup
                                          (Delivery Delay Recognized/normal delivery delay recognized
)
	~	dmnl
	~		|

sales effectiveness = normal sales effectivness * effect of delivery delay recognized
	~	unit/(person*Month)
	~		|

effect of backlog on delivery rate lookup                ([(0.8,0)-(20,8)],
(0.9,0),(1,1),(1.7,3.5),(2.3,4.3),(3.5,5),(6.3,5.6),(10,6),(20,6.5)
 )
	~	dmnl
	~		|

effect of delivery delay recognized lookup        ([(0,0)-(3,2)],
(0,1.15),(0.5,1.1),(1,1),(1.5,0.75),(2,0.5),(2.5,0.35),(3,0.3)
 )
	~	dmnl
	~		|

Backlog = INTEG(orders entered - orders completed, 8000)
	~	unit
	~		|

budget = orders booked * revenue to sales
	~	dollars/Month
	~		|

delivery delay impending = Backlog / delivery rate
	~	Month
	~		|

indicated sales force = budget / sales person salary
	~	person
	~		|

net hires = (indicated sales force - Sales Force) / sales force adjustment time
	~	person/Month
	~		|

orders booked = Sales Force * sales effectiveness
	~	unit/Month
	~		|

orders completed = delivery rate
	~	unit/Month
	~		|

orders entered = orders booked
	~	unit/Month
	~		|

revenue to sales = 10
	~	dollars/unit
	~		|

sales force adjustment time = 20
	~	Month
	~		|

sales person salary = 2000
	~	dollars/(person*Month)
	~		|

Sales Force = INTEG(net hires, 10)
	~	person
	~		|

time for delivery delay recognition = 5
	~	Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Month
	~	The time step for the simulation.
	|

