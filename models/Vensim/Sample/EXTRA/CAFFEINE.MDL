{UTF-8}
{UTF-8}

Body's Expected Caffeine = INTEG((Caffeine in Body - Body's Expected Caffeine) /
                          caffeine tolerance time, Caffeine in Body)
	~	Mg
	~		|

caffeine consumption = normal caffeine consumption * 
                      effect of drowsiness on caffeine consumption lookup(drowsiness/
		normal amount of drowsiness)
	~	Mg/Day
	~		|

caffeine disposal = Caffeine in Body/caffeine disposal time
	~	Mg/Day
	~		|

caffeine disposal time = 0.25
	~	Day
	~		|

Caffeine in Body = INTEG(caffeine consumption - caffeine disposal,
                           normal caffeine consumption*caffeine disposal time)
	~	Mg
	~		|

caffeine tolerance time = 5
	~	Day
	~		|

drowsiness = normal amount of drowsiness* XIDZ(Body's Expected Caffeine,
                   Caffeine in Body,10) * effect of stress on drowsiness
	~	Yawn/Hour
	~		|

effect of drowsiness on caffeine consumption lookup(
	[(0,0)-(10,20)],
	(0,0.01),(1,1),(2,7),(3,9.2),(4,9.9),(5,10),(10,10.0033))
	~	Dmnl
	~		|

effect of stress on drowsiness=
	  1 + STEP(0.2,10)
	~	Dmnl
	~		|

FINAL TIME  = 50
	~	Day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Day
	~	The initial time for the simulation.
	|

normal caffeine consumption=
	 100
	~	Mg/Day
	~		|

normal amount of drowsiness = 1
	~	Yawn/Hour
	~		|

SAVEPER  = 
        TIME STEP
	~	Day
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Day
	~	The time step for the simulation.
	|

