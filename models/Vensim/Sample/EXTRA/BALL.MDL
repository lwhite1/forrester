{UTF-8}
acceleration = g + compression acceleration
	~	Feet/Second/Second
	~		|

ball diameter = 0.25
	~	Feet
	~		|

big time step = 0.0625
	~	Second
	~		|

compression acceleration = IF THEN ELSE(Position <= ball diameter,
        (ball diameter-Position)*stiffness constant,0)
	~	Feet/Second/Second
	~		|

could be position = IF THEN ELSE(Velocity>0,Position,
        Position+Velocity*big time step)
	~	Feet
	~		|

g = -32
	~	Feet/(Second*Second)
	~	Negative because up is positive.
	|

little time step =    0.000488281
	~	Second
	~		|

Position = INTEG(Velocity,30)
	~	Feet
	~		|

stiffness constant = 200000
	~	1/Second/Second
	~		|

Velocity = INTEG(acceleration,0)
	~	Feet/Second
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

TIME STEP=
	 IF THEN ELSE(could be position <= ball diameter , little time step,big time step)
	~	Second
	~	The time step for the simulation.
	|

FINAL TIME  = 20
	~	Second
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Second
	~	The initial time for the simulation.
	|

SAVEPER  = 0.125
	~	Second
	~	The frequency with which output is stored.
	|

