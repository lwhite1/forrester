{UTF-8}
{UTF-8}

average fox life=
	 4
	~	Year
	~		|

average rabbit life=
	 2
	~	Year
	~		|

carrying capacity=
	 500
	~	Rabbit
	~		|

effect of crowding on deaths lookup(
	[(0,0)-(10,20)],(0,0.75)
	,(3,2.5),(6,6),(8,11),(10,20))
	~	Dmnl
	~		|

FINAL TIME  = 50
	~	Year
	~	  The final time for the simulation.
	|

fox birth rate = 0.25
	~	1/Year [0,2]
	~		|

fox births = Fox Population * fox birth rate
	~	Fox/Year
	~		|

fox deaths = Fox Population / average fox life *
                    fox mortality lookup(fox food availability)
	~	Fox/Year
	~		|

fox food availability = fox consumption of rabbits/(Fox Population * fox food requirements
)
	~	Dmnl
	~	 A lookup table showing the relationship between the input (crowding) along the x 														\
		axis and the
		         output
		         (the effect that crowding has on the death rate) along the y-axis.
	|

fox food requirements = 25
	~	Rabbit/Year/Fox
	~		|

fox mortality lookup(
	[(0,0)-(2,20)],(0,20),(0.3,5),(0.5,2),
	(1,1),(2,0.5))
	~	Dmnl
	~		|

Fox Population = INTEG(fox births-fox deaths,initial fox population)
	~	Fox
	~		|

fox consumption of rabbits = Fox Population * fox food requirements *
                     fox rabbit consumption lookup(rabbit crowding)
	~	Rabbit/Year
	~		|

fox rabbit consumption lookup   ([(0,0)-(6,6)],(0,0),(1,1),(2,2),
(6,2) )
	~	Dmnl
	~	 Relating rabbits to foxes
	|

initial fox population=
	 30
	~	Fox
	~		|

initial rabbit population=
	 500
	~	Rabbit
	~		|

INITIAL TIME  = 0
	~	Year
	~	  The initial time for the simulation.
	|

rabbit birth rate=
	 2
	~	1/Year
	~		|

rabbit births = Rabbit Population * rabbit birth rate
	~	Rabbit/Year
	~		|

rabbit crowding = Rabbit Population/carrying capacity
	~	Dmnl
	~		|

rabbit deaths = MAX(Rabbit Population / average rabbit life *
                   effect of crowding on deaths lookup(rabbit crowding),
                   fox consumption of rabbits)
	~	Rabbit/Year
	~		|

Rabbit Population = INTEG(rabbit births-rabbit deaths,initial rabbit population)
	~	Rabbit
	~		|

SAVEPER  = TIME STEP
	~	Year
	~	  The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Year
	~	  The time step for the simulation.
	|

