{UTF-8}

FINAL TIME  = 10
	~	Minute
	~	The final time for the simulation.
	|

initial snowball size = 0.25
	~	Kg
	~		|

INITIAL TIME  = 0
	~	Minute
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Minute
	~	The frequency with which output is stored.
	|

snowball growth = Snowball Size * stickiness of snow
	~	Kg/Minute
	~		|

Snowball Size = INTEG(snowball growth,initial snowball size)
	~	Kg
	~		|

stickiness of snow = 1
	~	1/Minute
	~	The amount of snow that sticks to a given amount of snow in a minute.
	|

TIME STEP  = 0.25
	~	Minute
	~	The time step for the simulation.
	|

