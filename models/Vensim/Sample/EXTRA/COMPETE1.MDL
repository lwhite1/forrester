{UTF-8}
average life of goods = 8
	~	Month
	~		|

Average Markup = INTEG((markup-Average Markup)/time for average markup,target markup)
	~	Dmnl
	~		|

cost = fixed cost + sales * marginal cost
	~	$/Month
	~		|

discards = Stock of Goods/average life of goods
	~	Pair/Month
	~		|

effect price target = effect price target lookup(Price/reference price)
	~	Dmnl
	~		|

effect price target lookup ([(0,0)-(4,6)],(0.2,5),(0.5,2),(1,1)
,(2,0.5),(4,0.02) )
	~	Dmnl
	~		|

FINAL TIME  = 60
	~	Month
	~	 The final time for the simulation.
	|

fixed cost = 500000
	~	$/Month
	~		|

initial price = 1
	~	$/Pair
	~		|

INITIAL TIME  = 0
	~	Month
	~	 The initial time for the simulation.
	|

marginal cost = 0.5
	~	$/Pair
	~		|

markup = revenue/cost
	~	Dmnl
	~		|

normal target = 2.4e+007
	~	Pair
	~		|

Price = INTEG(price change,initial price)
	~	$/Pair
	~		|

price change = (target price - Price)/time to adjust price
	~	$/Pair/Month
	~		|

purchases = MAX(0,
          discards + (target stock of goods - Stock of Goods)/time to adjust goods)
	~	Pair/Month
	~		|

reference price = 1
	~	$/Pair
	~		|

revenue = sales*Price
	~	$/Month
	~		|

sales = purchases
	~	Pair/Month
	~		|

SAVEPER  = 
        TIME STEP
	~	Month
	~	 The frequency with which output is stored.
	|

Stock of Goods = INTEG(purchases-discards,target stock of goods)
	~	Pair
	~		|

target markup = 1.5
	~	Dmnl
	~		|

target price = Price * target markup/Average Markup
	~	$/Pair
	~		|

target stock of goods = normal target * effect price target
	~	Pair
	~		|

time to adjust goods = 5
	~	Month
	~		|

time for average markup = 4
	~	Month
	~		|

TIME STEP  = 0.25
	~	Month
	~	 The time step for the simulation.
	|

time to adjust price = 3
	~	Month
	~		|

