{UTF-8}
{UTF-8}

normal consumption= INITIAL(
	 slaughtering / population)
	~	hogs/(Month*person)
	~		|

acquiring breeding stock = if then else ( desired breeding stock > Breeding Stock , if then else
 ( Mature Stock
                  > TIME STEP * ( desired breeding stock - Breeding Stock ) / breeding stock acquisition delay
                            , ( desired breeding stock - Breeding Stock ) / breeding stock acquisition delay
                       , Mature Stock / TIME STEP ) , ( desired breeding stock - Breeding Stock
 ) / 
                  breeding stock acquisition delay )
	~	hogs/Month
	~		 Net rate at which sows and gilts are either acquired for breeding or returned to 				\
		mature
		        stock for slaughtering. A positive rate indicates more sows and gilts are 				\
		being acquired
		        for breeding than are being returned to feeding pens for slaughter. A 				\
		negative number
		        indicates more are being returned for slaughter than are being added to the 				\
		breeding
		        stock. Note: The basic policy is (Desired Breeding Stock-Breeding 				\
		Stock)/Breeding Stock
		         Acquisition Delay. The complication keeps the level of mature 				\
		hogs from going negative.
	|

breeding = Breeding Stock * fertility
	~	hogs/Month
	~		 Rate at which pigs are created in utero. This rate is net of any pigs that do not 				\
		survive to
		         maturity.
	|

Breeding Stock = INTEG( acquiring breeding stock , desired breeding stock )
	~	hogs
	~		 Sows and gilts held for breeding.
	|

breeding stock acquisition delay = 5
	~	months
	~		 Dealy for farmers to adjust their breeding stocks to desired levels. Source: 				\
		Meadows' Hog
		         Cycle model (BSAD)
	|

consuming = if then else ( Inventory + slaughtering * TIME STEP > Per Capita Consumption
 * population
                       * TIME STEP , Per Capita Consumption * population , Inventory 
/ TIME STEP )
	~	hog/Month
	~		 National consumption of pork
	|

coverage effect on price = coverage effect on price func ( relative coverage )
	~	dmnl
	~		 Effect that surplus or deficient pork inventories have on the price of 				\
		live hogs.
	|

coverage effect on price func ( [(0,0)-(2,2.12)],(0,2.12),(0.25,1.61),(0.5,1.32),(0.75
,1.13),(1,1),(
1.25,0.79)
            ,(1.5,0.58),(1.75,0.33),(2,0.100421) )
	~	dmnl
	~		 Functional relationship between pork relative pork inventory coverage and its 				\
		effect on the
		        price of live-hogs. Source: Meadows (HPTAB). Normalized around 16.5, the 				\
		coverage effect
		        for a relative coverage of 1. Meadow's table goes to 0 at rcov=2; the above 				\
		table does
		         not.
	|

desired breeding stock=
	GAME( normal breeding stock * price effect on breeding stock )
	~	hogs
	~		 Number of sows and gilts farmers would like to have for breeding.
	|

desired coverage = 0.36
	~	months
	~		 Desired months of pork inventory. Source: Meadows (DCOV)
	|

effect of price on consumption = effect of price on consumption func ( relative hog price
 )
	~	dmnl
	~		 Impact of retail price on national consumption of pork.
	|

effect of price on consumption func ( [(0.67,0.74)-(1.33,1.28)],(0.67,1.28),(1,1),(1.33
,0.74) )
	~	dmnl
	~		 Functional relationship between relative price of pork and its impact on per capita
		        consumption. Source: Meadows PCCP. We have assumed the "Normal" retail price 				\
		is 60, and
		         so the normal consumption per capita is 5/person/month
	|

expected corn price = 1.14
	~	$/bushel
	~		 Farmers' expected price of corn. Source: Meadows (FECCP)
	|

Expected Hog Price = SMOOTHI ( hog price , time to form price expectations , normal hog price
 )
	~	$/hog
	~		 The price farmers expect to receive for live hogs.
	|

farrowing = Piglets In Utero / gestation time
	~	hogs/Month
	~		 Hog birth rate.
	|

fertility = 0.83
	~	hogs/(Month*hog)
	~		 The fertility of hogs after accounting for hogs lost at birth, weaning or 				\
		elswewhere before
		        slaughter or breeding. Source: Meadows: Litters per hog * pigs saved per 				\
		litter * weaning
		         survival factor =LPHM*PSPL*WSF = .17*7 *.7=0.83
	|

FINAL TIME  = 100
	~	Month
	~		 The final time for the simulation.
	|

gestation time = 3.7
	~	months
	~		 Average pregnancy period for hogs. Source: Meadows, figure 5-14
	|

hog corn price ratio = Expected Hog Price / expected corn price
	~	bushel/hog
	~		 The ratio of the price of a hog to the price of a bushel of corn. The "exchange 				\
		rate" of a
		         hog in terms of bushels of corn.
	|

hog dressing yield = 0.58
	~	fraction
	~		 Fraction of each hog that is not discarded as waste during dressing. 				\
		Source: Meadows (DY)
	|

hog price = normal hog price * coverage effect on price
	~	$/hog
	~		 The price farmers receive for live hogs.
	|

indicated per capita consumption=
	 ( normal consumption * effect of price on consumption
	 ) * input
	~	hogs/(Month*person)
	~		 Per capita consumption that would hold if the retail price had worked its way 				\
		through the
		         system, and if people had had time to completely react to it.
	|

INITIAL TIME  = 0
	~	Month
	~		 The initial time for the simulation.
	|

input=
	 ( 1 + STEP ( 0.1, 0) )
	~	dmnl
	~		 Test input that disturbs the system from an initial equilibrium. The test input is 				\
		designed
		        to elicit the inherent dynamics of the system. The test input does not 				\
		represent an
		         historical event.
	|

Inventory = INTEG( - consuming + slaughtering , normal consumption * population * desired coverage
 )
	~	hogs
	~		 Inventory of frozen and cured pork.
	|

inventory coverage = Inventory / consuming
	~	Month
	~		 Months of inventory at the current consumption rate
	|

live weight of slaughtered hogs = 240
	~	lbs/hog
	~		 Weight of fully mature hogs, ready for slaughter. Source: Meadows (LWSH)
	|

marketing margin = 30
	~	$/hog
	~		 Marketing Margin in Meadows is $28/100 lbs. A hog is 240 lbs, and the dressing 				\
		yield in .58.
		        So the margin is $39/hog. However, this leads to unstable (or undamped) 				\
		oscillations,
		        because of the delay in consumption (which is not in the original model) so 				\
		we go with
		         $30/hog.
	|

Mature Stock = INTEG( - acquiring breeding stock - slaughtering + maturing , mature stock feeding period
             * maturing )
	~	hogs
	~		 "Hogs in the terminal stage of feeding and preparation either for slaughter or for 				\
		addition
		         to the breeding stock." (Meadows, p.54).
	|

mature stock feeding period = 2
	~	months
	~		 Average time hogs are held (and fed) after becoming mature. Source: 				\
		Meadows, figure 5-14.
	|

maturing = Piglets / time to mature
	~	hogs/Month
	~		 Rate at which piglets becoming mature hogs.
	|

normal breeding stock = 9e+06
	~	hogs
	~		 The normal number of sows and gilts held for breeding. This is the equilibrium 				\
		quantity,
		        given the normal hog/corn price ratio. Source: Meadows (BSTAB). Note: the 				\
		normal hog
		         dcorn price ratio is about 20 bushels per hog.
	|

normal hog corn price ratio = normal hog price / expected corn price
	~	bushel/hog
	~		 The equilibrium hog corn price ratio.
	|

normal hog price = normal price per pounds * live weight of slaughtered hogs * hog dressing yield
	~	$/hog
	~		 The initial normal hog price.
	|

normal price per pounds = 0.165
	~	$/lbs
	~		 The initial normal price per pound of live hogs. Source: From meadows HPTAB, this 				\
		is the
		         price per lbs when RCOV = 1. (In Meadows, the price is 16.5 per 				\
		hundred pound.
	|

normal retail price = normal hog price + marketing margin
	~	$/hog
	~		 The initial normal retail price of pork.
	|

Per Capita Consumption = SMOOTHI ( indicated per capita consumption , time to change consumption
 , 
             normal consumption )
	~	hogs/(Month*person)
	~		 Pork consumption per person per month in the U.S.
	|

Piglets = INTEG( farrowing - maturing , time to mature * farrowing )
	~	hogs
	~		 Immature hogs.
	|

Piglets In Utero = INTEG( breeding - farrowing , breeding * gestation time )
	~	hogs
	~		 Pig fetuses that will survive birth and weening.
	|

population = 2e+08
	~	people
	~		 U.S. population. Source: Meadows (POP)
	|

price effect on breeding stock = price effect on breeding stock function ( Relative Hog Corn Ratio
 )
	~	dmnl
	~		 Impact of relative hog/corn price ratio on desired breeding stock. As the relative 				\
		hog/corn
		        price ratio increases, farmers desire to increase their production, and 				\
		hence to increase
		         breeding stock.
	|

price effect on breeding stock function ( [(0.5,0.55)-(1.25,1.18)],(0.5,0.55),(0.75,0.78\
		)
,(1,1),(1.25,1.18
)
            )
	~	dmnl
	~		 Functional relationship between relative Hog/Corn price ratio and its impact on 				\
		desired
		        breeding stock. Source: Meadows(BSTAB). We have normalized in the following 				\
		way. The
		        normal expected hog corn ratio is about 20 bushels/hog. The normal breeding 				\
		stock (from
		         the table, then, is about 9 million hogs.
	|

relative coverage = inventory coverage / desired coverage
	~	fraction
	~		 Months of pork inventory, relative to desired.
	|

Relative Hog Corn Ratio = hog corn price ratio / normal hog corn price ratio
	~	dimensionless
	~		 The hog corn price ratio relative to normal
	|

relative hog price = retail price / normal retail price
	~	fraction
	~		 Retail price of pork, relative to normal retail price
	|

retail price = hog price + marketing margin
	~	$/hog
	~		 Retail price of pork.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~		 The frequency with which output is stored.
	|

slaughtering = Mature Stock / mature stock feeding period
	~	hogs/Month
	~		 Hog slaughter rate.
	|

TIME STEP  = 1
	~	Month
	~		 The time step for the simulation.
	|

time to change consumption = 0.5
	~	months
	~		 Average for pork consumption to react to a change in price. Represents perception 				\
		and
		        reaction delays, as well as the time it takes for a wholesale price increase 				\
		to work its
		        way through the system. This constant does not appear in Meadows. Source: 				\
		LeapTec
		         estimate.
	|

time to form price expectations = 6
	~	months
	~		 Average time for farmers to adjust their expectations to a change in the level of 				\
		live-hog
		         prices. Source: Meadows (FEHPAD)
	|

time to mature = 5
	~	months
	~		 Average time for a pig to reach maturity. The average period from Farrowing to 				\
		Maturity.
		        Includes time from Farrowing to Weaning (2 months), Weaning to First Heat (1 				\
		month), and
		         from First Heat to Maturity (2 months). Source: Meadows, figure 				\
		5-14.
	|

