{UTF-8}
********************************************************
	.procrast
********************************************************~
		 A Little procrastion model (It's the model that is little, the
		         procrastination can be large).
	|

correct thinking rate=
	intensity effort applied
	             * fraction thinking correct
	~	Bytes / Day
	~	 The rate at which in formation is thought about and correctly interpreted.
	|

thinking error rate=
	intensity effort applied
	             * ( 1
	                  - fraction thinking correct )
	~	Bytes / Day
	~	  The rate at which errors are being made in the review of information.
	|

intensity effort applied  = IF THEN ELSE(Decision is Made,0,
        indicated intensity of effort applied)
	~	Bytes / Day
	~	 The intensity with which the problem is attacked by the decision maker.
	|

Decision is Made = INTEG(
      IF THEN ELSE(perc info req thought < min threshold delay,1/TIME STEP,0),0)
	~	Dmnl
	~	An indication that the decision has been made.
	|

effect of tension on frac correct  =
        effect tension on frac correct lookup ( tension/normal tension )
	~	Dimensionless
	~	 The effect of tension on the fraction of the thinking that is
		        done correctly.
	|

indicated intensity of effort applied  = INITIAL(perc info req thought/Expected Decision Time
)
	~	Bytes / Day
	~	The  intensity with which a problem of the specified importance is 		\
		attacked by the decision maker.
	|

eff importance tension = 1
	~	Dimensionless
	~	 The effect of the importance of a decision on the tension that
		         decision generates.
	|

tension  = IF THEN ELSE(Decision is Made,0,
        normal tension
             * eff importance tension
             * eff time remaining tension)
	~	Tension units
	~	 The tension that the decision maker is under.
	|

eff time remaining tension  =
        eff time remaining tension lookup ( time remaining/Expected Decision Time )
	~	Dimensionless
	~	 The effect of time remaining on the tension felt by the decision maker.
	|

Expected Decision Time = 15
	~	Day
	~	The time expected to make a decision before any of the thinking takes 		\
		place.
	|

FINAL TIME  = 100
	~	days
	~	 The final time for the simulation.
	|

INITIAL TIME  = 0
	~	days
	~	 The time at which the simulation is started
	|

initial info proc  = 0
	~	Bytes
	~	 The intial amount of information that has actually been processed
		        (thought about).
	|

min threshold delay  = 1
	~	Bytes
	~	 The minimum threshold in terms of information that remains to be thought
		        about warranting further delay.
	|

SAVEPER  = 0.5
	~	days
	~	 The frequency with which variable are stored for later review.
	|

TIME STEP  = 0.25
	~	days
	~	 The solution interval for integrating the model.
	|

Time to detect errors  = 2
	~	days
	~	 The time to detect errors that have occured in the processing of
		        information.
	|

disc info req rethink  =
        Info Requiring Rethinking
             / Time to detect errors
	~	Bytes/Day
	~	 The discovery of information that has been misinterpreted and therefore
		        requires rethinking.
	|

perc info req thought  =
        tot info req thought
             - info perceived reviewed
	~	Bytes
	~	 The percieved amount of information that remains to be though about.
	|

Thought Accomplished  =  INTEG( correct thinking rate  ,   initial info proc )
	~	Bytes
	~	 Information that has been reviewed and correctly interpretted.
	|

info perceived reviewed  =
        Thought Accomplished
             + Info Requiring Rethinking
	~	Bytes
	~	 The amount of information that it is perceived has been correctly
		        reviewed.
	|

Info Requiring Rethinking  =
        INTEG( thinking error rate  - disc info req rethink ,
             initial info proc  * ( 1 - norm frac thinking correct ) )
	~	Bytes
	~	 The amount of information that has been interpreted incorrectly,
		       but for which that error has not yet been discovered.
	|

fraction thinking correct  =
        norm frac thinking correct
             * effect of tension on frac correct
	~	Fraction
	~	 The fraction of thinking that is done correctly.
	|

norm frac thinking correct  = 0.8
	~	Fraction
	~	 The fraction of information that is normally processed without error
		        or misinterpretation.
	|

normal tension  = 10
	~	Tension units
	~	 The normal amount of tension that a decision of this importance would
		        bring about.
	|

effect tension on frac correct lookup ([(0,0)-(20,2)],(0,1.2),(2.5,1.1)
,(5,0.9),(7.5,0.6),(10,0.2),(11,0.12),(12.5,0.08),(20,0.05) )
	~	Dimensionless
	~	 Table for the effect of tension on the fraction of thinking that
		        is done correctly.
	|

eff time remaining tension lookup     ([(0,0)-(10,4)],(0,3),(0.1,2)
,(0.2,1.5),(0.3,1.25),(0.4,1.1),(0.5,1),(0.6,0.95),(0.7,0.925)
,(0.8,0.9),(0.9,0.9),(10,0.9),(10,0.9) )
	~	Dimensionless
	~	 Table for the effect of time remaining on tension.
	|

time remaining  = max(0,ZIDZ(perc info req thought -  min threshold delay,
             intensity effort applied))
	~	days
	~	 Time remaining required to make the decision - given no external
		        deadlines.
	|

tot info req thought  = 10
	~	Bytes
	~	 The size of the decision.
	|

