{UTF-8}
{UTF-8}

average lifetime=
	60
	~	Year
	~		|

age :(age 0-age 69)
	~	
	~		|

ageh : (age 1-age 69)
	~	
	~		|

sex : Male,Female
	~	
	~		|

ag65 : (age 65 - age 69)
	~	
	~		|

ag60 : (age 60 - age 64)
	~	
	~		|

ag55 : (age 55 - age 59)
	~	
	~		|

ag50 : (age 50 - age 54)
	~	
	~		|

ag45 : (age 45 - age 49)
	~	
	~		|

ag40 : (age 40 - age 44)
	~	
	~		|

ag35 : (age 35 - age 39)
	~	
	~		|

ag30 : (age 30 - age 34)
	~	
	~		|

ag25 : (age 25 - age 29)
	~	
	~		|

ag20 : (age 20 - age 24)
	~	
	~		|

ag15 : (age 15 - age 19)
	~	
	~		|

ag10 : (age 10 - age 14)
	~	
	~		|

ag05 : (age 5 - age 9)
	~	
	~		|

ag00 : (age 0 - age 4)
	~	
	~		|

age group :  ag 65,
         ag 60, ag 55, ag 50, ag 45, ag 40, ag 35, ag 30,
        ag 25, ag 20, ag 15, ag 10, ag 5, ag under
	~	
	~		|

Population Group[sex,ag 65] = SUM(Population[sex,ag65!]) ~~|
Population Group[sex,ag 60] = SUM(Population[sex,ag60!]) ~~|
Population Group[sex,ag 55] = SUM(Population[sex,ag55!]) ~~|
Population Group[sex,ag 50] = SUM(Population[sex,ag50!]) ~~|
Population Group[sex,ag 45] = SUM(Population[sex,ag45!]) ~~|
Population Group[sex,ag 40] = SUM(Population[sex,ag40!]) ~~|
Population Group[sex,ag 35] = SUM(Population[sex,ag35!]) ~~|
Population Group[sex,ag 30] = SUM(Population[sex,ag30!]) ~~|
Population Group[sex,ag 25] = SUM(Population[sex,ag25!]) ~~|
Population Group[sex,ag 20] = SUM(Population[sex,ag20!]) ~~|
Population Group[sex,ag 15] = SUM(Population[sex,ag15!]) ~~|
Population Group[sex,ag 10] = SUM(Population[sex,ag10!]) ~~|
Population Group[sex,ag 5] = SUM(Population[sex,ag05!]) ~~|
Population Group[sex,ag under] = SUM(Population[sex,ag00!])
	~	Person
	~		~	:SUPPLEMENTARY 
	|

Population[sex,age 0] = INTEG(births[sex]-deaths[sex,age 0],
                                              init population[sex,age 0]) ~~|
Population[sex,ageh] = INTEG(-deaths[sex,ageh],
                                   init population[sex,ageh])
	~	Person
	~	 Population broken down into one year cohorts.  Note that the cohorts are
		         shifted
		       annually to prevent dispersion of demographic trends.  This is why there is 		\
		no 
			  inflow to anything other than the first cohort.
	|

deaths[sex,age]=
	 Population[sex,age] / average lifetime
	~	Person/Year
	~		|

births[sex] =RANDOM NORMAL(30,60,50,20,0)
	~	Person/Year
	~		|

init population[sex,age 0] = 0 ~~|
init population[Male,ageh] = 200 ~~|
init population[Female,ageh] = 150
	~	Person
	~		|

Population cohort shift[sex] = SHIFT IF TRUE(
		Population[sex,age 0],
   		 MODULO(Time,1) = 0,age 69,0,0)
	~	Person
	~	  Population is shifted from one age cohort to another with this function.  This
		         is
		       a special function that directly modifies levels.  Marked supplementary to 		\
		suppress not 
			  used mesasge.
	~	:SUPPLEMENTARY 
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 1
	~	Year
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year
	~	The time step for the simulation.
	|

