{UTF-8}
{UTF-8}

death rate=
	0.01
	~	fraction/Month
	~		|

birth rate=
	0.03
	~	fraction/Month
	~		|

Population=INTEG(births-deaths,100)
	~	Rabbit
	~		|

births= GAME (
	Population * birth rate)
	~	Rabbit/Month
	~		|

deaths=
	Population* death rate
	~	Rabbit/Month
	~		|

FINAL TIME  = 100
	~	Month
	~	 FINAL TIME
	|

INITIAL TIME  = 0
	~	Month
	~	 The initial time for the simulation.
	|

SAVEPER  = 1
	~	Month
	~	 The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month
	~	 The time step for the simulation.
	|

