{UTF-8}
{UTF-8}

Initial Pt = 12
	~	mmHg
	~		|

********************************************************
	.Mosekilde
********************************************************~
		Erik Mosekilde's model of chaos in rat kidneys. Replicated
		from equations presented in Mosekilde's paper by Tom
		Fiddaman, with help from Bob Eberlein on the use of Vensim's
		SIMULTANEOUS function. While I have been unable to find chaotic
		behavior at the exact parameter values specified in the paper,
		try setting d = 0.10, T_Mac_Dens_Aff_Art_Delay = 10 for a
		chaotic or at least very high periodicity regime.
		
		For chaotic runs, you should extend the final time to 1000 or
		2000 seconds and set the time axis controls so that results
		are plotted only after initial transients have died out - 200
		to 500 seconds.
	|

********************************************************
	.Afferent
********************************************************~
	|

Ra Afferent Arter Resist= INTEG (
	dRa,
		 Ra0)
	~	sec*mmHg/nl
	~		|

Alpha = 9
	~	dmnl
	~		|

Chg dRa=
	-2*d*Omega*(K)^0.5*dRa-Omega*Omega*K*(Ra Afferent Arter Resist-Psi Input*Ra0)
	~	mmHg/nl/sec
	~		|

d = 0.16
	~	dmnl
	~	
		Raising d may increase the amplitude of oscillation!
	|

dRa = INTEG(Chg dRa, 0)
	~	s*mmHg/nl/s
	~	{initialized stationary}
	|

K =IF THEN ELSE(Ra Normalized>K Thresh Max,1+K Coeff* 
(Ra Normalized-K Thresh Max)^2,IF THEN ELSE(Ra Normalized
<K Thresh Min,1+K Coeff*(K Thresh Min-Ra Normalized)^2,1))
	~	dmnl
	~		|

K Coeff = 600
	~	dmnl
	~		|

K Thresh Max = 1.5
	~	dmnl
	~		|

K Thresh Min = 0.75
	~	dmnl
	~		|

Omega = 0.22
	~	1/s
	~	{1/s}
	|

Psi = Psi max-(Psi max-Psi min)/(1+exp(Alpha*(Fhen Norm Delayed-S)))
	~	dmnl
	~	Note: there was apparently a mistake in the specification of this logistic-type \
		curve in the
		         article.
	|

Psi Input = Psi Test SW*Psi Test+(1-Psi Test SW)*Psi
	~	dmnl
	~		|

Psi max = 1.5
	~	dmnl
	~		|

Psi min = 0.75
	~	dmnl
	~		|

Psi Test = 1+step(0.1,20)
	~	dmnl
	~		|

Psi Test SW = 0
	~	dmnl
	~		|

Ra0 = 18.3
	~	mmHg*s/nl
	~	{mmHg*s/nl}
	|

Ra Normalized = Ra Afferent Arter Resist/Ra0
	~	dmnl
	~		|

S = INITIAL(1-ln((1-Psi min)/(Psi max-1))/Alpha)
	~	dmnl
	~	INITIAL used to save a few clock cycles.
	|

********************************************************
	.Blood
********************************************************~
		This portion of the model solves a system of simultaneous
		equations describing the equilibrium glomerular pressure
		and blood flow. Mosekilde uses a Pascal routine to solve
		the equations; here the Vensim SIMULTANEOUS function is
		used.
	|

Indicated BF =  SIMULTANEOUS(
 (Pa Arterial Pressure-Actual Pg)/Ra Afferent Arter Resist,
(Pa Arterial Pressure-Actual Pg)/Ra Afferent Arter Resist)
	~	nl/s
	~	Note: the indicated BF and BF loop is a dummy loop ied to reduce
		the gain of the Pg->BF->Pg positive loop, so that the convergence routine
		will work properly.
	|

chg BF Blood Flow = SIMULTANEOUS((Indicated BF-BF Blood Flow)*bld flow adj frac,0)
	~	nl/s
	~		|

bld flow adj frac = 0.2
	~	dmnl
	~		|

a = 0.163
	~	mmHg*nl/ng
	~	{mmHg*l/g}
	|

Actual Pg = SIMULTANEOUS(Actual Pg + dPg, 45)
	~	mmHg
	~		|

b = 0.0029
	~	mmHg*(nl*nl)/(ng*ng)
	~	{mmHg*l^2/g^2}
	|

BF Blood Flow = SIMULTANEOUS(
BF Blood Flow + chg BF Blood Flow,
Indicated BF)
	~	nl/s
	~		|

Ca Affer Blood Protein Conc = 54
	~	ng/nl
	~	{g/l}
	|

Ce Effer Blood Protein Conc = SIMULTANEOUS(
((a/2/b)^2+(Actual Pg-Pt Proxim Tub Pressure)/b)^0.5-a/2/b,
((a/2/b)^2+(Actual Pg-Pt Proxim Tub Pressure)/b)^0.5-a/2/b)
	~	ng/nl
	~		|

dPg =  SIMULTANEOUS((Indicated Pg-Actual Pg)*Pg Adj Frac,0)
	~	mmHg
	~		|

Ha Hematocrit = 0.5
	~	dmnl
	~		|

Indicated Pg =SIMULTANEOUS(
Pv Veinous Pressure+Re Efferent Resist*(BF Blood Flow-SNGFR Filtrat Flow),
Pv Veinous Pressure+Re Efferent Resist*(BF Blood Flow-SNGFR Filtrat Flow))
	~	mmHg
	~	Note: the Indicated Pg and Actual Pg loop is a dummy loop inserted to reduce
		the gain of both Pg loops, so that the convergence routine
		will work properly.
	|

Pa Arterial Pressure = 100
	~	mmHg
	~	{mmHg}
	|

Pg Adj Frac = 0.2
	~	dmnl
	~	Note: this parameter has no physical meaning; it sets the gain around the \
		SIMULTANEOUS equation loop needed to solve for the blood & filtration flow \
		and pressure.
	|

Pv Veinous Pressure = 10
	~	mmHg
	~	{mmHg}
	|

Re Efferent Resist = 14
	~	mmHg*s/nl
	~	{mmHg*s/nl}
	|

SNGFR Filtrat Flow =SIMULTANEOUS(
BF Blood Flow*(1-Ha Hematocrit)*(1-Ca Affer Blood Protein Conc/Ce Effer Blood Protein Conc\
		),
BF Blood Flow*(1-Ha Hematocrit)*(1-Ca Affer Blood Protein Conc/Ce Effer Blood Protein Conc\
		))
	~	nl/s
	~	{ Equation 2 }
	|

********************************************************
	.Loop
********************************************************~
	|

Fhen0 = 0.1875
	~	nl/s
	~		|

Fhen Flow to Loop of Henle =
(Pt Proxim Tub Pressure-Pd Distal Tub Pressure)/Rhen Henle Loop Resist
	~	nl/s
	~		|

Fhen Norm Delayed =
smOOth3(Fhen Flow to Loop of Henle,T Mac Dens Aff Art Delay)/Fhen0
	~	dmnl
	~		|

Pd Distal Tub Pressure = 4.5
	~	mmHg
	~	{mmHg}
	|

Rhen Henle Loop Resist = 40
	~	mmHg*s/nl
	~	{mmHg*s/nl}
	|

T Mac Dens Aff Art Delay = 4.5 { + 9*RAMP(1/(FINAL_TIME-INITIAL_TIME),INITIAL_TIME,FINAL_TIME)}
	~	s
	~		|

********************************************************
	.Proximal
********************************************************~
	|

Ctub Tubule Compliance = 0.4
	~	nl/mmHg
	~	{nl/mmHg}
	|

dPt Chg Prox Tub Press =
(SNGFR Filtrat Flow-Freab Reabsorb Flow-Fhen Flow to Loop of Henle)/Ctub Tubule Compliance
	~	mmHg/s
	~		|

Freab Reabsorb Flow = 0.3
	~	nl/s
	~	{nl/s}
	|

Pt Proxim Tub Pressure = INTEG(dPt Chg Prox Tub Press, Initial Pt)
	~	mmHg
	~	{mmHg - guestimate, pg. 92 left side 3rd paragraph}
	|

********************************************************
	.Control
********************************************************~
		Note: the model MUST be simulated with RK4 integration for
		reasonable accuracy. Mosekilde uses RK4 with a fixed step
		of .05; you could probably do better with a variable step
		of similar or perhaps larger size (.0625 or .125). I haven't
		tested these in this version.
	|

TIME STEP  = 0.05
	~	seconds
	~		|

FINAL TIME  = 400
	~	seconds
	~		|

INITIAL TIME  = 0
	~	seconds
	~		|

SAVEPER  = 0.25
	~	seconds
	~		|

