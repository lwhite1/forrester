{UTF-8}
{UTF-8}


FINAL TIME  = 1500
	~	Year
	~	The final time for the simulation.
	|

tree harvesting = MIN ( Population * per capita tree consumption , Trees / TIME STEP 
)
	~	trees / Year
	~		|

Trees = INTEG(-tree harvesting,initial trees)
	~	trees
	~		|

initial trees = 30000
	~	trees
	~		|

per capita tree consumption = 0.01
	~	trees / people / Year [0,0.2,0.001]
	~		|

net birth rate = 0.0035
	~	fraction / Year
	~		|

net births per year = net birth rate * Population
	~	people / Year
	~		|

initial population = 10
	~	people
	~		|

INITIAL TIME  = -500
	~	Year
	~	The initial time for the simulation.
	|

Population = INTEG(net births per year,initial population)
	~	people
	~		|

SAVEPER  = 
        TIME STEP
	~	Year
	~	The frequency with which output is stored.
	|

TIME STEP  = 10
	~	Year
	~	The time step for the simulation.
	|

