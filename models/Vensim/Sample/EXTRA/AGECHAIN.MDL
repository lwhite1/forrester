{UTF-8}
{UTF-8}


Population Middle= INTEG (
	aging young-aging middle,
		initial pop middle)
	~	person
	~		|

aging middle=
	Population Middle / average time in middle
	~	person/Year
	~		|

aging old=
	Population Old / average time in old
	~	person/Year
	~		|

initial pop middle=
	2e+07
	~	person
	~		|

initial pop old=
	1e+06
	~	person
	~		|

average time in middle=
	47
	~	Year
	~		|

average time in old=
	10
	~	Year
	~		|

initial pop infant=
	100000
	~	person
	~		|

Population Old= INTEG (
	aging middle - aging old,
		initial pop old)
	~	person
	~		|

aging young=
	Population Young / average time in young
	~	person/Year
	~		|

average time in young=
	18
	~	Year
	~		|

birth rate=
	0.08
	~	fraction/Year
	~		|

births=
	Population Middle * birth rate
	~	person/Year
	~		|

Population Young= INTEG (
	births - aging young,
		initial pop infant)
	~	person
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Year
	~	The time step for the simulation.
	|

