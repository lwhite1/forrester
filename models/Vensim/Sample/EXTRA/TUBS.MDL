{UTF-8}
{UTF-8}

inflow[T1]=
	IF THEN ELSE(Time > 10,1,0) ~~|
inflow[lowtub] = outflow[hightub]
	~	Gallon/Minute
	~	The inflow into each tub.
	|

FINAL TIME  = 100
	~	Minute
	~	The final time for the simulation.
	|

hightub : T1, T2, T3, T4 -> lowtub
	~	
	~	The four highest tubs.
	|

INITIAL TIME  = 0
	~	Minute
	~	The initial time for the simulation.
	|

lowtub : T2, T3, T4, T5
	~	
	~	The four lowest tubs.
	|

outflow[tub] = IF THEN ELSE(Water[tub] > 10,inflow[tub],0)
	~	Gallon/Minute
	~	The amount of water flowing out of the tub.
	|

SAVEPER  = 
        TIME STEP
	~	Minute
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Minute
	~	The time step for the simulation.
	|

tub : T1, T2, T3, T4, T5
	~	
	~	The different tubs in the experiment.
	|

Water[tub] = INTEG(inflow[tub]-outflow[tub],0)
	~	Gallon
	~	The amount of water in each tub.
	|

