{UTF-8}
{UTF-8}

rate that people contact other people=
	 5
	~	1/day
	~		|

contacts between infected and unaffected = rate of potential infectious contacts  * fraction of population infected
	~	Person/day
	~		|

Infected Population  = INTEG (infections, initial infected)
	~	Person
	~		|

total population = Susceptible Population + Infected Population
	~	Person
	~		|

fraction infected from contact = 0.1
	~	Dmnl
	~		|

fraction of population infected = Infected Population / total population
	~	Dmnl
	~		|

infections = contacts between infected and unaffected  * fraction infected from contact
	~	Person/day
	~		|

initial infected = 10
	~	Person
	~		|

initial susceptible = 1e+06
	~	Person
	~		|

rate of potential infectious contacts = Susceptible Population  * rate that people contact other people
	~	Person/day
	~		|

Susceptible Population = INTEG( - infections, initial susceptible)
	~	Person
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 50
	~	day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	day
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	day
	~	The time step for the simulation.
	|

