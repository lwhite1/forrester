{UTF-8}
{UTF-8}

adjust=
	IF THEN ELSE(Time >= adjust time :AND: :NOT: adjusted,adjust amount/TIME STEP,0)
	~	$/Month
	~		|

adjust amount=
	230
	~	$
	~		|

adjust time=
	GAME(FINAL TIME)
	~	Month
	~		|

adjusted= INTEG (
	IF THEN ELSE(adjust <> 0,1/TIME STEP,0),
		0)
	~	DMnl
	~		|

inflow=
	norm inflow * (1-STEP(1,10))
	~	$/Month
	~		|

init stock=
	100
	~	$
	~		|

msg=SAMPLE IF TRUE(
	:NOT: msg, IF THEN ELSE(:NOT: msg :AND: stock < target stock,MESSAGE('PROB',5),0),0)
	~	DMnl
	~		|

norm inflow=
	100
	~	$/Month
	~		|

outflow=
	stock/outflow time
	~	$/Month
	~		|

outflow time=
	20
	~	Month
	~		|

stock= INTEG (
	adjust+inflow-outflow,
		init stock)
	~	$
	~		|

target stock=
	50
	~	$
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month
	~	The time step for the simulation.
	|

