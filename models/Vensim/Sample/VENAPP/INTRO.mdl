{UTF-8}
{UTF-8}

Average Worker Hours= INTEG (
	change in hours worked,
		normal workweek)
	~	Hour/Month
	~	   The average number of hours worked per week
	|

change in hours worked=
	(required worker hours-Average Worker Hours) / delay in adding or removing overtime hours
	~	Hour/(Month*Month)
	~		|

delay in adding or removing overtime hours=
	3
	~	Month
	~		|

production=
	 Workforce * required worker hours * productivity / normal workweek
	~	Widget/Month
	~	   Total amount produced.
	~	:SUPPLEMENTARY 
	|

required worker hours=
	ZIDZ(target production, Workforce*productivity) * normal workweek
	~	Hour/Month
	~	   The amount relative to normal that people have to work to
		         produce enough.
	|

net hires=
	 (desired workforce-Workforce)/time to hire or layoff
	~	Person/Month
	~	   The net number of people hired (laid off if negative).
	|

normal workweek=
	40
	~	Hour/Month
	~		|

time to hire or layoff=
	6
	~	Month
	~		|

desired workforce=
	ZIDZ( target production, productivity)
	~	Person
	~	   The desired number of workers.
	|

effect of morale on productivity lookup(
	[(0,0)-(4,4)],(0,0),(1,1),(2,2),(2.63444,2.36842),(3.29909,2.52632),(3.97583,2.57895\
		))
	~	Dmnl
	~	   The effect that morale has on the ability to produce\!\!\!
	|

FINAL TIME  = 100
	~	Month
	~	   FINAL TIME
	|

INITIAL TIME  = 0
	~	Month
	~	   The initial time for the simulation.
	|

morale=
	 morale lookup(Average Worker Hours/normal workweek)
	~	Dmnl
	~	   Morale - 1 is normal.
	|

morale lookup(
	[(0,0.5)-(2,1.5)],(0,1.5),(0.326284,1.4386),(0.495468,1.40351),(0.682779,1.32018),(0.839879\
		,1.18421),(1,1),(1.14804,0.833333),(1.3716,0.640351),(1.66767,0.526316),(2,0.5))
	~	Dmnl
	~	   Lookup relating the average level of overtime to morale.\!\!\!
	|

normal productivity = 1
	~	Widget/Month/Person
	~	   The normal amount produced in the absence of morale effects.
	|

productivity = normal productivity*effect of morale on productivity lookup(morale)
	~	Widget/(Month*Person)
	~	   The amount each peson can produce given morale effects.
	|

sales = IF THEN ELSE(Time > 20,120,100)
	~	Widget/Month
	~	   The total amount sold.
	|

SAVEPER  = 1
	~	Month
	~	   The frequency with which output is stored.
	|

target production = sales
	~	Widget/Month
	~	   The target amount produced.
	|

TIME STEP  = 1
	~	Month
	~	   The time step for the simulation.
	|

Workforce = INTEG(net hires,target production/normal productivity)
	~	Person
	~	   The number of workers
	|

