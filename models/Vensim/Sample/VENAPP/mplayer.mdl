{UTF-8}
{UTF-8}

region:
	north,south,east
	~	
	~		|

SPECIAL GI=
	10
	~	
	~		~	:SUPPLEMENTARY 
	|

average lifetime[region]=
	standard lifetime * eff pop life[region]
	~	Month
	~		|

birth rate[region]=
	0.08,0,0.1
	~	1/Month
	~		|

births[region]=
	GAME(Pop by region[region] * birth rate[region])
	~	Rabbit/Month
	~		|

deaths[region]=
	Pop by region[region]/average lifetime[region]
	~	Rabbit/Month
	~		|

eff pop life[region]=
	sat lookup[region](Pop by region[region]/max pop[region])
	~	Dmnl
	~		|

max pop[region]=
	1000,2000,2500
	~	Rabbit
	~		|

Pop by region[region]= INTEG (
	births[region]-deaths[region],
		100)
	~	Rabbit
	~		|

sat lookup[region](
	[(0,0)-(10,10)],(0,2),(1,1),(2,0.5),(5,0.1))
	~	Dmnl
	~		|

standard lifetime=
	40
	~	Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 1000
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month
	~	The time step for the simulation.
	|

