{UTF-8}
{UTF-8}

Total Age Of Failing Parts= INTEG (
	Failing Parts - 
	          ( failures + proactive replacements)* avg age failing parts,
		             Failing Parts* NORM FAIL TIME)
	~	Part*Month
	~	     The total age of parts that are failing (relative to
		        when they began failing.
	|

normal age of failing parts=
	1
	~	Month
	~		|

accept pro overtime = INITIAL(IF THEN ELSE(pro overtime percent > 0,
                 1 + pro overtime percent / 100,1))
	~	Dmnl
	~	    The acceptable level of overtime introduced to manage
		         proactive parts replacement.
	|

aging parts = Good Parts/AVG PART LIFE
	~	Part/Month
	~	     The number of parts that are aged and therefore no
		        longer good.
	|

antic labor hiring = 0
	~	Dmnl
	~	    Switch to indicate if labor hiring is being done in
		        anticipation of what the required labor force
		         will be.
	|

attrition  = Labor/avg labor tenancy
	~	Person/Month
	~	     The rate at which service engineers leave to go on to
		        other jobs or retirement.
	|

avail pro capacity = IF THEN ELSE(Labor*lab hours per month*accept pro overtime
 > 
                    reactive service time, Labor * lab hours per month
*accept pro overtime
                                - reactive service time,0)
	~	Hour/Month
	~	     The amount of labor capacity available for use in
		         proactive
		         service delivery.
	|

avg age failing parts  = Total Age Of Failing Parts/Failing Parts
	~	Month
	~	     The average age of parts that have begun the failure
		         process.
	|

average diagnostic time = 1
	~	Hour/Part
	~	     The average amount of time spent diagnosing a problem to
		         determine the correct part to replace.
	|

average assembly time = 1
	~	Hour/Part
	~	     The average amount of time that is spent doing the actual
		        replacement of a part not including any
		         diagnosis.
	|

avg labor tenancy = 30
	~	Month
	~	     The average time service engineers remain working as
		         service
		        engineers.
	|

AVG PART LIFE = 60
	~	Month
	~	     The mean lifetime of a part.
	|

eff age fail ((0,0),(1,1),(1.8866,2.05263),(2.75258,3.19737)
,(3.29897,3.96711),(3.84536,4.98684),(6.10825,24.4737) )
	~	Dmnl
	~	     The effect of age relative to the normal fail time on
		        failure.
	|

eff age failure ((0,0),(1,1),(10,10))
	~	Dmnl
	~	     The effect of age on the rate of parts failure.
	|

eff error proactive rpl ((0,0),(1,1),(2,2))
	~	Dmnl
	~	     The effect of measured error rates on the proactive
		        replacement of parts.
	|

excess rpl penalty = 5
	~	$/Part
	~	    The penalty assessed for monthly replacements in excess of
		         the specified maximum.
	|

exp tot rpl = aging parts
	~	Part/Month
	~	    The expected total number of replacements that will be
		         made.
	|

Failing Parts = INTEG(aging parts - failures - proactive replacements,
INIT FAILING PARTS)
	~	Part
	~	     The number of parts that have begun to fail, but not 
		         yet failed.
	|

failures  = Failing Parts/NORM FAIL TIME * eff age fail(
            avg age failing parts/NORM FAIL TIME)
	~	Part/Month
	~	     The rate at which parts fail, and therefore require
		         replacement.
	|

FINAL TIME  = 24
	~	Month
	~	      FINAL TIME
	|

Good Parts  = INTEG(NEW EQUIPMENT PARTS + reactive replacements + proactive replacements
 - aging parts,
                INIT GOOD PARTS)
	~	Part
	~	     The number of parts that are good.
	|

hiring  = IF THEN ELSE( indicated net hiring > -attrition,
          indicated net hiring + attrition,0)
	~	Person/Month
	~	     The net number of people hired.  Note that only attrition
		        is used to decrease the workforce.
	|

ind proactive rpl  = IF THEN ELSE(Time > pro start time,
                  Failing Parts / plan pro rpl time * 
                 implement table((Time-pro start time)/pro phase in time
)*
                   eff error proactive rpl( avg soft faults/
                         norm err generation),0)
	~	Part/Month
	~	     Indicate proactive replacement of parts based on the error
		         rate
		        of failing parts.
	|

implement table   ((0,1),(1,1) )
	~	Dmnl
	~	    The profile of proactive service implementation over time.
	|

ind proactive service time = ind proactive rpl * average assembly time
	~	Hour/Month
	~	    The indicated number of hours that should be spent doing
		         proactive service.
	|

indicated labor  = IF THEN ELSE(antic labor hiring :AND:
                            Time > pro start time,
                                   pot pro service time/lab hours per month
,
                                                ind total service time
/lab hours per month)
	~	Person
	~	     The indicated amount of labor for proactive and 
		        reactive servicing.
	|

ind total service time  = ind proactive service time+reactive service time
	~	Hour/Month
	~	     The total amount of time reuquired to do service.
	|

indicated net hiring  = (indicated labor-Labor)/time adj labor
	~	Person/Month
	~	     The indicated net number of people to hire.
	|

INIT FAILING PARTS = INITIAL(Good Parts*NORM FAIL TIME/
                   AVG PART LIFE)
	~	Part
	~	     The initial number of failing parts.
	|

INIT GOOD PARTS = 100000
	~	Part
	~	     The initial number of good parts.
	|

INITIAL TIME  = 0
	~	Month
	~	     The initial time for the simulation.
	|

lab hours per month = 130
	~	Hour/Person/Month
	~	     The number of hours of direct labor available from 
		        workers after netting sick leave, vacation, holiday,
		        training and travel time.
	|

Labor  = INTEG(hiring-attrition,indicated labor)
	~	Person
	~		|

labor utilization = (proactive service time + reactive service time)/
                         (Labor*lab hours per month)
	~	Dmnl
	~	    The utilization rate of labor relative to plan.  1.0 is
		         normal, anything over that requires overtime.
	|

max accept rpl = 2000
	~	Part/Month
	~	    The maximum acceptable number of replacements in a month
		         above which a penalty must be assessed.
	|

NEW EQUIPMENT PARTS = 0
	~	Part/Month
	~	    New parts coming into the stock of good parts as a
		         consequence of new equipment.
	|

norm err generation = 10
	~	Fault/Part/Month
	~	     The normal rate of error generation on parts that are
		         failing, but have not yet failed.
	|

NORM FAIL TIME = 3
	~	Month
	~	     The normal time a part that is prone to failure remains
		        in use without failing.
	|

plan pro rpl time  = 1
	~	Month
	~	     The planned time to proactively replace parts indicating
		         that
		        they may have failed.
	|

overtime wage = 20
	~	$/Hour
	~	    The wage that is paid for overtime work.
	|

pot pro service time = exp tot rpl * average assembly time
	~	Hour/Month
	~	    The potential time spent on proactive service when steady
		         state is achieved.
	|

pro overtime percent = 0
	~	Dmnl
	~	    The acceptable amount of overtime for proactive service. 
		         Entered as a percent.
	|

pro phase in time = 4
	~	Month
	~	    The time over which proactive replacement is phased in. 
		        Used only when the 
		IMPLEMENT TABLE is not flat
		         at 1.
	|

pro start time = 3
	~	Month
	~	     The time at which the proactive replacemnt of parts
		        begins.
	|

proactive replacements  = ACTIVE INITIAL(
                 IF THEN ELSE(avail pro capacity / average assembly time
                   > ind proactive rpl,ind proactive rpl,avail pro capacity
/average assembly time),
                  0)
	~	Part/Month
	~	     The number of parts replaced proactively.
	|

proactive service time  = proactive replacements*average assembly time
	~	Hour/Month
	~	     The amount of time spent in the proactive replacement
		         of parts.
	|

reactive replacements  = failures
	~	Part/Month
	~	     The number of parts replaced.
	|

reactive service time  = reactive replacements *(average assembly time+
              average diagnostic time)
	~	Hour/Month
	~	     The amount of time spent in the diagnosis and replacement
		        of failed parts.
	|

SAVEPER  = 0.125
	~	Month
	~	      The frequency with which output is stored.
	|

time adj labor = 24
	~	Month
	~	     The time required to adjust the labor force.
	|

TIME STEP  = 0.125
	~	Month
	~	      The time step for the simulation.
	|

total parts = Good Parts + Failing Parts
	~	Part
	~	     The total number of parts in the system.
	~	:SUPPLEMENTARY 
	|

total replacements = reactive replacements + proactive replacements
	~	Part/Month
	~	    The total number of parts being replaced.
	|

variable cost =  Labor*wage* lab hours per month + 
              MAX(0,labor utilization-1)*Labor*lab hours per month*overtime wage
 +
                  MAX(0,total replacements- max accept rpl)*excess rpl penalty
	~	$/Month
	~	    The variable cost of providing service.  Use in the
		        determination of the best rollout time and
		         overtime policies.
	~	:SUPPLEMENTARY 
	|

wage = 10
	~	$/Hour
	~	    The base wage rate in the model.
	|

