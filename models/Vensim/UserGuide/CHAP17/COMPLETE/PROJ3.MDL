{UTF-8}
is a prerequisite[design,prereqtask] = 0,0,0 ~~|
is a prerequisite[prototype,prereqtask] = 1,0,0 ~~|
is a prerequisite[build,prereqtask] = 1,1,0
	~	Dmnl
	~		|

max work accomplishment[task] = 8, 15, 10
	~	Drawing/Month
	~		|

prereqtask <-> task
	~	
	~		|

task : design, prototype, build
	~	
	~		|

task has started[task] =
	VMIN( IF THEN ELSE( is a prerequisite[task,prereqtask!],
                                    task is done[prereqtask!],
                                   1))
	~	Dmnl
	~		|

task is active[task] = IF THEN ELSE(task has started[task] :AND: :NOT:
	task is done[task],1,0)
	~	Dmnl
	~		|

task is done[task] = IF THEN ELSE( Work Done[task] >= 0.98 * task size[task], 1, 0)
	~	Dmnl
	~		|

task size[task]=
	 180,250,500
	~	Drawing
	~		|

work accomplishment[task] = IF THEN ELSE(task is active[task],
         max work accomplishment[task],0)
	~	Drawing/Month
	~		|

Work Done[task] = INTEG(work accomplishment[task],0)
	~	Drawing
	~		|

Work To Do[task] = INTEG(-work accomplishment[task],task size[task])
	~	Drawing
	~		~	:SUPPLEMENTARY 
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  =
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Month
	~	The time step for the simulation.
	|

