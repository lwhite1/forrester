{UTF-8}
total work done = SUM(Work Done[task!])
	~	Drawing
	~		~	:SUPPLEMENTARY 
	|

work accomplishment[task] = max work accomplishment[task] * task is active[task]
	~	Drawing/Month
	~		|

max work accomplishment[task] = 8, 10, 15
	~	Drawing/Month
	~		|

task : design, prototype, build
	~	
	~		|

task is active[task] = IF THEN ELSE( Work Done[task] < task size[task], 1, 0)
	~	Dmnl
	~		|

task size[task]=
	 180, 250, 500
	~	Drawing
	~		|

Work Done[task] = INTEG(work accomplishment[task], 0)
	~	Drawing
	~		|

Work To Do[task] = INTEG( - work accomplishment[task], task size[task])
	~	Drawing
	~		~	:SUPPLEMENTARY 
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Month
	~	The time step for the simulation.
	|

