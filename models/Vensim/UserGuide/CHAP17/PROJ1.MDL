{UTF-8}
work accomplishment = max work accomplishment * task is active
	~	Drawing/Month
	~		|

max work accomplishment = 8
	~	Drawing/Month
	~		|

task is active = IF THEN ELSE( Work Done < task size, 1, 0)
	~	Dmnl
	~		|

task size=
	 180
	~	Drawing
	~		|

Work Done = INTEG(work accomplishment, 0)
	~	Drawing
	~		|

Work To Do= INTEG (
	 - work accomplishment,
		task size)
	~	Drawing
	~		~	:SUPPLEMENTARY 
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Month
	~	The time step for the simulation.
	|

