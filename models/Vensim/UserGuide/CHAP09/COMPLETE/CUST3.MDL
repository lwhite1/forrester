{UTF-8}
Capacity = INTEG(investment-reductions,
    target capacity )
	~	Gadget/Month
	~		|

capacity adjustment = (target capacity - Capacity)/time to adjust capacity
	~	Gadget/Month/Month
	~		|

capacity life = 20
	~	Month
	~		|

production =  MIN(desired production,potential production)
	~	Gadget/Month
	~		~	:SUPPLEMENTARY 
	|

reductions = Capacity/capacity life
	~	Gadget/(Month*Month)
	~		|

investment=
	 capacity adjustment
	~	Gadget/Month/Month
	~		|

desired production=
	target capacity
	~	Gadget/Month
	~		|

potential production = Capacity
	~	Gadget/Month
	~		|

sales=
	new customers * widgets per person
	~	Widget/Month
	~		|

sales revenue=
	sales * price
	~	dollar/Month
	~		|

new customers = MIN(word of mouth demand, Capacity/widgets per person)
	~	person/Month
	~		|

Cumulative Revenue = INTEG(sales revenue, 0)
	~	dollar
	~		~	:SUPPLEMENTARY 
	|

contacts of noncustomers with customers = contacts with customers*potential customer concentration
	~	contact/Month
	~		|

contacts with customers = Customers*sociability
	~	contact/Month
	~		|

Customers = INTEG(new customers,1000)
	~	person
	~		|

price = 50
	~	dollar/Widget
	~		|

fruitfulness = 0.01
	~	person/contact
	~		|

potential customer concentration = Potential Customers/total market
	~	dmnl
	~		|

Potential Customers = INTEG( - new customers,1e+006)
	~	person
	~		|

sociability = 20
	~	contact/person/Month
	~		|

target capacity = word of mouth demand*widgets per person
	~	Widget/Month
	~		|

time to adjust capacity = 12
	~	Month
	~		|

total market = Customers+Potential Customers
	~	person
	~		|

widgets per person = 1
	~	Widget/person
	~		|

word of mouth demand = contacts of noncustomers with customers*fruitfulness
	~	person/Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month
	~	The time step for the simulation.
	|

