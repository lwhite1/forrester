{UTF-8}
routine maintenance work done=
	MIN(total machines/machine wear time,workers available for routine maintenance * maintenance productivity\
		)
	~	Machine/Month
	~		|

repair completions=
	workers performing repairs * repair productivity
	~	Machine/Month
	~		|

total maintenance workforce
	~	Person
	~		|

effect machine wear reliability= WITH LOOKUP (
	average time since service/machine wear time,
		([(0,0)-(10,10)],(0,0.9),(1,1),(1.5,1.1),(2,1.5),(3,3),(4,6) ))
	~	Dmnl
	~		|

machine wear time=
	2
	~	Month
	~		|

workers performing repairs=
	MIN(number of repairs required/repair productivity,total maintenance workforce)
	~	Person
	~		|

maintenance productivity=
	120
	~	Machine/Person/Month
	~		|

workers available for routine maintenance=
	total maintenance workforce - workers performing repairs
	~	Person
	~		|

average machine failure rate=
	maintained machine failure rate * effect machine wear reliability
	~	1/Month
	~		|

average time since service=
	total time since service/total machines
	~	Month
	~		|

maintained machine failure rate=
	0.1
	~	1/Month
	~		|

number of repairs required=
	average machine failure rate * total machines
	~	Machine/Month
	~		|

repair productivity=
	30
	~	Machine/Person/Month
	~		|

total machines=
	1000
	~	Machine
	~		|

total time since service= INTEG (
	total machines - (repair completions + routine maintenance work done) * average time since service\
		,
		total machines * machine wear time)
	~	Machine*Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 24
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

