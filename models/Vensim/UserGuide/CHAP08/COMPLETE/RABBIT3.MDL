{UTF-8}
effect of rabbit crowding on deaths=
	effect of rabbit crowding on deaths function( normalized population )
	~	Dmnl
	~		|

effect of rabbit crowding on deaths function(
	[(0,0)-(4,2)],(0,0.9),(1,1),(2,1.2),(3,1.5),(4,2))
	~	Dmnl
	~		|

normal death rate=
	Rabbit Population / average lifetime
	~	rabbit/Year
	~		|

normalized population=
	Rabbit Population / carrying capacity
	~	Dmnl
	~		|

deaths=
	normal death rate * effect of rabbit crowding on deaths
	~	rabbit/Year
	~		|

average lifetime=
	8
	~	Year
	~		|

birth rate=
	0.23
	~	fraction/Year
	~		|

births=
	Rabbit Population * birth rate
	~	rabbit/Year
	~		|

initial population=
	1000
	~	rabbit
	~		|

carrying capacity=
	1000
	~	rabbit
	~		|

Rabbit Population= INTEG (
	births - deaths,
		initial population)
	~	rabbit
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 30
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Year
	~	The time step for the simulation.
	|

