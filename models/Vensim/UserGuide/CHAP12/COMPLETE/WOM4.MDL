{UTF-8}
GAME INTERVAL=
	0.25
	~	Year
	~		~	:SUPPLEMENTARY 
	|

new customers=
	sales / sales size
	~	person/Year
	~		|

advertising spending= GAME (
	c advertising spending)
	~	$/Year
	~		|

c advertising spending=
	2e+007
	~	$/Year
	~		|

customer sales effectiveness=
	3
	~	widget/person/Year
	~		|

Customers= INTEG (
	+new customers-leaving customers,
		seed customers)
	~	person
	~		|

fraction would be with real prospects=
	Potential Customers / market size
	~	Dmnl
	~		|

leaving customers=
	Customers / obsolescence time
	~	person/Year
	~		|

market size=
	1e+008
	~	person
	~		|

sales size=
	1
	~	widget/person
	~		|

obsolescence time=
	2
	~	Year
	~		|

Potential Customers= INTEG (
	leaving customers - new customers,
		market size - seed customers)
	~	person
	~		|

sales=
	(would be word of mouth sales + would be advertising sales ) * fraction would be with real prospects
	~	widget/Year
	~		|

would be advertising sales=
	advertising spending * advertising effectiveness
	~	widget/Year
	~		|

seed customers=
	10000
	~	person
	~		|

would be word of mouth sales=
	Customers * customer sales effectiveness
	~	widget/Year
	~		|

advertising effectiveness=
	0.1
	~	widget/$
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 5
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year
	~	The time step for the simulation.
	|

