{UTF-8}
Cumulative Profit = INTEG(profit,0)
	~	dollars
	~		~	:SUPPLEMENTARY 
	|

distr orders other =0
	~	unit/day
	~		|

ORDER RULE SWITCH = 2
	~	Dmnl
	~	1 for periodic replenishment rule, 2 for minimum rule 3 for other rule
	|

distr orders =IF THEN ELSE(ORDER RULE SWITCH=1,
               distr orders periodic,
      IF THEN ELSE(ORDER RULE SWITCH=2,
             distr orders minimum,
             distr orders other))
	~	unit/day
	~		|

distr orders minimum =IF THEN ELSE(
               Store Inventory+Qty On Order<min inventory value,
               (max inventory value-Qty On Order-Store Inventory)/TIME STEP,0)
	~	unit/day
	~		|

Order Cost = IF THEN ELSE(
        distr orders>0,
        PROCESSING COST+transport cost,
        0)
	~	dollars/day
	~		|

transport cost =TRANSPORT RATE(distr orders/UNIT ORDER)
	~	dollars/day
	~		|

max inventory value = 100
	~	unit
	~		|

receipts = DELAY MATERIAL(distr orders,leadtime,0,0)
	~	unit/day
	~		|

min inventory value = 20
	~	unit
	~		|

UNIT ORDER = 1
	~	unit/day
	~		|

distr orders periodic =IF THEN ELSE(order placement day<>0,
     ( forecast orders*(leadtime+REPLENISH PERIOD)-
     Store Inventory-Qty On Order)/order placement day
    ,0)
	~	unit/day
	~		|

total cost = Cost Of Goods + Holding Cost + Order Cost
	~	dollars/day
	~		|

profit =Sales Revenue -  total cost
	~	dollars/day
	~		|

order placement day = IF THEN ELSE(MODULO(Time,REPLENISH PERIOD)=0,1,0)
	~	day
	~		|

DAYS PER YEAR = 365
	~	day/Year
	~		|

forecast orders = INTEG((orders-forecast orders)*
          WEIGHT TO CURRENT,orders)
	~	unit/day
	~		|

WEIGHT TO CURRENT = 0.2
	~	1/day
	~		|

Cost Of Goods = item cost*units sold
	~	dollars/day
	~		|

item : I1111,I2222,I3333
	~	
	~		~	:SUPPLEMENTARY 
	|

REPLENISH PERIOD = 10
	~	day
	~		|

Store Inventory = INTEG(receipts-units sold,
               orders*(leadtime))
	~	unit
	~		|

orders
	~	
	~		|

item cost = (1-PCT MARGIN/100)*ITEM PRICE
	~	dollars/unit
	~		|

PCT MARGIN = 10
	~	Dmnl
	~		|

leadtime = 5
	~	day
	~		|

Qty On Order = INTEG(distr orders-receipts,0)
	~	unit
	~		|

ITEM PRICE = 200
	~	dollars/unit
	~		|

PROCESSING COST = 2
	~	dollars/day
	~		|

Holding Cost = Store Inventory*item cost*INTEREST/DAYS PER YEAR
	~	dollars/day
	~		|

Sales Revenue =units sold*ITEM PRICE
	~	dollars/day
	~		|

INTEREST = 0.25
	~	1/Year
	~		|

units sold = IF THEN ELSE(Store Inventory-orders>0,orders,Store Inventory)
	~	unit/day
	~		|

TRANSPORT RATE     ([(0,0)-(800,250)],(0,10),(5,30),(15,75),
(30,100),(50,125),(100,165),(150,180),(200,185),(700,235) )
	~	dollars/day
	~		|

FINAL TIME  = 60
	~	day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	day
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	day
	~	The time step for the simulation.
	|

