{UTF-8}
average water=
	 ZIDZ(Water,Yeast Count)
	~	ml/Cell
	~	The average amount of water.  Note use of ZIDZ to prevent problems on 0 								\
		yeast count.
	|

average lifetime  = norm lifetime*
              life from temp lookup( temperature/norm temperature) *
             life from water lookup(average water/norm water) *
             life from sugar lookup(average sugar/norm sugar)
	~	Minute
	~	  The average length of time a yeast survives.
	|

average sugar = ZIDZ(Sugar,Yeast Count)
	~	g/Cell
	~	The average amount of sugar.  Note the use of ZIDZ to prevent problems 								\
		when Yeast Count is 0.
	|

division from sugar lookup  ([(0,0)-(1,1)],(0,0),(1,1) )
	~	Dmnl
	~		|

life from sugar lookup   ([(0,0)-(1,1)],(0,0.001),(1,1) )
	~	Dmnl
	~		|

division from water lookup    ([(0,0)-(1,1)],(0,0),(1,1) )
	~	Dmnl
	~		|

division rate  = norm division rate *
             division from temp lookup( temperature/norm temperature) *
             division from sugar lookup(average sugar/norm sugar) *
             division from water lookup(average water/norm water)
	~	1/Minute
	~	  The rate at which yeast divide.
	|

norm water = 0.001
	~	ml/Cell
	~	The normal amount of water for a cell.
	|

norm sugar = 0.001
	~	g/Cell
	~	The normal amount of sugar.
	|

life from water lookup    ([(0,0)-(1,1)],(0,0.001),(1,1) )
	~	Dmnl
	~		|

norm lifetime = 250
	~	Minute
	~	 The normal lifetime of a cell at normal temperature.
	|

norm temperature = 80
	~	degrees farenheit
	~	 The normal termperature used as a reference to determine division and 								\
		termination effects.
	|

division from temp lookup  ([(0,0)-(2,1)],(0,0),(0.8,0),(1,1)
,(2,1) )
	~	Dmnl
	~		|

norm division rate = 0.08
	~	1/Minute
	~	 The normal rate of division at normal temperatures
	|

life from temp lookup  ([(0,0)-(2,1)],(0,1),(1,1),(1.25,0.02)
,(2,0.001) )
	~	Dmnl
	~		|

divisions  = Yeast Count*division rate
	~	Cell/Minute
	~		|

FINAL TIME  = 300
	~	Minute
	~	  FINAL TIME
	|

INITIAL TIME  = 0
	~	Minute
	~	  The initial time for the simulation.
	|

SAVEPER  = 1
	~	Minute
	~	  The frequency with which output is stored.
	|

Sugar  = 100
	~	g
	~	  The amount of sugar in the bowl.
	|

temperature  = 85
	~	degrees farenheit
	~	  The temperature of the water in the bowl.
	|

terminations  = MIN(Yeast Count/TIME STEP,Yeast Count/average lifetime)
	~	Cell/Minute
	~	  The rate of termination of yeast.  Using a MIN to prevent silly results on extreme 								\
		conditions
		         integration.
	|

TIME STEP  = 1
	~	Minute
	~	  The time step for the simulation.
	|

Water  = 100
	~	ml
	~	  The amount of water in the bowl.
	|

Yeast Count  = INTEG( divisions-terminations,100)
	~	Cell
	~	   The number of yeast.
	|

********************************************************
	.Constraints
********************************************************~
	|

RC START TIME = 10
	~	Minute
	~		~	:SUPPLEMENTARY 
	|

cold is dormant :THE CONDITION: temperature < 50 :IMPLIES: 
		divisions = 0
	~	
	~		|

hot is dead:THE CONDITION:
	 temperature = RC STEP(120,1):IMPLIES: Yeast Count <= RC DECAY CHECK(1,Yeast Count,5\
		)
	~	
	~		|

eat or die :THE CONDITION: Sugar = RC STEP(Sugar,0) :AND: temperature > 65 :IMPLIES:
		Yeast Count <= RC DECAY CHECK(1,Yeast Count,15)
	~	
	~		|

drink or die :THE CONDITION: Water = RC STEP(Water,0) :AND: temperature > 65
		:IMPLIES: Yeast Count <= RC DECAY CHECK(1,Yeast Count,1)
	~	
	~		|

big growth :TEST INPUT: divisions = 1e+022
	~	
	~		|

hunger from growth :THE CONDITION: big growth :IMPLIES:
		Sugar <= RC DECAY CHECK(1,Sugar,0.5,INITIAL TIME)
	~	
	~		|

thirst from growth :THE CONDITION: big growth :IMPLIES:
		Water <= RC DECAY CHECK(1,Water,0.5,INITIAL TIME)
	~	
	~		|

