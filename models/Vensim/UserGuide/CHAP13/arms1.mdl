{UTF-8}
target armament 1=
	Total Armament 2 * desired strength ratio 1
	~	M$
	~		|

target armament 2=
	Total Armament 1 * desired strength ratio 2
	~	M$
	~		|

desired strength ratio 1=
	1
	~	Dmnl
	~		|

desired strength ratio 2=
	1
	~	Dmnl
	~		|

capacity lifetime 2=
	30
	~	Year
	~		|

armament capacity 2=
	Economic Capacity 2 * max capacity to armament 2
	~	M$/Year
	~		|

armament lifetime 2=
	20
	~	Year
	~		|

initial armament 2=
	50
	~	M$
	~		|

armament obsolescence 2=
	Total Armament 2/armament lifetime 2
	~	M$/Year
	~		|

initial economic capacity2=
	100
	~	M$/Year
	~		|

armament spending 2=
	armament capacity 2 * fraction armament capacity used 2
	~	M$/Year
	~		|

investment spending 2=
	non armament spending 2 * fraction spending to investment 2
	~	M$/Year
	~		|

capacity degradation 2=
	Economic Capacity 2/capacity lifetime 2
	~	M$/Year/Year
	~		|

growth in capacity 2=
	investment spending 2 * investment effectiveness 2
	~	M$/Year/Year
	~		|

Total Armament 2= INTEG (
	armament spending 2-armament obsolescence 2,
		initial armament 2)
	~	M$
	~		|

indicated armament building 2=
	MAX(0,armament obsolescence 2 + (target armament 2 - Total Armament 2)/time to correct armament 2\
		)
	~	M$/Year
	~		|

non armament spending 2=
	Economic Capacity 2 - armament spending 2
	~	M$/Year
	~		|

Economic Capacity 2= INTEG (
	growth in capacity 2 - capacity degradation 2,
		initial economic capacity2)
	~	M$/Year
	~		|

fraction armament capacity used 2= WITH LOOKUP (
	ZIDZ(indicated armament building 2,armament capacity 2),
		([(0,0)-(10,1),(0,0),(1,1),(10,1)],(0,0),(0.4,0.4),(2,0.8),(3,0.9),(5,1),(10,1) ))
	~	Dmnl
	~		|

time to correct armament 2=
	5
	~	Year
	~		|

fraction spending to investment 2=
	0.3
	~	Fraction
	~		|

investment effectiveness 2=
	0.15
	~	1/Year
	~		|

non armament spending 1=
	Economic Capacity 1 - armament spending 1
	~	M$/Year
	~		|

max capacity to armament 2=
	0.4
	~	Fraction
	~		|

armament capacity 1=
	Economic Capacity 1 * max capacity to armament 1
	~	M$/Year
	~		|

armament spending 1=
	armament capacity 1 * fraction armament capacity used 1
	~	M$/Year
	~		|

armament lifetime 1=
	20
	~	Year
	~		|

armament obsolescence 1=
	Total Armament 1/armament lifetime 1
	~	M$/Year
	~		|

capacity degradation 1=
	Economic Capacity 1/capacity lifetime1
	~	M$/Year/Year
	~		|

capacity lifetime1=
	30
	~	Year
	~		|

indicated armament building 1=
	MAX(0,armament obsolescence 1 + (target armament 1 - Total Armament 1)/time to correct armament 1\
		)
	~	M$/Year
	~		|

Economic Capacity 1= INTEG (
	growth in capacity1 - capacity degradation 1,
		initial economic capacity1)
	~	M$/Year
	~		|

fraction armament capacity used 1= WITH LOOKUP (
	ZIDZ(indicated armament building 1,armament capacity 1),
		([(0,0)-(10,1),(0,0),(1,1),(10,1)],(0,0),(0.4,0.4),(2,0.8),(3,0.9),(5,1),(10,1) ))
	~	Dmnl
	~		|

fraction spending to investment 1=
	0.3
	~	Fraction [0,0.6]
	~		|

growth in capacity1=
	investment spending 1 * investment effectiveness1
	~	M$/Year/Year
	~		|

initial armament 1=
	50
	~	M$
	~		|

initial economic capacity1=
	100
	~	M$/Year
	~		|

investment spending 1=
	non armament spending 1 * fraction spending to investment 1
	~	M$/Year
	~		|

investment effectiveness1=
	0.15
	~	1/Year [0.01,0.4]
	~		|

max capacity to armament 1=
	0.4
	~	Fraction [0,1]
	~		|

time to correct armament 1=
	5
	~	Year
	~		|

Total Armament 1= INTEG (
	armament spending 1-armament obsolescence 1,
		initial armament 1)
	~	M$
	~		|

