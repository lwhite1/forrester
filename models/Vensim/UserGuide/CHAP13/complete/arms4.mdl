{UTF-8}
armament capacity 1[region]=
	Economic Capacity 1[region] * max capacity to armament 1[region]
	~	M$/Year
	~		|

armament capacity 2[region]=
	Economic Capacity 2[region] * max capacity to armament 2[region]
	~	M$/Year
	~		|

armament lifetime 1[region]=
	20
	~	Year [2,60,1]
	~		|

armament lifetime 2[region]=
	20
	~	Year [2,60,1]
	~		|

armament obsolescence 1[region]=
	Total Armament 1[region]/armament lifetime 1[region]
	~	M$/Year
	~		|

armament obsolescence 2[region]=
	Total Armament 2[region]/armament lifetime 2[region]
	~	M$/Year
	~		|

armament spending 1[region]=
	armament capacity 1[region] * fraction armament capacity used 1[region]
	~	M$/Year
	~		|

armament spending 2[region]=
	armament capacity 2[region] * fraction armament capacity used 2[region]
	~	M$/Year
	~		|

capacity degradation 1[region]=
	Economic Capacity 1[region]/capacity lifetime1[region]
	~	M$/Year/Year
	~		|

capacity degradation 2[region]=
	Economic Capacity 2[region]/capacity lifetime 2[region]
	~	M$/Year/Year
	~		|

capacity lifetime 2[region]=
	30
	~	Year [3,80,1]
	~		|

capacity lifetime1[region]=
	30
	~	Year [3,80,1]
	~		|

desired strength ratio 1[region]=
	1
	~	Dmnl [0,5,0.1]
	~		|

desired strength ratio 2[region]=
	1
	~	Dmnl [0,5,0.1]
	~		|

Economic Capacity 1[region]= INTEG (
	growth in capacity1[region] - capacity degradation 1[region],
		initial economic capacity1[region])
	~	M$/Year
	~		|

Economic Capacity 2[region]= INTEG (
	growth in capacity 2[region] - capacity degradation 2[region],
		initial economic capacity2[region])
	~	M$/Year
	~		|

fraction armament capacity used 1[region]= WITH LOOKUP (
	ZIDZ(indicated armament building 1[region],armament capacity 1[region]),
		([(0,0)-(10,1),(0,0),(1,1),(10,1)],(0,0),(0.4,0.4),(2,0.8),(3,0.9),(5,1),(10,1) ))
	~	Dmnl
	~		|

fraction armament capacity used 2[region]= WITH LOOKUP (
	ZIDZ(indicated armament building 2[region],armament capacity 2[region]),
		([(0,0)-(10,1),(0,0),(1,1),(10,1)],(0,0),(0.4,0.4),(2,0.8),(3,0.9),(5,1),(10,1) ))
	~	Dmnl
	~		|

fraction spending to investment 1[region]=
	0.3
	~	Fraction [0,0.6,0.05]
	~		|

fraction spending to investment 2[region]=
	0.3
	~	Fraction [0,0.6,0.05]
	~		|

growth in capacity 2[region]=
	investment spending 2[region] * investment effectiveness 2[region]
	~	M$/Year/Year
	~		|

growth in capacity1[region]=
	investment spending 1[region] * investment effectiveness1[region]
	~	M$/Year/Year
	~		|

indicated armament building 1[region]=
	MAX(0,armament obsolescence 1[region] + (target armament 1[region] - Total Armament 1\
		[region])/time to correct armament 1[region])
	~	M$/Year
	~		|

indicated armament building 2[region]=
	MAX(0,armament obsolescence 2[region] + (target armament 2[region] - Total Armament 2\
		[region])/time to correct armament 2[region])
	~	M$/Year
	~		|

initial armament 1[region]=
	50
	~	M$ [0,200,5]
	~		|

initial armament 2[region]=
	50
	~	M$ [0,200,5]
	~		|

initial economic capacity1[region]=
	100
	~	M$/Year [10,500,5]
	~		|

initial economic capacity2[region]=
	100
	~	M$/Year [10,500,5]
	~		|

investment effectiveness 2[region]=
	0.15
	~	1/Year [0.01,0.4,0.01]
	~		|

investment effectiveness1[region]=
	0.15
	~	1/Year [0.01,0.4,0.01]
	~		|

investment spending 1[region]=
	non armament spending 1[region] * fraction spending to investment 1[region]
	~	M$/Year
	~		|

investment spending 2[region]=
	non armament spending 2[region] * fraction spending to investment 2[region]
	~	M$/Year
	~		|

max capacity to armament 1[region]=
	0.4
	~	Fraction [0,1,0.05]
	~		|

max capacity to armament 2[region]=
	0.4
	~	Fraction [0,1,0.05]
	~		|

non armament spending 1[region]=
	Economic Capacity 1[region] - armament spending 1[region]
	~	M$/Year
	~		|

non armament spending 2[region]=
	Economic Capacity 2[region] - armament spending 2[region]
	~	M$/Year
	~		|

region:
	east,west
	~	
	~		|

target armament 1[region]=
	Total Armament 2[region] * desired strength ratio 1[region]
	~	M$
	~		|

target armament 2[region]=
	Total Armament 1[region] * desired strength ratio 2[region]
	~	M$
	~		|

time to correct armament 1[region]=
	5
	~	Year [1,20,1]
	~		|

time to correct armament 2[region]=
	5
	~	Year [1,20,1]
	~		|

Total Armament 1[region]= INTEG (
	armament spending 1[region]-armament obsolescence 1[region],
		initial armament 1[region])
	~	M$
	~		|

Total Armament 2[region]= INTEG (
	armament spending 2[region]-armament obsolescence 2[region],
		initial armament 2[region])
	~	M$
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Year [0,?]
	~	The time step for the simulation.
	|

