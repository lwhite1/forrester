{UTF-8}
atmospheric CFC 11 releases
	~	
	~		|

CFC 11 destroyed = CFC 11 in Stratosphere / lifetime of CFC 11 in stratosphere
	~	Mkg/Year
	~		|

CFC 11 in Troposphere = INTEG(atmospheric CFC 11 releases-migration to stratosphere,0
)
	~	Mkg
	~		|

CFC 11 in Stratosphere = INTEG(+migration to stratosphere-CFC 11 destroyed,0)
	~	Mkg
	~		|

lifetime of CFC 11 in stratosphere = 55
	~	Year
	~		|

migration to stratosphere = CFC 11 in Troposphere / time to rise to stratosphere
	~	Mkg/Year
	~		|

time to rise to stratosphere = 5
	~	Year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 2130
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1930
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year
	~	The frequency with which output is stored.
	|

TIME STEP  = 2
	~	Year
	~	The time step for the simulation.
	|

