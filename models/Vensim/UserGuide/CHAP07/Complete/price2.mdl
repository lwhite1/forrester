{UTF-8}
change in price=
	IF THEN ELSE(target price > price,
	(target price - price)/time to adjust price up,
	(target price-price)/time to adjust price down)
	~	$/Box/Month
	~		|

time to adjust price down=
	6
	~	Month
	~		|

target price=
	target revenue/expected demand
	~	$/Box
	~		|

demand=
	reference demand * effect price demand
	~	Box/Month
	~		|

demand elasticity=
	1
	~	Dmnl
	~		|

effect price demand=
	EXP(-demand elasticity * LN(price/reference price))
	~	Dmnl
	~		|

expected demand=
	SMOOTH(demand,time to form expectations)
	~	Box/Month
	~		|

initial price=
	100
	~	$/Box
	~		|

price= INTEG (
	change in price,
		initial price)
	~	$/Box
	~		|

reference demand=
	100
	~	Box/Month
	~		|

reference price=
	100
	~	$/Box
	~		|

target revenue=
	10000+STEP(5000, 10)
	~	$/Month
	~		|

time to adjust price up=
	4
	~	Month
	~		|

time to form expectations=
	6
	~	Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

