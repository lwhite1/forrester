{UTF-8}
from minor to adult= DELAY FIXED (
	births, age of consent, 222222)
	~	person/Year
	~	kinderen/duur minderjarigheid
	|

delivery time=
	1
	~	Year
	~		|

new foreign prostitutes=
	MAX(profitability of prostitution*expected gap between demand and supply/delivery time\
		,0)
	~	person/Year
	~	profitability of prostitution*normal trafficked prostitutes
	|

loss of sexual activity=
	sexually active adults/sexual lifetime
	~	person/Year
	~		|

expected gap between demand and supply=
	demand for prostitutes-supply of prostitutes+prostitution outflow*delivery time
	~	
	~		|

total annual prostitution revenues=
	supply of prostitutes*frequency of prostitution visit*Johns per prostitute*average price of sex services
	~	euro/Year
	~		|

average price of sex services=
	SMOOTH3I(2*naked costs per sex service*supply demand effect on the price of sex services\
		, 1, 2*naked costs per sex service)
	~	euro/service
	~		|

prostitution outflow=
	supply of prostitutes/average lifetime in prostitution
	~	person/Year
	~		|

naked costs per sex service=
	20
	~	euro/service
	~		|

supply demand ratio=
	supply of prostitutes/demand for prostitutes
	~	Dmnl
	~		|

frequency of prostitution visit=
	24
	~	
	~		|

new Dutch prostitutes=
	MAX(from minor to adult/2*normal fraction of young Dutch adults open for a job in prostitution\
		*profitability of prostitution*societal acceptability of prostitution,0)
	~	person/Year
	~		|

societal acceptability of prostitution=
	SMOOTH3( MIN(1,MAX(0,influence of illegalisation on the societal acceptability of prostitution\
		*(1-supply of prostitutes/100000))), 3)
	~	Dmnl
	~		|

influence of illegalisation on the societal acceptability of prostitution=
	1-STEP(0.9,2013)
	~	
	~		|

demand for prostitutes=
	normal percentage clients of prostitutes*effect of societal acceptability on the percentage of Johns\
		*price effect on the demand for prostitutes/Johns per prostitute*sexually active adults\
		/2
	~	person/Year
	~		|

reduction of supply through illegalisation=
	supply of prostitutes/TIME STEP * PULSE(2013,1)
	~	
	~	aanbod aan prostituees/TIME STEP * PULSE(2012,1)*1
	|

supply of prostitutes= INTEG (
	new Dutch prostitutes+new foreign prostitutes-prostitution outflow-reduction of supply through illegalisation\
		,
		28254)
	~	persons
	~	23000
	|

sexually active adults= INTEG (
	from minor to adult-loss of sexual activity,
		1.2e+007)
	~	person
	~		|

sexual lifetime=
	45
	~	Year
	~		|

age of consent=
	18
	~	Year
	~		|

average lifetime in prostitution=
	10
	~	Year
	~		|

births=
	sexually active adults*birth rate
	~	person/Year
	~		|

birth rate=
	0.017
	~	1/Year
	~		|

children= INTEG (
	births-from minor to adult,
		4e+006)
	~	person
	~		|

effect of societal acceptability on the percentage of Johns=
	societal acceptability of prostitution/1.5+0.5
	~	Dmnl
	~	([(0,0)-(1,3)],(0,0.5),(1,1.2) )
	|

supply demand effect on the price of sex services= WITH LOOKUP (
	supply demand ratio,
		([(0,0)-(3,10)],(0,5),(0.05,3),(0.25,2),(1,1),(2,0.6),(3,0.5) ))
	~	Dmnl
	~		|

normal fraction of young Dutch adults open for a job in prostitution=
	0.001
	~	Dmnl
	~		|

normal percentage clients of prostitutes=
	0.12
	~	Dmnl
	~	0.12
	|

Johns per prostitute=
	50
	~	Dmnl
	~		|

price effect on the demand for prostitutes= WITH LOOKUP (
	average price of sex services,
		([(0,0)-(1000,4)],(0,4),(50,1.5),(100,1),(200,0.5),(400,0.2),(800,0.1),(1000,0.1) )\
		)
	~	Dmnl
	~		|

profitability of prostitution=
	(average price of sex services-naked costs per sex service)/naked costs per sex service
	~	Dmnl
	~	([(0,-0.6)-(500,5)],(0,0),(25,0),(50,0.1),(100,0.4),(200,1),(500,4) )
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2040
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 2000
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0078125
	~	Year [0,?]
	~	The time step for the simulation.
	|

