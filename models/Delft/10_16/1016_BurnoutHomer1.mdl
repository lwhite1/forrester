{UTF-8}
cumulative accomplishments= INTEG (
	accomplishments per week,
		0)
	~	
	~		|

perceived adequacy of accomplishment=
	perceived accomplishments per week / expected accomplishments per week
	~	Dmnl
	~		|

fractional change in expectations from perceived adequacy = WITH LOOKUP (
	perceived adequacy of accomplishment,
		([(0,-0.8)-(1.6,0.4)],(0,-0.7),(0.2,-0.5),(0.4,-0.35),(0.6,-0.2),(0.8,-0.1),(1,0),(\
		1.2,0.1),(1.4,0.25),(1.6,0.4) ))
	~	1/week
	~		|

energy level= INTEG (
	energy recovery-energy depletion,
		1)
	~	energyunits
	~		|

bias for fractional change in expectations=
	0.1
	~	1/week
	~		|

change in expected accomplishments per week=
	expected accomplishments per week * fractional change in expected accomplishments per week
	~	tasks/week/week
	~		|

change in hours worked per week=
	(indicated hours worked per week - hours worked per week) / time to adjust hours worked per week
	~	hour / week / week
	~		|

change in perceived accomplishments per week=
	(accomplishments per week - perceived accomplishments per week) / time to perceive accomplishments per week
	~	tasks/week/week
	~		|

effect of energy level on hours worked = WITH LOOKUP (
	energy level,
		([(0,0)-(1,1)],(0,0),(0.2,0.4),(0.4,0.7),(0.6,0.9),(0.8,1),(1,1) ))
	~	Dmnl
	~		|

effect of high energy on further recovery= WITH LOOKUP (
	energy level,
		([(0,0)-(1,1)],(0,1),(0.8,1),(0.85,0.9),(0.9,0.7),(0.95,0.4),(1,0) ))
	~	Dmnl
	~		|

effect of hours worked on energy depletion = WITH LOOKUP (
	hours worked per week,
		([(0,0)-(120,3)],(0,0.3),(20,0.6),(40,1),(60,1.5),(80,2),(100,2.5),(120,3) ))
	~	Dmnl
	~		|

effect of hours worked on recovery = WITH LOOKUP (
	hours worked per week,
		([(0,0)-(120,1.4)],(0,1.3),(20,1.2),(40,1),(60,0.7),(80,0.5),(100,0.35),(120,0.25) \
		))
	~	Dmnl
	~		|

effect of low energy on further depletion= WITH LOOKUP (
	energy level,
		([(0,0)-(1,1)],(0,0),(0.05,0.4),(0.1,0.7),(0.15,0.9),(0.2,1),(1,1) ))
	~	Dmnl
	~		|

effect of perceived adequacy on energy depletion = WITH LOOKUP (
	perceived adequacy of accomplishment,
		([(0,0)-(1.6,5)],(0,5),(0.2,4),(0.4,3.1),(0.6,2.3),(0.8,1.6),(1,1),(1.2,0.6),(1.4,0.4\
		),(1.6,0.3) ))
	~	Dmnl
	~		|

effect of perceived adequacy on hours worked = WITH LOOKUP (
	perceived adequacy of accomplishment,
		([(0,0.5)-(1.6,2.5)],(0,2.3),(0.2,1.9),(0.4,1.6),(0.6,1.35),(0.8,1.15),(1,1),(1.2,0.9\
		),(1.4,0.8),(1.6,0.75) ))
	~	Dmnl
	~		|

energy depletion=
	energy depletion normal * effect of perceived adequacy on energy depletion * effect of hours worked on energy depletion\
		 * effect of low energy on further depletion
	~	energyunits/week
	~		|

energy depletion normal=
	0.06
	~	energyunits/week
	~		|

indicated hours worked per week=
	MIN(limit on hours worked per week, (hours worked per week * effect of energy level on hours worked\
		 * effect of perceived adequacy on hours worked))
	~	hour/week
	~		|

energy recovery=
	energy recovery normal * effect of hours worked on recovery * effect of high energy on further recovery
	~	energyunits/week
	~		|

energy recovery normal=
	0.3
	~	energyunits/week
	~		|

expected accomplishments per week= INTEG (
	change in expected accomplishments per week,
		40)
	~	tasks/week
	~		|

fractional change in expected accomplishments per week=
	bias for fractional change in expectations + fractional change in expectations from perceived adequacy
	~	1/week
	~		|

hours worked per week= INTEG (
	change in hours worked per week,
		40)
	~	hour/week
	~		|

limit on hours worked per week=
	80
	~	hour/week
	~		|

perceived accomplishments per week= INTEG (
	change in perceived accomplishments per week,
		accomplishments per week)
	~	tasks/week
	~		|

time to perceive accomplishments per week=
	1
	~	week
	~		|

time to adjust hours worked per week=
	1
	~	week
	~		|

accomplishments per week=
	hours worked per week * accomplishments per hour
	~	tasks/week
	~		|

accomplishments per hour = WITH LOOKUP (
	energy level,
		([(0,0)-(1,1)],(0,0),(0.2,0.2),(0.4,0.4),(0.6,0.6),(0.8,0.8),(1,1) ))
	~	tasks/hour
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 75
	~	week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	week [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.015625
	~	week [0,?]
	~	The time step for the simulation.
	|

\\\---/// Sketch information - do not modify anything except names
V300  Do not put anything below this section - it will be ignored
