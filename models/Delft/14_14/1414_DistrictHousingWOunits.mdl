{UTF-8}
average lifetime=
	30
	~	Year
	~		|

fraction leaving= WITH LOOKUP (
	perceived quality of life by social housing families,
		([(0,0)-(1,1)],(0,1),(0.25,0.45),(0.5,0.15),(0.75,0.05),(1,0) ))
	~	
	~	100% of the remaining social housing families leave at a perceived quality of life \
		(QoL) of 0%, that 45% leave at a perceived QoL of 25%, that 15% leave at a \
		perceived QoL of 50%, that 5% leave at a perceived QoL of 75%,
		and that 0% leave at a perceived QoL of 100%
	|

fraction of social housing families=
	social housing families/3000
	~	
	~		|

importance foshf=
	2
	~	
	~		|

importance qosha=
	1
	~	
	~		|

initial average quality of the social housing apartments=
	0.7
	~	
	~		|

loss of quality of social housing apartments through ageing=
	total quality of all social housing apartments/average lifetime
	~	
	~		|

loss of total quality of social housing apartments at privatisation=
	outflow of social housing families*quality of social housing apartments
	~	
	~		|

outflow of social housing families=
	fraction leaving*social housing families
	~	
	~		|

perceived quality of life by social housing families=
	(fraction of social housing families*importance foshf+importance qosha*quality of social housing apartments\
		)/(importance foshf+importance qosha)
	~	
	~		|

quality of social housing apartments=
	total quality of all social housing apartments/social housing families
	~	
	~		|

refurbishment=
	refurbishment rate*(1-quality of social housing apartments)*social housing families
	~	
	~		|

refurbishment rate=
	0.05
	~	
	~		|

social housing families= INTEG (
	-outflow of social housing families,
		2990)
	~	
	~		|

total quality of all social housing apartments= INTEG (
	refurbishment-loss of quality of social housing apartments through ageing-loss of total quality of social housing apartments at privatisation\
		,
		initial average quality of the social housing apartments*social housing families)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 50
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

