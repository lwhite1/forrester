{UTF-8}
"Post-Operative Patients Directed Towards Aftercare"=
	MAX( ("Capacity of the Post-Operative Aftercare" - "Post-Operative Patients in Aftercare"\
		)/Average Administrative Processing Time before Hospitalisation of Transfer to Aftercare\
		 + "Non-Recovered Patients With Aftercare Referred Back to the Hospital"
	 + "Recovered Post-Operative Patients With Aftercare","Number of Discharged Post-Operative Patients"\
		)
	~	patient/Week
	~		|

Average Administrative Processing Time before Hospitalisation=
	1
	~	Week
	~		|

Average Administrative Processing Time before Hospitalisation of Transfer to Aftercare\
		=
	1
	~	Week
	~		|

"Hospitalisation of Pre-Operative Patients"=
	MAX((Capacity of the Hospital - Operative Patients in the Hospital)/Average Administrative Processing Time before Hospitalisation\
		 + "Post-Operative Patients Directed Towards Aftercare" + "Post-Operative Patients Directed Home Without Aftercare"
	,"Pre-Operative Patients on the Waiting List for Hospitalisation"/Average Administrative Processing Time before Hospitalisation\
		)
	~	patient/Week
	~		|

"Number of Discharged Post-Operative Patients"=
	Operative Patients in the Hospital/Average Residence Time in the Hospital
	~	patient/Week
	~		|

"Capacity of the Post-Operative Aftercare"=
	1000 + STEP(Capacity Extension of the Aftercare,26)
	~	patient
	~		|

Capacity of the Hospital=
	700+STEP(Capacity Extension of the Hospital,52)
	~	patient
	~		|

Capacity Extension of the Aftercare=
	0
	~	patient
	~	500
	|

Capacity Extension of the Hospital=
	0
	~	patient
	~	250
	|

Fraction of Recovered Patients With Aftercare=
	0.98
	~	Dmnl
	~		|

Fraction of Recovered Patients Without Aftercare=
	0.8
	~	Dmnl
	~		|

Average Recovery Time Without Aftercare=
	7
	~	Week
	~		|

Average Residence Time in Aftercare=
	3
	~	Week
	~		|

Average Residence Time in the Hospital=
	1
	~	Week
	~		|

"Recovered Post-Operative Patients With Aftercare"=
	Fraction of Recovered Patients With Aftercare * "Post-Operative Patients in Aftercare"\
		 / Average Residence Time in Aftercare
	~	patient/Week
	~		|

"Recovered Post-Operative Patients Without Aftercare"=
	Fraction of Recovered Patients Without Aftercare * "Post-Operative Patients Without Aftercare"\
		/Average Recovery Time Without Aftercare
	~	patient/Week
	~		|

"Newly Referred Pre-Operative Patients"=
	800
	~	patient/Week
	~		|

Operative Patients in the Hospital= INTEG (
	+"Hospitalisation of Pre-Operative Patients"-"Post-Operative Patients Directed Towards Aftercare"\
		-"Post-Operative Patients Directed Home Without Aftercare",
		Capacity of the Hospital)
	~	patient
	~		|

"Post-Operative Patients in Aftercare"= INTEG (
	+"Post-Operative Patients Directed Towards Aftercare"+"Recovered Post-Operative Patients With Aftercare"\
		-"Non-Recovered Patients With Aftercare Referred Back to the Hospital",
		"Capacity of the Post-Operative Aftercare")
	~	patient
	~		|

"Post-Operative Patients Directed Home Without Aftercare"=
	"Number of Discharged Post-Operative Patients" - "Post-Operative Patients Directed Towards Aftercare"
	~	patient/Week
	~		|

"Post-Operative Patients Without Aftercare"= INTEG (
	+"Post-Operative Patients Directed Home Without Aftercare"-"Recovered Post-Operative Patients Without Aftercare"\
		-"Non-Recovered Patients Without Aftercare Referred Back to the Hospital",
		300)
	~	patient
	~		|

"Pre-Operative Patients on the Waiting List for Hospitalisation"= INTEG (
	"Newly Referred Pre-Operative Patients"+"Non-Recovered Patients Without Aftercare Referred Back to the Hospital"\
		+"Non-Recovered Patients With Aftercare Referred Back to the Hospital"-"Hospitalisation of Pre-Operative Patients"\
		,
		2000)
	~	patient
	~		|

"Non-Recovered Patients Without Aftercare Referred Back to the Hospital"=
	(1-Fraction of Recovered Patients Without Aftercare) * "Post-Operative Patients Without Aftercare"\
		 / Average Recovery Time Without Aftercare
	~	patient/Week
	~		|

"Non-Recovered Patients With Aftercare Referred Back to the Hospital"=
	(1 - Fraction of Recovered Patients With Aftercare) * "Post-Operative Patients in Aftercare"\
		 / Average Residence Time in Aftercare
	~	patient/Week
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 156
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Week [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.03125
	~	Week [0,?]
	~	The time step for the simulation.
	|

