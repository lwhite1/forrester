fractie effectieve wachttijd over gewenste wachttijd  = A FUNCTION OF( gemiddelde effectieve wachttijd per toestel\
		,gewenste wachttijd)
	~	
	~		|

gewenste wachttijd  = A FUNCTION OF( impliciete maximaal aanvaardbare wachttijd per apparaat\
		)
	~	
	~		|

aantal fitness toestellen  = A FUNCTION OF( )
	~	
	~		|

aantal leden  = A FUNCTION OF( nieuwe leden,ontevreden opzeggers)
	~	
	~		|

fractie aantal leden over gewenste aantal leden  = A FUNCTION OF( aantal leden,gewenste aantal leden\
		)
	~	
	~		|

gemiddelde effectieve wachttijd per toestel  = A FUNCTION OF( aantal leden,aantal fitness toestellen\
		)
	~	
	~		|

impliciete maximaal aanvaardbare wachttijd per apparaat  = A FUNCTION OF( )
	~	
	~		|

gewenste aantal leden  = A FUNCTION OF( )
	~	
	~		|

inschrijvingskostprijs  = A FUNCTION OF( fractie aantal leden over gewenste aantal leden\
		)
	~	
	~		|

maandelijkse kostprijs lidmaatschap  = A FUNCTION OF( )
	~	
	~		|

nieuwe leden  = A FUNCTION OF( inschrijvingskostprijs,maandelijkse kostprijs lidmaatschap\
		,positieve mond tot mond reclame)
	~	
	~		|

ontevreden opzeggers  = A FUNCTION OF( tevredenheid)
	~	
	~		|

positieve mond tot mond reclame  = A FUNCTION OF( aantal leden,tevredenheid)
	~	
	~		|

tevredenheid  = A FUNCTION OF( fractie effectieve wachttijd over gewenste wachttijd)
	~	
	~		|

