{UTF-8}
EV batteries needed=
	electrification European vehicle fleet*battery per vehicle+"electric vehicles (EV)"/\
		average lifetime EV batteries*batteries per vehicle
	~	accu/year
	~		|

battery per vehicle=
	1
	~	accu/auto
	~		|

lithium exploitation=
	MAX(MIN(total demand lithium to be exploited-lithium in recycling/average recycling time\
		,unexploited lithium reserves/exploitation time),0)
	~	ktonLi/year
	~		|

lithium from recycling to reprocessing=
	lithium in recycling/average recycling time
	~	ktonLi/year
	~		|

average recycling time=
	0.25
	~	year
	~		|

processing and introduction time
	=1
	~	year
	~		|

exploitation time=
	0.0825
	~	year
	~		|

lithium products brought into use=
	processing of lithium in products/processing and introduction time
	~	ktonLi/year
	~		|

batteries per vehicle=
	1
	~	accu/auto
	~		|

approximated fraction of lithium use in EV batteries over the total amount of lithium in use\
		=
	lithium needed for EV batteries/total demand lithium to be exploited
	~	Dmnl
	~		|

lithium needed for EV batteries=
	lithium per EV battery*EV batteries needed
	~	ktonLi/year
	~		|

conventional vehicles= INTEG (
	-electrification European vehicle fleet,
		1e+008)
	~	auto
	~		|

average lifetime products containing lithium=
	average use time of ICT products containing lithium*(1-approximated fraction of lithium use in EV batteries over the total amount of lithium in use\
		)+"average lifetime EV batteries (during and after use in EV)"*approximated fraction of lithium use in EV batteries over the total amount of lithium in use
	~	year
	~		|

electrification European vehicle fleet=
	intensive advertisement*conventional vehicles/average lifetime conventional vehicles\
		*"electric vehicles (EV)"/totale European vehicle fleet
	~	auto/year
	~		|

"electric vehicles (EV)"= INTEG (
	+electrification European vehicle fleet,
		1000)
	~	auto
	~		|

"average lifetime EV batteries (during and after use in EV)"=
	10
	~	year
	~		|

average use time of ICT products containing lithium=
	5
	~	year
	~		|

average lifetime conventional vehicles=
	9
	~	year
	~		|

average lifetime EV batteries=
	3
	~	year
	~		|

lithium per EV battery=
	2e-005
	~	ktonLi/accu
	~		|

growth rate lithium demand ICT sector=
	0
	~	1/year
	~		|

total demand lithium to be exploited=
	lithium needed for EV batteries+annual ICT lithium demand
	~	ktonLi/year
	~		|

processing of lithium in products= INTEG (
	+lithium exploitation-lithium products brought into use+lithium from recycling to reprocessing\
		,
		22)
	~	ktonLi
	~		|

net increase annual ICT lithium demand=
	annual ICT lithium demand*growth rate lithium demand ICT sector
	~	ktonLi/year/year
	~		|

intensive advertisement=
	10-STEP(9,2017)
	~	Dmnl
	~		|

annual ICT lithium demand= INTEG (
	net increase annual ICT lithium demand,
		20)
	~	ktonLi/year
	~		|

totale European vehicle fleet=
	conventional vehicles+"electric vehicles (EV)"
	~	auto
	~		|

lithium in products= INTEG (
	lithium products brought into use-"loss of non-recyled lithium"-recovery lithium through recycling\
		,
		initial value lithium in products)
	~	ktonLi
	~		|

initial value lithium in products=
	100
	~	ktonLi
	~		|

initially unexploited lithium reserves=
	13000
	~	ktonLi
	~		|

lithium in recycling= INTEG (
	recovery lithium through recycling-lithium from recycling to reprocessing,
		0)
	~	ktonLi
	~		|

recovery lithium through recycling=
	lithium in products/average lifetime products containing lithium * effective recycling fraction lithium
	~	ktonLi/year
	~		|

"loss of non-recyled lithium"=
	lithium in products/average lifetime products containing lithium * (1-effective recycling fraction lithium\
		)
	~	ktonLi/year
	~		|

unexploited lithium reserves= INTEG (
	-lithium exploitation,
		initially unexploited lithium reserves)
	~	ktonLi
	~		|

effective recycling fraction lithium=
	0.2
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2100
	~	year
	~	The final time for the simulation.
	|

INITIAL TIME  = 2009
	~	year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	year
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.015625
	~	year
	~	The time step for the simulation.
	|

