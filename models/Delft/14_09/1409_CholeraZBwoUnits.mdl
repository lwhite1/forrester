{UTF-8}
recorded cholera cases=
	heavily infected+mildly infected*0.25
	~	
	~		|

effect of prevention and sanitation on the indirect degree of infection= WITH LOOKUP \
		(
	MAX(condition of the sanitary infrastructure,level of prevention),
		([(0,0)-(1,1)],(0,1),(0.25,0.9),(0.5,0.5),(0.75,0.1),(1,0) ))
	~	
	~		|

level of prevention= GAME (
	0.1)
	~	Dmnl
	~	([(0,0)-(4000,10)],(0,0.1),(130,0.1),(186,0.3),(206,0.5),(365,0.8),(3650,0.\
		8) )
	|

fraction of infected=
	(recently infected population+mildly infected population+heavily infected population\
		)/(recently infected population
+mildly infected population+heavily infected population+susceptible population+recovered temporarily immune population\
		)
	~	Dmnl
	~		|

smoothed fraction of contaminated water=
	DELAY3I(effect of the fraction of infected on the fraction of contaminated water, 14\
		, 0.0004)
	~	
	~		|

indirect degree of infection=
	smoothed fraction of contaminated water*effect of prevention and sanitation on the indirect degree of infection\
		*connectedness of aquifers
	~	1/Day
	~		|

cumulative cholera cases= INTEG (
	recorded cholera cases,
		0)
	~	
	~		|

connectedness of aquifers=
	0.28
	~	
	~		|

cholera deaths=
	heavily infected population/average duration of illness*effect of the average state of health services on the fraction of cholera deaths
	~	person/Day
	~		|

cumulative cholera deaths= INTEG (
	cholera deaths,
		0)
	~	person
	~		|

effect of the fraction of infected on the fraction of contaminated water= WITH LOOKUP\
		 (
	fraction of infected,
		([(0,0)-(1,1)],(0,0),(0.125,0.5),(0.25,0.75),(0.5,0.9),(0.75,0.99),(1,1) ))
	~	
	~	([(0,0)-(1,1)],(0,0),(0.25,0.8),(0.5,0.95),(0.75,0.98),(1,1) )\!\!\!
	|

effect of the average health condition on the fraction of mildly infected of all infected\
		=
	0.95
	~	
	~		|

effect of the average state of health services on the fraction of cholera deaths= WITH LOOKUP\
		 (
	average state of health services,
		([(0,0)-(1,1)],(0,1),(0.25,0.5),(0.5,0.2),(0.75,0.05),(1,0) ))
	~	
	~		|

recently infected population= INTEG (
	cholera infections-mildly infected-heavily infected,
		0)
	~	
	~		|

average immunity period=
	6*365
	~	Day
	~		|

average incubation time=
	1
	~	Day
	~		|

average state of health services= GAME (
	0.15)
	~	
	~	([(0,0)-(4000,1)],(0,0.15),(130,0.15),(183,0.4),(206,0.7),(250,0.75),(300,0\
		.8),(3650,0.8) ) over time
	|

average duration of illness=
	10
	~	Day
	~		|

recovered from heavy infection=
	heavily infected population/average duration of illness*(1-effect of the average state of health services on the fraction of cholera deaths\
		)
	~	person/Day
	~		|

recovered temporarily immune population= INTEG (
	recovered from heavy infection+recovered from mild infection-recovered to susceptible by loss of immunity\
		,
		1.3228e+007-3e+006-1000-1000-50)
	~	person
	~		|

recovered to susceptible by loss of immunity=
	recovered temporarily immune population/average immunity period
	~	
	~		|

cholera infections=
	susceptible population*indirect degree of infection
	~	person/Day
	~		|

mildly infected population= INTEG (
	+mildly infected-recovered from mild infection,
		0)
	~	person
	~		|

recovered from mild infection=
	mildly infected population/average duration of illness
	~	person/Day
	~		|

condition of the sanitary infrastructure= GAME (
	0.5)
	~	Dmnl
	~	([(0,0)-(4000,1)],(0,0.5),(183,0.55),(365,0.6),(1825,0.85),(3650,0.9) ) \
		over time
	|

mildly infected=
	recently infected population/average incubation time*effect of the average health condition on the fraction of mildly infected of all infected
	~	person/Day
	~		|

heavily infected=
	recently infected population/average incubation time*(1-effect of the average health condition on the fraction of mildly infected of all infected\
		)
	~	
	~		|

heavily infected population= INTEG (
	+heavily infected-cholera deaths-recovered from heavy infection,
		0)
	~	person
	~		|

susceptible population= INTEG (
	recovered to susceptible by loss of immunity-cholera infections,
		3e+006)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 3650
	~	Day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Day
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.5
	~	Day
	~	The time step for the simulation.
	|

