{UTF-8}
cumulative cholera deaths  = A FUNCTION OF( average state of health services,infected population\
		) ~~|
cumulative cholera deaths= INTEG (
	cholerasterftes,
		0)
	~	person
	~		|

fraction of infected  = A FUNCTION OF( recovered temporarily immune population,infected population\
		,susceptible population) ~~|
fraction of infected=
	(infecties+infected population+Zwaar Geinfecteerde Populatie)/(infecties
+infected population+Zwaar Geinfecteerde Populatie+susceptible population+recovered temporarily immune population
)
	~	Dmnl
	~		|

smoothed fraction of contaminated water  = A FUNCTION OF( fraction of infected) ~~|
smoothed fraction of contaminated water=
	DELAY1I(effect van de fractie geinfecteerden op de fractie besmet water, 30, 0.0005)
	~	
	~		|

recovered temporarily immune population  = A FUNCTION OF( infected population) ~~|
recovered temporarily immune population= INTEG (
	herstelden van een zwaar ziekbed+herstelden van een licht ziekbed-herstelden naar vatbaren door verlies immuniteit\
		,
		7.25e+006)
	~	person
	~		|

indirect infection rate  = A FUNCTION OF( prevention and sanitation infrastructure on the infection rate\
		,smoothed fraction of contaminated water) ~~|
indirect infection rate=
	smoothed fraction of contaminated water*prevention and sanitation infrastructure on the infection rate\
		*verbondenheid aquifers
	~	1/Day
	~		|

infections  = A FUNCTION OF( indirect infection rate,susceptible population) ~~|
infections= INTEG (
	cholera infecties-zieken met lichte symptomen-zieken met zware symptomen,
		280)
	~	
	~		|

prevention and sanitation infrastructure on the infection rate  = A FUNCTION OF( ) ~~|
prevention and sanitation infrastructure on the infection rate= WITH LOOKUP (
	MAX(conditie van de sanitaire infrastructuur,niveau van preventie),
		([(0,0)-(1,1)],(0,1),(0.25,0.9),(0.5,0.5),(0.75,0.1),(1,0) ))
	~	
	~		|

infected population  = A FUNCTION OF( infections) ~~|
infected population= INTEG (
	+zieken met lichte symptomen-herstelden van een licht ziekbed,
		1500)
	~	person
	~		|

susceptible population  = A FUNCTION OF( recovered temporarily immune population,infections\
		) ~~|
susceptible population= INTEG (
	herstelden naar vatbaren door verlies immuniteit-cholera infecties,
		4e+006)
	~	
	~		|

average state of health services=
	0.7
	~	
	~	0.35 + 0*STEP(0.35,150)
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 3650
	~	Day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Day
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Day
	~	The time step for the simulation.
	|

