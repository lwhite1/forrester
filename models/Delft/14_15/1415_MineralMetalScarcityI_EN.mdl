{UTF-8}
use of RAM in production of goods=
	MIN(Available Supply of RAM/demand supply time,demand for RAM)
	~	t/Year
	~		|

demand supply time=
	1
	~	Year
	~		|

planning time=
	1
	~	Year
	~		|

decommissioning unprofitable extraction capacity=
	Installed Extraction Capacity* (-MIN(profitability of RAM extraction,0))/closing time
	~	t/Year/Year
	~	SMOOTH3I(winstgevendheid ZAM extractie,5,winstgevendheid ZAM extractie)
	|

closing time=
	1
	~	Year
	~		|

newly planned extraction capacity=
	MIN(MAX(profitability of RAM extraction, 0),1)*MIN(MAX(desired extraction capacity-Installed Extraction Capacity\
		,0),Installed Extraction Capacity
	)/planning time
	~	t/Year/Year
	~		|

supply demand ratio=
	Available Supply of RAM/demand for RAM/demand supply time
	~	Dmnl
	~		|

substitution loses=
	MAX((relative price-relative price of the cheapest price substitute)/relative price \
		* demand for RAM, 0)/demand supply time
	~	t/Year/Year
	~	IF THEN ELSE(relatieve prijs > relatieve prijs van het goedkoopste \
		prijssubstituut, (relatieve prijs-relatieve prijs van het goedkoopste \
		prijssubstituut)/relatieve prijs * vraag naar ZAM, 0)
	|

economic growth rate= WITH LOOKUP (
	relative price,
		([(0,-0.2)-(100,10)],(0,0.05),(1,0.03),(100,-0.1) ))
	~	1/Year
	~	([(2000,-0.4)-(2050,0.4)],(2000,0.03),(2008,0.03),(2009,-0.3),(2010,0.2),(2\
		011,0.03),(2050,0.03) )
	|

real RAM extraction=
	Installed Extraction Capacity*MIN(scarcity price effect,1)
	~	t/Year
	~	maximale ZAM extractie maal schaarsteprijseffect
	|

net change intrinsic demand=
	economic growth rate*Intrinsic Demand
	~	t/Year/Year
	~	economic growth rate*Intrinsic Annual Demand
	|

growth demand for RAM=
	demand for RAM*economic growth rate
	~	t/Year/Year
	~		|

commissioning extraction capacity= DELAY FIXED (
	newly planned extraction capacity, precise construction time of extraction capacity,\
		 Extraction Capaciteit under Construction/precise construction time of extraction capacity\
		)
	~	t/Year/Year
	~		|

profitability of RAM extraction=
	(relative price-average RAM extraction costs)/average RAM extraction costs
	~	Dmnl
	~		|

processing of RAM=
	real RAM extraction
	~	t/Year
	~	MIN(X,Annual Demand-recycled)
	|

average RAM extraction costs= WITH LOOKUP (
	(Cumulatively Extracted RAM-initially cumulatively extracted amount),
		([(0,0)-(2e+007,800)],(0,1),(2e+006,2),(4e+006,4),(6e+006,8),(8e+006,16),(1e+007,32\
		),(1.2e+007,64),(1.4e+007,128),(1.6e+007,256),(1.8e+007,512) ))
	~	Dmnl
	~	([(0,0)-(2e+007,800)],(0,1.25),(2e+006,2.5),(4e+006,5),(6e+006,10),(8e+006,\
		20),(1e+007,40),(1.2e+007,80),(1.4e+007,160),(1.6e+007,320),(1.8e+007,640) \
		)
	|

Available Supply of RAM= INTEG (
	processing of RAM-use of RAM in production of goods,
		initial available supply of RAM)
	~	t
	~		|

relative price=
	scarcity price effect * average RAM extraction costs * (1+normal profitability margin\
		)
	~	Dmnl
	~		|

average lifetime in goods=
	15
	~	Year
	~		|

loss of RAM in goods=
	RAM in Goods/average lifetime in goods
	~	t/Year
	~		|

RAM in Goods= INTEG (
	use of RAM in production of goods-loss of RAM in goods,
		initial amount of RAM in goods)
	~	t
	~		|

desired extraction capacity=
	demand for RAM
	~	t/Year
	~	FORECAST( vraag naar ZAM, 2, 4)
	|

normal profitability margin=
	0.15
	~	Dmnl
	~		|

initial extraction capacity under construction=
	60000
	~	t/Year
	~		|

Extraction Capaciteit under Construction= INTEG (
	newly planned extraction capacity-commissioning extraction capacity,
		60000)
	~	t/Year
	~		|

relative price of the cheapest price substitute=
	100
	~	Dmnl
	~		|

demand for RAM= INTEG (
	growth demand for RAM-substitution loses-demand reduction via price elasticity of demand\
		,
		initial annual demand for RAM)
	~	t/Year
	~		|

demand reduction via price elasticity of demand=
	-price elasticity of demand*demand for RAM*(1/relative price-1/relative price previous year\
		)/(1/relative price previous year)
	~	t/Year/Year
	~		|

scarcity price effect= WITH LOOKUP (
	supply demand ratio,
		([(0,0)-(40,1)],(0,100),(0.55,10),(1.1,1),(2.2,0.75),(10.2752,0.372807),(22,0.2) ))
	~	Dmnl
	~		|

price elasticity of demand=
	0.1
	~	1/Year
	~		|

relative price previous year=
	DELAY FIXED(relative price, 1, relative price)
	~	Dmnl
	~	MIN(MAX(1/(DELAY1I(relative price, 1, relative price)),0),1)
	|

production wrt intrinsic demand=
	use of RAM in production of goods/Intrinsic Demand
	~	Dmnl
	~		|

precise construction time of extraction capacity=
	8
	~	Year
	~		|

average life time of extraction capacity=
	30
	~	Year
	~		|

Installed Extraction Capacity= INTEG (
	commissioning extraction capacity-decommissioning extraction capacity at end of lifetime\
		-decommissioning unprofitable extraction capacity,
		initial extraction infrastructure)
	~	t/Year
	~		|

decommissioning extraction capacity at end of lifetime=
	MAX(Installed Extraction Capacity/average life time of extraction capacity-decommissioning unprofitable extraction capacity\
		,0)
	~	t/Year/Year
	~		|

initially cumulatively extracted amount=
	4e+006
	~	t
	~		|

Cumulatively Extracted RAM= INTEG (
	real RAM extraction,
		initially cumulatively extracted amount)
	~	t
	~		|

Intrinsic Demand= INTEG (
	net change intrinsic demand,
		initial annual demand for RAM)
	~	t/Year
	~		|

initial annual demand for RAM=
	100000
	~	t/Year
	~		|

initial available supply of RAM=
	250000
	~	t
	~		|

initial extraction infrastructure=
	100000
	~	t/Year
	~		|

initial amount of RAM in goods=
	2e+006
	~	t
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2200
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 2000
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

