{UTF-8}
replacement houses = demolishing
	~	house/Month
	~		|

planning=
	replacement houses + (houses gap / average time to respond to housing gap)
	~	house/Month
	~		|

average house lifetime = 1200
	~	Month
	~		|

building = planned houses / average time from planning to building
	~	house/Month
	~		|

completing = houses under construction / time to build houses
	~	house/Month
	~		|

demolishing = houses / average house lifetime
	~	house/Month
	~		|

houses gap=
	( desired number of houses - houses)
	~	house
	~		|

houses= INTEG (
	+completing-demolishing,
		 5e+006)
	~	house
	~		|

houses under construction = INTEG(building-completing, building * time to build houses\
		)
	~	house
	~		|

desired number of houses=
	5e+006-STEP(50000,20)+STEP(100000,40)
	~	house
	~		|

planned houses = INTEG(+planning - building, planning * average time from planning to building\
		)
	~	house
	~		|

time to build houses = 6
	~	Month
	~		|

average time from planning to building=
	 3
	~	Month
	~		|

average time to respond to housing gap=
	 8
	~	Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Month
	~		The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~		The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~		The frequency with which output is stored.
	|

TIME STEP  = 0.5
	~	Month
	~		The time step for the simulation.
	|

