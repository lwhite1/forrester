{UTF-8}
Additional licenses=
	Muskrat population/Number of muskrats per additional license * switch additional licenses
	~	licenses/Year
	~		|

Muskrats caught=
	Muskrats per trap*Traps per license* (Initial licences + Additional licenses)
	~	Muskrats/Year
	~		|

Initial number of muskrats=
	200
	~	Muskrats
	~		|

Muskrat population= INTEG (
	+New muskrats-Muskrats caught,
		Initial number of muskrats)
	~	Muskrats
	~		|

switch additional licenses=
	0
	~	dmnl
	~	1 to turn on
	|

Number of muskrats per additional license=
	1000
	~	Muskrats/(licenses/Year)
	~	0
	|

Initial licences=
	10
	~	licenses/Year
	~	10
	|

Muskrats per trap=
	Muskrat population * Proportionality factor
	~	Muskrats/traps
	~		|

New muskrat rate=
	20
	~	1/Year
	~		|

New muskrats=
	New muskrat rate*Muskrat population
	~	Muskrats/Year
	~		|

Proportionality factor=
	0.195
	~	1/traps
	~		|

Traps per license=
	10
	~	traps/licenses
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 10
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

