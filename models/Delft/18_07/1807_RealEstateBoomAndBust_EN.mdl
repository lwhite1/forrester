{UTF-8}
relative attractiveness to immigrate=
	(avg salary immigrants/normal salary immigrants)/(REU price/subsidy)
	~	Dmnl
	~		|

subsidy=
	960
	~	dollar/real estate unit
	~		|

workforce emigration=
	MAX((immigrants-labour demand)/avg emigration time,0)
	~	person/Month
	~	+ MAX(exogenous emigration/avg emigration time,0)
	|

REU price=
	normal cost REU*REU shortage price effect(REU shortage)
	~	dollar/real estate unit
	~		|

REU under construction= INTEG (
	new REU plans approved-REU commissioning,
		immigrants/workers per REU under construction)
	~	real estate unit
	~		|

labour shortage=
	labour demand/immigrants
	~	Dmnl
	~		|

REU shortage price effect(
	[(0,0)-(100,25)],(0,0.6),(10,4),(50,7.5),(100,10))
	~	Dmnl
	~		|

avg REU approval time=
	1
	~	Month
	~		|

avg emigration time=
	1
	~	Month
	~		|

avg immigration time=
	1
	~	Month
	~		|

avg lifetime REU=
	500
	~	Month
	~		|

avg salary immigrants=
	normal salary immigrants*labour shortage
	~	dollar/person/Month
	~		|

Al Maktoum exogenous investment rate=
	0.01
	~	Dmnl
	~	-STEP(0.01,10)
	|

expected new REU due to immigration=
	(immigrants - immigrants previous period)*immigration multiplication factor
	~	real estate unit
	~		|

expected REU shortage=
	REU demand-REU supply-REU under construction + expected new REU due to immigration
	~	real estate unit
	~		|

immigrants= INTEG (
	workforce immigration-workforce emigration-immigrant integration,
		2e+006)
	~	person
	~		|

immigrants previous period=
	DELAY FIXED(immigrants, 1, immigrants)
	~	person
	~		|

workforce immigration=
	MAX(relative attractiveness to immigrate*immigrants/avg immigration time,0)
	~	person/Month
	~	+MIN((labour demand-immigrants)/avg emigration time,0)   relative \
		attractiveness to immigrate*immigrants/avg immigration time
	|

immigration multiplication factor=
	1
	~	real estate unit/person
	~		|

immigrant integration=
	immigrants*immigrant integration rate
	~	person/Month
	~		|

immigrant integration rate=
	0.001
	~	1/Month
	~		|

labour demand=
	workers per REU under construction*REU under construction
	~	person
	~	number of workers per real estate unit under construction*real estate units under \
		construction*normal reu construction time
		/real estate unit construction time
	|

locals= INTEG (
	immigrant integration,
		220000)
	~	person
	~		|

new REU plans approved=
	MAX(expected REU shortage/avg REU approval time,0) + Al Maktoum exogenous investment rate\
		*REU supply/avg REU approval time
	~	real estate unit/Month
	~		|

normal cost REU=
	50000 + avg salary immigrants*REU construction time*workers per REU under construction
	~	dollar/real estate unit
	~		|

normal salary immigrants=
	1000
	~	dollar/person/Month
	~		|

REU supply= INTEG (
	REU commissioning-REU demolition,
		1.8e+006)
	~	real estate unit
	~		|

REU shortage=
	REU demand/REU supply
	~	Dmnl
	~		|

REU commissioning=
	MIN(immigrants/workers per REU under construction,REU under construction)/REU construction time
	~	real estate unit/Month
	~	MIN(real estate units under construction/real estate unit construction \
		time,MAX(0,buffer))
	|

REU construction time=
	3
	~	Month
	~		|

REU demand=
	(immigrants+locals)*REU demand per person
	~	real estate unit
	~		|

REU demand per person= WITH LOOKUP (
	Time,
		([(0,0)-(2000,10)],(0,1),(240,2)))
	~	real estate unit/person
	~		|

REU demolition=
	REU supply/avg lifetime REU
	~	real estate unit/Month
	~		|

workers per REU under construction=
	25
	~	person/real estate unit
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 240
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Month [0,?]
	~	The time step for the simulation.
	|

\\\---/// Sketch information - do not modify anything except names
