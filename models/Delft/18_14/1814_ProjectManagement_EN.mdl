{UTF-8}
fraction personnel for testing= WITH LOOKUP (
	reported fraction detection undiscovered rework,
		([(0,0)-(1,1)],(0,0.1),(0.2,0.15),(0.4,0.3),(0.6,0.6),(0.8,0.75),(1,0.8) ))
	~	dmnl
	~	gerapporteerde fractie detectie van onontdekt rework
	|

average quality of completed project tasks=
	properly completed project tasks/MAX((properly completed project tasks+undiscovered rework\
		),1)
	~	dmnl
	~		|

productivity of testing=
	maximum productivity of testing*fraction undiscovered rework
	~	tasks/(person*Month)
	~		|

initial project time remaining=
	40
	~	Month
	~		|

remaining project tasks= INTEG (
	detecting undiscovered rework-poor completion of project tasks-proper completion of project tasks\
		,
		initial number of project tasks)
	~	tasks
	~		|

perceived time remaining=
	MAX(0.25,SMOOTHI(Time + (perceived effort remaining/desired workforce),time to adapt the project schedule\
		,initial project time remaining) - Time)
	~	Month
	~	Time remaining
	|

additional cumulative effort=
	workforce
	~	Month*person/Month
	~		|

reported fraction detection undiscovered rework=
	DELAY3I( detecting undiscovered rework/(proper completion of project tasks+detecting undiscovered rework\
		),1,0)
	~	dmnl
	~		|

fraction undiscovered rework=
	undiscovered rework/MAX(perceived cumulative progress,0.01)
	~	dmnl
	~		|

project personnel=
	(1-fraction personnel for testing)*workforce
	~	person
	~		|

maximum productivity of testing=
	2
	~	tasks/(person*Month)
	~		|

detecting undiscovered rework=
	productivity of testing*testing personnel
	~	tasks/Month
	~		|

progress=
	gross productivity of project personnel*project personnel
	~	tasks/Month
	~		|

testing personnel=
	fraction personnel for testing*workforce
	~	person
	~		|

gross productivity of project personnel= WITH LOOKUP (
	remaining project tasks,
		([(0,0)-(1200,1)],(0,0.2),(50,0.85),(75,0.95),(100,1),(200,1),(1200,1) ))
	~	tasks/person/Month
	~		|

perceived effort remaining=
	remaining project tasks/MAX(perceived productivity,1)
	~	person*Month
	~		|

undiscovered rework= INTEG (
	poor completion of project tasks - detecting undiscovered rework,
		0)
	~	tasks
	~		|

cumulative effort= INTEG (
	additional cumulative effort,
		0.001)
	~	person*Month
	~		|

properly completed project tasks= INTEG (
	proper completion of project tasks,
		0)
	~	tasks
	~		|

poor completion of project tasks=
	progress*(1 - fraction properly completed)
	~	tasks/Month
	~		|

proper completion of project tasks=
	progress* fraction properly completed
	~	tasks/Month
	~		|

time to adapt workforce=
	1
	~	Month
	~		|

time to adapt the project schedule=
	1
	~	Month
	~		|

net hiring of personnel=
	(desired workforce - workforce)/time to adapt workforce
	~	person/Month
	~	(gewenst personeelsbestand - personeelsbestand)/tijd om personeelsbestand \
		aan te passen
	|

perceived cumulative progress=
	properly completed project tasks + undiscovered rework
	~	tasks
	~	behoorlijk afgewerkte projecttaken + MAX(0,"gebrekkig afgewerkte \
		projecttaken (undiscovered rework)")
	|

FINAL TIME=
	IF THEN ELSE(perceived fraction completed<0.999,200,Time)
	~	Month
	~	The final time for the simulation.
	|

perceived fraction completed = perceived cumulative progress/initial number of project tasks
	~	fraction
	~		|

fraction properly completed=
	0.5
	~	dmnl
	~		|

initial number of project tasks = 1200
	~	tasks
	~		|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

perceived productivity = perceived cumulative progress/cumulative effort
	~	tasks/person/Month
	~		|

SAVEPER  = 
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0078125
	~	Month
	~	The time step for the simulation.
	|

workforce = INTEG(net hiring of personnel,2)
	~	person
	~		|

desired workforce=
	perceived effort remaining/perceived time remaining
	~	person
	~		|

