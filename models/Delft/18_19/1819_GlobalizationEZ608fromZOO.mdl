CUSTOMS DUTY 0=
	0
	~	1
	~		|

INVESTMENT FACTOR 0=
	2
	~	1
	~		|

progress function=
	IF THEN ELSE(Time<10, 2, PROGRESS FACTOR)
	~	1
	~		|

progress function 0=
	IF THEN ELSE(Time<10, 1, PROGRESS FACTOR 0)
	~	1
	~		|

EXPORT SUBSIDY=
	0
	~	1
	~		|

investment function 0=
	IF THEN ELSE(Time<10, 0.2, INVESTMENT FACTOR 0)
	~	1
	~		|

investment=
	IF THEN ELSE(surplus<0, INVESTMENT RATE*production capacity*investment function, 0)
	~	1/Year
	~		|

investment 0=
	IF THEN ELSE(surplus 0<0,INVESTMENT RATE 0*production capacity 0*investment function 0\
		, 0)
	~	1/Year
	~		|

PROGRESS FACTOR=
	2
	~	1
	~		|

PROGRESS FACTOR 0=
	2
	~	1
	~		|

inland price=
	product price 0*(1-subsidy 0+customs)
	~	$
	~		|

inland price 0=
	product price*(1-subsidy+customs 0)
	~	$
	~		|

progress investment=
	progress function*investment
	~	1/Year
	~		|

progress investment 0=
	progress function 0*investment 0
	~	1/Year
	~		|

subsidy=
	IF THEN ELSE(Time<10, 0.75, EXPORT SUBSIDY)
	~	1
	~		|

subsidy 0=
	IF THEN ELSE(Time<10, 0, EXPORT SUBSIDY 0)
	~	1
	~		|

investment function=
	IF THEN ELSE(Time<10, 2, INVESTMENT FACTOR)
	~	1
	~		|

customs=
	IF THEN ELSE(Time<10, 0.5, CUSTOMS DUTY)
	~	1
	~		|

customs 0=
	IF THEN ELSE(Time<10, 0, CUSTOMS DUTY 0)
	~	1
	~		|

CUSTOMS DUTY=
	0
	~	1
	~		|

surplus=
	supply-demand
	~	1/Year
	~		|

progress 0=
	progress investment 0*standards 0*(1-product price 0/REFERENCE PRICE 0)
	~	1/Year
	~		|

REFERENCE PRICE 0=
	5
	~	$
	~		|

INVESTMENT RATE=
	0.1
	~	1/Year
	~		|

INVESTMENT RATE 0=
	0.1
	~	1/Year
	~		|

progress=
	progress investment*standards*(1-product price/REFERENCE PRICE)
	~	1/Year
	~		|

REFERENCE PRICE=
	5
	~	$
	~		|

price ratio domestic vs imported product=
	product price/inland price
	~	1
	~		|

supply=
	PRODUCTION RATE*production capacity
	~	1/Year
	~		|

supply 0=
	PRODUCTION RATE 0*production capacity 0
	~	1/Year
	~		|

production costs=
	STANDARD FACTOR*standards
	~	$
	~		|

production costs 0=
	STANDARD FACTOR 0*standards 0
	~	$
	~		|

EXPORT SUBSIDY 0=
	0
	~	1
	~		|

INVESTMENT FACTOR=
	2
	~	1
	~		|

production capacity= INTEG (
	investment-depreciation,
		1)
	~	1
	~		|

production capacity 0= INTEG (
	investment 0-depreciation 0,
		0.1)
	~	1
	~		|

purchase decision = WITH LOOKUP (
	price ratio domestic vs imported product,
		([(0,0)-(5,2)],(0,1),(0.5,1),(1,0.5),(1.5,0),(2,0),(5,0) ))
	~	1
	~		|

purchase decision 0 = WITH LOOKUP (
	price ratio domestic vs imported product 0,
		([(0,0)-(5,2)],(0,1),(0.5,1),(1,0.5),(1.5,0),(2,0),(5,0) ))
	~	1
	~		|

MARKET VOLUME=
	1
	~	1/Year
	~		|

MARKET VOLUME 0=
	1
	~	1/Year
	~		|

demand=
	purchase decision*MARKET VOLUME+(1-purchase decision 0)*MARKET VOLUME 0
	~	1/Year
	~		|

demand 0=
	purchase decision 0*MARKET VOLUME 0+(1-purchase decision)*MARKET VOLUME
	~	1/Year
	~		|

price ratio domestic vs imported product 0=
	product price 0/inland price 0
	~	1
	~		|

product costs=
	RESOURCE COSTS+production costs
	~	$
	~		|

product costs 0=
	RESOURCE COSTS 0+production costs 0
	~	$
	~		|

PRODUCTION RATE=
	1
	~	1/Year
	~		|

PRODUCTION RATE 0=
	1
	~	1/Year
	~		|

product price=
	(1+TAX RATE)*product costs
	~	$
	~		|

product price 0=
	(1+TAX RATE 0)*product costs 0
	~	$
	~		|

RESOURCE COSTS=
	1
	~	$
	~		|

RESOURCE COSTS 0=
	1
	~	$
	~		|

deterioration=
	DETERIORATION RATE*standards
	~	1/Year
	~		|

deterioration 0=
	DETERIORATION RATE 0*standards 0
	~	1/Year
	~		|

DETERIORATION RATE=
	0.05
	~	1/Year
	~		|

DETERIORATION RATE 0=
	0.05
	~	1/Year
	~		|

STANDARD FACTOR=
	1
	~	$
	~		|

STANDARD FACTOR 0=
	1
	~	$
	~		|

standards= INTEG (
	progress-deterioration,
		1)
	~	1
	~		|

standards 0= INTEG (
	progress 0-deterioration 0,
		0.1)
	~	1
	~		|

TAX RATE=
	0.2
	~	1
	~		|

TAX RATE 0=
	0.2
	~	1
	~		|

surplus 0=
	supply 0-demand 0
	~	1/Year
	~		|

depreciation=
	DEPRECIATION RATE*production capacity
	~	1/Year
	~		|

depreciation 0=
	DEPRECIATION RATE 0*production capacity 0
	~	1/Year
	~		|

DEPRECIATION RATE=
	0.05
	~	1/Year
	~		|

DEPRECIATION RATE 0=
	0.05
	~	1/Year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 50
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

