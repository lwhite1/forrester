{UTF-8}
"1985 construction cost new houses"=
	95000
	~	Euros
	~		|

aging of houses=
	DELAY FIXED(construction of new houses,lifetime of new houses,construction of new houses\
		)
	~	
	~		|

average house prices=
	SMOOTH(average house spending capacity per household*housing scarcity ratio,1)
	~	Euros
	~	SMOOTH(average lending capacity per household*housing scarcity,10)
	|

average house spending capacity per household=
	average salary per household*(1+salary lending multiplier)
	~	Euros
	~		|

average lifetime old houses=
	60
	~	Year
	~		|

average salary per household=
	initial average salary * SMOOTH3(cumulative inflation,2) * expected effective workforce\
		/expected households
	~	Euros
	~		|

construction of new houses=
	DELAY3I(in planning and construction, normal planning and construction time, in planning and under construction\
		/normal planning and construction time)
	~	houses/Year
	~	in planning and under construction/average planning and construction time
	|

cumulative inflation= INTEG (
	expected inflation rate * cumulative inflation * MAX((1 - (uncertainty-1)),0),
		1)
	~	
	~		|

demolition multiplicator= DELAY FIXED (
	1/housing scarcity ratio,1,1/housing scarcity ratio)
	~	
	~	MAX(1,housing scarcity),3,MAX(1,housing scarcity)
	|

demolition of old houses=
	old houses/average lifetime old houses * demolition multiplicator
	~	houses/Year
	~		|

expected effective workforce= WITH LOOKUP (
	Time,
		([(1985,0)-(2085,1e+007)],(1985,5.75e+006),(2012,7.5e+006),(2020,8e+006),(2040,7.6e+006\
		),(2050,7.3e+006),(2085,6e+006) ))
	~	
	~	2000, 2020, 2040 RC 7,5 7,5 6,6
		SE 7,5 8,1 7,9
		TM 7,5 8,1 7,6
		GE 7,5 8,7 9,0
	|

houses per household=
	1
	~	houses/households
	~		|

housing scarcity ratio=
	expected households/total expected supply of houses
	~	Dmnl
	~		|

in planning and construction=
	housing gap * profitability multiplier
	~	
	~	SMOOTH(profitable housing gap * (1 + MAX(profitability of new house \
		construction,0)),1)
	|

in planning and under construction= INTEG (
	in planning and construction-construction of new houses,
		ini in planning and under construction)
	~	
	~		|

expected inflation rate=
	0.02
	~	
	~		|

ini in planning and under construction=
	250000
	~	houses
	~		|

initial average salary=
	27000
	~	Euros
	~		|

lifetime of new houses=
	15
	~	Year
	~		|

loan risk=
	DELAY3(MAX(0,uncertainty-1)/2,2)
	~	
	~		|

new house premium=
	0.05
	~	
	~		|

new houses= INTEG (
	construction of new houses-aging of houses,
		1.55e+006)
	~	houses
	~		|

normal planning and construction time= WITH LOOKUP (
	in planning and under construction/ini in planning and under construction,
		([(0,0)-(20,10)],(0,1),(1,1.5),(2,2),(5,3),(9,3.75),(20,5) ))
	~	Year
	~		|

normal salary lending multiplier= WITH LOOKUP (
	Time,
		([(1985,0)-(2085,10)],(1985,3),(2011,5),(2013,3),(2035,3),(2050,3),(2085,3) ))
	~	Dmnl
	~		|

old houses= INTEG (
	aging of houses-demolition of old houses,
		3.6e+006)
	~	houses
	~	schaarste...
	|

profitability multiplier= WITH LOOKUP (
	profitability of new house construction,
		([(-1,0)-(1,2)],(-1,0),(-0.5,0.01),(-0.2,0.02),(-0.1,0.2),(0,0.8),(0.1,1),(0.2,1.1)\
		,(0.5,1.2),(1,1.25) ))
	~	Dmnl
	~		|

profitability of new house construction=
	((1+new house premium)*average house prices-total construction cost new houses)/total construction cost new houses
	~	Dmnl
	~	(((1+new house premium) * average house prices-total construction cost new houses)* \
		construction of new houses - capacity house construction sector
		*fixed costs construction sector)/ (total construction cost new houses * \
		construction of new houses + capacity house construction sector
		*fixed costs construction sector)
	|

housing gap=
	MAX(expected households*houses per household-total expected supply of houses,0)
	~	houses
	~	IF THEN ELSE(profitability of new house construction>0,MAX(total demand \
		for houses-total supply of houses,0),0)
	|

salary lending multiplier=
	normal salary lending multiplier * (1-loan risk)/uncertainty
	~	Dmnl
	~		|

total construction cost new houses=
	"1985 construction cost new houses"*cumulative inflation
	~	Euros
	~		|

total expected supply of houses=
	new houses+in planning and under construction+old houses-old houses/average lifetime old houses
	~	houses
	~	new houses+in planning and under construction+old houses-old \
		houses/average lifetime old houses                     2010: 7118344. \
		Bron: \
		http://www.z24.nl/z24geld/huizen_wonen/artikel_255353.z24/Huizenmarkt__feit\
		en_en_cijfers.html
	|

expected households= WITH LOOKUP (
	Time,
		([(1985,0)-(2085,1e+007)],(1985,5.43e+006),(1990,5.978e+006),(2000,6.798e+006),(2010\
		,7.397e+006),(2011,7.47e+006),(2050,8.5e+006),(2085,9e+006) ))
	~	houses
	~	Het aantal huishoudens op 1 januari 2011 bedroeg 7,47 miljoen en neemt \
		sterker toe dan de bevolkingsomvang. Dit wordt veroorzaakt door de sterke \
		toename van het aantal eenpersoonshuishoudens tot ruim 2,75 miljoen op 1 \
		januari 2011.REF: \
		http://www.compendiumvoordeleefomgeving.nl/indicatoren/nl0001-Bevolkingsomv\
		ang-en-huishoudens.html?i=15-12
	|

uncertainty= WITH LOOKUP (
	Time,
		([(1985,0)-(2085,2)],(1985,1),(2000,1),(2007,1),(2009,2),(2015,1),(2035,1),(2050,1)\
		,(2085,1) ))
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2085
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1985
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 0.0625
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0078125
	~	Year [0,?]
	~	The time step for the simulation.
	|

