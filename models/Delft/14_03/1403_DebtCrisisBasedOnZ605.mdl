{UTF-8}
INITIAL PRODUCTION PLANTS=
	0
	~	$ [0,500,50]
	~		|

INITIAL DEBT=
	0
	~	$ [0,2000,100]
	~		|

production plants= INTEG (
	expansion-deterioration,
		INITIAL PRODUCTION PLANTS)
	~	$
	~		|

debt= INTEG (
	+debt increase-debt decrease,
		INITIAL DEBT)
	~	$
	~		|

expansion=
	INVESTMENT EFFECTIVENESS*investment
	~	$/Year
	~		|

revenue=
	price factor*production
	~	$/Year
	~		|

profit=
	(1-INVESTMENT FRACTION)*investment generation/INVESTMENT FRACTION
	~	$/Year
	~		|

profit rate=
	profit
	~	$/Year
	~		|

profit sum= INTEG (
	profit rate,
		0)
	~	$
	~		|

INVESTMENT FRACTION=
	0.5
	~	1
	~		|

investment generation=
	INVESTMENT FRACTION*MAX((net revenue-repayment), 0)
	~	$/Year
	~	MAX((net revenue-repayment), 0)
	|

investment=
	investment generation+credit
	~	$/Year
	~		|

INVESTMENT EFFECTIVENESS=
	0.5
	~	1
	~		|

credit=
	CREDIT AMOUNT*CREDIT FUNCTION
	~	$/Year
	~		|

CREDIT FUNCTION = WITH LOOKUP (
	Time,
		([(0,0)-(200,2)],(0,0),(2,0),(4,1),(6,1),(8,1),(10,1),(12,0),(14,0),(16,0),(18,0),(\
		200,0),(200,0) ))
	~	1
	~		|

CREDIT AMOUNT=
	100
	~	$/Year
	~		|

DEMAND=
	100
	~	Stück/Year
	~		|

net revenue=
	revenue-interest payment
	~	$/Year
	~		|

price factor = WITH LOOKUP (
	production/DEMAND,
		([(0,0)-(2,2.5)],(0,2),(0.2,2),(0.4,2),(0.6,2),(0.8,1.4),(1,1),(1.2,0.6),(1.4,0.1),\
		(1.6,0.1),(1.8,0.1),(2,0.1) ))
	~	1
	~		|

production=
	SPECIFIC PRODUCTION*production plants
	~	$/Year
	~		|

DEBT REPAYMENT FRACTION=
	0.5
	~	1
	~		|

repayment=
	IF THEN ELSE((net revenue>0):AND:(debt>0), DEBT REPAYMENT FRACTION*net revenue, 0)
	~	$/Year
	~		|

debt decrease=
	repayment
	~	$/Year
	~		|

debt increase=
	credit+interest debt
	~	$/Year
	~		|

SPECIFIC PRODUCTION=
	1
	~	($/Year)/$
	~		|

deterioration=
	DETERIORATION RATE*production plants
	~	$/Year
	~		|

DETERIORATION RATE=
	0.05
	~	1/Year
	~		|

interest=
	interest payment
	~	$/Year
	~		|

INTEREST RATE=
	0.07
	~	1/Year
	~		|

interest debt=
	MAX(-net revenue, 0)
	~	$/Year
	~		|

interest sum= INTEG (
	interest,
		0)
	~	$
	~		|

interest payment=
	INTEREST RATE*debt
	~	$/Year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Year [0,?]
	~	The time step for the simulation.
	|

