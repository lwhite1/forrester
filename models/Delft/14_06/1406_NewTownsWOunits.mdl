{UTF-8}
births=
	birth rate*population
	~	
	~		|

birth rate=
	0.03
	~	
	~		|

death rate=
	0.015
	~	
	~		|

housing vacancy ratio=
	MIN(MAX((1-households to houses ratio), 0 ), 1 )
	~	
	~		|

unemployment ratio=
	MIN(MAX((1-1/labor force to jobs ratio), 0 ), 1 )
	~	
	~		|

population= INTEG (
	births+immigration-deaths-emmigration,
		50000)
	~	
	~		|

average size of households=
	4
	~	
	~		|

business labor force multiplier= WITH LOOKUP (
	labor force to jobs ratio,
		([(0,0)-(10,10)],(0,0.2),(0.5,0.3),(1,1),(1.5,1.7),(2,2) ))
	~	
	~		|

businesses= INTEG (
	construction of business structures-demolition of business structures
	,
		1000)
	~	
	~		|

construction of business structures=
	land availability multiplier for business structures*business labor force multiplier\
		*businesses*construction rate of business structures
	~	
	~		|

construction of houses=
	DELAY3( land availability multiplier for houses*housing scarcity multiplier*houses*construction rate of houses\
		 , 2 )
	~	
	~		|

construction rate of business structures=
	0.07
	~	
	~		|

construction rate of houses=
	0.07
	~	
	~		|

deaths=
	death rate*population
	~	
	~		|

demolition of business structures=
	businesses*demolition rate of business structures
	~	
	~		|

demolition of houses=
	houses*demolition rate
	~	houses/year
	~		|

demolition rate=
	0.015
	~	Dmnl/year
	~		|

demolition rate of business structures=
	0.025
	~	
	~		|

emmigration=
	0.07*population
	~	
	~		|

households=
	population/average size of households
	~	
	~		|

households to houses ratio=
	houses/households
	~	
	~		|

houses= INTEG (
	construction of houses-demolition of houses,
		14000)
	~	
	~		|

housing availability multiplier for immigration= WITH LOOKUP (
	households to houses ratio,
		([(0,0)-(10,10)],(0,1.4),(0.5,1.3),(1,1),(1.5,0.25),(2,0) ))
	~	
	~		|

housing scarcity multiplier= WITH LOOKUP (
	households to houses ratio,
		([(0,0)-(10,10)],(0,0.2),(0.5,0.3),(1,1),(1.5,1.7),(2,2) ))
	~	
	~		|

immigration=
	population*normal immigration rate*job availability multiplier for immigration*housing availability multiplier for immigration
	~	
	~		|

initial number of jobs per business structures=
	18
	~	
	~		|

job availability multiplier for immigration= WITH LOOKUP (
	labor force to jobs ratio,
		([(0,0)-(10,10)],(0,2),(0.5,1.75),(1,1),(1.5,0.25),(2,0.1) ))
	~	
	~		|

jobs=
	businesses*initial number of jobs per business structures
	~	
	~		|

labor force=
	population*labor force to population ratio
	~	
	~		|

labor force to jobs ratio=
	labor force/jobs
	~	
	~		|

labor force to population ratio=
	0.35
	~	
	~		|

land availability multiplier for business structures= WITH LOOKUP (
	land fraction occupied,
		([(0,0)-(10,10)],(0,1),(0.5,1.5),(1,0) ))
	~	
	~		|

land availability multiplier for houses= WITH LOOKUP (
	land fraction occupied,
		([(0,0)-(1,10)],(0,0.4),(0.25,1),(0.5,1.5),(0.75,1),(1,0) ))
	~	
	~		|

land fraction occupied=
	(land use of all businesses+land use of all houses)/total area
	~	
	~		|

land per business=
	0.1
	~	
	~		|

land per house=
	0.05
	~	hectare
	~		|

land use of all businesses=
	businesses*land per business
	~	
	~		|

land use of all houses=
	land per house*houses
	~	
	~		|

normal immigration rate=
	0.1
	~	
	~		|

total area=
	5000
	~	hectare
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 200
	~	year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	year [0,?]
	~	The time step for the simulation.
	|

