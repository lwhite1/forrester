{UTF-8}
emigratie=
	bevolking*normale emigratiegraad*(1+(1-slummultiplicator voor migratie))
	~	people/year
	~		|

switch jobs=
	1
	~	
	~		|

immigratie=
	bevolking*normale immigratiegraad*jobbeschikbaarheids multiplicator voor immigratie*\
		huizenbeschikbaarheids multiplicator voor immigratie
	*(slummultiplicator voor migratie*switch leegstandseffect+(1-switch leegstandseffect\
		))
	~	people/year
	~		|

slummultiplicator voor migratie= WITH LOOKUP (
	leegstandsgraad van huizen,
		([(0,0)-(1,1)],(0,1),(0.2,1),(0.4,0.5),(0.6,0.1),(0.8,0) ))
	~	
	~		|

grondgebruik per bedrijf=
	0.1
	~	ha/structure
	~		|

afbraak van huizen=
	afbraakgraad van huizen*huizen+extra afbraakgraad*huizen*switch leegstandseffect
	~	structure/year
	~		|

landgebruik=
	(bedrijven*grondgebruik per bedrijf + huizen*grondgebruik per huis)/totale grondoppervlakte
	~	fraction
	~		|

leegstandsgraad van huizen=
	MIN(MAX((1-verhouding huishoudens tot huizen),0),1)
	~	
	~		|

effect schaarste landgebruik op intensiviteit bedrijfsgebouwen= WITH LOOKUP (
	landgebruik,
		([(0,0)-(1,3)],(0,1),(0.5,1),(0.75,1.15),(1,2) ))
	~	
	~		|

totale grondoppervlakte=
	5000
	~	ha
	~		|

extra afbraakgraad= WITH LOOKUP (
	leegstandsgraad van huizen,
		([(0,0)-(100,10)],(0,0),(0.1,0),(0.15,0.05),(1,0.5) ))
	~	
	~		|

switch leegstandseffect=
	1
	~	
	~		|

jobs=
	initieel aantal jobs per bedrijfsgebouw*bedrijven*(effect schaarste landgebruik op intensiviteit bedrijfsgebouwen\
		*switch jobs + (1- switch jobs))
	~	job
	~		|

verhouding huishoudens tot huizen=
	huishoudens/huizen
	~	family/structure
	~		|

geboortes=
	geboortegraad*bevolking
	~	people/year
	~		|

huishoudens=
	bevolking/gemiddelde grootte van huishoudens
	~	units
	~		|

bevolking= INTEG (
	immigratie+geboortes-emigratie-sterftes,
		50000)
	~	people
	~		|

sterftes=
	sterftegraad*bevolking
	~	
	~		|

werkloosheidsgraad=
	MIN(MAX((1 - 1/beroepsbevolking tot jobs ratio),0),1)
	~	
	~		|

constructie van huizen=
	 constructiegraad van huizen*landbeschikbaarheids multiplicator voor huizen*huizenschaarste multiplicator\
		*huizen
	~	structure/year
	~		|

constructie van bedrijfsgebouwen=
	constructiegraad van bedrijfsgebouwen*landbeschikbaarheids multiplicator voor bedrijfsgebouwen\
		*beroepsbevolkings multiplicator voor bedrijven*bedrijven
	~	structure/year
	~		|

jobbeschikbaarheids multiplicator voor immigratie= WITH LOOKUP (
	beroepsbevolking tot jobs ratio,
		([(0,0)-(2,2)],(0,2),(0.5,1.75),(1,1),(1.5,0.25),(2,0.1) ))
	~	fraction
	~		|

huizenbeschikbaarheids multiplicator voor immigratie= WITH LOOKUP (
	verhouding huishoudens tot huizen,
		([(0,0)-(2,2)],(0,1.4),(0.5,1.3),(1,0.9),(1.5,0.05),(2,0) ))
	~	fraction
	~		|

constructiegraad van bedrijfsgebouwen = 0.07
	~	fraction/year
	~		|

afbraakgraad van bedrijfsgebouwen = 0.025
	~	fraction/year
	~		|

geboortegraad=
	0.03
	~	fraction/year
	~		|

afbraak van bedrijfsgebouwen = afbraakgraad van bedrijfsgebouwen*bedrijven
	~	structure/year
	~		|

beroepsbevolkings multiplicator voor bedrijven= WITH LOOKUP (
	beroepsbevolking tot jobs ratio,
		([(0,0)-(2,2)],(0,0.2),(0.5,0.3),(1,1),(1.5,1.7),(2,2) ))
	~	fraction
	~		|

landbeschikbaarheids multiplicator voor bedrijfsgebouwen= WITH LOOKUP (
	landgebruik,
		([(0,0)-(1,2)],(0,1),(0.5,1.5),(1,0) ))
	~	fraction
	~		|

bedrijven = INTEG(constructie van bedrijfsgebouwen-afbraak van bedrijfsgebouwen,1000)
	~	units
	~		|

sterftegraad = 0.015
	~	fraction/year
	~		|

constructiegraad van huizen = 0.07
	~	fraction/year
	~		|

afbraakgraad van huizen = 0.015
	~	fraction/year
	~		|

huizen = INTEG(constructie van huizen-afbraak van huizen,14000)
	~	units
	~		|

huizenschaarste multiplicator= WITH LOOKUP (
	verhouding huishoudens tot huizen,
		([(0,0)-(2,2)],(0,0.2),(0.5,0.3),(1,1),(1.5,1.7),(2,2) ))
	~	fraction
	~		|

landbeschikbaarheids multiplicator voor huizen= WITH LOOKUP (
	landgebruik,
		([(0,0)-(1,2)],(0,0.4),(0.25,1),(0.5,1.5),(0.75,1),(1,0) ))
	~	fraction
	~		|

gemiddelde grootte van huishoudens = 4
	~	people/family
	~		|

normale immigratiegraad = 0.1
	~	fraction/year
	~		|

initieel aantal jobs per bedrijfsgebouw = 18
	~	job/structure
	~		|

beroepsbevolking = beroepsbevolkingsratio*bevolking
	~	people
	~		|

beroepsbevolking tot jobs ratio = beroepsbevolking/jobs
	~	people/job
	~		|

beroepsbevolkingsratio = 0.35
	~	fraction
	~		|

grondgebruik per huis=
	0.05
	~	ha/structure
	~		|

normale emigratiegraad = 0.07
	~	fraction/year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 200
	~	year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	year
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.03125
	~	year
	~	The time step for the simulation.
	|

