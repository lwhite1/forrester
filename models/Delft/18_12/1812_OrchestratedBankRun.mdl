{UTF-8}
initial credibility DSB=
	0.9
	~	Dmnl
	~		|

concerted liquid fraction running=
	organised run*(STEP(concerted percentage running,2)-STEP(concerted percentage running\
		,4))
	~	Dmnl
	~		|

concerted percentage running=
	0.05
	~	Dmnl
	~		|

credibility denials=
	initial credibility DSB-STEP(loss of credibility DSB,1)*organised run
	~	Dmnl
	~		|

new fixed loan= GAME (
	0)
	~	EURO/Day
	~		|

loss of credibility DSB=
	0.8
	~	Dmnl
	~		|

new fixed deposits and loans=
	liquid deposits and loans lost*new fixed loan as fraction of liq lost+new fixed loan
	~	EURO/Week
	~		|

fixed deposits and loans= INTEG (
	new fixed deposits and loans,
		1e+009)
	~	EURO
	~		|

intervention cost= INTEG (
	new liquid assets,
		0)
	~	
	~		|

new liquid assets=
	new fixed deposits and loans+new liquid equity
	~	EURO/Day
	~		|

new liquid equity= GAME (
	0)
	~	EURO/Day
	~		|

liquid assets= INTEG (
	liquidation+new liquid assets-liquid assets lost,
		1.15e+009)
	~	EURO
	~		|

new fixed loan as fraction of liq lost= GAME (
	0)
	~	Dmnl
	~		|

organised run=
	1
	~	Dmnl
	~		|

total asset total liability ratio=
	(fixed assets+liquid assets)/(liquid deposits and loans+fixed deposits and loans)
	~	Dmnl
	~		|

perceived likelihood bank failure risk=
	MAX(perceived likelihood liquidity failure,perceived likelihood solvency failure)*(1\
		-credibility denials)
	~	Dmnl
	~		|

anger=
	0.5
	~	Dmnl
	~		|

liquid fraction running= WITH LOOKUP (
	perceived likelihood bank failure risk,
		([(0,0)-(1,1)],(0,0),(0.25,0),(0.5,0.01),(0.75,0.1),(1,0.5) ))
	~	Dmnl
	~		|

liquidation losses=
	liquidation/(1-liquidation premium)*liquidation premium
	~	EURO/Day
	~		|

fixed assets= INTEG (
	-liquidation-liquidation losses,
		4.6e+009)
	~	EURO
	~		|

liquidation time=
	1
	~	Day
	~		|

liquid asset liability target=
	0.2
	~	Dmnl
	~		|

liquidation=
	MAX(0,(liquid asset liability target*liquid deposits and loans-liquid assets)/liquidation time\
		*(1-liquidation premium))
	~	EURO/Day
	~		|

liquid deposits and loans lost=
	MIN((liquid fraction running*(1+expected hindrance possible bank failure)*(1+anger)+\
		concerted liquid fraction running)*liquid deposits and loans
	/withdrawal time
	,liquid deposits and loans/withdrawal time)
	~	EURO/Day
	~	MIN((liquid fraction running+concerted liquid fraction running)*hindrance \
		bank failures*liquid deposits and loans/opnametijd,liquid deposits and \
		loans/opnametijd)
	|

DNB bank failure declaration=
	IF THEN ELSE(liquid asset liability ratio < 0.01 :OR: total asset total liability ratio\
		 < 0.9, 1, 0)
	~	
	~		|

liquid deposits and loans= INTEG (
	-liquid deposits and loans lost,
		4.5e+009)
	~	EURO
	~		|

expected hindrance possible bank failure=
	0.5
	~	Dmnl
	~		|

perceived likelihood solvency failure= WITH LOOKUP (
	total asset total liability ratio,
		([(0,0)-(2,1)],(0,1),(0.8,1),(0.9,0.9),(1,0.5),(1.1,0.1),(1.2,0),(2,0) ))
	~	Dmnl
	~	solvency = total assets/total deposits and loans
	|

liquid asset liability ratio=
	liquid assets/liquid deposits and loans
	~	Dmnl
	~		|

perceived likelihood liquidity failure= WITH LOOKUP (
	liquid asset liability ratio,
		([(-1,0)-(1,1)],(-1,1),(0,1),(0.1,0.8),(0.2,0.4),(0.3,0.1),(0.4,0.01),(0.5,0),(1,0)\
		 ))
	~	Dmnl
	~		|

withdrawal time=
	1
	~	Day
	~		|

liquid assets lost=
	liquid deposits and loans lost
	~	EURO/Day
	~		|

initial number of shares=
	1e+008
	~	share
	~		|

liquidation premium=
	0.15
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Day
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Day
	~	The time step for the simulation.
	|

