{UTF-8}
liquid deposits and loans loss fraction=
	average bank client's fear and uncertainty/average stickiness of deposits and loans
	~	1/Week
	~		|

underlying asset loss=
	MAX((liquid deposits and loans loss fraction*fraction of asset loss to deposit loss+\
		external shock real value loss)*estimated underlying asset value
	,0)
	~	EURO/Week
	~		|

fraction of asset loss to deposit loss=
	1
	~	Dmnl
	~		|

external shock real value loss=
	STEP(size of the external underlying asset shock,10) - STEP(size of the external underlying asset shock\
		,11)
	~	1/Week
	~	 0.01 - STEP(0.01,11)
	|

size of the external underlying asset shock= GAME (
	0.35)
	~	1/Week
	~		|

stock market value increase=
	MAX(stock market value * perceived undervaluation/market increase delay,0)
	~	EURO/Week
	~		|

action delay=
	1
	~	Week
	~		|

average profitability=
	0.002
	~	1/Week
	~		|

average stickiness of deposits and loans= GAME (
	4)
	~	Week
	~		|

degree of external climate of fear= GAME (
	2)
	~	Dmnl
	~		|

market loss delay=
	1
	~	Week
	~		|

estimated underlying asset value= INTEG (
	+underlying asset increase-underlying asset loss,
		initial estimated underlying asset value)
	~	EURO
	~		|

financial intervention=
	MAX(0,(fraction initial guaranteed*initial estimated underlying asset value - estimated underlying asset value\
		)/action delay) * policy switch
	~	EURO/Week
	~	IF THEN ELSE(estimated asset value<initial underlying value*0.5, initial \
		underlying value*0.2, 0)
	|

fraction initial guaranteed= GAME (
	0.5)
	~	Dmnl
	~		|

initial market fear and uncertainty=
	0
	~	Dmnl
	~		|

initial stock market value=
	24.6
	~	EURO
	~		|

initial estimated underlying asset value=
	25
	~	EURO
	~		|

instant market fear and uncertainty=
	MIN(stock market value loss/(stock market value/market loss delay*stock market fear factor\
		) * degree of external climate of fear,1)
	~	Dmnl
	~		|

average bank client's fear and uncertainty=
	smoothed market fear and uncertainty
	~	Dmnl
	~		|

perceived overvaluation=
	MAX((stock market value-estimated underlying asset value)/stock market value,0)
	~	Dmnl
	~		|

perceived undervaluation=
	MAX((estimated underlying asset value-stock market value)/stock market value,0)
	~	Dmnl
	~		|

policy switch= GAME (
	0)
	~	Dmnl
	~		|

market increase delay=
	4
	~	Week
	~		|

smoothed market fear and uncertainty=
	DELAY3I(instant market fear and uncertainty, uncertainty and fear delay, initial market fear and uncertainty\
		)
	~	Dmnl
	~		|

stock market fear factor= GAME (
	0.25)
	~	Dmnl
	~		|

stock market value= INTEG (
	+stock market value increase-stock market value loss,
		initial stock market value)
	~	EURO
	~		|

stock market value loss=
	MAX(stock market value * (perceived overvaluation/market loss delay),0)
	~	EURO/Week
	~		|

uncertainty and fear delay=
	2
	~	Week
	~		|

underlying asset increase=
	average profitability*estimated underlying asset value + financial intervention
	~	EURO/Week
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 52
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Week
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0078125
	~	Week
	~	The time step for the simulation.
	|

\\\---/// Sketch information - do not modify anything except names
