"."=
	0
	~	
	~	This is the book's example
	|

Cocaine= INTEG (
	imports-confiscation-use,
		20000)
	~	kg
	~		|

confiscation=
	Cocaine*confiscation rate
	~	kg/Month
	~		|

confiscation rate=
	0.1
	~	1/Month
	~		|

imports=
	4000
	~	kg/Month
	~		|

use=
	3000
	~	kg/Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 24
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Month [0,?]
	~	The time step for the simulation.
	|

