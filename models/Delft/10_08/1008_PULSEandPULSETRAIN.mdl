{UTF-8}
inflow=
	2*PULSE TRAIN(5, TIME STEP , 2 , 35)/TIME STEP
	~	units/Year
	~		|

outflow=
	PULSE TRAIN(6, 1, 2 , 40 ) * stock/TIME STEP
	~	units/Year
	~		|

stock= INTEG (
	inflow-outflow,
		0)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 40
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Month [0,?]
	~	The time step for the simulation.
	|

