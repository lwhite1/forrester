{UTF-8}
initial value susceptible population region 2=
	2e+009
	~	persons
	~		|

initial value infected population region 1=
	10
	~	persons
	~		|

normal immune population fraction region 1= WITH LOOKUP (
	Time,
		([(0,0)-(60,1)],(0,0.3),(6,0.7),(12,0.3),(18,0.7),(24,0.3),(30,0.7),(36,0.3),(42,0.7\
		),(48,0.3) ))
	~	Dmnl
	~		|

initial value immune population region 1=
	2.7e+008
	~	persons
	~		|

initial value immune population region 2=
	1e+009
	~	persons
	~		|

initial value susceptible population region 1=
	3.3e+008
	~	persons
	~		|

initial value infected population region 2=
	10
	~	persons
	~		|

initial value recovered population region 1=
	0
	~	persons
	~		|

initial value recovered population region 2=
	0
	~	persons
	~		|

interregional contact rate=
	0.1
	~	contacts/person/Month
	~		|

recoveries region 2=
	infected population region 2/recovering time
	~	persons/Month
	~		|

susceptible to immune population flow region 2=
	IF THEN ELSE((normal immune population region 2-immune population region 2)/susceptible to immune population delay time region 2
	>0, MIN((normal immune population region 2-immune population region 2)/susceptible to immune population delay time region 2\
		,susceptible population region 2/susceptible to immune population delay time region 2
	), MIN((normal immune population region 2-immune population region 2)/susceptible to immune population delay time region 2\
		,immune population region 2/susceptible to immune population delay time region 2
	))
	~	persons/Month
	~		|

normal immune population fraction region 2= WITH LOOKUP (
	Time,
		([(0,0)-(60,1)],(0,0.3),(6,0.1),(12,0.3),(18,0.1),(24,0.3),(30,0.1),(36,0.3),(42,0.1\
		),(48,0.3) ))
	~	Dmnl
	~		|

normal immune population region 2=
	normal immune population fraction region 2*total population region 2
	~	persons
	~		|

susceptible to immune population delay time region 2=
	1
	~	Month
	~		|

contact rate region 1=
	50
	~	contacts/person/Month
	~		|

contact rate region 2=
	100
	~	contacts/person/Month
	~		|

infected population region 1= INTEG (
	infections region 1-recoveries region 1,
		initial value infected population region 1)
	~	persons
	~		|

infected population region 2= INTEG (
	infections region 2-recoveries region 2,
		initial value infected population region 2)
	~	persons
	~		|

recoveries region 1=
	infected population region 1/recovering time
	~	persons/Month
	~		|

infection fraction region 1=
	infected population region 1/total population region 1*100
	~	percent
	~		|

infection fraction region 2=
	infected population region 2/total population region 2*100
	~	Dmnl
	~		|

infection rate region 1=
	0.1
	~	persons/contacts
	~		|

infection rate region 2=
	0.15
	~	persons/contacts
	~		|

total population region 1=
	infected population region 1+recovered population region 1+susceptible population region 1\
		+immune population region 1
	~	persons
	~		|

total population region 2=
	infected population region 2+recovered population region 2+susceptible population region 2\
		+immune population region 2
	~	persons
	~		|

recovered population region 1= INTEG (
	recoveries region 1,
		initial value recovered population region 1)
	~	persons
	~		|

recovered population region 2= INTEG (
	recoveries region 2,
		0)
	~	persons
	~		|

susceptible population region 1= INTEG (
	-infections region 1-susceptible to immune population flow region 1,
		initial value susceptible population region 1)
	~	persons
	~		|

susceptible population region 2= INTEG (
	-infections region 2-susceptible to immune population flow region 2,
		initial value susceptible population region 2)
	~	persons
	~		|

infections region 1=
	susceptible population region 1*contact rate region 1*infection rate region 1*infection fraction region 1\
		/100 + susceptible population region 1*interregional contact rate*infection rate region 1\
		*infection fraction region 2/100
	~	persons/Month
	~		|

infections region 2=
	susceptible population region 2*contact rate region 2*infection rate region 2*infection fraction region 2\
		 /100 + susceptible population region 2*interregional contact rate*infection rate region 2\
		*infection fraction region 1/100
	~	persons/Month
	~		|

susceptible to immune population flow region 1=
	IF THEN ELSE((normal immune population region 1-immune population region 1)/susceptible to immune population delay time region 1\
		>0, MIN((normal immune population region 1-immune population region 1)/susceptible to immune population delay time region 1\
		,susceptible population region 1/susceptible to immune population delay time region 1\
		), MIN((normal immune population region 1-immune population region 1)/susceptible to immune population delay time region 1\
		,immune population region 1/susceptible to immune population delay time region 1))
	~	persons/Month
	~		|

susceptible to immune population delay time region 1=
	1
	~	Month
	~		|

immune population region 1= INTEG (
	susceptible to immune population flow region 1,
		initial value immune population region 1)
	~	persons
	~		|

immune population region 2= INTEG (
	susceptible to immune population flow region 2,
		initial value immune population region 2)
	~	persons
	~		|

normal immune population region 1=
	normal immune population fraction region 1*total population region 1
	~	persons
	~		|

recovering time=
	0.5
	~	Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 48
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Month [0,?]
	~	The time step for the simulation.
	|

