{UTF-8}
new professors teaching SD=
	constant perc increase*SD professors
	~	
	~		|

constant perc increase=
	0.125
	~	
	~		|

average SD student cohort size per professor=
	25
	~	student/professor/Year
	~		|

average time to finish SD studies=
	7
	~	Year
	~		|

ini SD professors=
	1
	~	professor
	~		|

ini SD trained=
	0
	~	student
	~		|

ini students in SD programs=
	10
	~	student
	~		|

SD professors= INTEG (
	new professors teaching SD,
		ini SD professors)
	~	professor
	~		|

SD students entering=
	average SD student cohort size per professor*SD professors
	~	student/Year
	~		|

SD students finishing=
	students in SD programs/average time to finish SD studies
	~	student/Year
	~		|

SD trained= INTEG (
	SD students finishing,
		ini SD trained)
	~	
	~		|

students in SD programs= INTEG (
	SD students entering-SD students finishing,
		ini students in SD programs)
	~	student
	~		|

