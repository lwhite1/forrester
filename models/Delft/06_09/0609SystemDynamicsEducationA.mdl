{UTF-8}
new professors teaching SD=
	SD students finishing * percentage of SD students finishing that become SD professors
	~	professor/year
	~		|

average SD student cohorte size per professor=
	25
	~	person/professor/year
	~	+ STEP(1000,2014)
	|

average time to finish SD studies=
	7
	~	year
	~		|

people trained in SD= INTEG (
	SD students finishing,
		1)
	~	person
	~		|

percentage of SD students finishing that become SD professors=
	0.01
	~	professor/person
	~		|

SD Professors= INTEG (
	new professors teaching SD,
		1)
	~	professor
	~		|

SD students= INTEG (
	SD students entering-SD students finishing,
		20)
	~	person
	~		|

SD students entering=
	SD Professors * average SD student cohorte size per professor
	~	person/year
	~		|

SD students finishing=
	SD students/average time to finish SD studies
	~	person/year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2020
	~	year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1962
	~	year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	year [0,?]
	~	The time step for the simulation.
	|

