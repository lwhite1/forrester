{UTF-8}
desired component inventory=
	full capacity internal component order rate*desired component inventory coverage
	~	component
	~		|

desired component inventory coverage=
	1.5
	~	week
	~		|

assembly finished product=
	MAX(deliveries of components,0)/number of components per finished product
	~	item/week
	~		|

assembly time=
	1
	~	week
	~		|

capacity change assembly line=
	(desired inventory final product-inventory finished products)/assembly time/adaptation time assembly line
	~	item/week/week
	~		|

capacity change component production capacity=
	(desired component inventory-inventory component)/component production time/adaptation time component production capacity
	~	component/week/week
	~	IF THEN ELSE( desired component inventory<inventory component, IF THEN \
		ELSE(-(desired component inventory-inventory component
		)/component production time/adaptation time component production capacity>production \
		capacity components, -production capacity components/adaptation time \
		component production capacity , (desired component inventory
		-inventory component)/component production time/adaptation time component production \
		capacity), (desired component inventory-inventory component)/component \
		production time/
		adaptation time component production capacity)
	|

component production time=
	1
	~	week
	~		|

cumulative unfulfilled company orders= INTEG (
	unfulfilled component orders,
		0)
	~	component
	~		|

cumulative unfulfilled final customer orders= INTEG (
	unfulfilled customer orders,
		0)
	~	item
	~		|

customer order rate=
	10000+STEP(1000,5) - STEP(1000,10)
	~	item/week
	~	10000+STEP(1000,5) - STEP(1000,10)
	|

deliveries of components=
	MAX(MIN(full capacity internal component order rate,inventory component/delivery period\
		),0)
	~	component/week
	~		|

deliveries of finished product=
	MIN(internal order rate final product,inventory finished products/delivery period finished products\
		)
	~	item/week
	~		|

delivery period=
	1
	~	week
	~		|

delivery period finished products=
	1
	~	week
	~		|

unfulfilled customer orders=
	MAX(internal order rate final product-deliveries of finished product,0)
	~	item/week
	~		|

number of components per finished product=
	2
	~	component/item
	~		|

desired inventory coverage finished product=
	1.5
	~	week
	~		|

desired inventory final product=
	desired inventory coverage finished product*internal order rate final product
	~	item
	~		|

full capacity internal component order rate=
	production capacity assembly line*number of components per finished product
	~	component/week
	~	internal order rate final product*number of components per finished product
	|

internal order rate final product=
	customer order rate
	~	item/week
	~	SMOOTH3I(customer order rate, 26, customer order rate)
	|

inventory component= INTEG (
	+production component-deliveries of components,
		desired component inventory)
	~	component
	~		|

inventory finished products= INTEG (
	+assembly finished product-deliveries of finished product,
		desired inventory final product)
	~	item
	~		|

production component=
	MAX(production capacity components line,0)
	~	component/week
	~		|

production capacity assembly line= INTEG (
	capacity change assembly line,
		internal order rate final product)
	~	item/week
	~		|

production capacity components line= INTEG (
	capacity change component production capacity,
		number of components per finished product*internal order rate final product)
	~	component/week
	~		|

unfulfilled component orders=
	MAX(full capacity internal component order rate-deliveries of components,0)
	~	component/week
	~		|

adaptation time assembly line=
	12
	~	week
	~		|

adaptation time component production capacity=
	8
	~	week
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 208
	~	week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	week
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	week
	~	The time step for the simulation.
	|

\\\---/// Sketch information - do not modify anything except names
