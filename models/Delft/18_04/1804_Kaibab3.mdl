Predator Population=
	500-STEP(Change Predator Population,1910)
	~	lion
	~		|

Change Predator Population=
	500
	~	lion
	~		|

Food Consumption per Deer = WITH LOOKUP (
	Food/Food Capacity,
		([(0,0)-(1,1)],(0,0),(0.2,0.4),(0.4,0.8),(1,1) ))
	~	ton/Deer/year
	~	Food Consumption per Deer will depends from the Food Capacity and present \
		Food. We will assume that the ratio (Food/Food Capacity) will be a good \
		way to obtain the Food Consumption per Deer, using Table.  When Food = \
		Food Capacity we will assume that Food Regeneration time will be 1 ton. A \
		lower ratio will produce an lower Food Consumption per Deer.\!\!
	|

Food Regeneration Time = WITH LOOKUP (
	Food/Food Capacity,
		([(0,0)-(1,40)],(0,40),(0.5,1.5),(1,1) ))
	~	year
	~	Food Regeneration Time will depends from the Food Capacity and present \
		Food. We will assume that the ratio (Food/Food Capacity) will be a good \
		way to obtain the Food Regeneration Time, using Table.  When Food = Food \
		Capacity we will assume that Food Regeneration time will be 1 year. A \
		lower ratio will produce an higher Food Regeneration Time.
	|

Growth Rate Factor = WITH LOOKUP (
	Food per Deer/Initial Food per Deer,
		([(0,-0.8)-(1,0.4)],(0,-0.6),(0.05,0),(0.1,0.2),(1,0.2) ))
	~	1/year
	~	MODIFIED
	|

Deer Predation Rate=
	Deer Killed per Predator*Predator Population
	~	Deer/year
	~		|

Deer Killed per Predator = WITH LOOKUP (
	Deer Density/Initial Deer Density,
		([(0,0)-(6,8)],(0,0),(1,2),(2,4),(4,6),(5,6) ))
	~	Deer/(year*lion)
	~	When density is equal to 0, the deer killed are 0. Point (0.0). When the \
		Deer Density is equal to the Initial Deer Density each predator hunts 2 \
		deer each year. Point (1,2).
	|

Deer Net Growth Rate=
	Deer Population*Growth Rate Factor
	~	Deer/year
	~		|

Initial Food per Deer=
	20
	~	ton/Deer
	~		|

Initial Deer Density=
	200
	~	acre/Deer
	~	1,000,000 acres / 5,000 deer
	|

Food Capacity=
	100000
	~	ton
	~		|

Food Generation Rate=
	(Food Capacity-Food)/Food Regeneration Time
	~	ton/year
	~		|

Food= INTEG (
	Food Generation Rate-Food Consumption Rate,
		100000)
	~	ton
	~	MODIFIED - Now Food depends from the Food Consumption Rate and from the \
		Food Generation Rate.
	|

Food Consumption Rate=
	Deer Population*Food Consumption per Deer
	~	ton/year
	~		|

Area=
	1e+006
	~	acre
	~		|

Deer Population= INTEG (
	+Deer Net Growth Rate-Deer Predation Rate,
		5000)
	~	Deer
	~	Initial amount of deer is 5,000 and remains constant
	|

Deer Density=
	Area/Deer Population
	~	acre/Deer
	~	This is the amount of acres per deer
	|

Food per Deer=
	Food/Deer Population
	~	ton/Deer
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 1950
	~	year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1900
	~	year
	~	The initial time for the simulation.
	|

SAVEPER  = 1
	~	year
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	year
	~	The time step for the simulation.
	|

