{UTF-8}
members of OC active in HB in NL  = A FUNCTION OF( effective chance of being caught for burglary in NL\
		,net increase of active members of OC in HB in NL) ~~|
members of OC active in HB in NL= INTEG (
	net increase of active members of OC in HB in NL,
		2450)
	~	
	~		|

OC headstart loop  = A FUNCTION OF( )
	~	
	~		|

HB under investigation  = A FUNCTION OF( -closing of old HB investigations,opening of new HB investigations\
		,total number of burglaries) ~~|
HB under investigation= INTEG (
	opening of new HB investigations-closing of old HB investigations,
		32725)
	~	
	~		|

police catching up loop  = A FUNCTION OF( )
	~	
	~		|

"man-hours available for burglaries"  = A FUNCTION OF( "man-hours per policeman per month"\
		,"man-hours required",policemen assigned to HB,"total man-hours required for burglaries"\
		) ~~|
"man-hours available for burglaries"=
	policemen assigned to HB*"man-hours per policeman per month"
	~	
	~	MIN(9000,policemen assigned to HB)*"man-hours per policeman per month"
	|

burglaries by members of the OC  = A FUNCTION OF( chance of being caught for burglary in neighboring countries\
		,effective chance of being caught for burglary in NL,HB per member of the OC per month\
		,members of OC active in HB in NL) ~~|
burglaries by members of the OC=
	members of OC active in HB in NL*HB per member of the OC per month
	~	
	~	Het aantal WI door leden van de GM is gelijk aan het aantal leden van de \
		GM actief in WI in Nederland maal gemiddeld 4 WI per lid van de GM per \
		maand.
	|

effective chance of being caught for burglary in NL  = A FUNCTION OF( available hours for investigation wrt HB\
		,"man-hours available for burglaries","total man-hours required for investigation",\
		"total man-hours required for burglaries") ~~|
effective chance of being caught for burglary in NL = WITH LOOKUP (
	available hours for investigation wrt HB/"total man-hours required for investigation"\
		,
		([(0,0)-(10,1)],(0,0),(1,0.2),(2,0.3),(4,0.4),(8,0.5) ))
	~	
	~		|

"total man-hours required for investigation"  = A FUNCTION OF( HB under investigation\
		,"man-hours required for investigation of a HB under investigation per month",total number of burglaries\
		) ~~|
"total man-hours required for investigation"=
	HB under investigation*"man-hours required for investigation of a HB under investigation per month"
	~	
	~		|

percentage houses with opportunities for burglary  = A FUNCTION OF( relative media attention wrt burglaries\
		,seasonality burglaries,-vigilence regarding HB) ~~|
percentage houses with opportunities for burglary=
	seasonality burglaries * MAX((1 - vigilence regarding HB), 0.1)
	~	
	~	Het percentage woningen met gelegenheid voor WI is seizoensgevoelig. Modelleer
		het als de seizoensinvloed WI maal (1 - oplettendheid mbt WI) of 0.1 als \
		(1 - oplettendheid mbt WI) kleiner is dan 10%.
	|

occasional HB  = A FUNCTION OF( )
	~	
	~		|

opening of new HB investigations  = A FUNCTION OF( ) ~~|
opening of new HB investigations=
	total number of HB
	~	
	~		|

houses=
	7e+006
	~	
	~		|

"\"acceptable\" number of burglaries"=
	4500
	~	
	~	SMOOTH3I(0.25 * totaal aantal WI, 24, 4670) Het acceptabel aantal WI kan \
		gemodelleerd worden als een derde-orde vertraging met een vertragingstijd \
		van 24 maanden van een kwart van het totaal aantal WI, startend van een \
		initi¨ele waarde van 4670 WI per maand.
	|

"man-hours required"=
	("total man-hours required for burglaries"+"total man-hours required for investigation"\
		)/"man-hours per policeman per month"
	~	
	~		|

policemen assigned to HB= INTEG (
	net formation of teams of policemen assigned to HB,
		8760)
	~	
	~		|

"man-hours required for intervention per HB"=
	2
	~	
	~		|

"man-hours required for investigation of a HB under investigation per month"=
	40
	~	
	~		|

available hours for investigation wrt HB=
	"man-hours available for burglaries"-"total man-hours required for burglaries"
	~	
	~		|

average time under investigation=
	2
	~	Months
	~		|

monthly percentage HB by occasional thieves in houses with opportunities for HB=
	0.2
	~	
	~		|

"man-hours per policeman per month"=
	160
	~	
	~		|

net increase of active members of OC in HB in NL=
	normal size of OC in HB in NL*chance of being caught for burglary in neighboring countries\
		/effective chance of being caught for burglary in NL - members of OC active in HB in NL
	~	
	~	De netto toename van actieve leden van de GM in WI in NL zou bijvoorbeeld \
		gemodelleerd
		kunnen worden als het product van de normale omvang van de GM mbt WI in NL, de \
		pakkans
		mbt WI in omringende landen gedeeld door de effectieve pakkans WI in NL \
		min het aantal leden van de GM actief in WI in NL.
	|

net formation of teams of policemen assigned to HB=
	("man-hours required"-policemen assigned to HB)/conversion time to HB
	~	
	~		|

normal size of OC in HB in NL=
	2500
	~	
	~		|

conversion time to HB=
	1
	~	
	~		|

vigilence regarding HB=
	SMOOTH3I(relative media attention wrt burglaries, 3, 0.7)
	~	
	~	Modelleer de oplettendheid mbt WI als een derde-orde informatievertraging \
		van de relatieve media aandacht mbt WI met een gemiddelde vertragingstijd \
		van 3 maanden en een initi¨ele waarde gelijk aan 70%.
	|

chance of being caught for burglary in neighboring countries=
	0.2
	~	
	~		|

percentage occasional thieves among coincidental passers=
	0.05
	~	
	~		|

relative media attention wrt burglaries = WITH LOOKUP (
	total number of burglaries/"\"acceptable\" number of burglaries",
		((0,0),(2,0.2),(4,0.8),(6,1),(8,1),(12,1)))
	~	
	~		|

seasonality burglaries=
	(SIN(Time * 3.14 / 6 - 3.14 / 1.5) +2) /4
	~	
	~		|

closing of old HB investigations=
	HB under investigation/average time under investigation
	~	
	~		|

total number of burglaries=
	burglaries by occasional thieves+burglaries by members of the OC
	~	
	~	Het totaal aantal WI is de som van het aantal WI door leden van de GM (GM staat voor
		‘georganiseerde misdaad’) en het aantal WI door gelegenheidsdieven.
	|

"total man-hours required for burglaries"=
	"man-hours required for intervention per HB"*total number of burglaries
	~	
	~		|

burglaries by occasional thieves=
	houses*monthly percentage HB by occasional thieves in houses with opportunities for HB\
		*percentage occasional thieves among coincidental passers*percentage houses with opportunities for burglary
	~	
	~	Het aantal WI door gelegenheidsdieven is gelijk aan het product van het \
		aantal woningen, het percentage woningen met gelegenheid voor WI, het \
		percentage gelegenheidsdieven onder ‘toevallige’ voorbijgangers, en \
		het maandelijks percentage WI door gelegenheidsdieven in woningen met \
		gelegenheid tot inbraak.
	|

HB per member of the OC per month=
	4
	~	
	~		|

