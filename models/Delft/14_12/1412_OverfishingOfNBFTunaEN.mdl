{UTF-8}
Tuna Biomass= INTEG (
	growth existing tuna biomass+tuna recruitment-natural deaths-tuna catch,
		unfished biomass 1990)
	~	ton
	~		|

effect= WITH LOOKUP (
	perceived state of tuna fishery,
		([(-10,-1)-(100,10)],(-10,-0.9),(-7.5,-0.5),(-5,-0.25),(-2.5,-0.1),(0,0),(2.5,0.075\
		),(5,0.15),(7.5,0.21),(10,0.25),(100,0.25) ))
	~	Dmnl
	~		|

fraction tuna catch=
	average efficiency tuna ships*total number of tuna ships
	~	1/Year
	~		|

average efficiency tuna ships=
	4e-006
	~	1/Ship/Year
	~		|

perceived state of tuna fishery=
	SMOOTHI(most recent perception concerning tuna fishery, delay time, initial state tuna fishery\
		)
	~	Dmnl
	~		|

growth existing tuna biomass=
	Tuna Biomass*tuna growth rate
	~	ton/Year
	~		|

illegal tuna ships=
	10000-STEP(10000,2010)*0
	~	Ship
	~		|

implementation time delay=
	2
	~	Year
	~		|

initial state tuna fishery=
	10
	~	Dmnl
	~		|

most recent perception concerning tuna fishery=
	change in tuna perception lookup(ratio of biomass to unfished biomass)
	~	Dmnl
	~		|

natural deaths=
	Tuna Biomass*ratio of biomass to unfished biomass/normal death rate
	~	ton/Year
	~		|

net increase official number of tuna ships=
	proposed change in the number of tuna ships/implementation time delay
	~	Ship/Year
	~		|

normal death rate=
	20
	~	Year
	~		|

Official Number of Tuna Ships= INTEG (
	net increase official number of tuna ships,
		15000)
	~	Ship
	~		|

unfished biomass 1990=
	100000
	~	ton
	~		|

tuna recruitment= DELAY FIXED (
	Tuna Biomass*tuna recruitment rate,4,Tuna Biomass*tuna recruitment rate)
	~	ton/Year
	~		|

tuna recruitment rate=
	0.01
	~	1/Year
	~		|

delay time=
	2
	~	Year
	~		|

tuna growth rate=
	0.04
	~	1/Year
	~		|

tuna catch=
	Tuna Biomass*fraction tuna catch
	~	ton/Year
	~		|

total number of tuna ships=
	illegal tuna ships+Official Number of Tuna Ships
	~	Ship
	~		|

change in tuna perception lookup(
	[(0,-10)-(1,10)],(0,-10),(0.25,-2),(0.5,0),(0.75,1.5),(1,10))
	~	Dmnl
	~		|

ratio of biomass to unfished biomass=
	Tuna Biomass/unfished biomass 1990
	~	Dmnl
	~		|

proposed change in the number of tuna ships=
	(effect)*Official Number of Tuna Ships
	~	Ship
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2290
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1990
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Year [0,?]
	~	The time step for the simulation.
	|

\\\---/// Sketch information - do not modify anything except names
