{UTF-8}
uitstroom van onderwijsgelden=
	fractie langstudeerder*totaal aantal studenten*boete per langstudeerder+docenten*gemiddelde kost per docent
	~	
	~		|

hoogte boete per langstudeerder=
	3000
	~	
	~		|

instroom BSc studenten=
	jaarlijkse BSc instroom*kwaliteit
	~	
	~	OP DIT MOMENT KWALITEIT NOG NIET TOEGEVOEGD
	|

instroom MSc studenten=
	(jaarlijkse MSc instroom+fractie van BSc naar MSc*uitstroom BSc studenten)*kwaliteit
	~	
	~		|

fractie afvallers MSc=
	MIN(MAX((0.1+0.1)/kwaliteit,0),1)
	~	
	~		|

fractie afvallers BSc=
	MAX(MIN((0.3+0.1+0.05)/kwaliteit,1),0)
	~	
	~		|

boete per langstudeerder=
	IF THEN ELSE(Time>2011,hoogte boete per langstudeerder,0)
	~	
	~		|

aantal docenturen per student=
	SMOOTH3(1000*docenten/MAX(totaal aantal studenten,1),1)
	~	
	~		|

financien= INTEG (
	instroom onderwijsgelden-uitstroom van onderwijsgelden,
		0)
	~	euro
	~		|

afvallers MSc=
	MSc uitstroom na vaste en bijkomende vertraging*fractie afvallers MSc
	~	
	~	AFVALLERS JAARLIJKS LATEN AFVALLEN EN TESTEN
	|

jaarlijkse MSc instroom=
	evolutie van de nieuwe MSc instromers/TIME STEP*instroommoment MSc
	~	
	~		|

jaarlijkse lump sum en andere gelden=
	1e+006
	~	
	~		|

bijkomende jaarlijkse vertraging BSc=
	0.5/kwaliteit
	~	
	~		|

bijkomende jaarlijkse vertraging MSc=
	0.5/kwaliteit
	~	
	~		|

BSc uitstroom na vaste en bijkomende vertraging=
	DELAY1I(BSc uitstroom indien enkel vaste vertraging door minimale studieduur, minimale BSc studieduur\
		*bijkomende jaarlijkse vertraging BSc, 0)
	~	
	~		|

MSc uitstroom na vaste en bijkomende vertraging=
	DELAY1I(MSc uitstroom indien enkel vaste vertraging door minimale studieduur, bijkomende jaarlijkse vertraging MSc\
		*minimale MSc studieduur, 0)
	~	
	~		|

MSc studenten= INTEG (
	instroom MSc studenten-afvallers MSc-uitstroom MSc studenten,
		0)
	~	student
	~		|

netto werving van docenten=
	(maximaal aantal docenten-docenten)/wervingstijd
	~	
	~		|

docenten= INTEG (
	netto werving van docenten,
		5)
	~	
	~		|

instroom onderwijsgelden=
	subsidie per BSc instromer*instroom BSc studenten+subsidie per BSc afstudeerder*uitstroom BSc studenten\
		 + subsidie per MSc instromer*instroom MSc studenten+subsidie per MSc afstudeerder*\
		uitstroom MSc studenten + jaarlijkse lump sum en andere gelden
	~	
	~		|

evolutie van de nieuwe MSc instromers= WITH LOOKUP (
	Time,
		([(1990,0)-(2030,200)],(1990,0),(1995,0),(2000,0),(2008,2),(2010,5),(2015,15),(2020\
		,20),(2030,20) ))
	~	
	~		|

instroommoment MSc=
	PULSE TRAIN(1990,TIME STEP,1,2030)
	~	
	~		|

fractie langstudeerder= WITH LOOKUP (
	kwaliteit,
		([(0,0)-(2,1)],(0,0.9),(0.25,0.85),(0.5,0.66),(0.75,0.4),(1,0.25) ))
	~	
	~		|

fractie van BSc naar MSc=
	IF THEN ELSE(Time<2008,1,0.8)
	~	
	~		|

subsidie per BSc afstudeerder=
	5000
	~	euro/student
	~		|

subsidie per BSc instromer=
	15000
	~	euro/student
	~		|

subsidie per MSc afstudeerder=
	5000
	~	euro/student
	~		|

subsidie per MSc instromer=
	5000
	~	
	~		|

gemiddelde kost per docent=
	100000
	~	euro/docent/Year
	~		|

uitstroom MSc studenten=
	MSc uitstroom na vaste en bijkomende vertraging*(1-fractie afvallers MSc)
	~	student/Year
	~		|

MSc uitstroom indien enkel vaste vertraging door minimale studieduur= DELAY FIXED (
	instroom MSc studenten, minimale MSc studieduur, 0)
	~	
	~		|

totaal aantal studenten=
	BSc studenten+MSc studenten
	~	
	~		|

kwaliteit= WITH LOOKUP (
	aantal docenturen per student,
		([(0,0)-(200,2)],(0,0.1),(50,0.6),(100,0.9),(150,1),(200,1) ))
	~	
	~		|

maximaal aantal docenten=
	financien/gemiddelde kost per docent
	~	
	~	SMOOTH3( financien/gemiddelde kost docent,1)
	|

minimale MSc studieduur=
	2
	~	Year
	~		|

wervingstijd=
	2
	~	Year
	~		|

afvallers BSc=
	BSc uitstroom na vaste en bijkomende vertraging*fractie afvallers BSc
	~	
	~	AFVALLERS JAARLIJKS LATEN AFVALLEN EN TESTEN
	|

BSc studenten= INTEG (
	instroom BSc studenten-afvallers BSc-uitstroom BSc studenten,
		0)
	~	student
	~		|

evolutie van de nieuwe BSc instromers= WITH LOOKUP (
	Time,
		([(1990,0)-(2030,200)],(1990,20),(1995,90),(2000,120),(2008,130),(2010,200),(2015,200\
		),(2020,200),(2030,200) ))
	~	
	~		|

BSc instroommoment=
	PULSE TRAIN(1990,TIME STEP,1,2030)
	~	
	~		|

jaarlijkse BSc instroom=
	evolutie van de nieuwe BSc instromers/TIME STEP*BSc instroommoment
	~	
	~		|

minimale BSc studieduur=
	3
	~	Year
	~		|

uitstroom BSc studenten=
	BSc uitstroom na vaste en bijkomende vertraging*(1-fractie afvallers BSc)
	~	student/Year
	~		|

BSc uitstroom indien enkel vaste vertraging door minimale studieduur= DELAY FIXED (
	instroom BSc studenten, minimale BSc studieduur, 0)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2030
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1990
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.015625
	~	Year [0,?]
	~	The time step for the simulation.
	|

