{UTF-8}
marginal cost new capacity previous year T3=
	marginal cost new capacity T3/learning curve period
	~	EURO/MW/YEAR
	~		|

marginal cost new capacity previous year T2=
	marginal cost new capacity T2/learning curve period
	~	EURO/MW/YEAR
	~		|

marginal cost new capacity previous year T1=
	marginal cost new capacity T1/learning curve period
	~	EURO/MW/YEAR
	~		|

learning curve period=
	1
	~	YEAR
	~		|

sustainable fraction of total installed capacity=
	1-installed capacity T1/total installed capacity
	~	dmnl
	~		|

installed capacity T3= INTEG (
	+commissioning capacity T3-decommissioning capacity T3,
		initial capacity T3)
	~	MW
	~		|

marginal cost new capacity T3= INTEG (
	marginal cost capacity T3-marginal cost new capacity previous year T3,
		initial marginal cost new capacity T3)
	~	EURO/MW
	~		|

capacity under construction T3= INTEG (
	newly planned capacity T3-commissioning capacity T3,
		initial capacity under construction T3)
	~	MW
	~		|

average construction time T3=
	1
	~	YEAR
	~		|

cumulatively installed capacity T3=
	cumulatively decommissioned capacity T3 + installed capacity T3
	~	MW
	~		|

desired fraction new capacity T3=
	MIN(1, MAX(0, 1/marginal cost new capacity T3/(1/marginal cost new capacity T1+1/marginal cost new capacity T3\
		+1/marginal cost new capacity T2)))
	~	dmnl
	~	MIN(1, MAX(0, 1-(desired fraction new capacity of technology 2 + desired \
		fraction new capacity of technology 3)))
	|

newly planned capacity T3=
	MAX(expected new capacity to be installed * desired fraction new capacity T3,0)
	~	MW/YEAR
	~		|

cumulatively installed capacity previous year T3= DELAY FIXED (
	cumulatively installed capacity T3, 1, cumulatively installed capacity T3)
	~	MW
	~		|

commissioning capacity T3=
	capacity under construction T3/average construction time T3
	~	MW/YEAR
	~		|

initial capacity T3=
	1.5
	~	MW
	~		|

cumulatively decommissioned capacity T3= INTEG (
	decommissioning capacity T3,
		initial cumulatively decommissioned capacity T3)
	~	MW
	~		|

initial capacity under construction T3=
	0.5
	~	MW
	~		|

decommissioning capacity T3=
	installed capacity T3/lifetime techmology T3
	~	MW/YEAR
	~		|

lifetime techmology T3=
	30
	~	YEAR
	~		|

marginal cost capacity T3=
	marginal cost new capacity previous year T3 * (cumulatively installed capacity T3 / \
		cumulatively installed capacity previous year T3)^(-experience curve parameter T3)
	~	EURO/MW/YEAR
	~		|

progress ratio T3=
	0.8
	~	dmnl
