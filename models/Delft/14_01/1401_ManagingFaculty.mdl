{UTF-8}
budgetcoverage=
	1
	~	Month
	~		|

desired number of professors=
	money / average professor salary /budgetcoverage
	~	people
	~		|

teaching fee=
	150000
	~	euro/Month
	~		|

average hiring time=
	12
	~	Month
	~		|

average professor salary=
	3500
	~	euro/person/Month
	~		|

earnings from papers=
	earnings per published paper * number of papers published
	~	euro/Month
	~		|

earnings per published paper=
	4000
	~	euro/paper
	~		|

initially available money=
	500000
	~	euro
	~		|

money= INTEG (
	+subsidy and earnings from papers-money spent on salaries,
		initially available money)
	~	euro
	~		|

money spent on salaries=
	professors * average professor salary
	~	euro/Month
	~		|

new professors hired=
	MAX((desired number of professors - professors) / average hiring time,0 )
	~	person/Month
	~		|

number of papers per professor=
	0.5
	~	paper/person/Month
	~		|

number of papers published=
	number of papers per professor * professors
	~	paper/Month
	~		|

subsidy and earnings from papers=
	teaching fee + earnings from papers
	~	euro/Month
	~		|

professors leaving=
	professors*percentage of leavers
	~	person/Month
	~		|

professors= INTEG (
	+new professors hired-professors leaving,
		25)
	~	person
	~		|

percentage of leavers=
	0.1/12
	~	1/Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 200
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Month [0,?]
	~	The time step for the simulation.
	|

