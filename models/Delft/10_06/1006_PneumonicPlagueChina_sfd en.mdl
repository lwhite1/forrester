{UTF-8}
infection=
	contact rate*infection ratio*susceptible population*infected fraction
	~	persons/Week
	~		|

susceptible population= INTEG (
	-infection,
		initial total population-infected population)
	~	persons
	~		|

infected fraction=
	infected population/total population
	~	Dmnl
	~		|

total population=
	infected population+recovering population+susceptible population
	~	persons
	~		|

initial total population=
	10000
	~	persons
	~		|

contact rate= GAME (
	20)
	~	persons/persons/Week
	~		|

antibiotics coverage of the population= GAME (
	0)
	~	Dmnl
	~	LOOKUP (TIME ([(0,0)-(10,10)],(0,0),(1,0.5),(2,1),(3,1),(6,1) )  )
	|

infected population= INTEG (
	infection-recovery-deaths,
		1)
	~	persons
	~		|

recovery=
	(1-fatality ratio)*infected population/recovery time
	~	persons/Week
	~		|

recovering population= INTEG (
	recovery,
		0)
	~	persons
	~		|

recovery time= GAME (
	0.33)
	~	Week
	~		|

infection ratio= GAME (
	0.75)
	~	persons/persons
	~		|

deceased population= INTEG (
	deaths,
		0)
	~	persons
	~		|

deaths=
	infected population*fatality ratio/recovery time
	~	persons/Week
	~		|

fatality ratio= WITH LOOKUP (
	antibiotics coverage of the population,
		([(0,0)-(1,1)],(0,0.9),(1,0.15) ))
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 6
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Week [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Week [0,?]
	~	The time step for the simulation.
	|

