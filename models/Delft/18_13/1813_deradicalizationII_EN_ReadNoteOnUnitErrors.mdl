{UTF-8}
visibility of the problem=
	problem symptoms*radical action level*commitment of radical individuals to radical action
	~	Dmnl
	~		|

commitment of radical individuals to radical action=
	1
	~	1/citizens
	~		|

extremists= INTEG (
	activists 2 extremists,
		ini extremists)
	~	citizens
	~		|

frustration of convinced citizens=
	min(MAX((frustration due to marginalization+frustration due to inertia)*perceived animal distress\
		,0),1)
	~	Dmnl
	~	OLD: min(MAX(frustration due to marginalization*frustration due to \
		inertia*average degree of conviction of convinced citizens*percived \
		magnitude of the problem,0),1)
	|

"non-radical action level"=
	frustration of convinced citizens
	~	Dmnl
	~	OLD: (1-frustration of convinced citizens)*"total readiness to take \
		non-radical action"*(homegrown activists+convinced citizens)/total \
		population
	|

fraction of convinced citizens=
	(convinced citizens+activists+extremists)/(convinced citizens+activists+extremists+unconvinced citizens\
		+citizens that cannot be convinced)
	~	Dmnl
	~		|

radical action level=
	frustration of convinced citizens*extremists*fraction of convinced citizens
	~	citizens
	~	EXPRESSED IN TOTALLY FRUSTRATED CITIZENS TAKING RADICAL ACTION
	|

potential fraction of extremists=
	0.1
	~	Dmnl
	~		|

activists 2 extremists=
	(potential number of extremists-extremists)/average time to change states
	~	citizens/Year
	~		|

average time to change states=
	10
	~	Year
	~		|

persuasion=
	min(contact rate of convinced citizens*fraction of convinced citizens*unconvinced citizens\
		*"persuasiveness of non-radical actions" *visibility of the problem/"strength of incompatible self-interest"\
		/average time to change states,unconvinced citizens/average time to change states)
	~	citizens/Year
	~	min(dedicated contact rate of convinced citizens*fraction of convinced \
		citizens*unconvinced citizens*"persuasiveness of non-radical actions" \
		*visibility of the problem/"strength of incompatible \
		self-interest"/average time to change states,unconvinced citizens/average \
		time to change states)
	|

convinced 2 activist=
	(potential number of activitsts-activists)/average time to change states
	~	citizens/Year
	~		|

convinced citizens= INTEG (
	persuasion-convinced 2 activist,
		ini convinced)
	~	citizens
	~		|

contact rate of convinced citizens=
	min(normal contact rate of convinced citizens*"non-radical action level",3650)
	~	contacts/(citizen)
	~	DIFFERENT FORMULATION
	|

potential number of extremists=
	potential fraction of extremists*activists*frustration of convinced citizens*frustration due to marginalization
	~	citizens
	~		|

ini extremists=
	0
	~	citizens
	~		|

activists= INTEG (
	convinced 2 activist-activists 2 extremists,
		ini activists)
	~	citizens
	~		|

ini activists=
	1000
	~	citizens
	~		|

potential number of activitsts=
	potential fraction of activists*convinced citizens*frustration of convinced citizens
	~	citizens
	~		|

potential fraction of activists=
	0.1
	~	Dmnl
	~		|

"persuasiveness of non-radical actions"=
	0.01
	~	citizens/contacts
	~	OLD: "non-radical action level"*normal persuasiveness
	|

citizens that cannot be convinced=
	3e+006
	~	citizens
	~		|

frustration due to inertia=
	DELAY FIXED( (maximum attainable rate of decrease through societal change-rate of decrease through societal change\
		)/maximum attainable rate of decrease through societal change, 1, (maximum attainable rate of decrease through societal change\
		-rate of decrease through societal change)/maximum attainable rate of decrease through societal change\
		)
	~	Dmnl
	~		|

frustration due to marginalization= WITH LOOKUP (
	fraction of convinced citizens,
		([(0,0)-(1,1)],(0,1),(0.025,0.5),(0.103976,0.20614),(0.25,0.04),(0.5,0),(1,0) ))
	~	Dmnl
	~		|

ini convinced=
	100000
	~	citizens
	~		|

ini unconvinced=
	1.29e+007
	~	citizens
	~		|

initial value of underlying phenomenon=
	100
	~	Dmnl
	~		|

exogenous rate of increase of animal distress=
	0
	~	1/Year
	~		|

maximum attainable rate of decrease through societal change=
	0.05
	~	1/Year
	~		|

net increase of animal distress=
	animal distress*(exogenous rate of increase of animal distress-rate of decrease through societal change\
		)
	~	1/Year
	~		|

normal contact rate of convinced citizens=
	1000
	~	contacts/citizen
	~		|

perceived animal distress=
	SMOOTH3( animal distress/societal acceptation threshold with regard to animal distress\
		,1)
	~	Dmnl
	~		|

problem symptoms=
	MAX(animal distress-societal acceptation threshold with regard to animal distress,0)\
		/societal acceptation threshold with regard to animal distress
	~	Dmnl
	~		|

societal acceptation threshold with regard to animal distress= WITH LOOKUP (
	Time,
		([(1950,0)-(2100,100)],(1980,100),(2020,50),(2080,20) ))
	~	Dmnl
	~	60
	|

rate of decrease through societal change=
	fraction of convinced citizens*maximum attainable rate of decrease through societal change
	~	1/Year
	~		|

"strength of incompatible self-interest"=
	10
	~	Dmnl
	~		|

unconvinced citizens= INTEG (
	-persuasion,
		ini unconvinced)
	~	citizens
	~		|

animal distress= INTEG (
	net increase of animal distress,
		initial value of underlying phenomenon)
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2080
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1980
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Year [0,?]
	~	The time step for the simulation.
	|

