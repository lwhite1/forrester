{UTF-8}
average emigration time=
	1
	~	
	~		|

normal REU cost=
	50000+(average immigrant salary*REU construction time*number of workers per REU under construction\
		)
	~	
	~		|

number of immigrants in the previous period=
	DELAY FIXED(immigrants, 1, immigrants)
	~	
	~		|

REU shortage=
	REU demand/REU supply
	~	
	~		|

REU shortage price effect = WITH LOOKUP (
	REU shortage,
		([(0,0)-(100,10)],(0,0.6),(10,4),(50,7.5),(100,10) ))
	~	
	~		|

expected new REU due to immigration=
	immigration multiplication factor*(immigrants-number of immigrants in the previous period\
		)
	~	
	~		|

locals= INTEG (
	integration,
		22000)
	~	
	~		|

REU demolition=
	REU supply/average REU lifetime
	~	
	~		|

immigration multiplication factor=
	1
	~	
	~		|

REU price=
	normal REU cost*REU shortage price effect
	~	
	~		|

average immigrant salary=
	labor shortage*normal immigrant salary
	~	
	~		|

average immigration time=
	1
	~	Month
	~		|

average REU approval time=
	1
	~	Month
	~		|

average REU lifetime=
	500
	~	Month
	~		|

expected REU shortages=
	MAX((REU demand-REU supply-REU under construction+expected new REU due to immigration\
		),0)
	~	
	~		|

immigrants= INTEG (
	workforce immigration-integration-workforce emigration
	,
		2e+006)
	~	
	~		|

integration=
	immigrants*integration rate
	~	
	~		|

integration rate=
	0.001
	~	
	~		|

investment ratio of current REU supply=
	0.01
	~	
	~		|

labor demand=
	number of workers per REU under construction*REU under construction
	~	
	~		|

labor shortage=
	labor demand/immigrants
	~	
	~		|

new REU plans approved=
	(expected REU shortages/average REU approval time)+(investment ratio of current REU supply\
		*REU supply)
	~	
	~		|

normal immigrant salary=
	1000
	~	
	~		|

number of workers per REU under construction=
	25
	~	
	~		|

relative attractiveness to immigrate=
	average immigrant salary/normal immigrant salary
	~	
	~		|

REU commissioning=
	MIN(REU under construction/REU construction time,(immigrants/(REU construction time*\
		number of workers per REU under construction
	)))
	~	
	~		|

REU construction time=
	3
	~	Month
	~		|

REU demand=
	(immigrants+locals)/REU demand per person
	~	
	~		|

REU demand per person=
	1+(1/12*20)*Time
	~	
	~		|

REU supply= INTEG (
	REU commissioning-REU demolition,
		1.8e+006)
	~	
	~		|

REU under construction= INTEG (
	new REU plans approved-REU commissioning,
		(immigrants*REU construction time)/number of workers per REU under construction)
	~	
	~		|

workforce emigration=
	MAX((immigrants-labor demand)/average emigration time , 0)
	~	
	~		|

workforce immigration=
	MAX((relative attractiveness to immigrate*immigrants)/average immigration time,0)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0078125
	~	Month [0,?]
	~	The time step for the simulation.
	|

