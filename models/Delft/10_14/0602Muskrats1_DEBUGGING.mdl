{UTF-8}
Muskrats caught=
	-Muskrats caught per trap*Traps per license* Number of licenses
	~	Muskrats/Year
	~		|

Muskrat population= INTEG (
	+New Muskrats-Muskrats caught,
		Initial number of muskrats)
	~	Muskrats
	~		|

Initial number of muskrats=
	100
	~	Muskrats
	~		|

Number of licenses=
	10
	~	licenses/Year
	~	10
	|

Muskrats caught per trap=
	Muskrat population * Proportionality factor
	~	Muskrats/traps
	~		|

New muskrats rate=
	20
	~	1/Year
	~		|

New Muskrats=
	New muskrats rate*Muskrat population
	~	Muskrats/Year
	~		|

Proportionality factor=
	0.195
	~	1/traps
	~		|

Traps per license=
	10
	~	traps/licenses
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 10
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

