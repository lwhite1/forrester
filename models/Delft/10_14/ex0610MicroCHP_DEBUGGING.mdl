{UTF-8}
total market=
	clients+potential clients+new clients
	~	person
	~		|

"99 per cent"=
	0.99*total market
	~	person
	~		|

new clients=
	 contacts of potential clients with clients*convincing degree
	~	person/Month
	~		|

contacts of potential clients with clients = contacts with clients*potential client concentration
	~	contact/Month
	~		|

contacts with clients = clients*social contacts per person per month
	~	contact/Month
	~		|

clients= INTEG (
	new clients,
		100)
	~	person
	~		|

convincing degree = 0.01
	~	person/contact
	~		|

potential client concentration = potential clients/total market
	~	dmnl
	~		|

potential clients= INTEG (
	 - new clients,
		1.6e+007)
	~	persoon
	~		|

social contacts per person per month=
	50
	~	contact/person/Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Month
	~	The time step for the simulation.
	|

