{UTF-8}
lenght of the birth season=
	TIME STEP
	~	
	~		|

lenght of the death season=
	TIME STEP
	~	
	~		|

percentage death rate= WITH LOOKUP (
	large herbivores,
		([(0,0)-(10000,1)],(0,0.05),(1000,0.075),(3000,0.2),(4000,0.3),(5000,0.45),(6000,0.75\
		) ))
	~	
	~		|

births large herbivores=
	DELAY FIXED(large herbivores*percentage birth rate*birth season/lenght of the birth season\
		*randomizer births, 2, large herbivores*percentage birth rate*birth season/lenght of the birth season\
		*randomizer births)
	~	grote grazers/year
	~		|

randomizer births=
	RANDOM NORMAL(0, 2, 1, 0.5, 2)
	~	
	~	RANDOM NORMAL(0, 2, 1, 0.5, 2)
	|

initial number of large herbivores=
	75
	~	
	~		|

birth season=
	PULSE TRAIN(1982.5, lenght of the birth season, 1, FINAL TIME)
	~	
	~	/TIME STEP
	|

large herbivores= INTEG (
	-births large herbivores+deaths large herbivores,
		initial number of large herbivores)
	~	grote grazers
	~	Initial amount of deer is 5,000 and remains constant
	|

randomizer deaths=
	RANDOM UNIFORM(0.5, 3, 3)
	~	
	~	RANDOM NORMAL(0, 5, 1, 1, 1)
	|

averaged info large herbivores=
	SMOOTH3I(large herbivores, 1, initial number of large herbivores)
	~	grote grazers
	~		|

death season=
	PULSE TRAIN(1982, lenght of the death season, 1, FINAL TIME)
	~	
	~	/TIME STEP
	|

averaged info births large herbivores=
	SMOOTH3I(births large herbivores, 2,2)
	~	grote grazers/year
	~		|

deaths large herbivores=
	MAX(large herbivores*percentage death rate*death season/lenght of the death season*randomizer deaths\
		,large herbivores/TIME STEP)
	~	grote grazers/year
	~		|

averaged info deaths large herbivores=
	SMOOTH3I(deaths large herbivores, 2,0)
	~	grote grazers/year
	~		|

percentage birth rate= WITH LOOKUP (
	large herbivores,
		([(0,0)-(6000,0.6)],(0,0.5),(3500,0.25),(5000,0.15) ))
	~	1/year
	~	MODIFIED
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 2035
	~	year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1985
	~	year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	year
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	year
	~	The time step for the simulation.
	|

