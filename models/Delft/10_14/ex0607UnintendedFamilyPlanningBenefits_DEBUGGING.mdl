{UTF-8}
percentage of youngsters with criminal behavior=
	0.5
	~	
	~		|

crimes by others
	=
	2.6e+007
	~	
	~		|

crimes=
	criminal kids*ciminal acts per criminal kid + ciminal acts per criminal youngster*criminal youngsters\
		 + criminal acts per criminal adult
	*criminal adults + criminal acts per criminal retiree
	*criminal retirees + crimes by others
	~	
	~		|

criminal kids=
	kids*percentage of kids and youngsters with criminal behavior
	~	
	~		|

ciminal acts per criminal kid=
	2
	~	
	~		|

criminal youngsters=
	youngsters*percentage of youngsters with criminal behavior
	~	
	~		|

ciminal acts per criminal youngster=
	4
	~	
	~		|

annual fertility rate adults=
	0.03
	~	
	~		|

annual fertility rate youngsters=
	0.001
	~	
	~		|

average time as adult=
	40
	~	
	~		|

average time as kid=
	12
	~	
	~		|

average time as retirees=
	15
	~	
	~		|

average time as youngster=
	12
	~	
	~		|

average time pregnancy=
	0.75
	~	
	~		|

births=
	(1-percentage early ended pregnancies) * unborns *average time pregnancy
	~	
	~		|

percentage early ended pregnancies=
	0.75
	~	
	~		|

criminal acts per criminal adult=
	12
	~	
	~		|

criminal acts per criminal retiree=
	4
	~	
	~		|

criminal adults=
	adults*percentage of adults with criminal behavior
	~	
	~		|

criminal retirees=
	retirees*percentage of retirees with criminal behavior
	~	
	~		|

ini youngsters=
	1e+006
	~	
	~		|

ini adults=
	3e+006
	~	
	~		|

ini kids=
	1e+006
	~	
	~		|

percentage of adults with criminal behavior=
	0.6
	~	
	~		|

percentage of retirees with criminal behavior=
	0.1
	~	
	~		|

"total multi-problem family population"=
	adults+kids+retirees+youngsters
	~	
	~		|

percentage of kids and youngsters with criminal behavior=
	0.05
	~	
	~		|

ini unborns=
	68000
	~	
	~		|

ini retirees=
	750000
	~	
	~		|

adults= INTEG (
	from young adults to adults-from adults to retirees,
		ini adults)
	~	
	~		|

deaths=
	retirees/average time as retirees
	~	
	~		|

early ended pregnancies=
	percentage early ended pregnancies*unborns*average time pregnancy
	~	
	~		|

from adults to retirees=
	adults/average time as adult
	~	
	~		|

from young adults to adults=
	youngsters/average time as youngster
	~	
	~		|

growing up=
	kids/average time as kid
	~	
	~		|

kids= INTEG (
	births+growing up,
		ini kids)
	~	
	~		|

unborns= INTEG (
	conceptions-births-early ended pregnancies,
		ini unborns)
	~	
	~		|

retirees= INTEG (
	from adults to retirees-deaths,
		ini retirees)
	~	
	~		|

conceptions=
	adults*annual fertility rate adults + youngsters*annual fertility rate youngsters
	~	
	~		|

youngsters= INTEG (
	growing up+from young adults to adults,
		ini youngsters)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 50
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Year [0,?]
	~	The time step for the simulation.
	|

