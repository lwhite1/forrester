{UTF-8}
deaths=
	population/resource availability dependent lifetime
	~	consumer/Year
	~		|

resource availability dependent lifetime=
	MAX(15,MIN(100,normal lifetime*per capita renewable resource availability))
	~	
	~	MAX(MIN(normal lifetime*per capita renewable resource availability,100),20)
	|

rapid resource depletion time=
	1
	~	Year
	~		|

resource use=
	MIN(renewable resources/rapid resource depletion time, renewable resource consumption per capita\
		*population)
	~	resource/Year
	~	IF THEN ELSE(renewable resources/rapid resource depletion time < renewable \
		resource consumption per capita*population, renewable resources/rapid \
		resource depletion time, renewable resource consumption per \
		capita*population)
	|

INITIAL RESOURCES=
	7e+006
	~	resource
	~		|

INITIAL CONSUMERS=
	100000
	~	consumer
	~		|

renewable resources= INTEG (
	+regeneration-resource use,
		INITIAL RESOURCES)
	~	resource
	~		|

regeneration=
	regeneration rate*renewable resources*(renewable resources/carrying capacity)*(1-renewable resources\
		/carrying capacity)+minimum regeneration rate*carrying capacity
	~	resource/Year
	~		|

regeneration rate=
	1.2
	~	1/Year
	~		|

normal birth rate=
	0.0035
	~	1/Year
	~		|

minimum regeneration rate=
	0.01
	~	1/Year
	~		|

carrying capacity=
	7.5e+006
	~	resource
	~		|

per capita renewable resource availability=
	renewable resources/population
	~	resource/consumer
	~		|

renewable resource consumption per capita=
	1
	~	resource/(consumer*Year)
	~		|

normal lifetime=
	25
	~	1/Year
	~		|

population= INTEG (
	+births-deaths,
		INITIAL CONSUMERS)
	~	consumer
	~		|

births=
	normal birth rate*population/per capita renewable resource availability
	~	consumer/Year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 500
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.02
	~	Year [0,?]
	~	The time step for the simulation.
	|

