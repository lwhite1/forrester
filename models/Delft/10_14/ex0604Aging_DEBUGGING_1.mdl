{UTF-8}
retirees= INTEG (
	-deaths,
		initial number of retirees)
	~	personen
	~		|

births=
	average birth rate per adult*children
	~	personen/Year
	~		|

grey pressure=
	retirees/(adults+children)
	~	Dmnl
	~		|

total population=
	adults+children+retirees
	~	
	~		|

adults= INTEG (
	maturing-retiring,
		initial number of adults)
	~	personen
	~		|

children= INTEG (
	births-maturing,
		initial number of children)
	~	personen
	~		|

inactive population=
	children + retirees + adults not on labour market
	~	personen
	~		|

average birth rate per adult=
	0.02
	~	personen/personen/Year
	~		|

average childhood period=
	22
	~	Year
	~		|

average adult participation ratio=
	0.5
	~	Dmnl
	~		|

average retiree period= WITH LOOKUP (
	Time,
		([(2010,20)-(2100,25)],(2010,20),(2020,21),(2030,22),(2038.9,22.6535),(2053.76,23.5307\
		),(2072.75,24.2105),(2087.89,24.693),(2100,25) ))
	~	Year
	~		|

average adult period=
	40
	~	Year
	~		|

initial number of retirees=
	3e+006
	~	personen
	~		|

initial number of children=
	4e+006
	~	personen
	~		|

initial number of adults=
	9e+006
	~	personen
	~		|

burden per active adult=
	inactive population/adults on the labour market
	~	Dmnl
	~		|

retiring=
	adults/average adult period
	~	personen/Year
	~		|

maturing=
	children/average childhood period
	~	personen/Year
	~		|

deaths=
	retirees/average retiree period
	~	personen/Year
	~		|

adults not on labour market=
	adults*(1-average adult participation ratio)
	~	
	~		|

adults on the labour market=
	adults*average adult participation ratio
	~	personen
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 2010
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.03125
	~	Year [0,?]
	~	The time step for the simulation.
	|

