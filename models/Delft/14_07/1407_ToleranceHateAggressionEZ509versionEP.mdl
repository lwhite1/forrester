{UTF-8}
unfamiliar experience=
	intolerance*DEGREE OF UNFAMILIARITY*encounters*ENCOUNTER INTENSITY*unfamiliarity*(1-\
		unfamiliarity/MAX UNFAMILIARITY) * (1+violence)
	~	1/Month
	~		|

hate increase=
	unfamiliarity*intolerance*social problems*hate*(1-hate/MAX HATE)/adaptation TIME * (\
		1+violence)
	~	1/Month
	~		|

tolerance erosion=
	tolerance*hate/adaptation TIME * (1+violence)
	~	1/Month
	~		|

increase in tolerance through educational effort=
	SMOOTH(education effort*tolerance*(1-tolerance/MAX TOLERANCE),1)
	~	1/Month
	~		|

restraint loss=
	hate*social problems*VIOLENCE IN MEDIA*restraint threshold/adaptation TIME
	~	1/Month
	~		|

restraint buildup=
	max restraint*restraint threshold*(1-restraint threshold/max restraint)/adaptation TIME
	~	1/Month
	~		|

EDUCATION ACTIVITY=
	0.5
	~	1/Month
	~		|

education effort=
	0+EDUCATION ACTIVITY*STEP(1, 15)
	~	1/Month
	~		|

encounters=
	PULSE TRAIN(5,1, ENCOUNTER INTERVAL,50)
	~	1/Month
	~		|

ENCOUNTER INTERVAL=
	2
	~	Month
	~		|

ENCOUNTER INTENSITY=
	5
	~	1
	~		|

unfamiliarity= INTEG (
	unfamiliar experience-accustoming,
		0.1)
	~	1
	~		|

DEGREE OF UNFAMILIARITY=
	0.5
	~	1
	~		|

violence=
	hate*violent action
	~	1
	~		|

VIOLENCE IN MEDIA=
	0.4
	~	1
	~		|

violent action=
	IF THEN ELSE(hate-restraint threshold>0, 1, 0)
	~	1
	~		|

accustoming=
	unfamiliarity*tolerance/adaptation TIME
	~	1/Month
	~		|

ETHICAL SCRUPLES=
	0.1
	~	1
	~		|

hate= INTEG (
	+hate increase-hate decrease,
		0.1)
	~	1
	~		|

hate decrease=
	hate*tolerance/adaptation TIME
	~	1/Month
	~		|

restraint threshold= INTEG (
	+restraint buildup-restraint loss,
		0.5)
	~	1
	~		|

intolerance=
	MAX TOLERANCE-tolerance
	~	1
	~		|

MAX UNFAMILIARITY=
	1
	~	1
	~		|

MAX HATE=
	1
	~	1
	~		|

max restraint=
	govt authority*(1-VIOLENCE IN MEDIA)+ETHICAL SCRUPLES
	~	1
	~		|

MAX TOLERANCE=
	1
	~	1
	~		|

PROBLEM BEGINNING=
	5
	~	Month
	~		|

PROBLEM STRENGTH=
	4
	~	1
	~		|

social problems=
	STEP(PROBLEM STRENGTH, PROBLEM BEGINNING)
	~	1
	~		|

govt authority=
	0+GOVT RESOLVE*STEP(1, 10)
	~	1
	~		|

GOVT RESOLVE=
	1
	~	1
	~		|

tolerance= INTEG (
	increase in tolerance through educational effort-tolerance erosion,
		0.5)
	~	1
	~		|

adaptation TIME=
	5
	~	Month
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 50
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Month [0,?]
	~	The time step for the simulation.
	|

