{UTF-8}
visibillity of the problem=
	problem syntoms*"reinforcement of the visibility of the problem through radical and non-radical actions"
	~	Dmnl
	~		|

persuasion=
	contact rate of convinced citizens*fraction of convinced citizens*unconvinced citizens\
		*"persuasivness of non-radical actions"*visibillity of the problem/"strength of incompatible self-interest"
	~	citizens/Year
	~		|

average degree of conviction of convinced citizens=
	total readiness to take action of all the convinced citizens/convinced citizens
	~	Dmnl
	~		|

average readiness to take action=
	total readiness to take action of all the convinced citizens/convinced citizens
	~	Dmnl
	~		|

citizens that cannot be convinced=
	3e+006
	~	citizens
	~		|

contact rate of convinced citizens=
	normal contact rate of convinced citizens*(1-radical action level)
	~	contacts/(Year*citizen)
	~		|

convinced citizens= INTEG (
	persuasion,
		initial number of convinced citizens)
	~	citizens
	~		|

fraction of convinced citizens=
	convinced citizens/total population
	~	Dmnl
	~		|

frustration due to inertia=
	(maximum attainable rate of decrease through societal change-rate of decrease through societal change\
		)/maximum attainable rate of decrease through societal change
	~	Dmnl
	~		|

frustration due to marginalization = WITH LOOKUP (
	fraction of convinced citizens,
		([(0,0)-(1,1)],(0,1),(0.025,0.5),(0.05,0.2),(0.075,0.05),(0.1,0),(1,0) ))
	~	Dmnl
	~		|

frustration of convinced citizens=
	min(MAX(frustration due to marginalization*frustration due to inertia*average degree of conviction of convinced citizens\
		*percived magnitude of the problem,0),1)
	~	Dmnl
	~		|

initial number of convinced citizens=
	1000
	~	citizens
	~		|

initial number of unconvinced citizens=
	1.2999e+007
	~	citizens
	~		|

initial readiness to take action per contact=
	0.8
	~	Dmnl
	~		|

initial value of underlying phenomena=
	50
	~	Dmnl
	~		|

intristic rate of increase of the underlying phenomenon=
	0.01
	~	1/Year
	~		|

maximum attainable rate of decrease through societal change=
	0.05
	~	1/Year
	~		|

"net-increase of the underlying phenomenon"=
	underlying phenimenon*(intristic rate of increase of the underlying phenomenon-rate of decrease through societal change\
		)
	~	1/Year
	~		|

"non-radical action level"=
	(1-frustration of convinced citizens)*average readiness to take action
	~	Dmnl
	~		|

normal contact rate of convinced citizens=
	1000
	~	contacts/citizen/Year
	~		|

normal persuasiveness=
	0.01
	~	citizens/contacts
	~		|

percived magnitude of the problem=
	underlying phenimenon/problematic phenomenon level
	~	Dmnl
	~		|

"persuasivness of non-radical actions"=
	"non-radical action level"*normal persuasiveness
	~	citizens/contacts
	~		|

problem syntoms=
	MAX(underlying phenimenon-problematic phenomenon level,0)/problematic phenomenon level
	~	Dmnl
	~		|

problematic phenomenon level=
	60
	~	Dmnl
	~		|

radical action level=
	average readiness to take action*frustration of convinced citizens
	~	Dmnl
	~		|

rate of decrease through societal change=
	fraction of convinced citizens*maximum attainable rate of decrease through societal change
	~	1/Year
	~		|

readiness to take action of the newly convinced citizens=
	persuasion*readiness to take action per newly convinced citizen
	~	citizens/Year
	~		|

readiness to take action per newly convinced citizen=
	0.5
	~	Dmnl
	~		|

reinforcement of the visibility of the problem through radical actions=
	10
	~	Dmnl
	~		|

"reinforcement of the visibility of the problem through radical and non-radical actions"\
		=
	(1+"non-radical action level")*(1+radical action level*reinforcement of the visibility of the problem through radical actions\
		)
	~	Dmnl
	~		|

"strength of incompatible self-interest"=
	2
	~	Dmnl
	~		|

total population=
	citizens that cannot be convinced+convinced citizens+unconvinced citizens
	~	citizens
	~		|

total readiness to take action of all the convinced citizens= INTEG (
	readiness to take action of the newly convinced citizens,
		convinced citizens*initial readiness to take action per contact)
	~	citizens
	~		|

unconvinced citizens= INTEG (
	-persuasion,
		initial number of unconvinced citizens)
	~	citizens
	~		|

underlying phenimenon= INTEG (
	"net-increase of the underlying phenomenon",
		initial value of underlying phenomena)
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2080
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1980
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Year [0,?]
	~	The time step for the simulation.
	|

