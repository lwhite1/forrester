{UTF-8}
new fish  = A FUNCTION OF( Fish) ~~|
new fish=
	Fish*HATCH FRACTION
	~	Fish/Year
	~		|

catch per ship  = A FUNCTION OF( density,Fish) ~~|
catch per ship=
	density(density/NORMAL DENSITY)
	~	Fish/ship/Year
	~		|

costs  = A FUNCTION OF( Ships) ~~|
costs=
	Ships*UNIT SHIP OPERATING COST
	~	$/Year
	~		|

Ships  = A FUNCTION OF( ship building rate) ~~|
Ships= INTEG (
	ship building rate,
		INITIAL SHIPS)
	~	ship
	~		|

Fish  = A FUNCTION OF( new fish,total catch per year) ~~|
Fish= INTEG (
	new fish-fish death rate-total catch per year,
		INTIAL FISH)
	~	Fish
	~		|

Total Profits  = A FUNCTION OF( annual profits) ~~|
Total Profits= INTEG (
	annual profits,
		INITIAL TOTAL PROFITS)
	~	$
	~		|

revenues  = A FUNCTION OF( total catch per year) ~~|
revenues=
	FISH PRICE*total catch per year
	~	$/Year
	~		|

ship building rate  = A FUNCTION OF( annual profits) ~~|
ship building rate=
	MAX(0,annual profits*FRACTION INVESTED/SHIP COST)
	~	ship/Year
	~		|

annual profits=
	revenues-costs
	~	$/Year
	~		|

density(
	[(0,0)-(12,26)],(0,0),(1,5),(2,10.38),(3,15.88),(4,20.25),(5,22.13),(6,23.25),(7,23.75\
		),(8,24.25),(9,24.63),(10,25),(11,25.35),(12,25.48))
	~	fish/ship/Year
	~		|

total catch per year=
	Ships*catch per ship
	~	fish/Year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2025
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 2010
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Year [0,?]
	~	The time step for the simulation.
	|

