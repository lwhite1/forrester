{UTF-8}
"production Supplier (T2)"  = A FUNCTION OF( "productivity Supplier (T2)",WithWithoutProductionPolicy\
		,"Workforce Supplier (T2)") ~~|
"production Supplier (T2)"=
	 "Workforce Supplier (T2)"*"productivity Supplier (T2)"
	~	Sofa/Month
	~		|

production  = A FUNCTION OF( productivity,sales,WithWithoutProductionPolicy,Workforce\
		) ~~|
production = Workforce*productivity
	~	Sofa/Month
	~		|

WithWithoutProductionPolicy  = A FUNCTION OF( )
	~	
	~		|

"production Supplier (T1)"  = A FUNCTION OF( "productivity Supplier (T1)",WithWithoutProductionPolicy\
		,"Workforce Supplier (T1)") ~~|
"production Supplier (T1)"=
	 "Workforce Supplier (T1)"*"productivity Supplier (T1)"
	~	Sofa/Month
	~		|

"sales Supplier (T2)"=
	(1-WithWithoutSCMPolicy) * "production Supplier (T1)" + WithWithoutSCMPolicy * "sales Supplier (T1)"
	~	Sofa/Month
	~		|

"time to correct inventory Supplier (T2)" = 2
	~	Month
	~		|

"net hire rate Supplier (T2)" = ("target workforce Supplier (T2)"-"Workforce Supplier (T2)"\
		)/"time to adjust workforce Supplier (T2)"
	~	Person/Month
	~		|

"time to adjust workforce Supplier (T2)"=
	10
	~	Month
	~		|

"target inventory Supplier (T2)" = "sales Supplier (T2)" * "inventory coverage Supplier (T2)"
	~	Sofa
	~		|

"inventory correction Supplier (T2)" = ("target inventory Supplier (T2)" - "Inventory Supplier (T2)"\
		)/
                "time to correct inventory Supplier (T2)"
	~	Sofa/Month
	~		|

"target production Supplier (T2)" = "sales Supplier (T2)" + "inventory correction Supplier (T2)"
	~	Sofa/Month
	~		|

"inventory coverage Supplier (T2)" = 3
	~	Month
	~		|

"productivity Supplier (T2)" = 1
	~	Sofa/Month/Person
	~		|

"Inventory Supplier (T2)" = INTEG("production Supplier (T2)"-"sales Supplier (T2)",300\
		)
	~	Sofa
	~		|

"sales Supplier (T1)"=
	(1-WithWithoutSCMPolicy) * production + WithWithoutSCMPolicy * sales
	~	Sofa/Month
	~		|

"target workforce Supplier (T2)" = "target production Supplier (T2)"/"productivity Supplier (T2)"
	~	Person
	~		|

WithWithoutSCMPolicy=
	0
	~	Dmnl
	~	0 is without policy; 1 is with policy
	|

"Workforce Supplier (T2)" = INTEG("net hire rate Supplier (T2)",     "target workforce Supplier (T2)"\
		)
	~	Person
	~		|

"target workforce Supplier (T1)" = "target production Supplier (T1)"/"productivity Supplier (T1)"
	~	Person
	~		|

"net hire rate Supplier (T1)" = ("target workforce Supplier (T1)"-"Workforce Supplier (T1)"\
		)/"time to adjust workforce Supplier (T1)"
	~	Person/Month
	~		|

"Inventory Supplier (T1)" = INTEG("production Supplier (T1)"-"sales Supplier (T1)",300\
		)
	~	Sofa
	~		|

"inventory correction Supplier (T1)" = ("target inventory Supplier (T1)" - "Inventory Supplier (T1)"\
		)/
                "time to correct inventory Supplier (T1)"
	~	Sofa/Month
	~		|

"productivity Supplier (T1)" = 1
	~	Sofa/Month/Person
	~		|

"inventory coverage Supplier (T1)" = 3
	~	Month
	~		|

"target inventory Supplier (T1)" = "sales Supplier (T1)" * "inventory coverage Supplier (T1)"
	~	Sofa
	~		|

"time to correct inventory Supplier (T1)" = 2
	~	Month
	~		|

"time to adjust workforce Supplier (T1)"=
	10
	~	Month
	~		|

"Workforce Supplier (T1)" = INTEG("net hire rate Supplier (T1)",     "target workforce Supplier (T1)"\
		)
	~	Person
	~		|

"target production Supplier (T1)" = "sales Supplier (T1)" + "inventory correction Supplier (T1)"
	~	Sofa/Month
	~		|

FINAL TIME  = 100
	~	Month
	~		 The final time for the simulation.
	|

target inventory = sales * inventory coverage
	~	Sofa
	~		|

target production = sales + inventory correction
	~	Sofa/Month
	~		|

inventory correction = (target inventory - Inventory)/
                time to correct inventory
	~	Sofa/Month
	~		|

inventory coverage = 3
	~	Month
	~		|

time to correct inventory = 2
	~	Month
	~		|

INITIAL TIME  = 0
	~	Month
	~		 The initial time for the simulation.
	|

Inventory = INTEG(production-sales,300)
	~	Sofa
	~		|

net hire rate = (target workforce-Workforce)/time to adjust workforce
	~	Person/Month
	~		|

productivity = 1
	~	Sofa/Month/Person
	~		|

sales=
	 100+STEP(50,20)
	~	Sofa/Month
	~		|

SAVEPER  = 
        TIME STEP
	~	Month
	~		  The frequency with which output is stored.
	|

target workforce = target production/productivity
	~	Person
	~		|

TIME STEP  = 0.125
	~	Month
	~		 The time step for the simulation.
	|

time to adjust workforce=
	10
	~	Month
	~		|

Workforce = INTEG(net hire rate,     target workforce)
	~	Person
	~		|

