{UTF-8}
birth randomizer=
	RANDOM NORMAL(0, 2, 1, 0.5, seed births)
	~	
	~		|

death randomizer=
	RANDOM UNIFORM(0.5, 3, seed deaths)
	~	
	~		|

seed deaths=
	3
	~	
	~		|

seed births=
	2
	~	
	~		|

deaths=
	death randomizer*death season*large herbivores*percentage death rates/length of death season
	~	
	~		|

birth season=
	PULSE TRAIN(1982.5, length of the birth seaseon ,1 , 2050 )
	~	
	~		|

births=
	DELAY FIXED( birth randomizer*birth season*large herbivores*percentage birth rate/length of the birth seaseon\
		, 2, birth randomizer*birth season*large herbivores*percentage birth rate/length of the birth seaseon\
		)
	~	
	~		|

death season=
	PULSE TRAIN(1983, length of death season , 1 , 2050)
	~	
	~		|

large herbivores= INTEG (
	births-deaths,
		75)
	~	
	~		|

length of death season=
	TIME STEP
	~	
	~		|

length of the birth seaseon=
	TIME STEP
	~	
	~		|

percentage birth rate= WITH LOOKUP (
	large herbivores,
		([(0,0)-(5000,1)],(0,0.5),(1000,0.42),(2000,0.36),(3000,0.28),(4000,0.2),(5000,0.15\
		) ))
	~	
	~		|

percentage death rates= WITH LOOKUP (
	large herbivores,
		([(0,0)-(6000,1)],(0,0.05),(1000,0.08),(2000,0.12),(3000,0.2),(4000,0.3),(5000,0.45\
		),(6000,0.7) ))
	~	
	~		|

smoothed birth info=
	SMOOTH3(births, 1 )
	~	
	~		|

smoothed info on nr of herbivores=
	SMOOTH3(large herbivores, 1 )
	~	
	~		|

"smoothed nr. of deaths"=
	SMOOTH3(deaths, 1)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2050
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1985
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP 
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

