{UTF-8}
duur geboorte seizoen=
	TIME STEP
	~	
	~		|

duur sterfte seizoen=
	TIME STEP
	~	
	~		|

procentuele sterfte= WITH LOOKUP (
	grote grazers,
		([(0,0)-(10000,1)],(0,0.05),(1000,0.075),(3000,0.2),(4000,0.3),(5000,0.45),(6000,0.75\
		) ))
	~	
	~		|

geboortes grote grazers=
	DELAY FIXED(grote grazers*procentuele aanwas*geboorteseizoen/duur geboorte seizoen*randomizer geboortes\
		, 2, grote grazers*procentuele aanwas*geboorteseizoen/duur geboorte seizoen*randomizer geboortes\
		)
	~	grote grazers/year
	~		|

randomizer geboortes=
	RANDOM NORMAL(0, 2, 1, 0.5, 2)
	~	
	~	RANDOM NORMAL(0, 2, 1, 0.5, 2)
	|

initieel aantal grote grazers=
	75
	~	
	~		|

geboorteseizoen=
	PULSE TRAIN(1982.5, duur geboorte seizoen, 1, FINAL TIME)
	~	
	~	/TIME STEP
	|

grote grazers= INTEG (
	geboortes grote grazers-sterftes grote grazers,
		initieel aantal grote grazers)
	~	grote grazers
	~	Initial amount of deer is 5,000 and remains constant
	|

randomizer sterftes=
	RANDOM UNIFORM(0.5, 3, 3)
	~	
	~	RANDOM NORMAL(0, 5, 1, 1, 1)
	|

uitgemiddelde informatie grote grazers=
	SMOOTH3I(grote grazers, 1, initieel aantal grote grazers)
	~	grote grazers
	~		|

sterfteseizoen=
	PULSE TRAIN(1982, duur sterfte seizoen, 1, FINAL TIME)
	~	
	~	/TIME STEP
	|

uitgemiddelde info geboortes grote grazers=
	SMOOTH3I(geboortes grote grazers, 2,2)
	~	grote grazers/year
	~		|

sterftes grote grazers=
	MIN(grote grazers*procentuele sterfte*sterfteseizoen/duur sterfte seizoen*randomizer sterftes\
		,grote grazers/TIME STEP)
	~	grote grazers/year
	~		|

uitgemiddelde info sterftes grote grazers=
	SMOOTH3I(sterftes grote grazers, 2,0)
	~	grote grazers/year
	~		|

procentuele aanwas= WITH LOOKUP (
	grote grazers,
		([(0,0)-(6000,0.6)],(0,0.5),(3500,0.25),(5000,0.15) ))
	~	1/year
	~	MODIFIED
	|

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 2035
	~	year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1985
	~	year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	year
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.015625
	~	year
	~	The time step for the simulation.
	|

