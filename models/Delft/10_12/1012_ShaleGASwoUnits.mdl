{UTF-8}
annual gas demand= INTEG (
	new gas demand,
		2)
	~	whateverunitsofreserve/Year
	~		|

average time to turn SD Workshoppers into System Dynamicist=
	1
	~	
	~		|

"average time to turn SD Workshoppers into System Dynamicist."=
	1
	~	
	~		|

depletion gas resource base=
	MIN(annual gas demand,gas resource base)
	~	whateverunitsofreserve/Year
	~		|

gas resource base= INTEG (
	-depletion gas resource base,
		initial gas resource base)
	~	whateverunitsofreserve
	~		|

initial gas resource base=
	120
	~	whateverunitsofreserve
	~		|

new gas demand=
	annual gas demand*new gas demand growth rate
	~	whateverunitsofreserve/Year/Year
	~		|

new gas demand growth rate=
	0.02
	~	whateverunitsofreserve/Year/Year
	~		|

new SD workshoppers=
	0
	~	
	~		|

"new SD workshoppers."=
	0
	~	
	~		|

SD Workshoppers= INTEG (
	new SD workshoppers-System Dynamicists,
		0)
	~	
	~		|

System Dynamicists=
	SD Workshoppers/average time to turn SD Workshoppers into System Dynamicist
	~	
	~		|

"System Dynamicists."=
	DELAY1I("new SD workshoppers.", "average time to turn SD Workshoppers into System Dynamicist."\
		, 0)
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

