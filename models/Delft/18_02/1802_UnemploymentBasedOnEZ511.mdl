{UTF-8}
state cash inflow=
	tax revenues on sales value+state debt increase
	~	1/Year
	~		|

state debt increase=
	IF THEN ELSE(financial buffer of the state<0, -financial buffer of the state/ TIME STEP\
		, 0)
	~	1/Year
	~		|

state debt= INTEG (
	state debt increase,
		0)
	~	1
	~		|

REDUCTION RATE=
	0.1
	~	1/Year
	~		|

productivity increase=
	PRODUCTIVITY INCREASE RATE*productivity*(1-productivity/PRODUCTIVITY LIMIT)
	~	1/(Year*Year)
	~		|

net production jobs reductions=
	REDUCTION RATE * employment in production * MIN(relative production surplus,0.1)
	~	1/Year
	~	IF THEN ELSE(relative production surplus<0.1, REDUCTION RATE* relative \
		production surplus*employment in production, 0.1*REDUCTION RATE*employment \
		in production)
	|

PRODUCTIVITY INCREASE RATE=
	0.1
	~	1/Year
	~		|

net service jobs additions=
	(1-service demand fulfillment)*financial buffer of the state*unemployment rate*service jobs hiring rate
	~	1/Year
	~		|

service jobs hiring rate=
	0.05
	~	1/Year
	~		|

tax revenues on sales value=
	revenues dependent tax rate*sales value
	~	1/Year
	~		|

revenues dependent tax rate = WITH LOOKUP (
	financial buffer of the state,
		([(-2,0)-(2,1)],(-10,0.6),(-2,0.6),(-1.6,0.6),(-1.2,0.6),(-0.8,0.6),(-0.4,0.6),(0,0.6\
		),(0.4,0.5),(0.8,0.4),(1.2,0.3),(1.6,0.2),(2,0.2),(10,0.2) ))
	~	1
	~		|

sales value=
	IF THEN ELSE(DEMAND VALUE>product value, product value, DEMAND VALUE)
	~	1/Year
	~		|

POTENTIAL LABOR FORCE=
	1.5
	~	1
	~		|

unemployment rate=
	(POTENTIAL LABOR FORCE-employment in production-employment in services)/POTENTIAL LABOR FORCE
	~	1
	~		|

employment in services= INTEG (
	net service jobs additions,
		0.5)
	~	1
	~		|

employment in production= INTEG (
	-net production jobs reductions,
		1)
	~	1
	~		|

SERVICE DEMAND=
	1
	~	1
	~		|

service demand fulfillment=
	employment in services/SERVICE DEMAND
	~	1
	~		|

wages=
	wage index*WAGE FACTOR*employment in services
	~	1/Year
	~		|

WAGE FACTOR=
	0.25
	~	1
	~		|

wage index=
	productivity
	~	1/Year
	~		|

DEMAND VALUE=
	1
	~	1/Year
	~		|

productivity= INTEG (
	productivity increase,
		1)
	~	1/Year
	~		|

PRODUCTIVITY LIMIT=
	5
	~	1/Year
	~		|

product value=
	employment in production*productivity
	~	1/Year
	~		|

relative production surplus=
	(product value-DEMAND VALUE)/DEMAND VALUE
	~	1
	~		|

state cash outflow=
	wages
	~	1/Year
	~		|

financial buffer of the state= INTEG (
	+state cash inflow-state cash outflow,
		1)
	~	1
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 40
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0625
	~	Year [0,?]
	~	The time step for the simulation.
	|

