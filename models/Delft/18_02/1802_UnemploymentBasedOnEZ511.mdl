:DATASET wage factor=0,25
:LINE-WIDTH 1
:VAR state debt
:Y-MIN 0
:Y-MAX 40
:DATASET wage factor=0,5
:LINE-WIDTH 2
:VAR state debt
:Y-MIN 0
:Y-MAX 40
:DATASET wage factor=0,75
:LINE-WIDTH 3
:VAR state debt
:Y-MIN 0
:Y-MAX 40
:DATASET wage factor=1,0
:LINE-WIDTH 4
