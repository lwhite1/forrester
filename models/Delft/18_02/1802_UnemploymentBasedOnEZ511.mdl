:GRAPH EZ511b
:TITLE Unemployment
:X-AXIS Time
:X-DIV 8
:X-MIN 0
:X-MAX 40
:SCALE
:VAR employment in services
:Y-MIN 0
:Y-MAX 1
:LINE-WIDTH 2
:VAR employment in production
:Y-MIN 0
:LINE-WIDTH 3
:VAR unemployment
:Y-MIN 0
:LINE-WIDTH 4

:GRAPH EZ511c
:TITLE Unemployment
:X-AXIS Time
:X-DIV 8
:X-MIN 0
:X-MAX 40
:SCALE
:VAR state revenue income
:Y-MIN 0
:Y-MAX 2
:LINE-WIDTH 2
:VAR state expenses
:Y-MIN 0
:Y-MAX 2
:LINE-WIDTH 3
:VAR state debt increase
:Y-MIN 0
:Y-MAX 2
:LINE-WIDTH 4

:GRAPH EZ511f
:TITLE Unemployment
:X-AXIS Time
:X-DIV 8
:X-MIN 0
:X-MAX 40
:SCALE
:VAR unemployment
:Y-MIN 0
:Y-MAX 0.4
:DATASET wage factor=0,25
:LINE-WIDTH 1
:VAR unemployment
:Y-MIN 0
:Y-MAX 0.4
:DATASET wage factor=0,5
:LINE-WIDTH 2
:VAR unemployment
:Y-MIN 0
:Y-MAX 0.4
:DATASET wage factor=0,75
:LINE-WIDTH 3
:VAR unemployment
:Y-MIN 0
:Y-MAX 0.4
:DATASET wage factor=1,0
:LINE-WIDTH 4

:GRAPH EZ511g
:TITLE Unemployment
:X-AXIS Time
:X-DIV 8
:X-MIN 0
:X-MAX 40
:SCALE
:VAR state debt
:Y-MIN 0
