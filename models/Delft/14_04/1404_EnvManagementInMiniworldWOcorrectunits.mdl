{UTF-8}
births=
	birth rate*population*environmental quality*consumption level
	~	1/Year
	~		|

capacity increase=
	(normal growth rate*consumption level*environmental quality*population*(1-(consumption level\
		*population*environmental quality/consumption goal)))
	~	1/Year
	~	(GROWTH RATE*consumption level*environmental \
		pollution*population*(1-(consumption level*environmental \
		pollution/CONSUMPTION GOAL)))
	|

regeneration=
	normal regeneration rate*environmental pollution
	~	1/Year
	~	environmental pollution^(1/2)*REGENERATION RATE^(environmental pollution)                                              \
		+  REGENERATION RATE^(environmental pollution)
	|

consumption level=
	production capacity
	~	Dmnl
	~		|

degradation=
	normal degradation rate*population*consumption level
	~	1/Year
	~		|

INITAL POPULATION=
	1
	~	Dmnl
	~		|

INITIAL CAPACITY=
	1
	~	Dmnl
	~		|

INITIAL POLLUTION=
	1
	~	Dmnl
	~		|

population= INTEG (
	births-deaths,
		INITAL POPULATION)
	~	Dmnl
	~		|

environmental pollution= INTEG (
	+degradation-regeneration,
		INITIAL POLLUTION)
	~	Dmnl
	~		|

production capacity= INTEG (
	capacity increase,
		INITIAL CAPACITY)
	~	Dmnl
	~		|

normal regeneration rate=
	0.02
	~	1/Year
	~		|

birth rate=
	0.03
	~	1/Year
	~		|

normal growth rate=
	0.04
	~	1/Year
	~		|

consumption goal=
	4
	~	Dmnl
	~		|

DAMAGE THRESHOLD=
	2
	~	Dmnl
	~		|

deaths=
	death rate*population*DELAY3(environmental pollution,10)
	~	1/Year
	~		|

death rate=
	0.015
	~	1/Year
	~		|

environmental quality=
	DELAY3(MIN(DAMAGE THRESHOLD/environmental pollution,1),20)
	~	Dmnl
	~		|

normal degradation rate=
	0.02
	~	1/Year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 500
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.2
	~	Year [0,?]
	~	The time step for the simulation.
	|

