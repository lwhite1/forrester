{UTF-8}
births=
	piglets
	~	pig/year
	~		|

catch per trap=
	RANDOM UNIFORM(0.15, 0.17, 0.1)
	~	1/trap
	~		|

feral pig traps=
	traps per license*licences granted per year
	~	trap/year
	~		|

feral pigs= INTEG (
	births-pigs removed,
		20000)
	~	pig
	~		|

licences granted per year=
	10
	~	license/year
	~		|

litter=
	sows*litter per sow
	~	litter/year
	~		|

litter per sow=
	4
	~	litter/pig/year
	~		|

piglet per litter=
	8
	~	pig/litter
	~		|

piglets=
	litter*piglet per litter
	~	pig/year
	~		|

pigs removed=
	feral pigs*catch per trap*feral pig traps
	~	pig/year
	~		|

sows=
	feral pigs/2
	~	pig
	~		|

traps per license=
	feral pigs*traps per pig
	~	trap/license
	~		|

traps per pig=
	1/2500
	~	
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 10
	~	year
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	year
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	year [0,?]
	~	The time step for the simulation.
	|

