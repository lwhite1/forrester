{UTF-8}
market fear and uncertainty  = A FUNCTION OF( degree of external climate of fear,stock market fear factor\
		,stock market value loss) ~~|
market fear and uncertainty=
	MIN(stock market value loss/(stock market value/market loss delay*stock market fear factor\
		) * degree of external climate of fear
,1)
	~	Dmnl
	~		|

underlying asset loss  = A FUNCTION OF( average stickiness of assets,estimated underlying asset value\
		,external shock real value loss,market fear and uncertainty) ~~|
underlying asset loss=
	MAX((average bank client's fear and uncertainty/average stickiness of assets+external shock real value loss\
		)*estimated underlying asset value
,0)
	~	EURO/Week
	~		|

estimated underlying asset value  = A FUNCTION OF( underlying asset loss) ~~|
estimated underlying asset value= INTEG (
	+underlying asset increase-underlying asset loss,
		initial estimated underlying asset value)
	~	EURO
	~		|

stock market value loss  = A FUNCTION OF( underlying asset loss) ~~|
stock market value loss=
	MAX(stock market value * (perceived overvaluation/market loss delay),0)
	~	EURO/Week
	~		|

average stickiness of assets=
	4
	~	Week
	~		|

degree of external climate of fear=
	2
	~	Dmnl
	~		|

external shock real value loss=
	STEP(0.35,10) - STEP(0.35,11)
	~	1/Week
	~	 0.01 - STEP(0.01,11)
	|

stock market fear factor=
	0.25
	~	Dmnl
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 52
	~	Week
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Week
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Week
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.0078125
	~	Week
	~	The time step for the simulation.
	|

