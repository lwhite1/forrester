{
  "name": "Exponential Growth",
  "comment": "Population growing with constant birth and death rates",
  "stocks": [
    {
      "name": "Population",
      "initialValue": 100.0,
      "unit": "Person"
    }
  ],
  "flows": [
    {
      "name": "Births",
      "equation": "Population * Birth_Rate",
      "timeUnit": "Day",
      "sink": "Population"
    },
    {
      "name": "Deaths",
      "equation": "Population * Death_Rate",
      "timeUnit": "Day",
      "source": "Population"
    }
  ],
  "views": [],
  "defaultSimulation": {
    "timeStep": "Day",
    "duration": 365.0,
    "durationUnit": "Day"
  },
  "auxiliaries": [
    {
      "name": "Birth_Rate",
      "equation": "0.04",
      "unit": "Dimensionless unit"
    },
    {
      "name": "Death_Rate",
      "equation": "0.03",
      "unit": "Dimensionless unit"
    }
  ]
}
