{
  "name" : "Coffee Cooling",
  "comment" : "Coffee temperature decays toward room temperature",
  "stocks" : [ {
    "name" : "Coffee_Temperature",
    "initialValue" : 100.0,
    "unit" : "Celsius"
  } ],
  "flows" : [ {
    "name" : "Cooling",
    "equation" : "Discrepancy * Cooling_Rate",
    "timeUnit" : "Minute",
    "source" : "Coffee_Temperature"
  } ],
  "auxiliaries" : [ {
    "name" : "Discrepancy",
    "equation" : "Coffee_Temperature - Room_Temperature",
    "unit" : "Celsius"
  } ],
  "constants" : [ {
    "name" : "Room_Temperature",
    "value" : 18.0,
    "unit" : "Celsius"
  }, {
    "name" : "Cooling_Rate",
    "value" : 0.1,
    "unit" : "Dimensionless unit"
  } ],
  "views" : [ ],
  "defaultSimulation" : {
    "timeStep" : "Minute",
    "duration" : 45.0,
    "durationUnit" : "Minute"
  }
}