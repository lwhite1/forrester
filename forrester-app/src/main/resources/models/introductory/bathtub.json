{
  "name" : "Bathtub",
  "comment" : "Water drains at a fixed rate; inflow begins after 5 minutes",
  "stocks" : [ {
    "name" : "Water_in_Tub",
    "initialValue" : 50.0,
    "unit" : "Gallon"
  } ],
  "flows" : [ {
    "name" : "Outflow",
    "equation" : "MIN(Outflow_Rate, Water_in_Tub)",
    "timeUnit" : "Minute",
    "source" : "Water_in_Tub"
  }, {
    "name" : "Inflow",
    "equation" : "STEP(Inflow_Rate, 5)",
    "timeUnit" : "Minute",
    "sink" : "Water_in_Tub"
  } ],
  "constants" : [ {
    "name" : "Outflow_Rate",
    "value" : 5.0,
    "unit" : "Gallon per Minute"
  }, {
    "name" : "Inflow_Rate",
    "value" : 5.0,
    "unit" : "Gallon per Minute"
  } ],
  "views" : [ ],
  "defaultSimulation" : {
    "timeStep" : "Minute",
    "duration" : 10.0,
    "durationUnit" : "Minute"
  }
}