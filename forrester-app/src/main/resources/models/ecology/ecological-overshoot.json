    "value" : 100000.0,
    "unit" : "consumer"
  }, {
    "name" : "regeneration_rate",
    "comment" : "regeneration rate",
    "value" : 1.2,
    "unit" : "1/Year"
  }, {
    "name" : "normal_birth_rate",
    "comment" : "normal birth rate",
    "value" : 0.0035,
    "unit" : "1/Year"
  }, {
    "name" : "minimum_regeneration_rate",
    "comment" : "minimum regeneration rate",
    "value" : 0.01,
    "unit" : "1/Year"
  }, {
    "name" : "carrying_capacity",
    "comment" : "carrying capacity",
    "value" : 7500000.0,
