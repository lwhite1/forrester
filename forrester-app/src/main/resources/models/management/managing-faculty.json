{
  "name": "ManagingFaculty",
  "stocks": [
    {
      "name": "money",
      "comment": "money",
      "initialValue": 500000.0,
      "unit": "euro"
    },
    {
      "name": "professors",
      "comment": "professors",
      "initialValue": 25.0,
      "unit": "person"
    }
  ],
  "flows": [
    {
      "name": "money_net_flow",
      "comment": "Net flow for money",
      "equation": "+subsidy_and_earnings_from_papers-money_spent_on_salaries",
      "timeUnit": "Month",
      "sink": "money"
    },
    {
      "name": "professors_net_flow",
      "comment": "Net flow for professors",
      "equation": "+new_professors_hired-professors_leaving",
      "timeUnit": "Month",
      "sink": "professors"
    }
  ],
  "auxiliaries": [
    {
      "name": "desired_number_of_professors",
      "comment": "desired number of professors",
      "equation": "money / average_professor_salary /budgetcoverage",
      "unit": "people"
    },
    {
      "name": "earnings_from_papers",
      "comment": "earnings from papers",
      "equation": "earnings_per_published_paper * number_of_papers_published",
      "unit": "euro/Month"
    },
    {
      "name": "money_spent_on_salaries",
      "comment": "money spent on salaries",
      "equation": "professors * average_professor_salary",
      "unit": "euro/Month"
    },
    {
      "name": "new_professors_hired",
      "comment": "new professors hired",
      "equation": "MAX((desired_number_of_professors - professors) / average_hiring_time,0 )",
      "unit": "person/Month"
    },
    {
      "name": "number_of_papers_published",
      "comment": "number of papers published",
      "equation": "number_of_papers_per_professor * professors",
      "unit": "paper/Month"
    },
    {
      "name": "subsidy_and_earnings_from_papers",
      "comment": "subsidy and earnings from papers",
      "equation": "teaching_fee + earnings_from_papers",
      "unit": "euro/Month"
    },
    {
      "name": "professors_leaving",
      "comment": "professors leaving",
      "equation": "professors*percentage_of_leavers",
      "unit": "person/Month"
    },
    {
      "name": "percentage_of_leavers",
      "comment": "percentage of leavers",
      "equation": "0.1/12",
      "unit": "1/Month"
    },
    {
      "name": "budgetcoverage",
      "equation": "1",
      "comment": "budgetcoverage",
      "unit": "Month"
    },
    {
      "name": "teaching_fee",
      "equation": "150000",
      "comment": "teaching fee",
      "unit": "euro/Month"
    },
    {
      "name": "average_hiring_time",
      "equation": "12",
      "comment": "average hiring time",
      "unit": "Month"
    },
    {
      "name": "average_professor_salary",
      "equation": "3500",
      "comment": "average professor salary",
      "unit": "euro/person/Month"
    },
    {
      "name": "earnings_per_published_paper",
      "equation": "4000",
      "comment": "earnings per published paper",
      "unit": "euro/paper"
    },
    {
      "name": "initially_available_money",
      "equation": "500000",
      "comment": "initially available money",
      "unit": "euro"
    },
    {
      "name": "number_of_papers_per_professor",
      "equation": "0.5",
      "comment": "number of papers per professor",
      "unit": "paper/person/Month"
    }
  ],
