{
  "name" : "SIR Epidemic",
  "comment" : "Susceptible-Infectious-Recovered compartmental model",
  "stocks" : [ {
    "name" : "Susceptible",
    "initialValue" : 1000.0,
    "unit" : "Person"
  }, {
    "name" : "Infectious",
    "initialValue" : 10.0,
    "unit" : "Person"
  }, {
    "name" : "Recovered",
    "initialValue" : 0.0,
    "unit" : "Person"
  } ],
  "flows" : [ {
    "name" : "Infection",
    "equation" : "Contact_Rate * Infectious / (Susceptible + Infectious + Recovered) * Infectivity * Susceptible",
    "timeUnit" : "Day",
    "source" : "Susceptible",
    "sink" : "Infectious"
  }, {
    "name" : "Recovery",
    "equation" : "Infectious * Recovery_Rate",
    "timeUnit" : "Day",
    "source" : "Infectious",
    "sink" : "Recovered"
  } ],
  "constants" : [ {
    "name" : "Contact_Rate",
    "value" : 8.0,
    "unit" : "Dimensionless unit"
  }, {
    "name" : "Infectivity",
    "value" : 0.1,
    "unit" : "Dimensionless unit"
  }, {
    "name" : "Recovery_Rate",
    "value" : 0.2,
    "unit" : "Dimensionless unit"
  } ],
  "views" : [ ],
  "defaultSimulation" : {
    "timeStep" : "Day",
    "duration" : 56.0,
    "durationUnit" : "Day"
  }
}