{
  "name" : "SIR Epidemic",
  "comment" : "Susceptible-Infectious-Recovered compartmental model",
  "stocks" : [ {
    "name" : "Susceptible",
    "initialValue" : 1000.0,
    "unit" : "Person"
  }, {
    "name" : "Infectious",
    "initialValue" : 10.0,
    "unit" : "Person"
  }, {
    "name" : "Recovered",
    "initialValue" : 0.0,
    "unit" : "Person"
  } ],
  "flows" : [ {
    "name" : "Infection",
    "equation" : "Contact_Rate * Infectious / (Susceptible + Infectious + Recovered) * Infectivity * Susceptible",
    "timeUnit" : "Day",
    "source" : "Susceptible",
    "sink" : "Infectious"
  }, {
    "name" : "Recovery",
    "equation" : "Infectious * Recovery_Rate",
    "timeUnit" : "Day",
    "source" : "Infectious",
    "sink" : "Recovered"
  } ],
  "constants" : [ {
    "name" : "Contact_Rate",
    "value" : 8.0,
    "unit" : "Dimensionless unit"
  }, {
    "name" : "Infectivity",
    "value" : 0.1,
    "unit" : "Dimensionless unit"
  }, {
    "name" : "Recovery_Rate",
    "value" : 0.2,
    "unit" : "Dimensionless unit"
  } ],
  "views" : [ {
    "name" : "Auto Layout",
    "elements" : [ {
      "name" : "Susceptible",
      "type" : "stock",
      "x" : 100.0,
      "y" : 200.0
    }, {
      "name" : "Infection",
      "type" : "flow",
      "x" : 250.0,
      "y" : 200.0
    }, {
      "name" : "Infectious",
      "type" : "stock",
      "x" : 400.0,
      "y" : 200.0
    }, {
      "name" : "Recovery",
      "type" : "flow",
      "x" : 550.0,
      "y" : 200.0
    }, {
      "name" : "Recovered",
      "type" : "stock",
      "x" : 700.0,
      "y" : 200.0
    }, {
      "name" : "Contact_Rate",
      "type" : "constant",
      "x" : 100.0,
      "y" : 350.0
    }, {
      "name" : "Infectivity",
      "type" : "constant",
      "x" : 250.0,
      "y" : 350.0
    }, {
      "name" : "Recovery_Rate",
      "type" : "constant",
      "x" : 400.0,
      "y" : 350.0
    } ],
    "connectors" : [ {
      "from" : "Contact_Rate",
      "to" : "Infection"
    }, {
      "from" : "Infectious",
      "to" : "Infection"
    }, {
      "from" : "Infectious",
      "to" : "Recovery"
    }, {
      "from" : "Susceptible",
      "to" : "Infection"
    }, {
      "from" : "Recovered",
      "to" : "Infection"
    }, {
      "from" : "Infectivity",
      "to" : "Infection"
    }, {
      "from" : "Infection",
      "to" : "Susceptible"
    }, {
      "from" : "Infection",
      "to" : "Infectious"
    }, {
      "from" : "Recovery_Rate",
      "to" : "Recovery"
    }, {
      "from" : "Recovery",
      "to" : "Infectious"
    }, {
      "from" : "Recovery",
      "to" : "Recovered"
    } ]
  } ],
  "defaultSimulation" : {
    "timeStep" : "Day",
    "duration" : 56.0,
    "durationUnit" : "Day"
  }
}