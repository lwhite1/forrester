{
  "name": "PneumonicPlague",
  "stocks": [
    {
      "name": "susceptible_population",
      "comment": "susceptible population",
      "initialValue": 0.0,
      "initialExpression": "initial_total_population-infected_population",
      "unit": "persons"
    },
    {
      "name": "infected_population",
      "comment": "infected population",
      "initialValue": 1.0,
      "unit": "persons"
    },
    {
      "name": "recovering_population",
      "comment": "recovering population",
      "initialValue": 0.0,
      "unit": "persons"
    },
    {
      "name": "deceased_population",
      "comment": "deceased population",
      "initialValue": 0.0,
      "unit": "persons"
    }
  ],
  "flows": [
    {
      "name": "susceptible_population_net_flow",
      "comment": "Net flow for susceptible population",
      "equation": "-infection",
      "timeUnit": "Week",
      "sink": "susceptible_population"
    },
    {
      "name": "infected_population_net_flow",
      "comment": "Net flow for infected population",
      "equation": "infection-recovery-deaths",
      "timeUnit": "Week",
      "sink": "infected_population"
    },
    {
      "name": "recovering_population_net_flow",
      "comment": "Net flow for recovering population",
      "equation": "recovery",
      "timeUnit": "Week",
      "sink": "recovering_population"
    },
    {
      "name": "deceased_population_net_flow",
      "comment": "Net flow for deceased population",
      "equation": "deaths",
      "timeUnit": "Week",
      "sink": "deceased_population"
    }
  ],
  "auxiliaries": [
    {
      "name": "infection",
      "comment": "infection",
      "equation": "contact_rate*infection_ratio*susceptible_population*infected_fraction",
      "unit": "persons/Week"
    },
    {
      "name": "infected_fraction",
      "comment": "infected fraction",
      "equation": "infected_population/total_population",
      "unit": "Dmnl"
    },
    {
      "name": "total_population",
      "comment": "total population",
      "equation": "infected_population+recovering_population+susceptible_population",
      "unit": "persons"
    },
    {
      "name": "contact_rate",
      "comment": "contact rate",
      "equation": "20",
      "unit": "persons/persons/Week"
    },
    {
      "name": "antibiotics_coverage_of_the_population",
      "comment": "LOOKUP (TIME ([(0,0)-(10,10)],(0,0),(1,0.5),(2,1),(3,1),(6,1) )  )",
      "equation": "0",
      "unit": "Dmnl"
    },
    {
      "name": "recovery",
      "comment": "recovery",
      "equation": "(1-fatality_ratio)*infected_population/recovery_time",
      "unit": "persons/Week"
    },
    {
      "name": "recovery_time",
      "comment": "recovery time",
      "equation": "0.33",
      "unit": "Week"
    },
    {
      "name": "infection_ratio",
      "comment": "infection ratio",
      "equation": "0.75",
      "unit": "persons/persons"
    },
    {
      "name": "deaths",
      "comment": "deaths",
      "equation": "infected_population*fatality_ratio/recovery_time",
      "unit": "persons/Week"
    },
    {
      "name": "fatality_ratio",
      "comment": "fatality ratio",
      "equation": "LOOKUP(fatality_ratio_lookup, antibiotics_coverage_of_the_population)",
      "unit": "Dmnl"
    },
    {
      "name": "initial_total_population",
      "equation": "10000",
      "comment": "initial total population",
      "unit": "persons"
    }
  ],
  "lookupTables": [
    {
      "name": "fatality_ratio_lookup",
      "xValues": [
        0.0,
        1.0
      ],
      "yValues": [
        0.9,
        0.15
      ],
      "interpolation": "LINEAR"
    }
  ],
