  "auxiliaries" : [ {
    "name" : "progress_function",
    "comment" : "progress function",
    "equation" : "IF(TIME<10, 2, PROGRESS_FACTOR)",
    "unit" : "1"
  }, {
    "name" : "progress_function_0",
    "comment" : "progress function 0",
    "equation" : "IF(TIME<10, 1, PROGRESS_FACTOR_0)",
