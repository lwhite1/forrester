    "name" : "inland_price_0",
    "comment" : "inland price 0",
    "equation" : "product_price*(1-subsidy+customs_0)",
    "unit" : "$"
  }, {
    "name" : "progress_investment",
    "comment" : "progress investment",
    "equation" : "progress_function*investment",
    "unit" : "1/Year"
  }, {
    "name" : "progress_investment_0",
    "comment" : "progress investment 0",
    "equation" : "progress_function_0*investment_0",
    "unit" : "1/Year"
  }, {
    "name" : "subsidy",
    "comment" : "subsidy",
    "equation" : "IF(TIME<10, 0.75, EXPORT_SUBSIDY)",
