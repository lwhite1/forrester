  }, {
    "name" : "investment_function_0",
    "comment" : "investment function 0",
    "equation" : "IF(TIME<10, 0.2, INVESTMENT_FACTOR_0)",
    "unit" : "1"
  }, {
    "name" : "investment",
    "comment" : "investment",
    "equation" : "IF(surplus<0, INVESTMENT_RATE*production_capacity*investment_function, 0)",
    "unit" : "1/Year"
  }, {
    "name" : "investment_0",
    "comment" : "investment 0",
    "equation" : "IF(surplus_0<0,INVESTMENT_RATE_0*production_capacity_0*investment_function_0 , 0)",
