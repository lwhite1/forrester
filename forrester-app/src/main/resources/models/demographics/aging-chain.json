{
  "name": "Aging",
  "stocks": [
    {
      "name": "adults",
      "comment": "adults",
      "initialValue": 9000000.0,
      "unit": "personen"
    },
    {
      "name": "children",
      "comment": "children",
      "initialValue": 4000000.0,
      "unit": "personen"
    },
    {
      "name": "retirees",
      "comment": "retirees",
      "initialValue": 3000000.0,
      "unit": "personen"
    }
  ],
  "flows": [
    {
      "name": "adults net flow",
      "comment": "Net flow for adults",
      "equation": "maturing-retiring",
      "timeUnit": "Year",
      "sink": "adults"
    },
    {
      "name": "children net flow",
      "comment": "Net flow for children",
      "equation": "births-maturing",
      "timeUnit": "Year",
      "sink": "children"
    },
    {
      "name": "retirees net flow",
      "comment": "Net flow for retirees",
      "equation": "retiring-deaths",
      "timeUnit": "Year",
      "sink": "retirees"
    }
  ],
  "auxiliaries": [
    {
      "name": "grey pressure",
      "comment": "grey pressure",
      "equation": "retirees/(adults+children)",
      "unit": "Dmnl"
    },
    {
      "name": "total population",
      "comment": "total population",
      "equation": "adults+children+retirees",
      "unit": ""
    },
    {
      "name": "inactive population",
      "comment": "inactive population",
      "equation": "children + retirees + adults_not_on_labour_market",
      "unit": "personen"
    },
    {
      "name": "births",
      "comment": "births",
      "equation": "average_birth_rate_per_adult*adults",
      "unit": "personen/Year"
    },
    {
      "name": "average retiree period",
      "comment": "average retiree period",
      "equation": "LOOKUP(average_retiree_period_lookup, TIME)",
      "unit": "Year"
    },
    {
      "name": "burden per active adult",
      "comment": "burden per active adult",
      "equation": "inactive_population/adults_on_the_labour_market",
      "unit": "Dmnl"
    },
    {
      "name": "retiring",
      "comment": "retiring",
      "equation": "adults/average_adult_period",
      "unit": "personen/Year"
    },
    {
      "name": "maturing",
      "comment": "maturing",
      "equation": "children/average_childhood_period",
      "unit": "personen/Year"
    },
    {
      "name": "deaths",
      "comment": "deaths",
      "equation": "retirees/average_retiree_period",
      "unit": "personen/Year"
    },
    {
      "name": "adults not on labour market",
      "comment": "adults not on labour market",
      "equation": "adults*(1-average_adult_participation_ratio)",
      "unit": ""
    },
    {
      "name": "adults on the labour market",
      "comment": "adults on the labour market",
      "equation": "adults*average_adult_participation_ratio",
      "unit": "personen"
    },
    {
      "name": "average birth rate per adult",
      "equation": "0.02",
      "comment": "average birth rate per adult",
      "unit": "personen/personen/Year"
    },
    {
      "name": "average childhood period",
      "equation": "22",
      "comment": "average childhood period",
      "unit": "Year"
    },
    {
      "name": "average adult participation ratio",
      "equation": "0.5",
      "comment": "average adult participation ratio",
      "unit": "Dmnl"
    },
    {
      "name": "average adult period",
      "equation": "40",
      "comment": "average adult period",
      "unit": "Year"
    },
    {
      "name": "initial number of retirees",
      "equation": "3000000",
      "comment": "initial number of retirees",
      "unit": "personen"
    },
    {
      "name": "initial number of children",
      "equation": "4000000",
      "comment": "initial number of children",
      "unit": "personen"
    },
    {
      "name": "initial number of adults",
      "equation": "9000000",
      "comment": "initial number of adults",
      "unit": "personen"
    }
  ],
