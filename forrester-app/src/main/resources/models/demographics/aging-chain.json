{
  "name" : "Aging",
  "stocks" : [ {
    "name" : "adults",
    "comment" : "adults",
    "initialValue" : 9000000.0,
    "unit" : "personen"
  }, {
    "name" : "children",
    "comment" : "children",
    "initialValue" : 4000000.0,
    "unit" : "personen"
  }, {
    "name" : "retirees",
    "comment" : "retirees",
    "initialValue" : 3000000.0,
    "unit" : "personen"
  } ],
  "flows" : [ {
    "name" : "adults_net_flow",
    "comment" : "Net flow for adults",
    "equation" : "maturing-retiring",
    "timeUnit" : "Year",
    "sink" : "adults"
  }, {
    "name" : "children_net_flow",
    "comment" : "Net flow for children",
    "equation" : "births-maturing",
    "timeUnit" : "Year",
    "sink" : "children"
  }, {
    "name" : "retirees_net_flow",
    "comment" : "Net flow for retirees",
    "equation" : "retiring-deaths",
    "timeUnit" : "Year",
    "sink" : "retirees"
  } ],
  "auxiliaries" : [ {
    "name" : "grey_pressure",
    "comment" : "grey pressure",
    "equation" : "retirees/(adults+children)",
    "unit" : "Dmnl"
  }, {
    "name" : "total_population",
    "comment" : "total population",
    "equation" : "adults+children+retirees",
    "unit" : ""
  }, {
    "name" : "inactive_population",
    "comment" : "inactive population",
    "equation" : "children + retirees + adults_not_on_labour_market",
    "unit" : "personen"
  }, {
    "name" : "births",
    "comment" : "births",
    "equation" : "average_birth_rate_per_adult*adults",
    "unit" : "personen/Year"
  }, {
    "name" : "average_retiree_period",
    "comment" : "average retiree period",
    "equation" : "LOOKUP(average_retiree_period_lookup, TIME)",
    "unit" : "Year"
  }, {
    "name" : "burden_per_active_adult",
    "comment" : "burden per active adult",
    "equation" : "inactive_population/adults_on_the_labour_market",
    "unit" : "Dmnl"
  }, {
    "name" : "retiring",
    "comment" : "retiring",
    "equation" : "adults/average_adult_period",
    "unit" : "personen/Year"
  }, {
    "name" : "maturing",
    "comment" : "maturing",
    "equation" : "children/average_childhood_period",
    "unit" : "personen/Year"
  }, {
    "name" : "deaths",
    "comment" : "deaths",
    "equation" : "retirees/average_retiree_period",
    "unit" : "personen/Year"
  }, {
    "name" : "adults_not_on_labour_market",
    "comment" : "adults not on labour market",
    "equation" : "adults*(1-average_adult_participation_ratio)",
    "unit" : ""
  }, {
    "name" : "adults_on_the_labour_market",
    "comment" : "adults on the labour market",
    "equation" : "adults*average_adult_participation_ratio",
    "unit" : "personen"
  } ],
  "constants" : [ {
    "name" : "average_birth_rate_per_adult",
