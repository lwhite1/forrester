{
  "name": "FamilyPlanning",
  "stocks": [
    {
      "name": "adults",
      "comment": "adults",
      "initialValue": 3000000.0,
      "unit": ""
    },
    {
      "name": "kids",
      "comment": "kids",
      "initialValue": 1000000.0,
      "unit": ""
    },
    {
      "name": "unborns",
      "comment": "unborns",
      "initialValue": 68000.0,
      "unit": ""
    },
    {
      "name": "retirees",
      "comment": "retirees",
      "initialValue": 750000.0,
      "unit": ""
    },
    {
      "name": "youngsters",
      "comment": "youngsters",
      "initialValue": 1000000.0,
      "unit": ""
    }
  ],
  "flows": [
    {
      "name": "adults_net_flow",
      "comment": "Net flow for adults",
      "equation": "from_young_adults_to_adults-from_adults_to_retirees",
      "timeUnit": "Year",
      "sink": "adults"
    },
    {
      "name": "kids_net_flow",
      "comment": "Net flow for kids",
      "equation": "births-growing_up",
      "timeUnit": "Year",
      "sink": "kids"
    },
    {
      "name": "unborns_net_flow",
      "comment": "Net flow for unborns",
      "equation": "conceptions-births-early_ended_pregnancies",
      "timeUnit": "Year",
      "sink": "unborns"
    },
    {
      "name": "retirees_net_flow",
      "comment": "Net flow for retirees",
      "equation": "from_adults_to_retirees-deaths",
      "timeUnit": "Year",
      "sink": "retirees"
    },
    {
      "name": "youngsters_net_flow",
      "comment": "Net flow for youngsters",
      "equation": "growing_up-from_young_adults_to_adults",
      "timeUnit": "Year",
      "sink": "youngsters"
    }
  ],
  "auxiliaries": [
    {
      "name": "crimes",
      "comment": "crimes",
      "equation": "criminal_kids*ciminal_acts_per_criminal_kid + ciminal_acts_per_criminal_youngster*criminal_youngsters + criminal_acts_per_criminal_adult\n\t*criminal_adults + criminal_acts_per_criminal_retiree\n\t*criminal_retirees + crimes_by_others",
      "unit": ""
    },
    {
      "name": "criminal_kids",
      "comment": "criminal kids",
      "equation": "kids*percentage_of_kids_and_youngsters_with_criminal_behavior",
      "unit": ""
    },
    {
      "name": "criminal_youngsters",
      "comment": "criminal youngsters",
      "equation": "youngsters*percentage_of_youngsters_with_criminal_behavior",
      "unit": ""
    },
    {
      "name": "births",
      "comment": "births",
      "equation": "(1-percentage_early_ended_pregnancies) * unborns/average_time_pregnancy",
      "unit": ""
    },
    {
      "name": "criminal_adults",
      "comment": "criminal adults",
      "equation": "adults*percentage_of_adults_with_criminal_behavior",
      "unit": ""
    },
    {
      "name": "criminal_retirees",
      "comment": "criminal retirees",
      "equation": "retirees*percentage_of_retirees_with_criminal_behavior",
      "unit": ""
    },
    {
      "name": "total_multiproblem_family_population",
      "comment": "\"total multi-problem family population\"",
      "equation": "adults+kids+retirees+youngsters",
      "unit": ""
    },
    {
      "name": "deaths",
      "comment": "deaths",
      "equation": "retirees/average_time_as_retirees",
      "unit": ""
    },
    {
      "name": "early_ended_pregnancies",
      "comment": "early ended pregnancies",
      "equation": "percentage_early_ended_pregnancies*unborns/average_time_pregnancy",
      "unit": ""
    },
    {
      "name": "from_adults_to_retirees",
      "comment": "from adults to retirees",
      "equation": "adults/average_time_as_adult",
      "unit": ""
    },
    {
      "name": "from_young_adults_to_adults",
      "comment": "from young adults to adults",
      "equation": "youngsters/average_time_as_youngster",
      "unit": ""
    },
    {
      "name": "growing_up",
      "comment": "growing up",
      "equation": "kids/average_time_as_kid",
      "unit": ""
    },
    {
      "name": "conceptions",
      "comment": "conceptions",
      "equation": "adults*annual_fertility_rate_adults + youngsters*annual_fertility_rate_youngsters",
      "unit": ""
    },
    {
      "name": "percentage_of_youngsters_with_criminal_behavior",
      "equation": "0.5",
      "comment": "percentage of youngsters with criminal behavior"
    },
    {
      "name": "crimes_by_others",
