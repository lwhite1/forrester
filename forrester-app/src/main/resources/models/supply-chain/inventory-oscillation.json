{
  "name" : "Inventory Oscillation",
  "comment" : "Car dealership inventory with perception and delivery delays",
  "stocks" : [ {
    "name" : "Cars_on_Lot",
    "initialValue" : 200.0,
    "unit" : "Car"
  }, {
    "name" : "Perceived_Sales",
    "initialValue" : 20.0,
    "unit" : "Car"
  } ],
  "flows" : [ {
    "name" : "Sales",
    "equation" : "MIN(Cars_on_Lot, Customer_Demand)",
    "timeUnit" : "Day",
    "source" : "Cars_on_Lot"
  }, {
    "name" : "Perception_Adjustment",
    "equation" : "(Sales - Perceived_Sales) / Perception_Delay",
    "timeUnit" : "Day",
    "sink" : "Perceived_Sales"
  }, {
    "name" : "Deliveries",
    "equation" : "DELAY3(Orders_to_Factory, Delivery_Delay)",
    "timeUnit" : "Day",
    "sink" : "Cars_on_Lot"
  } ],
  "auxiliaries" : [ {
    "name" : "Customer_Demand",
    "equation" : "IF(TIME > 25, Step_Demand, Base_Demand)",
    "unit" : "Car"
  }, {
    "name" : "Desired_Inventory",
    "equation" : "Perceived_Sales * Desired_Inventory_Multiplier",
    "unit" : "Car"
  }, {
    "name" : "Inventory_Gap",
    "equation" : "Desired_Inventory - Cars_on_Lot",
    "unit" : "Car"
  }, {
    "name" : "Orders_to_Factory",
    "equation" : "MAX(Perceived_Sales + Inventory_Gap / Response_Delay, 0)",
    "unit" : "Car"
  } ],
  "constants" : [ {
    "name" : "Base_Demand",
    "value" : 20.0,
    "unit" : "Car per Day"
  }, {
    "name" : "Step_Demand",
    "value" : 22.0,
    "unit" : "Car per Day"
  }, {
    "name" : "Perception_Delay",
    "value" : 5.0,
    "unit" : "Day"
  }, {
    "name" : "Response_Delay",
    "value" : 3.0,
    "unit" : "Day"
  }, {
    "name" : "Delivery_Delay",
    "value" : 5.0,
    "unit" : "Day"
  }, {
    "name" : "Desired_Inventory_Multiplier",
    "value" : 10.0,
    "unit" : "Dimensionless unit"
  } ],
  "views" : [ {
    "name" : "Main",
    "elements" : [ {
      "name" : "Deliveries",
      "type" : "flow",
      "x" : 150.0,
      "y" : 200.0
    }, {
