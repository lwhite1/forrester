    }, {
      "name" : "Customer_Demand",
      "type" : "aux",
      "x" : 450.0,
      "y" : 50.0
    }, {
      "name" : "Desired_Inventory",
      "type" : "aux",
      "x" : 600.0,
      "y" : 50.0
    }, {
      "name" : "Inventory_Gap",
      "type" : "aux",
      "x" : 750.0,
      "y" : 50.0
    }, {
      "name" : "Orders_to_Factory",
