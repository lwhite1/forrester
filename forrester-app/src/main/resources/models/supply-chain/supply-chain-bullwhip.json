      "unit": "Person"
    }
  ],
  "flows": [
    {
      "name": "Inventory_net_flow",
      "comment": "Net flow for Inventory",
      "equation": "production-sales",
      "timeUnit": "Month",
      "sink": "Inventory"
    },
    {
      "name": "Workforce_net_flow",
      "comment": "Net flow for Workforce",
      "equation": "net_hire_rate",
      "timeUnit": "Month",
      "sink": "Workforce"
    }
  ],
  "auxiliaries": [
    {
      "name": "target_inventory",
      "comment": "target inventory",
      "equation": "sales * inventory_coverage",
      "unit": "Widget"
    },
    {
      "name": "target_production",
      "comment": "target production",
      "equation": "sales + inventory_correction",
      "unit": "Widget/Month"
    },
    {
      "name": "inventory_correction",
      "comment": "inventory correction",
      "equation": "(target_inventory - Inventory)/\n                time_to_correct_inventory",
      "unit": "Widget/Month"
    },
    {
      "name": "net_hire_rate",
      "comment": "net hire rate",
      "equation": "(target_workforce-Workforce)/time_to_adjust_workforce",
      "unit": "Person/Month"
    },
    {
      "name": "production",
      "comment": "production",
      "equation": "Workforce*productivity",
      "unit": "Widget/Month"
    },
    {
      "name": "sales",
      "comment": "sales",
      "equation": "100+STEP(50,20)",
      "unit": "Widget/Month"
    },
    {
      "name": "target_workforce",
      "comment": "target workforce",
      "equation": "target_production/productivity",
      "unit": "Person"
    },
    {
      "name": "inventory_coverage",
      "equation": "3",
      "comment": "inventory coverage",
      "unit": "Month"
    },
    {
      "name": "time_to_correct_inventory",
      "equation": "2",
      "comment": "time to correct inventory",
      "unit": "Month"
    },
    {
      "name": "productivity",
      "equation": "1",
      "comment": "productivity",
      "unit": "Widget/Month/Person"
    },
    {
      "name": "time_to_adjust_workforce",
      "equation": "10",
      "comment": "time to adjust workforce",
      "unit": "Month"
    }
